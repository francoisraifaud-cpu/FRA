        "jsCode": "// ==========================================\n// NŒUD ANALYSEUR TECHNIQUE v10\n// Enrichissements : Chiron, Lunaisons, Éclipses, Stations Rétro, Angles, Aspects T→T\n// + CORRECTION : Nœud Nord & Nœud Sud en transit (normalisation clés API)\n// ==========================================\n\nconst prepareOut    = $input.first().json;\nconst transitsData  = prepareOut.transitsData || prepareOut.data || prepareOut;\nconst luneData      = prepareOut.luneData     || {};\nconst eclipsesData  = prepareOut.eclipsesData || [];\n\nconst enrichedData  = $(\"Enrichissement Astrologique\").first().json;\nconst natalPlanets  = enrichedData.planetes;\nconst natalHouses   = enrichedData.maisons;\nconst perso         = enrichedData.perso || {};\n\nconst parseDate = (str) => {\n    if (!str) return null;\n    str = str.trim();\n    if (str.includes(\"/\")) {\n        const [d, m, y] = str.split(\"/\");\n        return new Date(`${y}-${m.padStart(2,\"0\")}-${d.padStart(2,\"0\")}`);\n    }\n    return new Date(str);\n};\n\nconst annee       = perso.annee || \"2026\";\nconst dStart      = parseDate(perso.date_entree) || new Date(`${annee}-01-01`);\nconst dEnd        = parseDate(perso.date_sortie) || new Date(`${annee}-12-31`);\nconst typeRapport = (perso.rapport || \"Annuel\").trim();\n\nconst allDays = Array.isArray(transitsData) ? transitsData : [transitsData];\nconst days = allDays.filter(day => {\n    if (!day?.date) return false;\n    const d = new Date(day.date);\n    return d >= dStart && d <= dEnd;\n});\nif (days.length === 0) throw new Error(`Aucun jour trouvé entre ${perso.date_entree} et ${perso.date_sortie}`);\n\n// ---- NORMALISATION DES CLÉS API ----\n// L'API retourne \"Noeud_Nord\" / \"Noeud_Sud\" (underscore, sans œ)\n// Le code utilise \"Nœud Nord\" / \"Nœud Sud\" (espace, avec œ)\n// On normalise une fois pour toutes ici\ndays.forEach(day => {\n    if (!day?.planetes) return;\n    if (day.planetes[\"Noeud_Nord\"] && !day.planetes[\"Nœud Nord\"]) {\n