    {
      "parameters": {
        "jsCode": "// ==========================================\n// GÉNÉRATEUR — RAPPORT TECHNIQUE HTML v10\n// Enrichissements complets : Chiron, Lunaisons, Éclipses, Stations, Angles, Aspects T→T\n// ==========================================\n\nconst items        = $input.all().map(i => i.json);\nconst enrichedData = $(\"Enrichissement Astrologique\").first().json;\nconst natalHouses  = enrichedData.maisons  || [];\nconst natalPlanets = enrichedData.planetes || [];\nconst perso        = enrichedData.perso    || {};\n\nconst typeRapport = (perso.rapport || \"Annuel\").trim();\nconst prenomNom   = `${perso.prenom || \"\"} ${perso.nom || \"\"}`.trim();\n\nconst formatDate = (str) => {\n    if (!str) return \"\";\n    str = str.trim();\n    if (str.includes(\"/\")) return str;\n    const [y, m, d] = str.split(\"-\");\n    return `${d}/${m}/${y}`;\n};\nconst annee         = perso.annee || \"2026\";\nconst dateEntreeStr = formatDate(perso.date_entree || `01/01/${annee}`);\nconst dateSortieStr = formatDate(perso.date_sortie || `31/12/${annee}`);\n\nconst labelType   = typeRapport;\nconst showRapides = [\"Mensuel\",\"Hebdomadaire\",\"Journalier\"].includes(typeRapport);\nconst titrePrincipal = `Données Techniques Prévisions - ${labelType} - ${dateEntreeStr} - ${dateSortieStr} - ${prenomNom}`;\n\nconst aspectColors = {\n    \"Conjonction\":{ border:\"#7c3aed\",bg:\"#f5f3ff\",text:\"#7c3aed\" },\n    \"Sextile\"    :{ border:\"#15803d\",bg:\"#f0fdf4\",text:\"#15803d\" },\n    \"Carré\"      :{ border:\"#c2410c\",bg:\"#fff7ed\",text:\"#c2410c\" },\n    \"Trigone\"    :{ border:\"#1d4ed8\",bg:\"#eff6ff\",text:\"#1d4ed8\" },\n    \"Opposition\" :{ border:\"#be123c\",bg:\"#fff1f2\",text:\"#be123c\" }\n};\nconst defaultColor = { border:\"#1e3a8a\",bg:\"#eff6ff\",text:\"#1e3a8a\" };\nconst THEMES = {\n    \"Annuel\"      :{ bg:\"#1F3864\", badge:\"#e8f0fe\", badgeTxt:\"#1F3864\" },\n    \"Mensuel\"     :{ bg:\"#1a4b2e\", badge:\"#e0f4e8\", badgeTxt:\"#1a4b2e\" },\n    \"Hebdomadaire\":{ bg:\"#3d1a5c\", badge:\"#f0e8ff\", badgeTxt:\"#3d1a5c\" },\n    \"Journalier\"  :{ bg:\"#5c2a0a\", badge:\"#fff0e8\", badgeTxt:\"#5c2a0a\" }\n};\nconst tc = THEMES[typeRapport] || { bg:\"#1e3a8a\", badge:\"#e8f0fe\", badgeTxt:\"#1e3a8a\" };\n\nconst glyphs = {\n    \"Soleil\":\"☉\",\"Lune\":\"☽\",\"Mercure\":\"☿\",\"Vénus\":\"♀\",\"Mars\":\"♂\",\n    \"Jupiter\":\"♃\",\"Saturne\":\"♄\",\"Uranus\":\"♅\",\"Neptune\":\"♆\",\"Pluton\":\"♇\",\n    \"Nœud Nord\":\"☊\",\"Nœud Sud\":\"☋\",\"Chiron\":\"⚷\",\"Cérès\":\"⚳\",\"Pallas\":\"⚴\",\n    \"Junon\":\"⚵\",\"Vesta\":\"⚶\",\"Part de Fortune\":\"⊕\",\"Lilith\":\"⚸\",\n    \"Milieu du Ciel\":\"MC\",\"Imum Coeli\":\"IC\",\"Ascendant\":\"Asc\",\"Descendant\":\"Desc\"\n};\nconst signGlyphs = {\n    \"Bélier\":\"♈\",\"Taureau\":\"♉\",\"Gémeaux\":\"♊\",\"Cancer\":\"♋\",\n    \"Lion\":\"♌\",\"Vierge\":\"♍\",\"Balance\":\"♎\",\"Scorpion\":\"♏\",\n    \"Sagittaire\":\"♐\",\"Capricorne\":\"♑\",\"Verseau\":\"♒\",\"Poissons\":\"♓\"\n};\nconst g     = (name) => glyphs[name] ? `<span class=\"glyph\">${glyphs[name]}</span>` : \"\";\nconst badge = (a, isAngle) => {\n    const c   = aspectColors[a] || defaultColor;\n    const cls = isAngle ? \"aspect-badge angle-aspect-badge\" : \"aspect-badge\";\n    return `<span class=\"${cls}\" style=\"color:${c.text};background:${c.bg};border-color:${c.text}\">${a}</span>`;\n};\n\nconst ANGLE_BY_HOUSE = { 1:\"ASC\", 4:\"IC\", 7:\"DSC\", 10:\"MC\" };\nconst ANGLE_COLORS = {\n    \"ASC\":{ bg:\"#f0fdf4\",text:\"#15803d\",border:\"#15803d\" },\n    \"IC\" :{ bg:\"#eff6ff\",text:\"#1d4ed8\",border:\"#1d4ed8\" },\n    \"DSC\":{ bg:\"#fdf4ff\",text:\"#7c3aed\",border:\"#7c3aed\" },\n    \"MC\" :{ bg:\"#fff7ed\",text:\"#c2410c\",border:\"#c2410c\" }\n};\nconst ANGLE_NAMES_SET = new Set([\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"]);\n\nconst signs = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\nconst houseCusps = natalHouses.map(h => ({\n    house : h.maison,\n    degree: (signs.indexOf(h.segments[0].signe) * 30 + h.segments[0].degre_debut) % 360\n})).sort((a,b) => a.degree - b.degree);\n\nconst findNatalHouse = (deg) => {\n    for (let i = 0; i < 12; i++) {\n        const h1 = houseCusps[i].degree, h2 = houseCusps[(i+1)%12].degree;\n        if (h1 < h2) { if (deg >= h1 && deg < h2) return houseCusps[i].house; }\n        else         { if (deg >= h1 || deg < h2) return houseCusps[i].house; }\n    }\n    return 1;\n};\n\nconst houseSegments = {};\nnatalHouses.forEach(h => { houseSegments[h.maison] = h.segments || []; });\n\nconst planetsByHouse = {};\nnatalPlanets.forEach(p => {\n    const name  = p.planet?.fr || p.planet?.en || \"\";\n    if (!name) return;\n    const deg   = p.fullDegree, sign = p.zodiac_sign?.name?.fr || signs[Math.floor(deg/30)%12];\n    const house = findNatalHouse(deg);\n    if (!planetsByHouse[house]) planetsByHouse[house] = [];\n    planetsByHouse[house].push({ name, deg:(deg%30).toFixed(1), sign, isAngle:ANGLE_NAMES_SET.has(name) });\n});\n\nconst natalAnglePos = {};\nnatalPlanets.forEach(p => {\n    const name = p.planet?.fr || p.planet?.en || \"\";\n    if (ANGLE_NAMES_SET.has(name)) natalAnglePos[name] = { deg:p.fullDegree, sign:p.zodiac_sign?.name?.fr || signs[Math.floor(p.fullDegree/30)%12] };\n});\n\n// ---- CALCULS STATIQUES NATAUX (C1-C5) ----\n\nconst MAITRES_R = {\"Bélier\":\"Mars\",\"Taureau\":\"Vénus\",\"Gémeaux\":\"Mercure\",\"Cancer\":\"Lune\",\"Lion\":\"Soleil\",\"Vierge\":\"Mercure\",\"Balance\":\"Vénus\",\"Scorpion\":\"Pluton\",\"Sagittaire\":\"Jupiter\",\"Capricorne\":\"Saturne\",\"Verseau\":\"Uranus\",\"Poissons\":\"Neptune\"};\nconst DOMICILE_R  = {\"Soleil\":[\"Lion\"],\"Lune\":[\"Cancer\"],\"Mercure\":[\"Gémeaux\",\"Vierge\"],\"Vénus\":[\"Taureau\",\"Balance\"],\"Mars\":[\"Bélier\",\"Scorpion\"],\"Jupiter\":[\"Sagittaire\",\"Poissons\"],\"Saturne\":[\"Capricorne\",\"Verseau\"],\"Uranus\":[\"Verseau\"],\"Neptune\":[\"Poissons\"],\"Pluton\":[\"Scorpion\"]};\nconst EXALTATION_R= {\"Soleil\":\"Bélier\",\"Lune\":\"Taureau\",\"Mercure\":\"Vierge\",\"Vénus\":\"Poissons\",\"Mars\":\"Capricorne\",\"Jupiter\":\"Cancer\",\"Saturne\":\"Balance\",\"Uranus\":\"Scorpion\",\"Neptune\":\"Cancer\",\"Pluton\":\"Lion\"};\nconst EXIL_R      = {\"Soleil\":[\"Verseau\"],\"Lune\":[\"Capricorne\"],\"Mercure\":[\"Sagittaire\",\"Poissons\"],\"Vénus\":[\"Bélier\",\"Scorpion\"],\"Mars\":[\"Taureau\",\"Balance\"],\"Jupiter\":[\"Gémeaux\",\"Vierge\"],\"Saturne\":[\"Cancer\",\"Lion\"],\"Uranus\":[\"Lion\"],\"Neptune\":[\"Vierge\"],\"Pluton\":[\"Taureau\"]};\nconst CHUTE_R     = {\"Soleil\":\"Balance\",\"Lune\":\"Scorpion\",\"Mercure\":\"Poissons\",\"Vénus\":\"Vierge\",\"Mars\":\"Cancer\",\"Jupiter\":\"Capricorne\",\"Saturne\":\"Bélier\",\"Uranus\":\"Taureau\",\"Neptune\":\"Capricorne\",\"Pluton\":\"Verseau\"};\n\nconst getDig = (p, s) => {\n    if ((DOMICILE_R[p]||[]).includes(s))  return {dignite:\"Domicile\",  force:\"FORT\",   sym:\"✦\",  cls:\"dig-fort\"};\n    if (EXALTATION_R[p] === s)            return {dignite:\"Exaltation\",force:\"FORT\",   sym:\"✧\",  cls:\"dig-fort\"};\n    if ((EXIL_R[p]||[]).includes(s))      return {dignite:\"Exil\",      force:\"FAIBLE\", sym:\"✗\",  cls:\"dig-faible\"};\n    if (CHUTE_R[p] === s)                 return {dignite:\"Chute\",     force:\"FAIBLE\", sym:\"✗✗\", cls:\"dig-chute\"};\n    return {dignite:\"Pérégrin\", force:\"NEUTRE\", sym:\"\", cls:\"dig-neutre\"};\n};\n\nconst natalDictR = {};\nnatalPlanets.forEach(p => {\n    const name = p.planet?.fr || p.planet?.en || \"\";\n    if (!name) return;\n    const deg  = p.fullDegree;\n    const sign = p.zodiac_sign?.name?.fr || signs[Math.floor(deg/30)%12];\n    const house= findNatalHouse(deg);\n    const isRetro = p.isRetro === true || p.isRetro === \"True\";\n    const dig  = getDig(name, sign);\n    natalDictR[name] = { deg, sign, house, isRetro, ...dig };\n});\n\nconst NALSP_ORB = {\"Conjonction\":10,\"Opposition\":10,\"Carré\":8,\"Trigone\":8,\"Sextile\":6};\nconst NALSP_DEG = {\"Conjonction\":0,\"Sextile\":60,\"Carré\":90,\"Trigone\":120,\"Opposition\":180};\nconst natalAspR = {};\nconst natalNamesR = Object.keys(natalDictR);\nnatalNamesR.forEach(n => { natalAspR[n] = []; });\nfor (let i=0; i<natalNamesR.length; i++) {\n    for (let j=i+1; j<natalNamesR.length; j++) {\n        const nA=natalNamesR[i], nB=natalNamesR[j];\n        let diff = Math.abs(natalDictR[nA].deg - natalDictR[nB].deg);\n        if (diff>180) diff=360-diff;\n        for (const [asp, maxOrb] of Object.entries(NALSP_ORB)) {\n            const orbe = parseFloat(Math.abs(diff - NALSP_DEG[asp]).toFixed(2));\n            if (orbe <= maxOrb) {\n                natalAspR[nA].push({ planete:nB, type:asp, orbe, maison:natalDictR[nB].house, signe:natalDictR[nB].sign });\n                natalAspR[nB].push({ planete:nA, type:asp, orbe, maison:natalDictR[nA].house, signe:natalDictR[nA].sign });\n            }\n        }\n    }\n}\nnatalNamesR.forEach(n => { natalAspR[n].sort((a,b)=>a.orbe-b.orbe); });\n\nconst receptionsR = [];\nfor (let i=0; i<natalNamesR.length; i++) {\n    for (let j=i+1; j<natalNamesR.length; j++) {\n        const pA=natalNamesR[i], pB=natalNamesR[j];\n        const sA=natalDictR[pA]?.sign, sB=natalDictR[pB]?.sign;\n        if (!sA||!sB) continue;\n        const AenDomB=(DOMICILE_R[pB]||[]).includes(sA), BenDomA=(DOMICILE_R[pA]||[]).includes(sB);\n        const AenExaB=EXALTATION_R[pB]===sA,              BenExaA=EXALTATION_R[pA]===sB;\n        if (AenDomB && BenDomA) receptionsR.push({ pA,pB,type:\"domicile\",maisA:natalDictR[pA].house,maisB:natalDictR[pB].house });\n        else if ((AenDomB&&BenExaA)||(BenDomA&&AenExaB)) receptionsR.push({ pA,pB,type:\"semi\",maisA:natalDictR[pA].house,maisB:natalDictR[pB].house });\n    }\n}\n\nconst buildAxe = (maisNum) => {\n    const h = natalHouses.find(h=>h.maison===maisNum); if (!h) return null;\n    const signe0 = h.segments[0].signe;\n    const m1 = MAITRES_R[signe0]; if (!m1||!natalDictR[m1]) return null;\n    const nd1=natalDictR[m1], r1=nd1.isRetro?\"[℞] \":\"\";\n    const m2=MAITRES_R[nd1.sign]; const nd2=m2?natalDictR[m2]:null;\n    const m3=nd2?MAITRES_R[nd2.sign]:null; const nd3=m3?natalDictR[m3]:null;\n    return {\n        signe0, m1, nd1, r1,\n        m2: m2&&m2!==m1?m2:null, nd2: nd2&&m2!==m1?nd2:null, r2: nd2?.isRetro?\"[℞] \":\"\",\n        m3: m3&&m3!==m2&&m3!==m1?m3:null, nd3: nd3&&m3!==m2&&m3!==m1?nd3:null, r3: nd3?.isRetro?\"[℞] \":\"\",\n    };\n};\n\nconst renderAxeMaitrises = (maisNum) => {\n    const ax = buildAxe(maisNum); if (!ax) return \"\";\n    const digColor = (force) => force===\"FORT\"?\"#15803d\":force===\"FAIBLE\"?\"#b91c1c\":\"#64748b\";\n    const digBg    = (force) => force===\"FORT\"?\"#f0fdf4\":force===\"FAIBLE\"?\"#fff1f2\":\"#f8fafc\";\n\n    const node = (p, nd, r) => nd ? `<span class=\"axe-node\">\n        <span class=\"axe-planet\">${g(p)}${p}</span>\n        ${r?`<span class=\"axe-retro\">℞</span>`:\"\"}\n        <span class=\"axe-pos\">M${nd.house} · ${nd.sign}</span>\n        <span class=\"axe-dig\" style=\"color:${digColor(nd.force)};background:${digBg(nd.force)}\">${nd.sym||\"\"} ${nd.dignite}</span>\n    </span>` : \"\";\n\n    const warnings = [];\n    if (ax.nd1.force===\"FAIBLE\") warnings.push(`⚠ ${ax.m1} ${ax.nd1.sym} ${ax.nd1.dignite} : signal fragilisé pour cette maison.`);\n    if (ax.nd1.force===\"FORT\")   warnings.push(`✦ ${ax.m1} ${ax.nd1.sym} ${ax.nd1.dignite} : signal direct et puissant.`);\n    if (ax.nd1.dignite===\"Pérégrin\" && ax.nd1.isRetro) warnings.push(`⚠ ${ax.m1} Pérégrin + Rétrograde : double fragilisation.`);\n    if (ax.nd3?.force===\"FAIBLE\") warnings.push(`⚠ Bout de chaîne : ${ax.m3} ${ax.nd3.sym} ${ax.nd3.dignite} → l'énergie finale est distordue.`);\n\n    return `<div class=\"section-title axe-title\">🔗 Axe de maîtrise — M${maisNum} (${ax.signe0})</div>\n    <div class=\"axe-chain\">\n        <span class=\"axe-label\">Cuspide ${ax.signe0}</span>\n        <span class=\"axe-arrow\">→</span>\n        ${node(ax.m1, ax.nd1, ax.nd1.isRetro)}\n        ${ax.m2 ? `<span class=\"axe-arrow\">→</span>${node(ax.m2, ax.nd2, ax.nd2?.isRetro)}` : \"\"}\n        ${ax.m3 ? `<span class=\"axe-arrow\">→</span>${node(ax.m3, ax.nd3, ax.nd3?.isRetro)}` : \"\"}\n    </div>\n    ${warnings.length ? `<div class=\"axe-warnings\">${warnings.map(w=>`<div class=\"axe-warn\">${w}</div>`).join(\"\")}</div>` : \"\"}`;\n};\n\nconst renderReceptionsMutuelles = (maisNum) => {\n    const planH = Object.entries(natalDictR).filter(([n,d])=>d.house===maisNum).map(([n])=>n);\n    const seg0  = natalHouses.find(h=>h.maison===maisNum)?.segments[0];\n    const maitre= seg0 ? MAITRES_R[seg0.signe] : null;\n    const relevant = receptionsR.filter(r=>\n        planH.includes(r.pA)||planH.includes(r.pB)||r.pA===maitre||r.pB===maitre\n    );\n    if (!relevant.length) return \"\";\n    const html = relevant.map(r => {\n        const isFull = r.type===\"domicile\";\n        const col  = isFull ? \"#b45309\" : \"#6b7280\";\n        const bg   = isFull ? \"#fffbeb\" : \"#f8fafc\";\n        return `<div class=\"timeline-item recep-item\" style=\"border-left-color:${col};background:${bg}\">\n            <div class=\"event-text\">\n                <span class=\"recep-badge\" style=\"color:${col};border-color:${col}\">${isFull?\"✦✦ Mutuelle\":\"✦ Semi-mutuelle\"}</span>\n                ${g(r.pA)} <strong>${r.pA}</strong> (M${r.maisA}) ↔ ${g(r.pB)} <strong>${r.pB}</strong> (M${r.maisB})\n                <span style=\"color:#94a3b8;font-size:0.82rem\">${isFull?\"échangent leurs domiciles — se renforcent mutuellement\":\"coopération partielle\"}</span>\n            </div>\n        </div>`;\n    }).join(\"\");\n    return `<div class=\"section-title recep-title\">↔ Réceptions mutuelles</div>${html}`;\n};\n\nconst renderFiguresNatales = (maisNum, aspectsList) => {\n    if (!aspectsList?.length) return \"\";\n    const planH = Object.entries(natalDictR).filter(([n,d])=>d.house===maisNum).map(([n])=>n);\n    if (!planH.length) return \"\";\n    const touched = new Set();\n    aspectsList.forEach(a => { if (a.maison === maisNum || (a.isAngle && maisNum===a.maison)) touched.add(a.pNatal); });\n    planH.forEach(p => touched.add(p));\n\n    const lines = [];\n    touched.forEach(pN => {\n        const links = (natalAspR[pN]||[]).filter(l => l.type===\"Conjonction\"||l.type===\"Opposition\" ? l.orbe<=6 : l.orbe<=5);\n        if (!links.length) return;\n        const linesP = links.map(l => {\n            const q   = l.orbe<=1?\"★ \":\"\";\n            const dig = natalDictR[l.planete];\n            return `<div class=\"fn-link\">\n                <span class=\"fn-asp\" style=\"color:${(aspectColors[l.type]||defaultColor).text}\">${l.type}</span>\n                ${g(l.planete)} <strong>${l.planete}</strong>\n                <span class=\"fn-meta\">M${l.maison} · ${l.signe} · ${q}${l.orbe}°</span>\n                ${dig&&dig.force!==\"NEUTRE\"?`<span class=\"fn-dig ${dig.cls}\">${dig.sym} ${dig.dignite}</span>`:\"\"}\n            </div>`;\n        }).join(\"\");\n        lines.push(`<div class=\"fn-group\">\n            <div class=\"fn-header\">${g(pN)} <strong>${pN}</strong> natal · réseau activé :</div>\n            ${linesP}\n        </div>`);\n    });\n    if (!lines.length) return \"\";\n    return `<div class=\"section-title fn-title\">◉ Figures natales & réseau N→N</div>${lines.join(\"\")}`;\n};\n\nconst renderDignitesActives = (aspectsList) => {\n    if (!aspectsList?.length) return \"\";\n    const items = [];\n    const seen = new Set();\n    aspectsList.forEach(a => {\n        const pN  = a.pNatal; if (!pN || seen.has(pN)) return;\n        const nd  = natalDictR[pN]; if (!nd || nd.force === \"NEUTRE\") return;\n        seen.add(pN);\n        const col = nd.force===\"FORT\"?\"#15803d\":\"#b91c1c\";\n        const bg  = nd.force===\"FORT\"?\"#f0fdf4\":\"#fff1f2\";\n        const msg = nd.force===\"FORT\"\n            ? `Transit amplifié — réponse directe et puissante.`\n            : `Transit fragilisé — l'énergie se déplace avec peine ou se retourne.`;\n        items.push(`<div class=\"timeline-item dig-item\" style=\"border-left-color:${col};background:${bg}\">\n            <div class=\"event-text\">\n                <span class=\"dig-badge\" style=\"color:${col};border-color:${col}\">${nd.sym} ${nd.dignite}</span>\n                ${g(pN)} <strong>${pN}</strong> natal en <strong>${nd.sign}</strong> — ${msg}\n            </div>\n        </div>`);\n    });\n    if (!items.length) return \"\";\n    return `<div class=\"section-title dig-title\">⚖ Filtres de dignité</div>${items.join(\"\")}`;\n};\n\nconst renderTranslationsLumiere = (list) => {\n    if (!list?.length) return \"\";\n    const html = list.map(tl =>\n        `<div class=\"timeline-item tl-item\" style=\"border-left-color:#0891b2\">\n            <div class=\"date-box\">${tl.debut} ➔ ${tl.fin}</div>\n            <div class=\"event-text\">\n                ${g(tl.pF)} <strong>${tl.pF}</strong>\n                <span class=\"tl-badge\">Translation</span>\n                traduit ${g(tl.pS1)} <strong>${tl.pS1}</strong> (M${tl.maisS1})\n                → ${g(tl.pS2)} <strong>${tl.pS2}</strong> (M${tl.maisS2})\n                <span style=\"color:#94a3b8;font-size:0.82rem\">via ${tl.asp1}/${tl.asp2}</span>\n            </div>\n        </div>`\n    ).join(\"\");\n    return `<div class=\"section-title tl-title\">⟿ Translations de lumière</div>${html}`;\n};\n\n// ---- RENDERERS C7 ----\nconst renderDegresCritiques = (list) => {\n    if (!list?.length) return \"\";\n    const seen = new Set();\n    const dedup = list.filter(t => { const k=t.slice(0,80); if(seen.has(k))return false; seen.add(k); return true; });\n    const html = dedup.map(txt =>\n        `<div class=\"timeline-item dc-item\" style=\"border-left-color:#d97706\">\n            <div class=\"event-text\">\n                <span class=\"dc-badge\">⚑ Degré critique</span>\n                ${txt}\n            </div>\n        </div>`\n    ).join(\"\");\n    return `<div class=\"section-title dc-title\">⚑ Degrés critiques & anarètes</div>${html}`;\n};\n\nconst renderProfection = (prof) => {\n    if (!prof) return \"\";\n    const isAnn  = prof.role === \"annuelle\";\n    const isSei  = !!prof.seigneurIci;\n    const isMens = prof.role === \"mensuelle\";\n    const col  = isAnn ? \"#0f766e\" : isSei ? \"#7c3aed\" : \"#0891b2\";\n    const bg   = isAnn ? \"#f0fdfa\" : isSei ? \"#faf5ff\" : \"#f0fdfe\";\n    const icon = isAnn ? \"✶\" : isSei ? \"♆\" : \"☽\";\n    let txt = \"\";\n    if (isAnn)  txt = `<strong>MAISON DE L'ANNÉE</strong> (profection annuelle) — secteur de vie central.${prof.seigneur ? `<br><span style=\"font-size:0.85rem\">Seigneur de l'année : <strong>${prof.seigneur}</strong> (M${prof.seignMaison}) — ses transits sont amplifiés toute l'année.</span>` : \"\"}`;\n    if (isSei)  txt = `<strong>${prof.seigneurIci}</strong> est le seigneur de l'année (M${prof.maisAnn} profectée) et réside ici — \"quartier général\" de l'année.`;\n    if (isMens) txt = `Profection mensuelle : M${prof.maisAnn} est la maison annuelle — cette maison est active ce mois.`;\n    return `<div class=\"prof-block\" style=\"border-left-color:${col};background:${bg}\">\n        <span class=\"prof-icon\" style=\"color:${col}\">${icon}</span>\n        <div class=\"prof-text\">${txt}</div>\n    </div>`;\n};\n\nconst renderAntiscia = (list) => {\n    if (!list?.length) return \"\";\n    const seen = new Set();\n    const dedup = list.filter(t => { const k=t.slice(0,80); if(seen.has(k))return false; seen.add(k); return true; });\n    const html = dedup.map(txt =>\n        `<div class=\"timeline-item ant-item\" style=\"border-left-color:#6366f1\">\n            <div class=\"event-text\">\n                <span class=\"ant-badge\">◈ Antiscion</span>\n                ${txt}\n            </div>\n        </div>`\n    ).join(\"\");\n    return `<div class=\"section-title ant-title\">◈ Antiscia & Contra-antiscia</div>${html}`;\n};\n\nconst renderIngress = (list) => {\n    if (!list?.length) return \"\";\n    const seen = new Set();\n    const dedup = list.filter(t => { const k=t.slice(0,70); if(seen.has(k))return false; seen.add(k); return true; });\n    const html = dedup.map(txt =>\n        `<div class=\"timeline-item ing-item\" style=\"border-left-color:#059669\">\n            <div class=\"event-text\"><span class=\"ing-badge\">➤ Ingress</span>${txt}</div>\n        </div>`\n    ).join(\"\");\n    return `<div class=\"section-title ing-title\">➤ Ingress planétaires</div>${html}`;\n};\n\nconst renderCyclesVie = (list) => {\n    if (!list?.length) return \"\";\n    const html = list.map(txt =>\n        `<div class=\"cyc-block\">\n            <span class=\"cyc-icon\">⧗</span>\n            <div class=\"cyc-text\">${txt}</div>\n        </div>`\n    ).join(\"\");\n    return `<div class=\"section-title cyc-title\">⧗ Cycles de vie</div>${html}`;\n};\n\nconst renderTransits = (list, emptyMsg) => {\n    if (!list?.length) return `<div class=\"empty\">${emptyMsg}</div>`;\n    return list.map(t =>\n        `<div class=\"timeline-item\" style=\"border-left-color:#1e3a8a\">\n            <div class=\"date-box\">${t.debut} ➔ ${t.fin}</div>\n            <div class=\"event-text\">${g(t.planete)} <strong>${t.planete}</strong> traverse ${signGlyphs[t.signe]||\"\"} <strong>${t.signe}</strong></div>\n        </div>`\n    ).join(\"\");\n};\n\nconst renderAspects = (list, emptyMsg) => {\n    if (!list?.length) return `<div class=\"empty\">${emptyMsg}</div>`;\n    return list.map(a => {\n        const c     = aspectColors[a.type] || defaultColor;\n        const isAng = a.isAngle || ANGLE_NAMES_SET.has(a.pNatal);\n        const rowBg = isAng ? \"background:#fffbeb;\" : \"\";\n        return `<div class=\"timeline-item${isAng ? \" angle-row\" : \"\"}\" style=\"border-left-color:${c.border};${rowBg}\">\n            <div class=\"date-box\">${a.debut} ➔ ${a.fin}</div>\n            <div class=\"event-text\">\n                ${g(a.pTransit)} <strong>${a.pTransit}</strong>\n                en ${badge(a.type, isAng)}\n                à votre ${g(a.pNatal)} <strong>${a.pNatal}</strong> natal\n                ${isAng ? `<span class=\"angle-pill\">${glyphs[a.pNatal]||a.pNatal}</span>` : \"\"}\n            </div>\n        </div>`;\n    }).join(\"\");\n};\n\nconst renderStations = (list) => {\n    if (!list?.length) return \"\";\n    const html = list.map(s => {\n        const isRetro = s.type === \"Station rétrograde\";\n        const color   = isRetro ? \"#7c3aed\" : \"#15803d\";\n        const bg      = isRetro ? \"#f5f3ff\" : \"#f0fdf4\";\n        return `<div class=\"timeline-item station-item\" style=\"border-left-color:${color}\">\n            <div class=\"date-box\">${s.date}</div>\n            <div class=\"event-text\">\n                ${g(s.planete)} <strong>${s.planete}</strong>\n                <span class=\"station-badge\" style=\"color:${color};background:${bg};border-color:${color}\">${isRetro ? \"℞\" : \"D\"} ${s.type}</span>\n                en ${signGlyphs[s.signe]||\"\"} <strong>${s.signe}</strong>\n            </div>\n        </div>`;\n    }).join(\"\");\n    return `<div class=\"section-title station-title\">⟳ Stations rétrogrades &amp; directes</div>${html}`;\n};\n\nconst renderLunaisons = (list) => {\n    if (!list?.length) return \"\";\n    const html = list.map(l => {\n        const isNL  = l.type === \"Nouvelle Lune\";\n        const color = isNL ? \"#0f172a\" : \"#b45309\";\n        const bg    = isNL ? \"#f8fafc\" : \"#fffbeb\";\n        return `<div class=\"timeline-item\" style=\"border-left-color:${color}\">\n            <div class=\"date-box\">${l.date}</div>\n            <div class=\"event-text\">\n                <span style=\"font-size:1.1rem\">${isNL ? \"🌑\" : \"🌕\"}</span>\n                <span class=\"lunai-badge\" style=\"color:${color};background:${bg};border-color:${color}\">${l.type}</span>\n                en ${signGlyphs[l.signe]||\"\"} <strong>${l.signe}</strong>\n                <span style=\"color:#94a3b8;font-size:0.82rem\">(${(l.degre % 30).toFixed(1)}°)</span>\n            </div>\n        </div>`;\n    }).join(\"\");\n    return `<div class=\"section-title lunai-title\">☽ Lunaisons</div>${html}`;\n};\n\nconst renderEclipses = (list) => {\n    if (!list?.length) return \"\";\n    const html = list.map(e => {\n        const isSol = e.astre === \"Soleil\";\n        const color = isSol ? \"#c2410c\" : \"#1d4ed8\";\n        const bg    = isSol ? \"#fff7ed\" : \"#eff6ff\";\n        return `<div class=\"timeline-item eclipse-item\" style=\"border-left-color:${color}\">\n            <div class=\"date-box\">${e.date}${e.heure ? \" \" + e.heure : \"\"}</div>\n            <div class=\"event-text\">\n                <span class=\"eclipse-icon\" style=\"color:${color}\">${isSol ? \"☉\" : \"☽\"}</span>\n                <span class=\"eclipse-badge\" style=\"color:${color};background:${bg};border-color:${color}\">ÉCLIPSE ${e.type.toUpperCase()} de ${e.astre.toUpperCase()}</span>\n                en ${signGlyphs[e.signe]||\"\"} <strong>${e.signe}</strong>\n            </div>\n        </div>`;\n    }).join(\"\");\n    return `<div class=\"section-title eclipse-title\">☀ Éclipses</div>${html}`;\n};\n\nconst renderPassagesAngles = (list, houseNum) => {\n    if (!list?.length) return \"\";\n    const angleKey = ANGLE_BY_HOUSE[houseNum];\n    if (!angleKey) return \"\";\n    const ac  = ANGLE_COLORS[angleKey] || defaultColor;\n    const html = list.map(a =>\n        `<div class=\"timeline-item angle-passage-item\" style=\"border-left-color:${ac.border}\">\n            <div class=\"date-box\">${a.debut} ➔ ${a.fin}</div>\n            <div class=\"event-text\">\n                ${g(a.planete)} <strong>${a.planete}</strong>\n                <span class=\"conj-badge\">Conjonction</span>\n                <span class=\"angle-key-badge\" style=\"color:${ac.text};background:${ac.bg};border-color:${ac.border}\">${a.angleKey}</span>\n                <span class=\"angle-full-name\">${a.angleName}</span>\n                <span style=\"font-size:0.82rem;color:#94a3b8;\">en ${signGlyphs[a.signe]||\"\"} ${a.signe}</span>\n            </div>\n        </div>`\n    ).join(\"\");\n    const angleFullNames = { \"ASC\":\"Ascendant\",\"IC\":\"Imum Coeli\",\"DSC\":\"Descendant\",\"MC\":\"Milieu du Ciel\" };\n    const anPos   = natalAnglePos[angleFullNames[angleKey]];\n    const posInfo = anPos ? ` — ${signGlyphs[anPos.sign]||\"\"} ${anPos.sign} ${(anPos.deg % 30).toFixed(1)}°` : \"\";\n    return `<div class=\"section-title angle-title\">⊕ Passages sur l'angle ${angleKey}${posInfo}</div>${html}`;\n};\n\nconst renderAspectsMondiaux = (list) => {\n    if (!list?.length) return \"\";\n    const ll = list.filter(a => a.cat === \"lente_lente\");\n    const rl = list.filter(a => a.cat === \"rapide_lente\");\n\n    const renderGroup = (items, subtitle, bgRow) =>\n        items.length === 0 ? \"\" : items.map(a => {\n            const c = aspectColors[a.type] || defaultColor;\n            return `<div class=\"timeline-item mondial-item\" style=\"border-left-color:${c.border};background:${bgRow}\">\n                <div class=\"date-box\">${a.debut} ➔ ${a.fin}</div>\n                <div class=\"event-text\">\n                    ${g(a.p1)} <strong>${a.p1}</strong>\n                    <span class=\"mondial-sign\">${signGlyphs[a.signe1]||\"\"}</span>\n                    ${badge(a.type, false)}\n                    ${g(a.p2)} <strong>${a.p2}</strong>\n                    <span class=\"mondial-sign\">${signGlyphs[a.signe2]||\"\"}</span>\n                    <span class=\"mondial-cat-badge ${a.cat === \"lente_lente\" ? \"ll-badge\" : \"rl-badge\"}\">${a.cat === \"lente_lente\" ? \"Cycle\" : \"Activation\"}</span>\n                    ${a.maison !== a.maison2 ? `<span class=\"dual-house\">M${a.maison}↔M${a.maison2}</span>` : \"\"}\n                </div>\n            </div>`;\n        }).join(\"\");\n\n    const llHTML = renderGroup(ll, \"Cycles Lente–Lente\", \"#fafafa\");\n    const rlHTML = renderGroup(rl, \"Activations Rapide–Lente\", \"#f0fdf4\");\n\n    if (!llHTML && !rlHTML) return \"\";\n\n    const subLL = ll.length ? `<div class=\"mondial-sub\">Cycles</div>${llHTML}` : \"\";\n    const subRL = rl.length ? `<div class=\"mondial-sub activation-sub\">Activations</div>${rlHTML}` : \"\";\n\n    return `<div class=\"section-title mondial-title\">⊛ Aspects du Ciel en Transit</div>${subLL}${subRL}`;\n};\n\nconst maisons = items.filter(it => it.maison >= 1 && it.maison <= 12).sort((a,b) => a.maison - b.maison);\n\nconst renderHouseBlock = (m) => {\n    const num  = m.maison;\n    const segs = houseSegments[num] || m.structure_natale || [];\n\n    const segHTML = segs.map(s =>\n        `<div class=\"structure-item\">${signGlyphs[s.signe]||\"\"} ${s.signe} (${(s.degre_debut||0).toFixed(1)}°)</div>`\n    ).join(\"\");\n\n    const natalHere = planetsByHouse[num] || [];\n    const natalHTML = natalHere.map(p => {\n        const cls = p.isAngle ? \"natal-planet-item angle-natal-item\" : \"natal-planet-item\";\n        return `<div class=\"${cls}\">\n            <span class=\"natal-glyph\">${glyphs[p.name]||\"\"}</span>\n            <span class=\"natal-name\">${p.name}</span>\n            <span class=\"natal-pos\">${p.deg}° ${p.sign}</span>\n        </div>`;\n    }).join(\"\");\n\n    const structureBar = `<div class=\"structure-bar\">\n        <div class=\"structure-signs\">${segHTML}</div>\n        ${natalHere.length ? `<div class=\"structure-divider\"></div><div class=\"structure-natal\">${natalHTML}</div>` : \"\"}\n    </div>`;\n\n    const angleBadge = ANGLE_BY_HOUSE[num]\n        ? (() => { const ak=ANGLE_BY_HOUSE[num]; const ac=ANGLE_COLORS[ak]; return `<span class=\"angle-banner-badge\" style=\"background:${ac.bg};color:${ac.text};border-color:${ac.border}\">${ak}</span>`; })()\n        : \"\";\n\n    const extraBadges = [\n        angleBadge,\n        m.passages_angles?.length   ? `<span class=\"extra-badge angle-cnt-badge\">⊕ ${m.passages_angles.length} passage${m.passages_angles.length>1?\"s\":\"\"}</span>` : \"\",\n        m.translations_lumiere?.length ? `<span class=\"extra-badge tl-badge2\">⟿ ${m.translations_lumiere.length}</span>` : \"\",\n        m.degres_critiques?.length     ? `<span class=\"extra-badge dc-badge2\">⚑</span>` : \"\",\n        m.profection                    ? `<span class=\"extra-badge prof-badge2\">✶</span>` : \"\",\n        m.ingress?.length               ? `<span class=\"extra-badge ing-badge2\">➤ ${m.ingress.length}</span>` : \"\",\n        m.cycles_vie?.length            ? `<span class=\"extra-badge cyc-badge2\">⧗</span>` : \"\",\n        m.antiscia?.length              ? `<span class=\"extra-badge ant-badge2\">◈ ${m.antiscia.length}</span>` : \"\",\n        receptionsR.some(r=>r.maisA===num||r.maisB===num) ? `<span class=\"extra-badge recep-badge2\">↔</span>` : \"\",\n        m.aspects_mondiaux?.length  ? `<span class=\"extra-badge mondial-badge\">⊛ ${m.aspects_mondiaux.length}</span>` : \"\",\n        m.stations_retro?.length    ? `<span class=\"extra-badge retro-badge\">${m.stations_retro.length} station${m.stations_retro.length>1?\"s\":\"\"}</span>` : \"\",\n        m.lunaisons?.length         ? `<span class=\"extra-badge lunai-badge2\">${m.lunaisons.length} lunaison${m.lunaisons.length>1?\"s\":\"\"}</span>` : \"\",\n        m.eclipses?.length          ? `<span class=\"extra-badge ecl-badge\">⚠ ${m.eclipses.length} éclipse${m.eclipses.length>1?\"s\":\"\"}</span>` : \"\"\n    ].filter(Boolean).join(\"\");\n\n    const s1 = `<div class=\"section-title slow-title\">Présence des planètes lentes</div>\n        ${renderTransits(m.transits_lentes, \"Aucune planète lente ne traverse ce secteur sur cette période.\")}`;\n    const s2 = `<div class=\"section-title slow-title\">Figures &amp; Aspects activés par les planètes lentes</div>\n        ${renderAspects(m.aspects_lentes, \"Aucun aspect de planète lente détecté.\")}`;\n\n    let s3 = \"\", s4 = \"\";\n    if (showRapides) {\n        s3 = `<div class=\"section-title fast-title\">Présence des planètes rapides</div>\n            ${renderTransits(m.transits_rapides, \"Aucune planète rapide ne traverse ce secteur sur cette période.\")}`;\n        s4 = `<div class=\"section-title fast-title\">Figures &amp; Aspects activés par les planètes rapides</div>\n            ${renderAspects(m.aspects_rapides, \"Aucun aspect de planète rapide détecté.\")}`;\n    }\n\n    const sMondiaux   = renderAspectsMondiaux(m.aspects_mondiaux);\n    const sAngles    = renderPassagesAngles(m.passages_angles, num);\n    const sStations  = renderStations(m.stations_retro);\n    const sLunai     = renderLunaisons(m.lunaisons);\n    const sEcl       = renderEclipses(m.eclipses);\n    const sAxe       = renderAxeMaitrises(num);\n    const sRecep     = renderReceptionsMutuelles(num);\n    const sFN        = renderFiguresNatales(num, m.aspects_lentes);\n    const sDig       = renderDignitesActives(m.aspects_lentes);\n    const sTL        = renderTranslationsLumiere(m.translations_lumiere);\n    const sDC        = renderDegresCritiques(m.degres_critiques);\n    const sProf      = renderProfection(m.profection);\n    const sAnt       = renderAntiscia(m.antiscia);\n    const sIng       = renderIngress(m.ingress);\n    const sCyc       = renderCyclesVie(m.cycles_vie);\n\n    return `\n    <div class=\"house-block${ANGLE_BY_HOUSE[num] ? \" angular-house\" : \"\"}\">\n        <div class=\"house-banner\">\n            <div class=\"house-title\">Maison ${num}</div>\n            <div class=\"house-meta\">\n                <span class=\"type-badge\" style=\"background:${tc.badge};color:${tc.badgeTxt}\">${labelType}</span>\n                <span class=\"periode-label\">${dateEntreeStr} → ${dateSortieStr}</span>\n                ${extraBadges}\n            </div>\n        </div>\n        ${structureBar}\n        <div class=\"house-content\">\n            ${sProf}${sCyc}${sAxe}${sRecep}${sEcl}${sLunai}${sAngles}${sStations}${sMondiaux}${sIng}${sTL}${sDC}${sAnt}${sDig}${sFN}${s1}${s2}${s3}${s4}\n        </div>\n    </div>`;\n};\n\nconst blocsMaisons = maisons.map(renderHouseBlock).join(\"\\n\");\n\nconst html = `<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>${titrePrincipal}</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap');\n        \n        body{font-family:'Segoe UI',system-ui,sans-serif;background:#f1f5f9;color:#1e293b;margin:0;padding:40px}\n        .report-container{max-width:1100px;margin:auto;background:white;padding:40px;border-radius:12px;box-shadow:0 10px 15px -3px rgba(0,0,0,0.1)}\n        \n        .main-header { background: ${tc.bg} !important; padding: 45px 30px 40px; color: white; text-align: center; border-radius: 12px; margin-bottom: 40px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n        .main-header h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 34px; font-weight: 700; letter-spacing: 0.3px; color: #ffffff; margin: 0 0 10px; line-height: 1.35; }\n        .main-header p.subtitle { font-family: 'Source Sans 3', 'Segoe UI', sans-serif; font-size: 14.5px; font-weight: 300; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(255,255,255,0.75); margin: 0 0 6px; }\n        .main-header p.details { font-family: 'Source Sans 3', 'Segoe UI', sans-serif; font-size: 14.5px; font-weight: 400; color: rgba(255,255,255,0.9); letter-spacing: 0.5px; margin: 8px 0 0; }\n        \n        .house-block{margin-bottom:45px;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden}\n        .angular-house{box-shadow:0 0 0 2px rgba(30,58,138,0.08)}\n        .house-banner{background:${tc.bg};color:white;padding:16px 25px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}\n        .house-title{font-size:1.5rem;font-weight:800}\n        .house-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}\n        .type-badge{padding:3px 12px;border-radius:12px;font-size:0.78rem;font-weight:800}\n        .periode-label{font-size:0.82rem;color:rgba(255,255,255,0.75);font-weight:600}\n        .extra-badge{padding:2px 10px;border-radius:10px;font-size:0.72rem;font-weight:800;border:1px solid currentColor}\n        .retro-badge{color:#a5b4fc;border-color:#a5b4fc}\n        .lunai-badge2{color:#fcd34d;border-color:#fcd34d}\n        .ecl-badge{color:#fca5a5;border-color:#fca5a5}\n        .angle-cnt-badge{color:#6ee7b7;border-color:#6ee7b7}\n        .mondial-badge{color:#f0abfc;border-color:#f0abfc}\n        .angle-banner-badge{padding:3px 12px;border-radius:12px;font-size:0.82rem;font-weight:900;border:1px solid currentColor;letter-spacing:0.05em}\n        .structure-bar{background:#fff;padding:12px 25px;border-bottom:1px solid #f1f5f9;display:flex;flex-direction:column;gap:10px}\n        .structure-signs,.structure-natal{display:flex;flex-wrap:wrap;gap:8px}\n        .structure-divider{height:1px;background:#f1f5f9;margin:2px 0}\n        .structure-item{background:#f8fafc;color:#334155;padding:5px 14px;border-radius:20px;font-size:0.85rem;font-weight:700;border:1px solid #e2e8f0}\n        .natal-planet-item{display:flex;align-items:center;gap:5px;background:#fef9c3;border:1px solid #fde68a;border-radius:20px;padding:4px 12px;font-size:0.82rem}\n        .angle-natal-item{background:#f0fdf4;border-color:#bbf7d0}\n        .natal-glyph{font-size:1.1rem;color:#92400e}\n        .angle-natal-item .natal-glyph{color:#15803d}\n        .natal-name{font-weight:700;color:#78350f}\n        .angle-natal-item .natal-name,.angle-natal-item .natal-pos{color:#15803d}\n        .natal-pos{color:#a16207;font-size:0.77rem}\n        .house-content{padding:2