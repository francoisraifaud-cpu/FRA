      "parameters": {
        "jsCode": "// [DHN v5.5 — C-n8n] Build Failed Payload\n// Why: lorsqu'un nœud du workflow DHN plante (API down, JS error, timeout…),\n// la commande reste bloquée en 'processing' côté site et l'utilisateur n'est\n// jamais notifié. Ce nœud construit le payload `failed` pour le callback site.\n//\n// Source de l'orderId :\n//   - Le payload Error Trigger expose $json.execution + $json.workflow mais PAS\n//     les données métier des nœuds qui ont tourné.\n//   - On tente donc d'accéder aux nœuds 'Extract Variables' (DHN) ou 'Webhook'\n//     du workflow planté via la syntaxe $(node) qui fonctionne en error workflow\n//     uniquement si l'Error Trigger est dans le MÊME workflow que celui qui plante.\n//   - Si l'erreur survient AVANT que ces nœuds aient tourné (très rare —\n//     auth Webhook, etc.), orderId sera null et le site logguera l'incident sans\n//     pouvoir lier à une commande.\n\nconst err = $input.first()?.json || {};\nconst execution = err.execution || {};\nconst workflow = err.workflow || {};\n\nfunction safeNode(nodeName) {\n  try {\n    const j = $(nodeName).first()?.json;\n    return j && typeof j === 'object' ? j : null;\n  } catch (e) {\n    return null;\n  }\n}\n\nfunction readOrderId() {\n  const candidates = ['Extract Variables', 'Extract Variables DHN', 'Extract Variables DHN1', 'Extract Variables1', 'Webhook'];\n  for (const n of candidates) {\n    const j = safeNode(n);\n    if (!j) continue;\n    if (typeof j.orderId === 'string' && j.orderId.trim()) return j.orderId.trim();\n    const body = j.body && typeof j.body === 'object' && !Array.isArray(j.body) ? j.body : null;\n    if (body && typeof body.orderId === 'string' && body.orderId.trim()) return body.orderId.trim();\n  }\n  return null;\n}\n\nconst orderId = readOrderId();\nconst execId = (execution.id !== undefined && execution.id !== null) ? String(execution.id) : null;\nconst errNode = execution.error?.node?.name || execution.lastNodeExecuted || null;\nconst errMsg = execution.error?.message || execution.error?.description || 'Erreur n8n DHN sans message';\n\n// Tronqué à 500 char pour rester raisonnable côté DB (lastError).\nconst safeMsg = String('[' + (errNode || '?') + '] ' + errMsg).slice(0, 500);\n\nreturn [{\n  json: {\n    orderId: orderId,\n    status: 'failed',\n    error: safeMsg,\n    n8nExecutionId: execId,\n    _meta: {\n      workflowId: workflow.id || null,\n      workflowName: workflow.name || null,\n      errorNode: errNode,\n      hasOrderId: Boolean(orderId)\n    }\n  }\n}];\n"
      },
