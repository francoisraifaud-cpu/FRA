    '&date_fin='+enc(_eclipseWin.date_fin)+
    '&year='+birthY+'&month='+birthM+'&date='+birthD+
    '&hours='+hh+'&minutes='+mm+'&seconds=0'+
    '&latitude='+lat+'&longitude='+lon+'&timezone='+tz;
  return 'http://46.225.174.155:8000/progressions/eclipses?'+qs;
