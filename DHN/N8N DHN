const RULER_OF={Belier:'Mars',Taureau:'V\u00e9nus',Gemeaux:'Mercure',Cancer:'Lune',Lion:'Soleil',Vierge:'Mercure',Balance:'V\u00e9nus',Scorpion:'Mars',Sagittaire:'Jupiter',Capricorne:'Saturne',Verseau:'Saturne',Poissons:'Jupiter'};
function _normSignKey(s){return String(s||'').normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().trim();}
function wScoreRawOf(sign){
  if(!scoreMap||sign==null)return 0;
  if(scoreMap[sign]!=null)return Number(scoreMap[sign])||0;
  const target=_normSignKey(sign);
  for(const k of Object.keys(scoreMap)){if(_normSignKey(k)===target)return Number(scoreMap[k])||0;}
  return 0;
}
function findNatalPlanet(name){
  if(!name||!natalBodies||!natalBodies.length)return null;
  const target=_normSignKey(name);
  for(const p of natalBodies){if(_normSignKey(p.name)===target)return p;}
  return null;
}
function signOfRulerForAsc(ascSignAny){
  if(!ascSignAny)return null;
  const target=_normSignKey(ascSignAny);
  let canonical=null;
  for(const k of Object.keys(RULER_OF)){if(_normSignKey(k)===target){canonical=k;break;}}
  if(!canonical)return null;
  const planetName=RULER_OF[canonical];
  const pl=findNatalPlanet(planetName);
  if(!pl||typeof pl.deg!=='number')return null;
  const idx=Math.floor(((pl.deg%360)+360)%360/30);
