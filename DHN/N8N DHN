  if(arcScore>ARC_CAP){
    arcScore=Math.round((ARC_CAP+(arcScore-ARC_CAP)*ARC_DAMP)*10)/10;
  }
  const totalScore=wScore+arcScore+progScore+srScore;
  return{time,ascDeg,mcDeg,ascSign,wSign,wScoreRaw,wScore,arcScore,arcScoreRaw,progScore,srScore,totalScore,arcDetails,progDetails,srDetails,src};
});

