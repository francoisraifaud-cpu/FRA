  if(typeof fetch==='function'){
    try{
      const r=await fetch(url,{method:'GET',headers:{Accept:'application/json'}});
      if(r.ok){const j=await r.json();const arr=_extractEclArr(j);_eclipseFetchDbg='fetch-ok-'+arr.length;return arr;}
      _eclipseFetchDbg='fetch-http-'+r.status;return[];
    }catch(e){_eclipseFetchDbg='fetch-err-'+(String(e?.message||e).slice(0,60));}
  }
