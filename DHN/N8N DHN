const PS={'Lune':1.5,'Soleil':1.0,'Mercure':1.0,'V\u00e9nus':1.0,'Mars':0.7,'Jupiter':0.3,'Saturne':0.3,'Uranus':0.15,'Neptune':0.15,'Pluton':0.15};
function ps(n){return PS[n]||0.5;}

function countProgHits(progSlice,slotAsc,slotMc,targets,slotJD){
  if(!progSlice||progSlice.length===0)return{score:0,details:[]};
  const data=progSlice.map(it=>it.json).filter(d=>d&&d.planetes&&d.date);
  if(data.length===0)return{score:0,details:[]};
  let score=0;const details=[];const seen=new Set();
  function toDecDate(d){const p=d.split('-');return parseInt(p[0])+((parseInt(p[1])-1)*30.44+parseInt(p[2]))/365.25;}
  const progPlanets=['Soleil','Lune','Mars','Mercure','Jupiter','V\u00e9nus','Saturne','Uranus','Neptune','Pluton'];
  for(const evt of events){
    const evtDec=evt.year+((evt.month-1)*30.44+evt.day)/365.25;
    let closest=data[0],minDist=999;
    for(const d of data){const dd=toDecDate(d.date);if(Math.abs(dd-evtDec)<minDist){minDist=Math.abs(dd-evtDec);closest=d;}}
    if(!closest?.planetes)continue;
    const pp=closest.planetes;
    // [P-detangles v5.6] Recalcul LOCAL des angles progress\u00e9s pAsc/pMc pour CE cr\u00e9neau et CET \u00e9v\u00e9nement.
    // Avant : on prenait pp['Ascendant'] / pp['MC'] de l'API, calcul\u00e9s pour une heure de naissance unique
    // (milieu de plage), donc identiques pour tous les slots du scan et faux pour les slots loin du milieu.
    // Maintenant : progression secondaire = jour-pour-an. L'instant progress\u00e9 = naissance candidate + age (j).
    // pAsc/pMc d\u00e9pendent fortement de l'heure de naissance candidate (~15\u00b0/h), pAsc = ASC sid\u00e9ral \u00e0 l'instant
    // birthCand + age. Les plan\u00e8tes progress\u00e9es (Lune, etc.) restent prises de l'API, ~insensibles \u00e0 l'heure.
    let pAscLocal,pMcLocal;
    if(slotJD!==undefined){
      const ageY=evtDec-birthDecimal;
      const progJD=slotJD+ageY;
      pAscLocal=calcASCjd(progJD);
      pMcLocal=calcMCjd(progJD);
    }
    // [P8 v5.2] Pour les progressions, le bonus d'affinité s'applique sur la PLANÈTE PROGRESSÉE
    // (la "source" qui transporte la sémantique de l'événement). Ex : voyage_important + pJupiter ↔ nXxx ⇒ ×1.5.
    if(slotAsc!==undefined){
      for(const pn of progPlanets){
        if(!pp[pn])continue;
        const ab=affinityBonus(evt.type,pn);
        const asp=bestAspect(pp[pn].longitude_absolue,slotAsc,1.0);
        if(asp){
          const key='p'+pn+'_'+asp.name+'_nASC';
          const dup=seen.has(key);if(!dup)seen.add(key);
          const tight=1-asp.ao/asp.ou;
          let w=Math.round(asp.weight*pw(pn)*ps(pn)*tight*(dup?0.25:1)*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){score+=w;details.push(evt.label+': p'+pn+' '+asp.name+' nASC ('+w.toFixed(1)+' '+asp.ao.toFixed(2)+'\u00B0'+(dup?'*':'')+(ab>1?' \u2295':'')+')');
          }
        }
      }
    }
    if(slotMc!==undefined){
      for(const pn of progPlanets){
        if(!pp[pn])continue;
        const ab=affinityBonus(evt.type,pn);
        const asp=bestAspect(pp[pn].longitude_absolue,slotMc,1.0);
        if(asp){
          const key='p'+pn+'_'+asp.name+'_nMC';
          const dup=seen.has(key);if(!dup)seen.add(key);
          const tight=1-asp.ao/asp.ou;
          let w=Math.round(asp.weight*pw(pn)*ps(pn)*tight*(dup?0.25:1)*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){score+=w;details.push(evt.label+': p'+pn+' '+asp.name+' nMC ('+w.toFixed(1)+' '+asp.ao.toFixed(2)+'\u00B0'+(dup?'*':'')+(ab>1?' \u2295':'')+')');
          }
        }
      }
    }
    // [P-detangles v5.6] Priorit\u00e9 : valeur locale recalcul\u00e9e par cr\u00e9neau ; fallback API si slotJD indisponible.
    const pAsc=(pAscLocal!==undefined)?pAscLocal:pp['Ascendant']?.longitude_absolue;
    const pMc=(pMcLocal!==undefined)?pMcLocal:pp['MC']?.longitude_absolue;
    // [P-circular-asp v5.1] Pénalité pour les aspects "auto-référents" entre angle progressé et angle natal.
    // pASC↔nASC, pASC↔nMC, pMC↔nASC, pMC↔nMC (et leurs équivalents DSC/IC) sont mathématiquement
    // sur-exprimés au slot candidat car n* dépend du slot et p* en est quasi indépendant : trouver une
    // conjonction parfaite revient à résoudre l'équation auto-référente, pas à valider une info externe.
    const CIRC_PEN=0.2;
    // [P8 v5.2] Pour pASC↔np / pMC↔np, le bonus s'applique sur la CIBLE NATALE (np.name)
    // car c'est elle qui porte la sémantique. Le bonus s'empile avec la pénalité circulaire
    // (un voyage_important sur Jupiter natal reste valide même si Jupiter ≠ angle).
    if(pAsc!==undefined){
      for(const np of targets){
        const asp=bestAspect(pAsc,np.deg,1.0);
        if(asp){
          const isCirc=ANGLE_NAMES.includes(np.name);
          const ab=affinityBonus(evt.type,np.name);
          const key='pASC_'+asp.name+'_n'+np.name;
          const dup=seen.has(key);if(!dup)seen.add(key);
          const tight=1-asp.ao/asp.ou;
          let w=Math.round(asp.weight*pw(np.name)*1.5*tight*(dup?0.25:1)*10)/10;
          if(isCirc)w=Math.round(w*CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){score+=w;details.push(evt.label+': pASC '+asp.name+' n'+np.name+' ('+w.toFixed(1)+' '+asp.ao.toFixed(2)+'\u00B0'+(dup?'*':'')+(isCirc?' \u21BB':'')+(ab>1?' \u2295':'')+')');
          }
        }
      }
    }
    if(pMc!==undefined){
      for(const np of targets){
        const asp=bestAspect(pMc,np.deg,1.0);
        if(asp){
          const isCirc=ANGLE_NAMES.includes(np.name);
          const ab=affinityBonus(evt.type,np.name);
          const key='pMC_'+asp.name+'_n'+np.name;
          const dup=seen.has(key);if(!dup)seen.add(key);
          const tight=1-asp.ao/asp.ou;
          let w=Math.round(asp.weight*pw(np.name)*tight*(dup?0.25:1)*10)/10;
          if(isCirc)w=Math.round(w*CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){score+=w;details.push(evt.label+': pMC '+asp.name+' n'+np.name+' ('+w.toFixed(1)+' '+asp.ao.toFixed(2)+'\u00B0'+(dup?'*':'')+(isCirc?' \u21BB':'')+(ab>1?' \u2295':'')+')');
          }
        }
      }
    }
  }
  return{score,details};
}
