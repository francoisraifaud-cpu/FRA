  // [v6.6 D2] Vrai Arc Solaire au lieu de l'arc symbolique 1°/an (Naibod).
  // Avant : dirASC = ascDeg + age (en annees decimales). Pure equation Naibod 1°/an.
  // Apres : dirASC = ascDeg + (sunLong(eventJD) - sunLong(birthJD)). Vrai deplacement
  // helio du Soleil sur l'intervalle. Le Soleil parcourt 0°57'-1°01'/jour selon la
  // position dans l'orbite ; sur 50 ans l'ecart cumule peut atteindre ~1° (= ~4 minutes
  // en heure de naissance). Plus precis, surtout pour les borderlines a margin <5pt.
  // Calcul du Soleil natal : 12h UT du jour de naissance (ecart < 0.05° / 12h car
  // Soleil bouge ~1°/jour, negligeable).
  const sunBirthLong=ascDeg!==undefined&&events.length>0?sunLong(jdFull(birthY,birthM,birthD,12)):0;
  if(ascDeg!==undefined&&events.length>0){
    for(const evt of events){
      const eventJD=jdFull(evt.year,evt.month,evt.day,12);
      const sunEventLong=sunLong(eventJD);
      const trueArc=((sunEventLong-sunBirthLong)%360+360)%360;
      const dirASC=normDeg(ascDeg+trueArc);
      const dirMC=mcDeg!==undefined?normDeg(mcDeg+trueArc):null;
      for(const p of slotTargets){
        const ab=affinityBonusArcProg(evt.type,p.name);
        const isCircArc=ANGLE_NAMES.includes(p.name);
        const aspA=bestAspect(dirASC,p.deg);
        if(aspA){
          const kA='dASC_'+aspA.name+'_'+p.name;
          const dupA=arcSeen.has(kA);if(!dupA)arcSeen.add(kA);
          const tight=1-aspA.ao/aspA.ou;
          let w=Math.round(aspA.weight*pw(p.name)*tight*(dupA?0.5:1)*10)/10;
          if(isCircArc)w=Math.round(w*ARC_CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){arcScore+=w;arcDetails.push(evt.label+': dirASC '+aspA.name+' '+p.name+' ('+w.toFixed(1)+' '+aspA.ao.toFixed(2)+'\u00B0'+(dupA?'*':'')+(isCircArc?' \u21BB':'')+(ab>1?' \u2295':'')+')');}
        }
        if(dirMC!==null){
          const aspM=bestAspect(dirMC,p.deg);
          if(aspM){
            const kM='dMC_'+aspM.name+'_'+p.name;
            const dupM=arcSeen.has(kM);if(!dupM)arcSeen.add(kM);
            const tight=1-aspM.ao/aspM.ou;
            let w=Math.round(aspM.weight*pw(p.name)*tight*(dupM?0.5:1)*10)/10;
            if(isCircArc)w=Math.round(w*ARC_CIRC_PEN*10)/10;
            if(ab>1)w=Math.round(w*ab*10)/10;
            if(w>=0.3){arcScore+=w;arcDetails.push(evt.label+': dirMC '+aspM.name+' '+p.name+' ('+w.toFixed(1)+' '+aspM.ao.toFixed(2)+'\u00B0'+(dupM?'*':'')+(isCircArc?' \u21BB':'')+(ab>1?' \u2295':'')+')');}
          }
        }
      }
    }
  }

  let progScore=0;let progDetails=[];
  if(validProg.length>0){
    // [P-detangles v5.6] On calcule le JD de la naissance candidate (slot) et on le passe \u00e0 countProgHits
    // pour qu'il recalcule pAsc/pMc localement \u00e0 chaque \u00e9v\u00e9nement (jour-pour-an depuis birthCand).
    const utSlot=(hh+mm/60)-tz;
    const slotJD=jdFull(birthY,birthM,birthD,utSlot);
    const ph=countProgHits(validProg,ascDeg,mcDeg,slotTargets,slotJD);
    progScore=ph.score;
    progDetails=ph.details;
  }

  
  let srScore=0;const srDetails=[];
  const natalSun=natalBodies.find(p=>p.name==='Soleil'||p.name==='Sun');
  if(natalSun&&events.length>0&&ascDeg!==undefined){
    const srSeen=new Set();
    const evtYears=[...new Set(events.map(e=>e.year))];
    for(const eY of evtYears){
      const srJD=findSRjd(natalSun.deg,eY,birthM,birthD);
      const srAsc=calcASCjd(srJD);
      const srMc=calcMCjd(srJD);
      // [P-circular-asp v5.1 RS] Même pénalité ×0.2 que pour les progressions sur les aspects
      // srASC/srMC vs angles natals du slot (auto-référents : srASC dépend très peu du slot,
      // nASC/nMC en dépendent fortement → conjonction parfaite = équation auto-réalisatrice).
      const SR_CIRC_PEN=0.2;
      // [P8 v5.2] Pour les RS, on collecte tous les types d'événements de l'année pour appliquer
      // l'affinité (ex 2008 = accident + deces_proche → Pluton bonifié sous deux titres mais ×1.5 une seule fois).
      const yearTypes=[...new Set(events.filter(e=>e.year===eY).map(e=>e.type).filter(Boolean))];
      const yearAffin=name=>yearTypes.some(t=>affinityBonus(t,name)>1)?AFFINITY_BONUS:1;
      for(const p of slotTargets){
        const isCircSR=ANGLE_NAMES.includes(p.name);
        const ab=yearAffin(p.name);
        const aspA=bestAspect(srAsc,p.deg,3.0);
        if(aspA){
          const kA='srASC_'+aspA.name+'_'+p.name;
          const dupA=srSeen.has(kA);if(!dupA)srSeen.add(kA);
          const tight=1-aspA.ao/aspA.ou;
          let w=Math.round(aspA.weight*pw(p.name)*tight*(dupA?0.5:1)*10)/10;
          if(isCircSR)w=Math.round(w*SR_CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){srScore+=w;srDetails.push(eY+': srASC '+aspA.name+' '+p.name+' ('+w.toFixed(1)+(isCircSR?' \u21BB':'')+(ab>1?' \u2295':'')+')');}
        }
        const aspM=bestAspect(srMc,p.deg,3.0);
        if(aspM){
          const kM='srMC_'+aspM.name+'_'+p.name;
          const dupM=srSeen.has(kM);if(!dupM)srSeen.add(kM);
          const tight=1-aspM.ao/aspM.ou;
          let w=Math.round(aspM.weight*pw(p.name)*tight*(dupM?0.5:1)*10)/10;
          if(isCircSR)w=Math.round(w*SR_CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){srScore+=w;srDetails.push(eY+': srMC '+aspM.name+' '+p.name+' ('+w.toFixed(1)+(isCircSR?' \u21BB':'')+(ab>1?' \u2295':'')+')');}
        }
      }
    }
  }

  // [v5.10 Fix A] Cap soft des arcs anormaux. Bench v5.9.1 : Hugo Lion 46.8 (outlier
  // +17 vs mediane ~30 sur les 4 cas profiles : Hugo 46.8, DG 35.2, Beauvoir 29.4,
  // Bardot 28.8) ecrase tout autre signal et fait gagner un faux ASC contre Scorpion
  // (vrai). On dampe lineairement le surplus au-dela de ARC_CAP avec coefficient
  // ARC_DAMP : valeurs saines (<=ARC_CAP) intactes, surplus dampe.
  // arcScoreRaw conserve pour tracabilite et debug bench.
  // [v6.1 Etape 4 - rejete] Test ARC_CAP=28 sur bench Q-informes : regression 3/8 -> 2/8 top-1
  // (perte Deneuve+Beauvoir, gain Gainsbourg). Biais Balance insensible (3/8 dans les deux cas).
  // -> ARC_CAP n'est pas le bon levier. Restaure 35. Hypothese suivante : le biais Balance
  // vient de la structure (signes longs ont plus de slots dans la grille 24h x 5min).
  const ARC_CAP=35;
  const ARC_DAMP=0.2;
  const arcScoreRaw=arcScore;
  if(arcScore>ARC_CAP){
    arcScore=Math.round((ARC_CAP+(arcScore-ARC_CAP)*ARC_DAMP)*10)/10;
  }
  // [v6.5 Chantier C - rejete] Test PROG_CAP=25 PROG_DAMP=0.2 : bench 16 cas top-1 5/16 -> 4/16.
  // Effet correct sur Famille A (KO progDelta : Napoleon margin 2.61->0.12, Francois 5.06->0,
  // Merkel 26.72->13.74, Chirac 15.45->8.34) MAIS effet collateral destructeur sur profils non
  // politiques (Hugo Lion #2->#9, Gainsbourg Lion #4->#11). Cause : le cap par slot modifie le
  // top-K=3 interne -> arcMean/srMean Lion deformes (Hugo Lion arc=25.53->13.17 alors que arc
  // n'est pas cape). Cap uniforme trop brutal : nivelle TOUS les signes a 25 et casse la
  // discrimination sur les profils dont le vrai signal prog legitime est ~22. Restaure v6.4.
  // Prochaine piste : capper signMean (post-mean) plutot que slot, ou reduire AFFINITY_BONUS
  // 1.5 -> 1.3 (effet proportionnel uniforme).
  // [v6.8 D1] transitScore : transits planetes lentes (Saturne, Uranus, Neptune, Pluton) sur
  // ASC/MC du slot, au jour exact de chaque evenement. Aspects DURS uniquement (conj/opp/car)
  // avec orb 1.0° : c'est le marqueur ponctuel le plus fort en rectification.
  //
  // [v6.8 fix1] BUG STRUCTUREL : tester ASC+DSC+MC+IC double-compte chaque transit (conj ASC
  // = opp DSC mathematiquement). On teste UNIQUEMENT ASC et MC : les opp/car couvrent
  // automatiquement DSC/IC sans double-counting.
  //
  // [v6.8.2 fix2] BUG STRUCTUREL fixe : 1 transit max par (planete, angle), on garde le plus
  // tight sur tous les events. Une planete lente positionnee sur un angle pendant 10 ans
  // (Pluton ~3°/decennie, Neptune ~2°/decennie) reste UN transit qui dure, pas N transits
  // independants. Convention astrologique standard. Pour le label, on enregistre l'event qui
  // donne le tightest aspect (l'apex du transit).
  let transitScore=0; const transitDetails=[];
  if(ascDeg!==undefined&&events.length>0&&Object.keys(transitsByDate).length>0){
    const SLOW_T=['Saturne','Uranus','Neptune','Pluton'];
    const T_ASP=[{name:'conj',angle:0,w:4},{name:'opp',angle:180,w:3},{name:'car',angle:90,w:2}];
    const T_ORB=1.0;
    const slotAng=[{name:'Ascendant',deg:ascDeg}];
    if(mcDeg!==undefined)slotAng.push({name:'Milieu du Ciel',deg:mcDeg});
    const tBest=new Map();
    for(const evt of events){
      const mm=String(evt.month).padStart(2,'0'), dd=String(evt.day).padStart(2,'0');
      const key=evt.year+'-'+mm+'-'+dd;
      const tDay=transitsByDate[key];
      if(!tDay)continue;
      for(const pname of SLOW_T){
        const p=tDay[pname];
        if(!p||typeof p.longitude_absolue!=='number')continue;
        const planLong=p.longitude_absolue;
        for(const ang of slotAng){
          const d=aspDist(planLong,ang.deg);
          let best=null;
          for(const a of T_ASP){const ao=Math.abs(d-a.angle);if(ao<T_ORB&&(!best||ao<best.ao)){best={name:a.name,w:a.w,ao:ao};}}
          if(!best)continue;
          const k=pname+'_'+ang.name;
          const cur=tBest.get(k);
          if(!cur||best.ao<cur.best.ao){tBest.set(k,{evt:evt,pname:pname,ang:ang.name,best:best});}
        }
      }
    }
    // [v6.8.3] TRANSIT_W_FACTOR=0.5 : reduit le poids global des transits a la moitie. Bench
    // v6.8.2 (sans facteur) montrait 3/16 (perte DG + Francois vs gain Delon) : poids trop
    // dominant. A 0.5, le transit reste un signal secondaire qui peut departager des slots
    // borderline (Delon margin 6.71->0) sans renverser des decisions sur des slots ou les
    // arcs/prog convergent (DG Vierge, Francois Cancer).
    const TRANSIT_W_FACTOR=0.5;
    for(const v of tBest.values()){
      const tight=1-v.best.ao/T_ORB;
      const ab=affinityBonus(v.evt.type,v.pname);
      let w=v.best.w*pw(v.pname)*pw(v.ang)*tight*TRANSIT_W_FACTOR;
      if(ab>1)w=w*ab;
      w=Math.round(w*10)/10;
      if(w>=0.5){
        transitScore+=w;
        transitDetails.push(v.evt.label+': T-'+v.pname+' '+v.best.name+' '+v.ang+' ('+w.toFixed(1)+' '+v.best.ao.toFixed(2)+'\u00B0'+(ab>1?' \u2295':'')+')');
      }
    }
  }
  const totalScore=wScore+arcScore+progScore+srScore+transitScore;
  return{time,ascDeg,mcDeg,ascSign,wSign,wScoreRaw,wScore,edgeBlendW,rulerBlendW,rulerSignNatal,m1BlendW,m1Score,m1Hits,blendCapApplied,arcScore,arcScoreRaw,progScore,srScore,transitScore,totalScore,arcDetails,progDetails,srDetails,transitDetails,src};
});

const cleanDetail=detail.filter(d=>d!==null);
const validDetail=cleanDetail.filter(d=>d.ascDeg!==undefined);

// [v5.11.D] Anti-saturation locale du stack technique (arcs + prog + RS) : si le créneau
// ne dépasse pas nettement le meilleur voisin dans ±WIN minutes, le pic sur la grille 5 min
// est souvent un artefact de corrélation temporelle. Petite pénalité du total (avant bonus
// cohérence v5.8). Bench : plateaux Proust/Hugo/YSL-like ; constantes à retoucher si régression.
// [v8.13] MARGIN_MIN 3.5->4 : exiger un ecart stack tech un peu plus net vs voisin ±30min
// (Delon / plateaux type faux pic prog+RS). Re-bench naïf 18 si doute.
const D11_TECH_WIN_MIN=30;
const D11_TECH_MARGIN_MIN=4;
const D11_TECH_PEN_MAX=2.5;
function techStackD11(dd){
  return (dd.arcScore||0)+(dd.progScore||0)+(dd.srScore||0);
}
for(const d of validDetail){
  const m0=slotMinOf(d);
  let maxOther=-Infinity;
  for(const o of validDetail){
    if(o===d)continue;
    if(Math.abs(slotMinOf(o)-m0)>D11_TECH_WIN_MIN)continue;
    const t=techStackD11(o);
    if(t>maxOther)maxOther=t;
  }
  if(!Number.isFinite(maxOther))continue;
  const tSelf=techStackD11(d);
  const margin=tSelf-maxOther;
  if(margin<D11_TECH_MARGIN_MIN){
    const pen=Math.min(D11_TECH_PEN_MAX,D11_TECH_PEN_MAX*(D11_TECH_MARGIN_MIN-margin)/D11_TECH_MARGIN_MIN);
    d.totalScore=Math.round(Math.max(0,d.totalScore-pen)*100)/100;
  }
}

// [v6.0] Cohérence multi-techniques — bonus ADDITIF BORNÉ.
// Avant (v5.8) : bonus multiplicatif +6% par technique alignée, max +24%.
// Problème : sur un total ~90, +24% = +21,6 pts, ce qui peut renverser le classement et
// surtout AMPLIFIER un signe déjà pointé par un faux pic d'arcs (auto-corrélation des
// techniques qui partagent les mêmes événements). Audit v6.0 : on remplace par un bonus
// additif plafonné (max +6 pts), comparable en magnitude à la pénalité D11 (max -2,5).
// L'idée reste valide (amplifier la convergence) mais l'effet est borné et calibré.
const techPeaks={arc:{sign:null,score:-1},prog:{sign:null,score:-1},sr:{sign:null,score:-1}};
for(const d of validDetail){
  const s=d.wSign||d.ascSign||'?';
  if(s==='?')continue;
  if(d.arcScore>techPeaks.arc.score)techPeaks.arc={sign:s,score:d.arcScore};
  if(d.progScore>techPeaks.prog.score)techPeaks.prog={sign:s,score:d.progScore};
  const sr=d.srScore||0;
  if(sr>techPeaks.sr.score)techPeaks.sr={sign:s,score:sr};
}
// Normalisation des noms : Scorer = sans accent, API = avec accent. Indispensable pour Bélier/Gémeaux.
function normSignName(x){return String(x||'').normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().trim();}
const qTopSign=(ranked&&ranked[0])?normSignName(ranked[0].sign):null;
const COHERENCE_PER_TECH_PTS=1.5;
const COHERENCE_BONUS_MAX_PTS=6;
for(const d of validDetail){
  const s=d.wSign||d.ascSign||'?';
  const sN=normSignName(s);
  let aligned=0;
  if(s!=='?'){
    if(qTopSign&&sN===qTopSign)aligned++;
    if(techPeaks.arc.sign&&normSignName(techPeaks.arc.sign)===sN)aligned++;
    if(techPeaks.prog.sign&&normSignName(techPeaks.prog.sign)===sN)aligned++;
    if(techPeaks.sr.sign&&normSignName(techPeaks.sr.sign)===sN)aligned++;
  }
  d.coherenceCount=aligned;
  d.coherenceBonus=Math.min(COHERENCE_BONUS_MAX_PTS,aligned*COHERENCE_PER_TECH_PTS);
  d.totalScoreRaw=d.totalScore;
  d.totalScore=Math.round((d.totalScore+d.coherenceBonus)*100)/100;
}

// [v6.2 Etape 2 — sign-first par moyenne top-K] Calcule signScoreMeanTopK[s] = moyenne
// des K meilleurs totalScore des slots dont l'ascSign==s. bestSign = argmax(signScoreMeanTopK)
// puis best slot = pickBest(validDetail | sign==bestSign). Motivation : signes "longs"
// (Balance/Vierge a Paris) accumulent mecaniquement plus de slots dans 24h x 5min ; le pic
// max ou la somme les avantage structurellement. La moyenne top-K juge chaque signe sur la
// qualite de ses meilleurs creneaux, pas sur le nombre de slots qu'il occupe. K=3 = compromis
// entre robustesse (>1 pour eviter outliers) et exigence (<5 pour penaliser signes pas
// nettement piques). Ne change pas bestPlage : plage restreinte = on respecte le user.
// [v6.3] K=3 (K=5 testé : iso top-1 mais Δmin succès médian dégradé 10→37 et perte De Gaulle).
const SIGN_TOP_K=3;
// [v6.4 Etape B reverted] Q_PRIOR_WEIGHT : amplifie le poids du wMean (questionnaire) dans le
// sign-ranking. Sweep sur 16 cas Q_PRIOR ∈ {1, 1.25, 1.5, 1.75, 2, 2.25, 2.5, 3} (simulation NDJSON):
// QP=2 → top1=9/16=56%, top3=12/16=75%. QP=3 → top1=9/16 ET top3=14/16=88% en simu. MAIS test reel
// v6.4 (QP=3) batch1 a regresse de 6/8 à 5/8 (de Gaulle bascule Balance→Lion par 0.46pt) : la
// simulation sous-estime le bruit systeme (~5-10pts sur arcMean entre runs identiques). Conclusion :
// QP=3 introduit instabilite (substitue Napoleon vs de Gaulle/Churchill) sans gain top1 net. Revert
// a QP=2 pour stabilite. Le bruit systeme est la prochaine cible (etape future = stabiliser arcs/RS).
// signScoreFinal[s] = scoreMean_topK[s] + (Q_PRIOR_WEIGHT-1) * wMean[s].
const Q_PRIOR_WEIGHT=2.0;
const signGroupsForMean={};
for(const d of validDetail){
  const k=d.wSign||d.ascSign||'?';
  if(k==='?')continue;
  if(!signGroupsForMean[k])signGroupsForMean[k]=[];
  signGroupsForMean[k].push(d);
}
const signScoreMeanTopK={};
const signTechBreakdown={};
for(const [s,arr] of Object.entries(signGroupsForMean)){
  const sorted=[...arr].sort((a,b)=>b.totalScore-a.totalScore);
  const topK=sorted.slice(0,Math.min(SIGN_TOP_K,sorted.length));
  const mean=topK.reduce((acc,d)=>acc+(d.totalScore||0),0)/topK.length;
  signScoreMeanTopK[s]=Math.round(mean*100)/100;
  // [v6.2 audit] Decompose le score moyen top-K en composantes techniques pour permettre
  // l'analyse "quelle technique pousse Balance/Vierge ?" sur les cas dont le bon signe rate.
  const meanArc=topK.reduce((a,d)=>a+(d.arcScore||0),0)/topK.length;
  const meanProg=topK.reduce((a,d)=>a+(d.progScore||0),0)/topK.length;
  const meanSr=topK.reduce((a,d)=>a+(d.srScore||0),0)/topK.length;
  const meanW=topK.reduce((a,d)=>a+(d.wScore||0),0)/topK.length;
  const meanCoh=topK.reduce((a,d)=>a+(d.coherenceBonus||0),0)/topK.length;
  const meanTransit=topK.reduce((a,d)=>a+(d.transitScore||0),0)/topK.length;
  signTechBreakdown[s]={
    arcMean:Math.round(meanArc*100)/100,
    progMean:Math.round(meanProg*100)/100,
    srMean:Math.round(meanSr*100)/100,
    transitMean:Math.round(meanTransit*100)/100,
    wMean:Math.round(meanW*100)/100,
    cohMean:Math.round(meanCoh*100)/100,
    nSlots:arr.length
  };
}
// [v6.9 E2 ROLLBACK] arcMean cap=22 (E2) testee : gain attendu sur arc-driven KO (ysl,
// beauvoir) confirme dans batch1, mais bench global degrade par bruit systeme (DG, francois,
// louis16 regressent sans cause attribuable a E2 - leurs arcMean sont < 22). Le bruit
// systeme provient probablement des API HTTP /progressions et /transits qui renvoient des
// scores fluctuants entre runs. Avant toute optim supplementaire, stabiliser le bruit
// systeme est prioritaire (cf. note v6.4). E2 conserve documente, a re-tester apres
// stabilisation. Bench compare : v6.8.3=9/18 vs v6.9=8/18 (-1), mais 4 cas ont change de
// reponse ce qui depasse l'amplitude du delta net (signal noyé dans le bruit).
// [v6.3] Score final pour le sign-ranking = scoreMean_topK + (Q_PRIOR_WEIGHT-1) * wMean.
// On garde scoreMeanTopK separement pour audit (pas de transformation cachee dans le ranking).
const signScoreFinal={};
for(const s of Object.keys(signScoreMeanTopK)){
  const wM=signTechBreakdown[s]?.wMean||0;
  signScoreFinal[s]=Math.round((signScoreMeanTopK[s]+(Q_PRIOR_WEIGHT-1)*wM)*100)/100;
}
let signScoreMeanSorted=Object.entries(signScoreFinal).sort((a,b)=>b[1]-a[1]);
let bestSignByMean=signScoreMeanSorted[0]?.[0]||null;

// [v8.0 ECLIPSE TIE-BREAK] Phase A (signe) + Phase B (heure)
// Idee : les eclipses progressees (1 jour = 1 an) lient une date de la vie reelle a un
// evenement cosmique calcule depuis l'heure de naissance candidate. Pour chaque slot
// candidat finaliste, on appelle /progressions/eclipses sur la fenetre des events du
// questionnaire. Si une eclipse progressee tombe a +/-N jours d'un event saisi, c'est
// un fort indice que le slot est correct (l'horloge progressee s'aligne avec la vie).
// Mode adaptatif : on n'appelle l'API QUE si margin top1<->top2 < 10pts (signe) ou < 8pts
// (heure dans signe, v8.9 : etait 5 — trop strict, Phase B inactive sur ecarts 5-8).
// Cout max 8 appels/cas (3 phase A + 5 phase B).
const ECLIPSE_TB_ENABLED=true;
const ECLIPSE_PHASEA_MARGIN=10; // pts : si > skip Phase A
// [v8.9 fiabilisation] Phase B 8pts (retenu) : ne renverse pas le signe ; trie l'heure dans le signe.
// [v8.8 abandon] Penalite M1 vide retiree : bench v88 8/18 vs v86 10/18 (Bardot/YSL regresses).
const ECLIPSE_PHASEB_MARGIN=8;
const ECLIPSE_PHASEA_TOPK=3;    // nb signes candidats
const ECLIPSE_PHASEB_TOPK=5;    // nb slots candidats dans signe gagnant
const ECLIPSE_TB_POINT_WEIGHT=2.5; // multiplicateur (eclipsScore * W) ajoute au scoreFinal
let eclipseAudit={mode:'disabled',phaseA:null,phaseB:null,_fetchDbg:null,_winSample:null,_urlSample:null};

// Helper bestByAsc precalcul (utilise par Phase A pour avoir le best slot par signe).
const _bestByAscEarly={};
for(const d of validDetail){
  const k=d.wSign||d.ascSign||'?';
  if(k==='?')continue;
  if(!_bestByAscEarly[k]||d.totalScore>_bestByAscEarly[k].totalScore)_bestByAscEarly[k]=d;
}

// Dates events (Date objects UTC) pour matching.
