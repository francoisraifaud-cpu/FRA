// Score eclipse-event : pour chaque eclipse, on cherche l'event le plus proche en
// date_vie. Coef gradue selon distance |date_vie - date_event| en jours. Pondere par
// l'astre (Soleil x1.2, Lune x1.0) et la magnitude locale (visible -> +20%).
function _eclipseScore(eclipses,eventDates){
  if(!Array.isArray(eclipses)||!eventDates.length)return{score:0,hits:[]};
  let sum=0;const hits=[];
  for(const e of eclipses){
    const dv=e.date_vie;if(!dv)continue;
    const ed=new Date(dv+'T12:00:00Z');if(isNaN(ed.getTime()))continue;
    let bestDays=Infinity;let bestIdx=-1;
    for(let i=0;i<eventDates.length;i++){
      const d=Math.abs((ed-eventDates[i])/86400000);
      if(d<bestDays){bestDays=d;bestIdx=i;}
    }
    let coef=0;
    if(bestDays<=30)coef=1.0;
    else if(bestDays<=60)coef=0.6;
    else if(bestDays<=90)coef=0.3;
    if(coef===0)continue;
    const astreW=e.astre==='Soleil'?1.2:1.0;
    const visW=e.visible_lieu_naissance?1.2:1.0;
    const sc=coef*astreW*visW;
    sum+=sc;
    hits.push({eclipse:dv,astre:e.astre,event:events[bestIdx]?.label||'?',days:Math.round(bestDays),coef:coef,score:Math.round(sc*100)/100});
  }
  return{score:Math.round(sum*100)/100,hits};
}

