const R=Math.PI/180;
function jd0(y,m,d){if(m<=2){y--;m+=12}const A=Math.floor(y/100);return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+2-A+Math.floor(A/4)-1524.5}
function calcASC(h){
  const ut=h-tz;const J=jd0(birthY,birthM,birthD);const T=(J-2451545)/36525;
  let g=280.46061837+360.98564736629*(J-2451545)+0.000387933*T*T;g=((g%360)+360)%360;
  const lst=((g+ut*1.00273790935*15+lon)%360+360)%360;
  const eps=(23.4393-0.013*T)*R;const A=lst*R;const L=lat*R;
  return((Math.atan2(-Math.cos(A),Math.sin(A)*Math.cos(eps)+Math.tan(L)*Math.sin(eps))/R+180)%360+360)%360;
}
const sgn=['Belier','Taureau','Gemeaux','Cancer','Lion','Vierge','Balance','Scorpion','Sagittaire','Capricorne','Verseau','Poissons'];
