function normDeg(d){return((d%360)+360)%360}
function aspDist(a,b){const d=Math.abs(normDeg(a)-normDeg(b));return Math.min(d,360-d)}

const ASPECTS=[
  {name:'conj',angle:0,orb:1.5,weight:4},
  {name:'opp',angle:180,orb:1.5,weight:3},
  {name:'car',angle:90,orb:1.5,weight:2},
