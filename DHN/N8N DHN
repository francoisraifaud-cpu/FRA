// [v5.8 P2.1] Reranking par COHÉRENCE multi-techniques.
// Constat benchmark (Bardot/Gainsbourg/Saint Laurent/Beauvoir/Hugo/de Gaulle) : le bon créneau a
// souvent un PIC d'une des techniques mais perd au total contre un faux pic où une seule
// technique sort très haut "par hasard". On corrige en bonifiant les slots dont le SIGNE
// est plébiscité par PLUSIEURS techniques indépendantes (questionnaire, arcs, progressions, RS).
// Bonus +6% par technique alignée (max 4 → +24%). N'ajoute pas de "fait nouveau" : amplifie un
// signal de convergence déjà présent. Préserve totalScoreRaw pour traçabilité.
const techPeaks={arc:{sign:null,score:-1},prog:{sign:null,score:-1},sr:{sign:null,score:-1}};
for(const d of validDetail){
  const s=d.wSign||d.ascSign||'?';
  if(s==='?')continue;
  if(d.arcScore>techPeaks.arc.score)techPeaks.arc={sign:s,score:d.arcScore};
  if(d.progScore>techPeaks.prog.score)techPeaks.prog={sign:s,score:d.progScore};
  const sr=d.srScore||0;
  if(sr>techPeaks.sr.score)techPeaks.sr={sign:s,score:sr};
}
// [v5.8 P2.1 fix] Normalisation des noms de signes pour comparaison robuste : le Scorer
// expose les noms SANS accent ("Belier", "Gemeaux") tandis que l'API astro renvoie les noms
// AVEC accent ("Bélier", "Gémeaux"). Sans cette normalisation, qTopSign === s échouait
// silencieusement pour Bélier/Gémeaux → coherenceCount sous-évalué (bug détecté sur le retest
// Gainsbourg v5.8 : Bélier qTopSign mais bonus de cohérence non appliqué).
function normSignName(x){return String(x||'').normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().trim();}
const qTopSign=(ranked&&ranked[0])?normSignName(ranked[0].sign):null;
const COHERENCE_PER_TECH=0.06;
for(const d of validDetail){
  const s=d.wSign||d.ascSign||'?';
  const sN=normSignName(s);
  let aligned=0;
  if(s!=='?'){
    if(qTopSign&&sN===qTopSign)aligned++;
    if(techPeaks.arc.sign&&normSignName(techPeaks.arc.sign)===sN)aligned++;
    if(techPeaks.prog.sign&&normSignName(techPeaks.prog.sign)===sN)aligned++;
    if(techPeaks.sr.sign&&normSignName(techPeaks.sr.sign)===sN)aligned++;
  }
  d.coherenceCount=aligned;
  d.coherenceBonus=aligned*COHERENCE_PER_TECH;
  d.totalScoreRaw=d.totalScore;
  d.totalScore=Math.round(d.totalScore*(1+d.coherenceBonus)*100)/100;
}

