      }
    }
  }

  let progScore=0;let progDetails=[];
  if(validProg.length>0){
    // [P-detangles v5.6] On calcule le JD de la naissance candidate (slot) et on le passe \u00e0 countProgHits
    // pour qu'il recalcule pAsc/pMc localement \u00e0 chaque \u00e9v\u00e9nement (jour-pour-an depuis birthCand).
    const utSlot=(hh+mm/60)-tz;
    const slotJD=jdFull(birthY,birthM,birthD,utSlot);
    const ph=countProgHits(validProg,ascDeg,mcDeg,slotTargets,slotJD);
    progScore=ph.score;
    progDetails=ph.details;
  }

  
  let srScore=0;const srDetails=[];
  const natalSun=natalBodies.find(p=>p.name==='Soleil'||p.name==='Sun');
  if(natalSun&&events.length>0&&ascDeg!==undefined){
    const srSeen=new Set();
    const evtYears=[...new Set(events.map(e=>e.year))];
    for(const eY of evtYears){
      const srJD=findSRjd(natalSun.deg,eY,birthM,birthD);
      const srAsc=calcASCjd(srJD);
      const srMc=calcMCjd(srJD);
      // [P-circular-asp v5.1 RS] Même pénalité ×0.2 que pour les progressions sur les aspects
      // srASC/srMC vs angles natals du slot (auto-référents : srASC dépend très peu du slot,
      // nASC/nMC en dépendent fortement → conjonction parfaite = équation auto-réalisatrice).
      const SR_CIRC_PEN=0.2;
      // [P8 v5.2] Pour les RS, on collecte tous les types d'événements de l'année pour appliquer
      // l'affinité (ex 2008 = accident + deces_proche → Pluton bonifié sous deux titres mais ×1.5 une seule fois).
      const yearTypes=[...new Set(events.filter(e=>e.year===eY).map(e=>e.type).filter(Boolean))];
      const yearAffin=name=>yearTypes.some(t=>affinityBonus(t,name)>1)?AFFINITY_BONUS:1;
      for(const p of slotTargets){
        const isCircSR=ANGLE_NAMES.includes(p.name);
        const ab=yearAffin(p.name);
        const aspA=bestAspect(srAsc,p.deg,3.0);
        if(aspA){
          const kA='srASC_'+aspA.name+'_'+p.name;
          const dupA=srSeen.has(kA);if(!dupA)srSeen.add(kA);
          const tight=1-aspA.ao/aspA.ou;
          let w=Math.round(aspA.weight*pw(p.name)*tight*(dupA?0.5:1)*10)/10;
          if(isCircSR)w=Math.round(w*SR_CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){srScore+=w;srDetails.push(eY+': srASC '+aspA.name+' '+p.name+' ('+w.toFixed(1)+(isCircSR?' \u21BB':'')+(ab>1?' \u2295':'')+')');}
        }
        const aspM=bestAspect(srMc,p.deg,3.0);
        if(aspM){
          const kM='srMC_'+aspM.name+'_'+p.name;
          const dupM=srSeen.has(kM);if(!dupM)srSeen.add(kM);
          const tight=1-aspM.ao/aspM.ou;
          let w=Math.round(aspM.weight*pw(p.name)*tight*(dupM?0.5:1)*10)/10;
          if(isCircSR)w=Math.round(w*SR_CIRC_PEN*10)/10;
          if(ab>1)w=Math.round(w*ab*10)/10;
          if(w>=0.3){srScore+=w;srDetails.push(eY+': srMC '+aspM.name+' '+p.name+' ('+w.toFixed(1)+(isCircSR?' \u21BB':'')+(ab>1?' \u2295':'')+')');}
        }
      }
    }
  }

  // [v5.10 Fix A] Cap soft des arcs anormaux. Bench v5.9.1 : Hugo Lion 46.8 (outlier
  // +17 vs mediane ~30 sur les 4 cas profiles : Hugo 46.8, DG 35.2, Beauvoir 29.4,
  // Bardot 28.8) ecrase tout autre signal et fait gagner un faux ASC contre Scorpion
  // (vrai). On dampe lineairement le surplus au-dela de ARC_CAP=35 avec coefficient
  // ARC_DAMP=0.2 : valeurs saines (<=35) intactes, Hugo Lion 46.8 -> 37.4 (perte 9.4).
  // arcScoreRaw conserve pour tracabilite et debug bench. Si insuffisant en bench,
