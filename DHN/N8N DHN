// [v6.12 G3] Planetes en maison 1 (equal-house : zone ASC-8 deg .. ASC+30 deg).
// Les planetes natales tombant dans la maison 1 d'un slot candidat "colorent" l'ASC :
// elles incarnent le persona du natif. Une candidate ASC qui place plusieurs luminaires /
// planetes personnelles en M1 a une signature plus probable que celle qui laisse M1 vide.
// On etend la zone de 8 deg en arriere de l'ASC pour capter les conjonctions traditionnelles
// (planete fin de M12 conjointe ASC = quasi en M1 dans la pratique astrologique).
// Pondération astrologique standard : luminaires > personnelles > sociales > lointaines.
// Bonus = G3_M1_FACTOR * somme(poids) cappe a G3_M1_MAX_PTS pour eviter qu'un stellium
// transpersonnelles ne domine. Aucune API supplementaire, lit natalBodies deja en cache.
const G3_M1_FACTOR=0.6;
const G3_M1_MAX_PTS=4.0;
const G3_M1_PRE_ASC_DEG=8.0;
const M1_PLANET_WEIGHT={
  'Soleil':3,'Sun':3,
  'Lune':3,'Moon':3,
  'Mercure':2,'Mercury':2,
  'V\u00e9nus':2,'Venus':2,
  'Mars':2,
  'Jupiter':1.5,
  'Saturne':1.5,'Saturn':1.5,
  'Uranus':1,
  'Neptune':1,
  'Pluton':1,'Pluto':1,
  'Chiron':0.8
};
function m1WeightOf(name){
  if(!name)return 0;
  if(M1_PLANET_WEIGHT[name]!=null)return M1_PLANET_WEIGHT[name];
  const target=_normSignKey(name);
  for(const k of Object.keys(M1_PLANET_WEIGHT)){if(_normSignKey(k)===target)return M1_PLANET_WEIGHT[k];}
  return 0;
}
function computeM1Bonus(ascDeg){
  if(typeof ascDeg!=='number'||!natalBodies||!natalBodies.length)return{bonus:0,score:0,hits:[]};
  const lo=((ascDeg-G3_M1_PRE_ASC_DEG)%360+360)%360;
  const span=30+G3_M1_PRE_ASC_DEG;
  let total=0;const hits=[];
  for(const p of natalBodies){
    if(typeof p.deg!=='number')continue;
    const off=((p.deg-lo)%360+360)%360;
    if(off<span){
      const w=m1WeightOf(p.name);
      if(w<=0)continue;
      total+=w;
      const fromAsc=((p.deg-ascDeg)%360+360)%360;
      const display=fromAsc>180?(fromAsc-360):fromAsc;
      hits.push(p.name+'@'+display.toFixed(1));
    }
  }
  const bonus=Math.min(G3_M1_MAX_PTS,total*G3_M1_FACTOR);
  return{bonus,score:total,hits};
}

