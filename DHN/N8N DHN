// final = heure (ordre lexical croissant). Suppression des critères inutilisés
// (les ties stricts sur des floats arrondis sont marginaux ; les critères chaînés
// donnaient une fausse impression de robustesse). Pas de référence à techPeaks ici.
function pickBest(arr){
  if(!arr||arr.length===0)return null;
  return [...arr].sort((a,b)=>{
    if(b.totalScore!==a.totalScore)return b.totalScore-a.totalScore;
    const tb=(b.arcScore||0)+(b.progScore||0)+(b.srScore||0);
    const ta=(a.arcScore||0)+(a.progScore||0)+(a.srScore||0);
