const _d1 = _s1 ? getDignity(a.p1, _s1) : \"-\", _d2 = _s2 ? getDignity(a.p2, _s2) : \"-\";\n    if (_d1 === \"Domicile\" || _d1 === \"Exaltation\") { bonus += 2; a._digMod1 = _d1; }\n    if (_d2 === \"Domicile\" || _d2 === \"Exaltation\") { bonus += 2; a._digMod2 = _d2; }\n    if ((_d1 === \"Exil\" || _d1 === \"Chute\")) { a._digMod1 = a._digMod1 || _d1; }\n    if ((_d2 === \"Exil\" || _d2 === \"Chute\")) { a._digMod2 = a._digMod2 || _d2; }\n\n    // v4.0 — Réception : les deux planètes en réception mutuelle (domicile) → adoucissement, constructivité\n    const _aspPairKey = [a.p1, a.p2].sort().join(\"|\");\n    if (_receptionPairsAsp.has(_aspPairKey)) { bonus += 3; a._receptionMutual = true; }\n    else {\n        const _uni1 = _uniReceptionMap[a.p1]?.has(a.p2);\n        const _uni2 = _uniReceptionMap[a.p2]?.has(a.p1);\n        if (_uni1 || _uni2) { bonus += 1; a._receptionUni = true; }\n    }\n\n    a.score        = base + exactBonus + bonus;\n    a.prioriteLabel = a.score >= 30 ? \"CAPITAL\" : a.score >= 20 ? \"FORT\" : a.score >= 12 ? \"MODÉRÉ\" : \"MINEUR\";\n    a.prioriteEmoji = a.score >= 30 ? \"🔴\" : a.score >= 20 ? \"🟠\" : a.score >= 12 ? \"🟡\" : \"⚪\";\n});\n// Tri global en place — toutes les fonctions avales héritent de cet ordre\naspects.sort((a, b) => b.score - a.score);\n\n// Flag isPromoted — Option B : seuil différencié petits corps vs planètes majeures\n// Si au moins UNE des deux planètes est un corps majeur → seuil 20 (FORT)\n// Si les DEUX sont des petits corps → seuil 28 (évite le bruit interprétatif)\nconst SMALL_BODIES_PROMO    = new Set([\"Vesta\",\"Cérès\",\"Ceres\",\"Pallas\",\"Junon\",\"Juno\",\"Lilith\"]);\nconst PROMO_THRESHOLD_CORE  = 20;\nconst PROMO_THRESHOLD_SMALL = 28;\naspects.forEach(a => {\n    if (a.isMajor !== false) { a.isPromoted = false; return; }\n    const bothSmall = SMALL_BODIES_PROMO.has(a.p1) && SMALL_BODIES_PROMO.has(a.p2);\n    const threshold = bothSmall ? PROMO_THRESHOLD_SMALL : PROMO_THRESHOLD_CORE;\n    a.isPromoted = a.score >= threshold;\n});\n\n// ─────────────────────────────────────────────────────────────────\n// 7. MAISONS ET DISPOSITIONS\n// ─────────────────────────────────────────────────────────────────\nlet signToHouses = {}; signs.forEach(s => signToHouses[s.fr] = []);\nmaisons.forEach((m, i) => {\n    let end = maisons[(i+1)%12].degree; if (end < m.degree) end += 360;\n    for (let s = Math.floor(m.degree/30); s <= Math.floor(end/30); s++) {\n        if (!signToHouses[signs[s%12].fr].includes(m.House)) signToHouses[signs[s%12].fr].push(m.House);\n    }\n});\n\nlet fiches_maisons = [], prompts = {};\nmaisons.forEach((m, i) => {\n    let nextM=maisons[(i+1)%12], start=m.degree, end=nextM.degree; if (end<start) end+=360;\n    let s_start=Math.floor(start/30), s_end=Math.floor(end/30);\n    let segments = [];\n\n    for (let s=s_start; s<=s_end; s++) {\n        let signId  = s % 12;\n        let signObj = signs[signId];\n        let type    = s===s_start ? \"Cuspide\" : (s===s_end ? \"Fin de Maison\" : \"Intercepté / Suite\");\n        let degDebut     = s===s_start ? m.normDegree : 0;\n        let decanCuspide = type===\"Cuspide\" ? (Math.min(Math.floor(degDebut/10),2)+1) : null;\n\n        let rulerP = planetes.find(p => p.planet.fr === signObj.ruler);\n        let proprioData = null;\n        if (rulerP) {\n            let p_sign   = rulerP.zodiac_sign?.name?.fr || \"Bélier\";\n            const _signObj = signs.find(sgn=>sgn.fr===p_sign);\n            if (!_signObj) continue;\n            let patronName = _signObj.ruler;\n            let patronP    = planetes.find(p=>p.planet.fr===patronName);\n            let patronData = (patronName!==signObj.ruler && patronP) ? { planete:patronName, maison:getHouseNumber(patronP.fullDegree), signe:patronP.zodiac_sign?.name?.fr || \"\" } : null;\n            proprioData = {\n                planete:signObj.ruler, retro:rulerP.retroStr, signe:p_sign, degre:rulerP.normDegree,\n                maison:getHouseNumber(rulerP.fu