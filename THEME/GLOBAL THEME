"Saturne\"],\n    \"Gémeaux\":[\"Jupiter\",\"Mars\",\"Soleil\"],\"Cancer\":[\"Vénus\",\"Mercure\",\"Lune\"],\n    \"Lion\":[\"Saturne\",\"Jupiter\",\"Mars\"],\"Vierge\":[\"Soleil\",\"Vénus\",\"Mercure\"],\n    \"Balance\":[\"Lune\",\"Saturne\",\"Jupiter\"],\"Scorpion\":[\"Mars\",\"Soleil\",\"Vénus\"],\n    \"Sagittaire\":[\"Mercure\",\"Lune\",\"Saturne\"],\"Capricorne\":[\"Jupiter\",\"Mars\",\"Soleil\"],\n    \"Verseau\":[\"Vénus\",\"Mercure\",\"Lune\"],\"Poissons\":[\"Saturne\",\"Jupiter\",\"Mars\"]\n};\n\n// Termes Égyptiens (Bounds) — 5 termes par signe [planète, degré_fin]\nconst EGYPTIAN_TERMS = {\n    \"Bélier\":[[\"Jupiter\",6],[\"Vénus\",12],[\"Mercure\",20],[\"Mars\",25],[\"Saturne\",30]],\n    \"Taureau\":[[\"Vénus\",8],[\"Mercure\",14],[\"Jupiter\",22],[\"Saturne\",27],[\"Mars\",30]],\n    \"Gémeaux\":[[\"Mercure\",6],[\"Jupiter\",12],[\"Vénus\",17],[\"Mars\",24],[\"Saturne\",30]],\n    \"Cancer\":[[\"Mars\",7],[\"Vénus\",13],[\"Mercure\",19],[\"Jupiter\",26],[\"Saturne\",30]],\n    \"Lion\":[[\"Jupiter\",6],[\"Vénus\",11],[\"Saturne\",18],[\"Mercure\",24],[\"Mars\",30]],\n    \"Vierge\":[[\"Mercure\",7],[\"Vénus\",17],[\"Jupiter\",21],[\"Mars\",28],[\"Saturne\",30]],\n    \"Balance\":[[\"Saturne\",6],[\"Mercure\",14],[\"Jupiter\",21],[\"Vénus\",28],[\"Mars\",30]],\n    \"Scorpion\":[[\"Mars\",7],[\"Vénus\",11],[\"Mercure\",19],[\"Jupiter\",24],[\"Saturne\",30]],\n    \"Sagittaire\":[[\"Jupiter\",12],[\"Vénus\",17],[\"Mercure\",21],[\"Saturne\",26],[\"Mars\",30]],\n    \"Capricorne\":[[\"Mercure\",7],[\"Jupiter\",14],[\"Vénus\",22],[\"Saturne\",26],[\"Mars\",30]],\n    \"Verseau\":[[\"Mercure\",7],[\"Vénus\",13],[\"Jupiter\",20],[\"Mars\",25],[\"Saturne\",30]],\n    \"Poissons\":[[\"Vénus\",12],[\"Jupiter\",16],[\"Mercure\",19],[\"Mars\",28],[\"Saturne\",30]]\n};\nconst getTermRuler = (sign, deg) => {\n    const terms = EGYPTIAN_TERMS[sign];\n    if (!terms) return null;\n    const d = deg % 30;\n    for (const [ruler, boundary] of terms) { if (d < boundary) return ruler; }\n    return terms[terms.length - 1][0];\n};\n\nconst planetRulerships = {\n    \"Soleil\":[\"Lion\"],\"Lune\":[\"Cancer\"],\"Mercure\":[\"Gémeaux\",\"Vierge\"],\"Vénus\":[\"Taureau\",\"Balance\"],\n    \"Mars\":[\"Bélier\",\"Scorpion\"],\"Jupiter\":[\"Sagittaire\",\"Poissons\"],\"Saturne\":[\"Capricorne\",\"Verseau\"],\n    \"Uranus\":[\"Verseau\"],\"Neptune\":[\"Poissons\"],\"Pluton\":[\"Scorpion\"]\n};\n\nconst dignities = {\n    \"Soleil\":   { dom:[\"Lion\"],                    exa:[\"Bélier\"],    exi:[\"Verseau\"],               chu:[\"Balance\"] },\n    \"Lune\":     { dom:[\"Cancer\"],                  exa:[\"Taureau\"],   exi:[\"Capricorne\"],             chu:[\"Scorpion\"] },\n    \"Mercure\":  { dom:[\"Gémeaux\",\"Vierge\"],        exa:[\"Vierge\"],    exi:[\"Sagittaire\",\"Poissons\"],  chu:[\"Poissons\"] },\n    \"Vénus\":    { dom:[\"Taureau\",\"Balance\"],        exa:[\"Poissons\"],  exi:[\"Scorpion\",\"Bélier\"],      chu:[\"Vierge\"] },\n    \"Mars\":     { dom:[\"Bélier\",\"Scorpion\"],        exa:[\"Capricorne\"],exi:[\"Balance\",\"Taureau\"],      chu:[\"Cancer\"] },\n    \"Jupiter\":  { dom:[\"Sagittaire\",\"Poissons\"],    exa:[\"Cancer\"],    exi:[\"Gémeaux\",\"Vierge\"],       chu:[\"Capricorne\"] },\n    \"Saturne\":  { dom:[\"Capricorne\",\"Verseau\"],     exa:[\"Balance\"],   exi:[\"Cancer\",\"Lion\"],          chu:[\"Bélier\"] },\n    \"Uranus\":   { dom:[\"Verseau\"],                  exa:[\"Scorpion\"],  exi:[\"Lion\"],                   chu:[\"Taureau\"] },\n    \"Neptune\":  { dom:[\"Poissons\"],                 exa:[\"Cancer\"],    exi:[\"Vierge\"],                 chu:[\"Capricorne\"] },\n    \"Pluton\":   { dom:[\"Scorpion\"],                 exa:[\"Lion\"],      exi:[\"Taureau\"],                chu:[\"Verseau\"] }\n};\n\nconst getDignity = (planet, sign) => {\n    if (![\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"].includes(planet)) return \"-\";\n    let d = dignities[planet]; if (!d) return \"-\";\n    if (d.dom.includes(sign)) return \"Domicile\";\n    if (d.exa.includes(sign)) return \"Exaltation\";\n    if (d.exi.includes(sign)) return \"Exil\";\n    if (d.chu.includes(sign)) return \"Chute\";\n    return \"Pérégrine\";\n};\n\nconst elements = {\n    \"Feu\":   [\"Bélier\",\"Lion\",\"Sagittaire\"],\n    \"Terre\": [\"Taureau\",\"Vierge\",\"Capricorne\"],\n    \"Air\":   [\"Gémeaux\",\"Balance\",\"Verseau\"],\n    \"Eau\":   [\"Cancer\",\"Scorpion\",\"Poissons\"]\n};\nconst modes = {\n    \"Cardinal\": [\"Bélier\",\"Cancer\",\"Balance\",\"Capricorne\"],\n    \"Fixe\":     [\"Taureau\",\"Lion\",\"Scorpion\",\"Verseau\"],\n    \"Mutable\":  [\"Gémeaux\",\"Vierge\",\"Sagittaire\",\"Poissons\"]\n};\n\n// 2. STATS ÉLÉMENTS & MODES\nlet stats = { elements: { Feu:0, Terre:0, Air:0, Eau:0 }, modes: { Cardinal:0, Fixe:0, Mutable:0 } };\nlet mainPoints = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Ascendant\",\"Milieu du Ciel\"];\nplanetes.forEach(p => {\n    p.retroStr = p.isRetro?.toLowerCase().includes('true') ? \" [Rétrograde]\" : \"\";\n    let name = p.planet.fr || p.planet.en;\n    if (mainPoints.includes(name)) {\n        let sign = p.zodiac_sign?.name?.fr;\n        if (sign) {\n            let el = Object.keys(elements).find(e => elements[e].includes(sign)); if(el) stats.elements[el]++;\n            let mo = Object.keys(modes).find(m => modes[m].includes(sign)); if(mo) stats.modes[mo]++;\n        }\n    }\n});\n\n// 3. MAISONS UTILS\nmaisons.sort((a,b) => a.House - b.House);\nfunction getHouseNumber(deg) {\n    deg = ((deg % 360) + 360) % 360;\n    for(let i=0; i<12; i++){\n        let h1=maisons[i].degree, h2=maisons[(i+1)%12].degree;\n        if((h1<h2 && deg>=h1 && deg<h2) || (h1>=h2 && (deg>=h1 || deg<h2))) return maisons[i].House;\n    }\n    return 1;\n}\n\nfunction angularDiff(a, b) {\n    let d = Math.abs(a - b);\n    return d > 180 ? 360 - d : d;\n}\n\n// 4. SECTE, NŒUD SUD, PART DE FORTUNE ET LOT DE L'ESPRIT\nlet asc  = planetes.find(p => p.planet.fr === \"Ascendant\");\nlet sun  = planetes.find(p => p.planet.fr === \"Soleil\");\nlet moon = planetes.find(p => p.planet.fr === \"Lune\");\n\nlet sunHouse  = sun ? getHouseNumber(sun.fullDegree) : 1;\n// Calcul géométrique de la secte (plus précis que par numéro de maison)\n// arc = ((sunDeg - ascDeg) + 360) % 360\n//   arc < 180° → Soleil entre ASC et DSC (Maisons 1–6) = SOUS l'horizon → Nocturne\n//   arc > 180° → Soleil entre DSC et ASC (Maisons 7–12) = AU-DESSUS de l'horizon → Diurne\nlet isDayChart;\nif (asc && sun) {\n    const arcSoleilDepuisAsc = ((sun.fullDegree - asc.fullDegree) + 360) % 360;\n    isDayChart = arcSoleilDepuisAsc > 180;\n} else {\n    isDayChart = [7,8,9,10,11,12].includes(Number(sunHouse)); // fallback par maison\n}\nlet sectStr = isDayChart ? \"Diurne (Soleil au-dessus de l'horizon)\" : \"Nocturne (Soleil sous l'horizon)\";\nstats.sect = sectStr;\nstats.sectLight   = isDayChart ? \"Soleil\" : \"Lune\";\nstats.sectBenefic = isDayChart ? \"Jupiter\" : \"Vénus\";\nstats.sectMalefic = isDayChart ? \"Saturne\" : \"Mars\";\nstats.contraSectMalefic = isDayChart ? \"Mars\" : \"Saturne\";\n\n// Triplicité — seigneurs diurne/nocturne (Ptolémée/Dorothée), utilisé par locataires + Almutem\nconst TRIPLIC_DAY_EARLY = {\n    \"Bélier\":\"Soleil\",\"Lion\":\"Soleil\",\"Sagittaire\":\"Soleil\",\n    \"Taureau\":\"Vénus\",\"Vierge\":\"Vénus\",\"Capricorne\":\"Vénus\",\n    \"Gémeaux\":\"Saturne\",\"Balance\":\"Saturne\",\"Verseau\":\"Saturne\",\n    \"Cancer\":\"Vénus\",\"Scorpion\":\"Vénus\",\"Poissons\":\"Vénus\"\n};\nconst TRIPLIC_NIGHT_EARLY = {\n    \"Bélier\":\"Jupiter\",\"Lion\":\"Jupiter\",\"Sagittaire\":\"Jupiter\",\n    \"Taureau\":\"Lune\",\"Vierge\":\"Lune\",\"Capricorne\":\"Lune\",\n    \"Gémeaux\":\"Mercure\",\"Balance\":\"Mercure\",\"Verseau\":\"Mercure\",\n    \"Cancer\":\"Mars\",\"Scorpion\":\"Mars\",\"Poissons\":\"Mars\"\n};\nconst TRIPLIC_PART_EARLY = {\n    \"Bélier\":\"Saturne\",\"Lion\":\"Saturne\",\"Sagittaire\":\"Saturne\",\n    \"Taureau\":\"Mars\",\"Vierge\":\"Mars\",\"Capricorne\":\"Mars\",\n    \"Gémeaux\":\"Jupiter\",\"Balance\":\"Jupiter\",\"Verseau\":\"Jupiter\",\n    \"Cancer\":\"Lune\",\"Scorpion\":\"Lune\",\"Poissons\":\"Lune\"\n};\nconst getTriplicityRuler = (sign) => isDayChart ? (TRIPLIC_DAY_EARLY[sign] || null) : (TRIPLIC_NIGHT_EARLY[sign] || null);\nconst getTriplicityParticipant = (sign) => TRIPLIC_PART_EARLY[sign] || null;\n\nif (asc && sun && moon) {\n    // Part de Fortune : diurne = ASC + Lune - Soleil ; nocturne = inverse\n    let pofDeg = isDayChart\n        ? (asc.fullDegree + moon.fullDegree - sun.fullDegree)\n        : (asc.fullDegree + sun.fullDegree  - moon.fullDegree);\n    pofDeg = ((pofDeg % 360) + 360) % 360;\n    planetes.push({ planet:{fr:\"Part de Fortune\",en:\"Part of Fortune\"}, fullDegree:pofDeg, normDegree:pofDeg%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(pofDeg/30)].fr}} });\n\n    // Lot de l'Esprit : inverse de Fortune\n    let posDeg = isDayChart\n        ? (asc.fullDegree + sun.fullDegree  - moon.fullDegree)\n        : (asc.fullDegree + moon.fullDegree - sun.fullDegree);\n    posDeg = ((posDeg % 360) + 360) % 360;\n    planetes.push({ planet:{fr:\"Lot de l'Esprit\",en:\"Lot of Spirit\"}, fullDegree:posDeg, normDegree:posDeg%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(posDeg/30)].fr}} });\n\n    // Sprint 7 — Action 6 : Lots hermétiques supplémentaires\n    const mars = planetes.find(p => p.planet.fr === \"Mars\");\n    const venus = planetes.find(p => p.planet.fr === \"Vénus\");\n    const jupiter = planetes.find(p => p.planet.fr === \"Jupiter\");\n    const saturn = planetes.find(p => p.planet.fr === \"Saturne\");\n    const mercury = planetes.find(p => p.planet.fr === \"Mercure\");\n\n    const lotCalc = (a, b, c) => (((a + b - c) % 360) + 360) % 360;\n    const lotCalcInverse = (a, b, c) => (((a + c - b) % 360) + 360) % 360;\n    const pushLot = (frName, enName, deg) => {\n        planetes.push({ planet:{fr:frName,en:enName}, fullDegree:deg, normDegree:deg%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(deg/30)].fr}} });\n    };\n\n    // Lot de Nécessité (Ananke) : diurne = ASC + Fortune - Mercure ; nocturne = inverse\n    if (mercury) {\n        const necDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, mercury.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, mercury.fullDegree);\n        pushLot(\"Lot de Nécessité\", \"Lot of Necessity\", necDeg);\n    }\n    // Lot d'Éros : diurne = ASC + Vénus - Esprit ; nocturne = inverse\n    if (venus) {\n        const erosDeg = isDayChart ? lotCalc(asc.fullDegree, venus.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, venus.fullDegree, posDeg);\n        pushLot(\"Lot d'Éros\", \"Lot of Eros\", erosDeg);\n    }\n    // Lot de Courage (Tolma) : diurne = ASC + Fortune - Mars ; nocturne = inverse\n    if (mars) {\n        const courDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, mars.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, mars.fullDegree);\n        pushLot(\"Lot de Courage\", \"Lot of Courage\", courDeg);\n    }\n    // Lot de Némésis : diurne = ASC + Fortune - Saturne ; nocturne = inverse\n    if (saturn) {\n        const nemDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, saturn.fullDegree);\n        pushLot(\"Lot de Némésis\", \"Lot of Nemesis\", nemDeg);\n    }\n    // Lot de Basis : ASC + Fortune - Esprit (invariant sect)\n    const basisDeg = lotCalc(asc.fullDegree, pofDeg, posDeg);\n    pushLot(\"Lot de Basis\", \"Lot of Basis\", basisDeg);\n\n    // Lot d'Exaltation : ASC + (degré exalt Soleil 19°Bélier) - Soleil\n    const exaltSunDeg = 19; // 19° Bélier\n    const exaltDeg = lotCalc(asc.fullDegree, exaltSunDeg, sun.fullDegree);\n    pushLot(\"Lot d'Exaltation\", \"Lot of Exaltation\", exaltDeg);\n\n    // Lot du Daemon : diurne = ASC + Soleil - Esprit ; nocturne = inverse\n    const daemonDeg = isDayChart ? lotCalc(asc.fullDegree, sun.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, sun.fullDegree, posDeg);\n    pushLot(\"Lot du Daemon\", \"Lot of Daemon\", daemonDeg);\n\n    // ── C7 : Parts Arabes élargies (Vettius Valens, Paulus Alexandrinus, Firmicus Maternus) ──\n    // Lot de Victoire (Nikè) : diurne = ASC + Jupiter - Esprit ; nocturne = inverse\n    if (jupiter) {\n        const vicDeg = isDayChart ? lotCalc(asc.fullDegree, jupiter.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, jupiter.fullDegree, posDeg);\n        pushLot(\"Lot de Victoire\", \"Lot of Victory\", vicDeg);\n    }\n    // Lot du Père : diurne = ASC + Saturne - Soleil ; nocturne = inverse\n    if (saturn) {\n        const pereDeg = isDayChart ? lotCalc(asc.fullDegree, saturn.fullDegree, sun.fullDegree) : lotCalcInverse(asc.fullDegree, saturn.fullDegree, sun.fullDegree);\n        pushLot(\"Lot du Père\", \"Lot of Father\", pereDeg);\n    }\n    // Lot de la Mère : diurne = ASC + Lune - Vénus ; nocturne = inverse\n    if (venus) {\n        const mereDeg = isDayChart ? lotCalc(asc.fullDegree, moon.fullDegree, venus.fullDegree) : lotCalcInverse(asc.fullDegree, moon.fullDegree, venus.fullDegree);\n        pushLot(\"Lot de la Mère\", \"Lot of Mother\", mereDeg);\n    }\n    // Lot de Maladie (Valens) : diurne = ASC + Mars - Saturne ; nocturne = inverse\n    if (mars && saturn) {\n        const malDeg = isDayChart ? lotCalc(asc.fullDegree, mars.fullDegree, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, mars.fullDegree, saturn.fullDegree);\n        pushLot(\"Lot de Maladie\", \"Lot of Illness\", malDeg);\n    }\n    // Lot du Mariage : diurne = ASC + DSC - Vénus ; nocturne = inverse (formule universelle Valens)\n    const dsc = maisons.find(m => m.House === 7);\n    if (venus && dsc) {\n        const mariDeg = isDayChart ? lotCalc(asc.fullDegree, dsc.degree, venus.fullDegree) : lotCalcInverse(asc.fullDegree, dsc.degree, venus.fullDegree);\n        pushLot(\"Lot du Mariage\", \"Lot of Marriage\", mariDeg);\n    }\n    // Lot des Enfants (Valens) : diurne = ASC + Jupiter - Saturne ; nocturne = inverse\n    if (jupiter && saturn) {\n        const enfDeg = isDayChart ? lotCalc(asc.fullDegree, jupiter.fullDegree, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, jupiter.fullDegree, saturn.fullDegree);\n        pushLot(\"Lot des Enfants\", \"Lot of Children\", enfDeg);\n    }\n    // Lot de Voyage (Firmicus) : diurne = ASC + Mars - Saturne renversé pour cette formule ≠ maladie\n    // → Firmicus : ASC + 9e cuspide - maître du 9e ; simplifié → ASC + Saturne - Jupiter (éloignement)\n    if (jupiter && saturn) {\n        const voyDeg = isDayChart ? lotCalc(asc.fullDegree, saturn.fullDegree, jupiter.fullDegree) : lotCalcInverse(asc.fullDegree, saturn.fullDegree, jupiter.fullDegree);\n        pushLot(\"Lot de Voyage\", \"Lot of Travel\", voyDeg);\n    }\n}\n\nlet nn = planetes.find(p => p.planet.fr === \"Nœud Nord\");\nif (nn) {\n    let sd = (nn.fullDegree + 180) % 360;\n    const sudDecl = typeof nn.declinaison === 'number' ? -nn.declinaison : undefined;\n    planetes.push({ planet:{fr:\"Nœud Sud\",en:\"South Node\"}, fullDegree:sd, normDegree:sd%30, retroStr:nn.retroStr, isRetro:nn.isRetro, zodiac_sign:{name:{fr:signs[Math.floor(sd/30)].fr}}, declinaison:sudDecl });\n}\n\n// 5. ASPECTS MAJEURS + MINEURS\nconst aspectTypes = [\n    {name:\"Conjonction\", deg:0,   orb:10, nodalOrb:8, smallOrb:8,  major:true},\n    {name:\"Sextile\",     deg:60,  orb:6,  nodalOrb:5, smallOrb:3,  major:true},\n    {name:\"Carré\",       deg:90,  orb:8,  nodalOrb:7, smallOrb:4,  major:true},\n    {name:\"Trigone\",     deg:120, orb:8,  nodalOrb:7, smallOrb:4,  major:true},\n    {name:\"Opposition\",  deg:180, orb:10, nodalOrb:8, smallOrb:6,  major:true},\n    {name:\"Quinconce\",   deg:150, orb:3,  nodalOrb:2, smallOrb:2,  major:false},\n    {name:\"Semi-Sextile\",deg:30,  orb:2,  nodalOrb:1, smallOrb:1,  major:false},\n    {name:\"Semi-Carré\",  deg:45,  orb:2,  nodalOrb:2, smallOrb:1,  major:false},\n    {name:\"Quintile\",    deg:72,  orb:2,  nodalOrb:2, smallOrb:1,  major:false},\n    {name:\"Biquintile\",  deg:144, orb:2,  nodalOrb:1, smallOrb:1,  major:false},\n    {name:\"Sesqui-Carré\",deg:135, orb:2,  nodalOrb:2, smallOrb:1,  major:false}\n];\nconst smallBodies  = [\"Chiron\",\"Vesta\",\"Cérès\",\"Ceres\",\"Pallas\",\"Junon\",\"Juno\",\"Lilith\"];\nconst nodalBodies  = [\"Nœud Nord\",\"Nœud Sud\",\"Part de Fortune\",\"Part of Fortune\",\"Lot de l'Esprit\",\"Lot of Spirit\",\"Lot de Nécessité\",\"Lot of Necessity\",\"Lot d'Éros\",\"Lot of Eros\",\"Lot de Courage\",\"Lot of Courage\",\"Lot de Némésis\",\"Lot of Nemesis\",\"Lot de Basis\",\"Lot of Basis\",\"Lot d'Exaltation\",\"Lot of Exaltation\",\"Lot du Daemon\",\"Lot of Daemon\"];\n\n// Facteur d'orbe planète-spécifique (Solar Fire standard)\nconst PLANET_ORB_FACTOR = {\n    \"Soleil\":1.0, \"Lune\":1.0, \"Ascendant\":1.0, \"Milieu du Ciel\":1.0,\n    \"Descendant\":1.0, \"Imum Coeli\":1.0,\n    \"Mercure\":0.75, \"Vénus\":0.75, \"Mars\":0.75,\n    \"Jupiter\":0.65, \"Saturne\":0.65,\n    \"Uranus\":0.55, \"Neptune\":0.55, \"Pluton\":0.55,\n    \"Chiron\":0.55, \"Nœud Nord\":0.6, \"Nœud Sud\":0.6\n};\n\nconst AXIS_PAIRS = [\n    new Set([\"Milieu du Ciel\", \"Imum Coeli\"]),\n    new Set([\"Ascendant\", \"Descendant\"]),\n    new Set([\"Nœud Nord\", \"Nœud Sud\"])\n];\nconst isAxisPair = (n1, n2) => AXIS_PAIRS.some(pair => pair.has(n1) && pair.has(n2));\n\nlet aspects = [];\nfor(let i=0; i<planetes.length; i++) {\n    for(let j=i+1; j<planetes.length; j++) {\n        let p1=planetes[i], p2=planetes[j];\n        let name1 = p1.planet.fr || p1.planet.en;\n        let name2 = p2.planet.fr || p2.planet.en;\n        if (isAxisPair(name1, name2)) continue;\n        let isSmall  = smallBodies.includes(name1) || smallBodies.includes(name2);\n        let isNodal  = nodalBodies.includes(name1) || nodalBodies.includes(name2);\n        let activeType = isSmall ? \"smallOrb\" : (isNodal ? \"nodalOrb\" : \"orb\");\n        const f1 = PLANET_ORB_FACTOR[name1] ?? 0.5;\n        const f2 = PLANET_ORB_FACTOR[name2] ?? 0.5;\n        const orbModulator = Math.max(f1, f2);\n        let diff = Math.abs(p1.fullDegree - p2.fullDegree);\n        if(diff > 180) diff = 360 - diff;\n        aspectTypes.forEach(a => {\n            let activeOrb  = a[activeType] * orbModulator;\n            let exactitude = Math.abs(diff - a.deg);\n            if(exactitude <= activeOrb) {\n                aspects.push({ p1:name1, p2:name2, aspect:a.name, exactitude:exactitude.toFixed(2), isMajor:a.major });\n            }\n        });\n    }\n}\n\n// Fonctions d'affichage des aspects — utilisent les scores calculés en bloc 6k\n// (appelées en bloc 7+ quand les aspects sont déjà enrichis, triés et flaggés isPromoted)\n\n// ── Sprint 6 — Module A : Qualificatif d'orbe calculé ──\nconst orbQualifier = (orb) => {\n    const o = typeof orb === \"string\" ? parseFloat(orb) : orb;\n    if (o < 1)   return \"exact\";\n    if (o < 3)   return \"serré\";\n    if (o < 5)   return \"moyen\";\n    return \"large\";\n};\n\n// ── Sprint 6 — Module B1+E2 : Natures planétaires ──\nconst PLANET_NATURES = {\n    \"Soleil\":\"luminaire\",\"Lune\":\"luminaire\",\n    \"Mercure\":\"neutre\",\"Vénus\":\"bénéfique\",\"Mars\":\"maléfique\",\n    \"Jupiter\":\"bénéfique\",\"Saturne\":\"maléfique\",\n    \"Uranus\":\"maléfique\",\"Neptune\":\"dissolvant\",\"Pluton\":\"maléfique\",\n    \"Chiron\":\"neutre\",\"Nœud Nord\":\"neutre\",\"Nœud Sud\":\"neutre\",\n    \"Lilith\":\"maléfique\",\"Cérès\":\"neutre\",\"Ceres\":\"neutre\",\n    \"Junon\":\"neutre\",\"Juno\":\"neutre\",\"Vesta\":\"neutre\",\"Pallas\":\"neutre\",\n    \"Ascendant\":\"neutre\",\"Milieu du Ciel\":\"neutre\",\"Descendant\":\"neutre\",\"Imum Coeli\":\"neutre\"\n};\n\nconst getNatureTag = (p1, p2) => {\n    const n1 = PLANET_NATURES[p1], n2 = PLANET_NATURES[p2];\n    if (!n1 || !n2 || n1 === \"neutre\" && n2 === \"neutre\") return \"\";\n    if (n1 === \"dissolvant\" || n2 === \"dissolvant\") {\n        const otherN = n1 === \"dissolvant\" ? n2 : n1;\n        if (otherN === \"maléfique\")  return \" [Nature: dissolution de la tension — transcendance possible mais risque de confusion]\";\n        if (otherN === \"bénéfique\")  return \" [Nature: sublimation — inspiration élevée mais risque d'idéalisation]\";\n        if (otherN === \"luminaire\")  return \" [Nature: voile sur le luminaire — intuition amplifiée mais identité potentiellement floue]\";\n        return \"\";\n    }\n    if (n1 === \"bénéfique\" && n2 === \"bénéfique\")  return \" [Nature: synergie bénéfique — énergies qui s'emboîtent harmonieusement]\";\n    if (n1 === \"maléfique\" && n2 === \"maléfique\")  return \" [Nature: friction maléfique — tension intensifiée, potentiel d'obstacle]\";\n    if ((n1===\"bénéfique\"&&n2===\"maléfique\")||(n1===\"maléfique\"&&n2===\"bénéfique\"))\n        return \" [Nature: mixte — le bénéfique tempère le maléfique, mais sous tension]\";\n    if (n1 === \"luminaire\" || n2 === \"luminaire\") {\n        const otherN = n1 === \"luminaire\" ? n2 : n1;\n        if (otherN === \"bénéfique\")  return \" [Nature: luminaire + bénéfique — vitalité amplifiée et soutenue]\";\n        if (otherN === \"maléfique\")  return \" [Nature: luminaire + maléfique — vitalité mise au défi]\";\n        if (otherN === \"dissolvant\") return \" [Nature: voile sur le luminaire — intuition amplifiée mais identité potentiellement floue]\";\n    }\n    return \"\";\n};\n\n// ── Sprint 6 — Module E1 : Appliquant / Séparant (aspects nataux) ──\nconst PLANET_SPEED_RANK = {\n    \"Lune\":1,\"Mercure\":2,\"Vénus\":3,\"Soleil\":4,\"Mars\":5,\n    \"Jupiter\":6,\"Saturne\":7,\"Uranus\":8,\"Neptune\":9,\"Pluton\":10,\n    \"Chiron\":7.5,\"Lilith\":4.5,\"Cérès\":5.5,\"Ceres\":5.5,\"Junon\":5.2,\"Juno\":5.2,\"Vesta\":5.3,\"Pallas\":5.4,\n    \"Nœud Nord\":7.2,\"Nœud Sud\":7.2\n};\nconst getAppSepTag = (pFaster, pSlower, aspDeg, exactitude) => {\n    const r1 = PLANET_SPEED_RANK[pFaster], r2 = PLANET_SPEED_RANK[pSlower];\n    if (!r1 || !r2) return \"\";\n    const fast = r1 < r2 ? pFaster : pSlower;\n    const slow = r1 < r2 ? pSlower : pFaster;\n    const pFast = planetes.find(p => p.planet.fr === fast);\n    const pSlow = planetes.find(p => p.planet.fr === slow);\n    if (!pFast || !pSlow) return \"\";\n    const fastRetro = pFast.isRetro === \"True\" || pFast.isRetro === true;\n    const diff = ((pFast.fullDegree - pSlow.fullDegree) + 360) % 360;\n    let approaching, separating;\n    if (aspDeg === 0) {\n        approaching = diff > 180;\n        separating  = diff <= 180 && diff > 0;\n    } else {\n        approaching = diff > aspDeg && diff < aspDeg + 15;\n        separating  = diff < aspDeg || diff > aspDeg + 345;\n    }\n    if (fastRetro) {\n        const tmp = approaching;\n        approaching = separating;\n        separating = tmp;\n    }\n    if (approaching) return \" [appliquant]\";\n    if (separating)  return \" [séparant]\";\n    return \"\";\n};\nconst ASP_DEG_MAP = {\"Conjonction\":0,\"Opposition\":180,\"Carré\":90,\"Trigone\":120,\"Sextile\":60,\"Quinconce\":150,\"Semi-Sextile\":30,\"Semi-Carré\":45,\"Quintile\":72,\"Biquintile\":144,\"Sesqui-Carré\":135};\n\nconst MINOR_ASPECT_MEANINGS = {\n    \"Quintile\":     \"harmonie créatrice, don structurel\",\n    \"Biquintile\":   \"harmonie créatrice avancée, talent latent\",\n    \"Semi-Sextile\": \"irritant mineur, ajustement progressif entre signes adjacents\",\n    \"Semi-Carré\":   \"friction légère, micro-tension de développement\",\n    \"Sesqui-Carré\": \"tension de friction constructive\",\n    \"Quinconce\":    \"ajustement obligatoire, tension inconsciente\"\n};\n\nconst getMajorAspectsStr = (pName) => {\n    let asps = aspects.filter(a => a.isMajor && (a.p1===pName || a.p2===pName));\n    if (!asps.length) return \"Aucun aspect majeur\";\n    return asps.map(a => {\n        const partner = a.p1===pName ? a.p2 : a.p1;\n        const prefix  = a.prioriteEmoji ? `${a.prioriteEmoji} ${a.prioriteLabel} — ` : \"\";\n        const oq = orbQualifier(a.exactitude);\n        const nt = getNatureTag(pName, partner);\n        const aspDeg = ASP_DEG_MAP[a.aspect] ?? 0;\n        const appSep = getAppSepTag(a.p1, a.p2, aspDeg, parseFloat(a.exactitude));\n        return `${prefix}${a.aspect} avec ${partner} (${a.exactitude}° — ${oq})${appSep}${nt}`;\n    }).join(\" | \");\n};\n\n// Aspects mineurs promus (score ≥ seuil Option B) — traités comme des aspects majeurs par le LLM\nconst getPromotedMinorAspectsStr = (pName) => {\n    let asps = aspects.filter(a => !a.isMajor && a.isPromoted && (a.p1===pName || a.p2===pName));\n    if (!asps.length) return null;\n    return asps.map(a => {\n        const partner  = a.p1===pName ? a.p2 : a.p1;\n        const meaning  = MINOR_ASPECT_MEANINGS[a.aspect] ? ` — nature : ${MINOR_ASPECT_MEANINGS[a.aspect]}` : \"\";\n        const oq = orbQualifier(a.exactitude);\n        const nt = getNatureTag(pName, partner);\n        const aspDeg = ASP_DEG_MAP[a.aspect] ?? 0;\n        const appSep = getAppSepTag(a.p1, a.p2, aspDeg, parseFloat(a.exactitude));\n        return `   ${a.prioriteEmoji} ${a.prioriteLabel} — ${a.aspect} avec ${partner} (${a.exactitude}° — ${oq})${appSep}${meaning}${nt}`;\n    }).join(\"\\n\");\n};\n\n// Aspects mineurs non promus (tous les autres aspects mineurs)\nconst getMinorAspectsStr = (pName) => {\n    let asps = aspects.filter(a => !a.isMajor && !a.isPromoted && (a.p1===pName || a.p2===pName))\n        .sort((a,b) => parseFloat(a.exactitude) - parseFloat(b.exactitude)).slice(0, 5);\n    if (!asps.length) return null;\n    return asps.map(a => {\n        const partner = a.p1===pName ? a.p2 : a.p1;\n        const prefix  = a.prioriteEmoji ? `${a.prioriteEmoji} ${a.prioriteLabel} — ` : \"\";\n        return `${prefix}${a.aspect} avec ${partner} (${a.exactitude}°)`;\n    }).join(\" | \");\n};\n\n// ─────────────────────────────────────────────────────────────────\n// 6. NOUVELLES TECHNIQUES\n// ─────────────────────────────────────────────────────────────────\n\n// 6a. CONDITIONS HÉLIOCENTRIQUES (Cazimi / Combuste / Sous les rayons / Oriental / Occidental)\nconst helioConditions = {};\nif (sun) {\n    const inferiorPlanets  = [\"Mercure\",\"Vénus\"];\n    const helioTargets     = [\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\"];\n    planetes.forEach(p => {\n        let name = p.planet.fr || p.planet.en;\n        if (!helioTargets.includes(name)) return;\n        let diff = p.fullDegree - sun.fullDegree;\n        while (diff >  180) diff -= 360;\n        while (diff < -180) diff += 360;\n        let absDiff = Math.abs(diff);\n        let condition = null;\n        const isLune = name === \"Lune\";\n        if (absDiff <= 0.283)   condition = isLune\n            ? \"CAZIMI LUNAIRE — Nouvelle Lune exacte au cœur du Soleil (fusion lumière/émotion, puissance exceptionnelle)\"\n            : \"CAZIMI — au cœur du Soleil (force exceptionnelle)\";\n        else if (absDiff <= 8)  condition = isLune\n            ? `NOUVELLE LUNE (conjonction Soleil-Lune à ${absDiff.toFixed(1)}°) — phase d'ensemencement, intériorisation émotionnelle intense, énergie tournée vers le subconscient`\n            : `COMBUSTE — brûlé par le Soleil à ${absDiff.toFixed(1)}° (affaibli, principe planétaire neutralisé)`;\n        else if (absDiff <= 15) condition = isLune\n            ? (diff > 0\n                ? `LUNE CROISSANT (${absDiff.toFixed(1)}° après le Soleil) — début de cycle, émergence émotionnelle progressive, volonté d'action instinctive`\n                : `LUNE BALSAMIQUE (${absDiff.toFixed(1)}° avant le Soleil) — fin de cycle, introspection profonde, lâcher-prise et sagesse distillée`)\n            : `SOUS LES RAYONS — à ${absDiff.toFixed(1)}° du Soleil (diminué, agit en coulisse)`;\n\n        let orientation = null;\n        if (inferiorPlanets.includes(name)) {\n            if (absDiff <= 15) {\n                orientation = diff < 0 ? \"Oriental — étoile du matin (se lève avant le Soleil)\" : \"Occidental — étoile du soir (se couche après le Soleil)\";\n            } else {\n                orientation = diff < 0 ? \"Oriental (élongation Ouest, étoile du matin)\" : \"Occidental (élongation Est, étoile du soir)\";\n            }\n        }\n        if (condition || orientation) helioConditions[name] = { condition, orientation };\n    });\n}\n\n// 6a-bis. PLANÈTES STATIONNAIRES (vitesse quotidienne quasi-nulle)\n// Seuils en °/jour — sous ce seuil, la planète est considérée stationnaire\nconst STATION_THRESHOLDS = {\n    \"Mercure\": 0.3, \"Vénus\": 0.15, \"Mars\": 0.08,\n    \"Jupiter\": 0.02, \"Saturne\": 0.01, \"Uranus\": 0.005,\n    \"Neptune\": 0.003, \"Pluton\": 0.002, \"Chiron\": 0.01\n};\nconst stationaryPlanets = [];\nObject.keys(STATION_THRESHOLDS).forEach(name => {\n    const p = planetes.find(x => (x.planet.fr || x.planet.en) === name);\n    if (!p) return;\n    const speed = p.vitesse_longitude ?? p.speed ?? p.daily_motion ?? null;\n    if (speed === null || speed === undefined) return;\n    const absSpeed = Math.abs(parseFloat(speed));\n    const threshold = STATION_THRESHOLDS[name];\n    if (absSpeed <= threshold) {\n        const isRetro = p.retroStr || (p.isRetro === \"True\" || p.isRetro === true);\n        const direction = isRetro ? \"Station Rétrograde (SR)\" : \"Station Directe (SD)\";\n        stationaryPlanets.push({\n            planet: name, speed: absSpeed.toFixed(4), threshold,\n            direction, house: getHouseNumber(p.fullDegree),\n            sign: p.zodiac_sign?.name?.fr\n        });\n    }\n});\n\n// 6b. PLANÈTES ANGULAIRES (within 5° of ASC / DSC / MC / IC)\nconst angleNames    = [\"Ascendant\",\"Descendant\",\"Milieu du Ciel\",\"Imum Coeli\"];\nconst corePlanets   = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\"];\nconst angularPlanets = [];\ncorePlanets.forEach(name => {\n    let p = planetes.find(x => x.planet.fr === name); if (!p) return;\n    angleNames.forEach(angleName => {\n        let angleP = planetes.find(a => a.planet.fr === angleName); if (!angleP) return;\n        let diff = angularDiff(p.fullDegree, angleP.fullDegree);\n        if (diff <= 5) angularPlanets.push({ planet:name, angle:angleName, orb:diff.toFixed(2), house:getHouseNumber(p.fullDegree), sign:p.zodiac_sign?.name?.fr });\n    });\n});\n\n// 6c. DEGRÉS CRITIQUES (29° Anarète, 0° Ingress, degrés critiques par modalité)\nconst criticalDegConfig = { cardinal:[0,13,26], fixed:[8,9,21,22], mutable:[4,17] };\nconst cardinalSigns = [\"Bélier\",\"Cancer\",\"Balance\",\"Capricorne\"];\nconst fixedSigns    = [\"Taureau\",\"Lion\",\"Scorpion\",\"Verseau\"];\nconst mutableSigns  = [\"Gémeaux\",\"Vierge\",\"Sagittaire\",\"Poissons\"];\nconst criticalPlanets = [];\ncorePlanets.forEach(name => {\n    let p = planetes.find(x => x.planet.fr === name); if (!p) return;\n    let deg  = p.normDegree;\n    let sign = p.zodiac_sign?.name?.fr;\n    let flags = [];\n    if (deg >= 29)    flags.push(\"29° Anarète — degré de fin de cycle, tension et urgence\");\n    if (deg < 1)      flags.push(\"0° Ingress — énergie brute non encore filtrée, commencement absolu\");\n    if (cardinalSigns.includes(sign)) criticalDegConfig.cardinal.forEach(cd => { if (Math.abs(deg-cd) < 1) flags.push(`Degré critique cardinal ${cd}° (crise et tournant)`); });\n    if (fixedSigns.includes(sign))    criticalDegConfig.fixed.forEach(cd   => { if (Math.abs(deg-cd) < 1) flags.push(`Degré critique fixe ${cd}° (tension accumulée)`); });\n    if (mutableSigns.includes(sign))  criticalDegConfig.mutable.forEach(cd => { if (Math.abs(deg-cd) < 1) flags.push(`Degré critique mutable ${cd}° (carrefour de choix)`); });\n    if (flags.length > 0) criticalPlanets.push({ planet:name, sign, degree:deg.toFixed(2), flags });\n});\n\n// 6d. RÉCEPTIONS MUTUELLES\nconst receptionPlanets  = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\nconst mutualReceptions  = [];\nfor (let i=0; i<receptionPlanets.length; i++) {\n    for (let j=i+1; j<receptionPlanets.length; j++) {\n        let nA=receptionPlanets[i], nB=receptionPlanets[j];\n        let pA=planetes.find(p=>p.planet.fr===nA), pB=planetes.find(p=>p.planet.fr===nB);\n        if (!pA || !pB) continue;\n        let sA=pA.zodiac_sign?.name?.fr, sB=pB.zodiac_sign?.name?.fr;\n        let aInBDom = dignities[nA] && dignities[nB]?.dom?.includes(sA);\n        let bInADom = dignities[nB] && dignities[nA]?.dom?.includes(sB);\n        if (aInBDom && bInADom) {\n            mutualReceptions.push({ p1:nA, sign1:sA, house1:getHouseNumber(pA.fullDegree), p2:nB, sign2:sB, house2:getHouseNumber(pB.fullDegree), type:\"domicile\" });\n        }\n        let aInBExa = dignities[nA] && dignities[nB]?.exa?.includes(sA);\n        let bInAExa = dignities[nB] && dignities[nA]?.exa?.includes(sB);\n        if (aInBExa && bInAExa && !(aInBDom && bInADom)) {\n            mutualReceptions.push({ p1:nA, sign1:sA, house1:getHouseNumber(pA.fullDegree), p2:nB, sign2:sB, house2:getHouseNumber(pB.fullDegree), type:\"exaltation\" });\n        }\n        // Réception mixte : A en domicile de B + B en exaltation de A (ou inverse)\n        if (!(aInBDom && bInADom) && !(aInBExa && bInAExa)) {\n            if ((aInBDom && bInAExa) || (aInBExa && bInADom)) {\n                mutualReceptions.push({ p1:nA, sign1:sA, house1:getHouseNumber(pA.fullDegree), p2:nB, sign2:sB, house2:getHouseNumber(pB.fullDegree), type:\"mixte\" });\n            }\n        }\n    }\n}\n\n// 6e. CONFIGURATIONS NATALES (Stellium, Grand Trigone, T-Carré, Grand Carré, Yod, Cerf-Volant)\n// confPlanets inclut les 10 planètes + Chiron + les 4 Angles (ASC, MC, DSC, IC).\n// Les Angles sont construits depuis les maisons si absents du payload API.\n// Sans cette extension, le bonus +40 \"Si Angle impliqué\" serait du code mort\n// et des configurations majeures (ex: T-Carré avec l'ASC comme apex) seraient manquées.\nconst CONF_ANGLES_SET = new Set([\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"]);\nconst confPlanetsBase = planetes.filter(p => corePlanets.includes(p.planet.fr || p.planet.en));\nconst angleObjectsConf = [\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"].map(angleName => {\n    let existing = planetes.find(p => p.planet.fr === angleName);\n    if (existing) return existing;\n    const houseNum = angleName === \"Descendant\" ? 7 : angleName === \"Imum Coeli\" ? 4 : null;\n    if (!houseNum) return null;\n    const m = maisons.find(m => m.House === houseNum);\n    if (!m) return null;\n    return { planet:{fr:angleName,en:angleName}, fullDegree:m.degree, normDegree:m.degree%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(m.degree/30)%12].fr}} };\n}).filter(Boolean);\nconst confPlanets = [...confPlanetsBase];\nangleObjectsConf.forEach(ao => {\n    const aoName = ao.planet.fr || ao.planet.en;\n    if (!confPlanets.find(p => (p.planet.fr || p.planet.en) === aoName)) confPlanets.push(ao);\n});\nconst configurations = [];\n\n// Stellium : 3+ planètes dans le même signe\nlet signGroups = {};\nconfPlanets.forEach(p => {\n    let sign = p.zodiac_sign?.name?.fr;\n    if (!signGroups[sign]) signGroups[sign] = [];\n    signGroups[sign].push(p.planet.fr || p.planet.en);\n});\nObject.entries(signGroups).forEach(([sign, pList]) => {\n    if (pList.length >= 3 && pList.filter(p => CONF_ANGLES_SET.has(p)).length < 3) {\n        configurations.push({ type:\"Stellium\", planets:pList, description:`${pList.join(\", \")} regroupés en ${sign} — concentration d'énergie ${sign} très intense` });\n    }\n});\n\n// Stellium par Maison : 3+ planètes dans la même maison (complémentaire du Stellium par signe)\n// Pertinent quand un Stellium s'étale sur deux signes dans une maison large ou interceptée.\nconst houseGroupsStellium = {};\nconfPlanets.forEach(p => {\n    const house = getHouseNumber(p.fullDegree);\n    if (!houseGroupsStellium[house]) houseGroupsStellium[house] = [];\n    const pName = p.planet.fr || p.planet.en;\n    if (!houseGroupsStellium[house].includes(pName)) houseGroupsStellium[house].push(pName);\n});\nObject.entries(houseGroupsStellium).forEach(([house, pList]) => {\n    if (pList.length >= 3) {\n        const alreadyCovered = configurations.some(c =>\n            c.type === \"Stellium\" && c.planets.length === pList.length && c.planets.every(p => pList.includes(p))\n        );\n        if (!alreadyCovered && pList.filter(p => CONF_ANGLES_SET.has(p)).length < 3) {\n            configurations.push({ type:\"Stellium\", planets:pList, description:`${pList.join(\", \")} concentrés en Maison ${house} — Stellium de maison, thématiques de M${house} hyper-activées` });\n        }\n    }\n});\n\n// Grand Trigone : 3 planètes à ~120° (orbe 8°)\nconst grandTrigoneSets = [];\nfor (let i=0; i<confPlanets.length; i++) {\n    for (let j=i+1; j<confPlanets.length; j++) {\n        for (let k=j+1; k<confPlanets.length; k++) {\n            let d12=angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree);\n            let d23=angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree);\n            let d13=angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree);\n            if (Math.abs(d12-120)<=8 && Math.abs(d23-120)<=8 && Math.abs(d13-120)<=8) {\n                let n1=confPlanets[i].planet.fr, n2=confPlanets[j].planet.fr, n3=confPlanets[k].planet.fr;\n                grandTrigoneSets.push([n1,n2,n3]);\n                configurations.push({ type:\"Grand Trigone\", planets:[n1,n2,n3], description:`${n1} — ${n2} — ${n3} : grande harmonie et facilité, risque d'inertie sans effort conscient` });\n            }\n        }\n    }\n}\n\n// T-Carré : 2 planètes en opposition + une troisième en carré aux deux\nlet tcarreKeys = new Set();\nfor (let i=0; i<confPlanets.length; i++) {\n    for (let j=i+1; j<confPlanets.length; j++) {\n        if (Math.abs(angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree)-180)>10) continue;\n        for (let k=0; k<confPlanets.length; k++) {\n            if (k===i||k===j) continue;\n            let dik=angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree);\n            let djk=angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree);\n            if (Math.abs(dik-90)<=8 && Math.abs(djk-90)<=8) {\n                let n1=confPlanets[i].planet.fr, n2=confPlanets[j].planet.fr, nk=confPlanets[k].planet.fr;\n                let key=[n1,n2,nk].sort().join(\"|\");\n                if (!tcarreKeys.has(key) && !isAxisPair(n1, n2) && ![n1,n2,nk].every(n => CONF_ANGLES_SET.has(n))) {\n                    tcarreKeys.add(key);\n                    configurations.push({ type:\"T-Carré\", planets:[n1,n2,nk], description:`${n1} opposition ${n2}, tous deux en carré à ${nk} (apex) — tension persistante, moteur de dépassement de soi` });\n                }\n            }\n        }\n    }\n}\n\n// Grand Carré : 4 planètes en carré/opposition mutuels\nlet grandcarreKeys = new Set();\nfor (let i=0; i<confPlanets.length; i++) for (let j=i+1; j<confPlanets.length; j++) for (let k=j+1; k<confPlanets.length; k++) for (let l=k+1; l<confPlanets.length; l++) {\n    let ps=[confPlanets[i],confPlanets[j],confPlanets[k],confPlanets[l]];\n    let sorted=[...ps].sort((a,b)=>a.fullDegree-b.fullDegree);\n    let d01=angularDiff(sorted[0].fullDegree,sorted[1].fullDegree);\n    let d12=angularDiff(sorted[1].fullDegree,sorted[2].fullDegree);\n    let d23=angularDiff(sorted[2].fullDegree,sorted[3].fullDegree);\n    let d30=angularDiff(sorted[3].fullDegree,sorted[0].fullDegree);\n    if ([d01,d12,d23,d30].every(d=>Math.abs(d-90)<=10)) {\n        let names=ps.map(p=>p.planet.fr); let key=names.slice().sort().join(\"|\");\n        if (!grandcarreKeys.has(key) && names.filter(n => CONF_ANGLES_SET.has(n)).length < 3) {\n            grandcarreKeys.add(key);\n            configurations.push({ type:\"Grand Carré\", planets:names, description:`${names.join(\", \")} : tension quadrilatérale maximale, défi de vie structurant et formateur` });\n        }\n    }\n}\n\n// Yod : 2 planètes en sextile, toutes deux en quinconce à un apex\nlet yodKeys = new Set();\nfor (let i=0; i<confPlanets.length; i++) {\n    for (let j=i+1; j<confPlanets.length; j++) {\n        if (Math.abs(angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree)-60)>6) continue;\n        for (let k=0; k<confPlanets.length; k++) {\n            if (k===i||k===j) continue;\n            let dik=angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree);\n            let djk=angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree);\n            if (Math.abs(dik-150)<=3 && Math.abs(djk-150)<=3) {\n                let n1=confPlanets[i].planet.fr, n2=confPlanets[j].planet.fr, nk=confPlanets[k].planet.fr;\n                let key=[n1,n2,nk].sort().join(\"|\");\n                if (!yodKeys.has(key)) {\n                    yodKeys.add(key);\n                    configurations.push({ type:\"Yod — Doigt de Dieu\", planets:[n1,n2,nk], description:`${n1} sextile ${n2}, tous deux en quinconce à ${nk} (apex) — mission de vie, ajustement karmique obligatoire` });\n                }\n            }\n        }\n    }\n}\n\n// Cerf-Volant (Kite) : Grand Trigone + opposition + 2 sextiles depuis un 4e point\nlet kiteKeys = new Set();\ngrandTrigoneSets.forEach(([n1,n2,n3]) => {\n    confPlanets.forEach(p => {\n        let pk=p.planet.fr; if ([n1,n2,n3].includes(pk)) return;\n        let triPs = [n1,n2,n3].map(tn => confPlanets.find(x=>(x.planet.fr||x.planet.en)===tn)).filter(Boolean);\n        let oppIdx = triPs.findIndex(tp => Math.abs(angularDiff(p.fullDegree,tp.fullDegree)-180)<=8);\n        if (oppIdx === -1) return;\n        let sextileCount = triPs.filter((tp,idx) => idx!==oppIdx && Math.abs(angularDiff(p.fullDegree,tp.fullDegree)-60)<=6).length;\n        if (sextileCount >= 2) {\n            let key=[n1,n2,n3,pk].sort().join(\"|\");\n            if (!kiteKeys.has(key)) {\n                kiteKeys.add(key);\n                configurations.push({ type:\"Cerf-Volant (Kite)\", planets:[n1,n2,n3,pk], description:`Grand Trigone ${n1}-${n2}-${n3} avec ${pk} en opposition à ${triPs[oppIdx].planet.fr} — talent exceptionnel canalisé, potentiel actionnable` });\n            }\n        }\n    });\n});\n\n// 6e-bis. CROIX MODALE (Cardinale / Fixe / Mutable)\n// 4+ planètes dans les 4 signes d'un même mode, reliées par des oppositions et carrés\nconst MODE_SIGNS = {\n    \"Cardinal\": [\"Bélier\",\"Cancer\",\"Balance\",\"Capricorne\"],\n    \"Fixe\":     [\"Taureau\",\"Lion\",\"Scorpion\",\"Verseau\"],\n    \"Mutable\":  [\"Gémeaux\",\"Vierge\",\"Sagittaire\",\"Poissons\"]\n};\nconst crossKeys = new Set();\nObject.entries(MODE_SIGNS).forEach(([modeName, mSigns]) => {\n    const inMode = confPlanets.filter(p => mSigns.includes(p.zodiac_sign?.name?.fr));\n    if (inMode.length < 4) return;\n    const signsCovered = new Set(inMode.map(p => p.zodiac_sign?.name?.fr));\n    if (signsCovered.size < 3) return;\n    const names = inMode.map(p => p.planet.fr);\n    let hasOpp = false, hasSq = false;\n    for (let i = 0; i < inMode.length && (!hasOpp || !hasSq); i++) {\n        for (let j = i+1; j < inMode.length; j++) {\n            let diff = Math.abs(inMode[i].fullDegree - inMode[j].fullDegree);\n            if (diff > 180) diff = 360 - diff;\n            if (Math.abs(diff - 180) <= 10) hasOpp = true;\n            if (Math.abs(diff - 90) <= 8) hasSq = true;\n        }\n    }\n    if (hasOpp && hasSq) {\n        const key = names.slice().sort().join(\"|\");\n        if (!crossKeys.has(key)) {\n            crossKeys.add(key);\n            const modeDesc = modeName === \"Cardinal\" ? \"action, initiative, crise\" : modeName === \"Fixe\" ? \"persévérance, résistance au changement, endurance\" : \"adaptabilité, dispersion, versatilité\";\n            configurations.push({ type:`Croix ${modeName}`, planets:names, description:`${names.join(\", \")} : axe ${modeName} activé (${modeDesc}) — dynamique de tension structurante sur le mode ${modeName}` });\n        }\n    }\n});\n\n// 6e-ter. RECTANGLE MYSTIQUE : 2 oppositions reliées par 2 sextiles et 2 trigones\nlet rectMystiqueKeys = new Set();\nfor (let i=0; i<confPlanets.length; i++) {\n    for (let j=i+1; j<confPlanets.length; j++) {\n        if (Math.abs(angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree)-180)>10) continue;\n        for (let k=0; k<confPlanets.length; k++) {\n            if (k===i||k===j) continue;\n            for (let l=k+1; l<confPlanets.length; l++) {\n                if (l===i||l===j) continue;\n                if (Math.abs(angularDiff(confPlanets[k].fullDegree,confPlanets[l].fullDegree)-180)>10) continue;\n                const ds = [\n                    angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree),\n                    angularDiff(confPlanets[i].fullDegree,confPlanets[l].fullDegree),\n                    angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree),\n                    angularDiff(confPlanets[j].fullDegree,confPlanets[l].fullDegree)\n                ];\n                const sextiles = ds.filter(d => Math.abs(d-60)<=6).length;\n                const trigones = ds.filter(d => Math.abs(d-120)<=8).length;\n                if (sextiles >= 2 && trigones >= 2) {\n                    const names = [confPlanets[i],confPlanets[j],confPlanets[k],confPlanets[l]].map(p=>p.planet.fr);\n                    const key = names.slice().sort().join(\"|\");\n                    if (!rectMystiqueKeys.has(key)) {\n                        rectMystiqueKeys.add(key);\n                        configurations.push({ type:\"Rectangle Mystique\", planets:names, description:`${names.join(\", \")} : double opposition harmonisée par sextiles et trigones — talent de médiation, capacité à résoudre les paradoxes` });\n                    }\n                }\n            }\n        }\n    }\n}\n\n// 6e-quater. GRAND SEXTILE (Étoile de David) : 6 planètes à ~60° l'une de l'autre\nlet grandSextileKeys = new Set();\nif (confPlanets.length >= 6) {\n    for (let i=0; i<confPlanets.length; i++) {\n        const candidates = [confPlanets[i]];\n        let lastDeg = confPlanets[i].fullDegree;\n        const sorted = confPlanets.filter((_,idx)=>idx!==i).sort((a,b) => {\n            const da = ((a.fullDegree - lastDeg + 360) % 360);\n            const db = ((b.fullDegree - lastDeg + 360) % 360);\n            return da - db;\n        });\n        for (const p of sorted) {\n            const dFromLast = angularDiff(candidates[candidates.length-1].fullDegree, p.fullDegree);\n            if (Math.abs(dFromLast - 60) <= 6) candidates.push(p);\n            if (candidates.length === 6) break;\n        }\n        if (candidates.length === 6) {\n            const dClose = angularDiff(candidates[5].fullDegree, candidates[0].fullDegree);\n            if (Math.abs(dClose - 60) <= 6) {\n                const names = candidates.map(p => p.planet.fr);\n                const key = names.slice().sort().join(\"|\");\n                if (!grandSextileKeys.has(key)) {\n                    grandSextileKeys.add(key);\n                    configurations.push({ type:\"Grand Sextile (Étoile de David)\", planets:names, description:`${names.join(\", \")} : hexagramme parfait — flux d'énergie circulaire, potentiel exceptionnel et multifacette (configuration extrêmement rare)` });\n                }\n            }\n        }\n    }\n}\n\n// 6e-sext. FORME DU THÈME (Jones Patterns)\nconst computeChartShape = () => {\n    const core10 = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\n    const pDegs = core10.map(n => ({ name: n, deg: planetes.find(p => p.planet.fr === n)?.fullDegree })).filter(pd => pd.deg !== undefined).sort((a,b) => a.deg - b.deg);\n    const n = pDegs.length;\n    if (n < 7) return { shape: \"Indéterminé\", description: \"Pas assez de planètes pour classifier\" };\n    const gaps = [];\n    for (let i = 0; i < n; i++) {\n        gaps.push(((pDegs[(i+1) % n].deg - pDegs[i].deg) + 360) % 360);\n    }\n    const maxGap = Math.max(...gaps);\n    const maxGapIdx = gaps.indexOf(maxGap);\n    const minGap = Math.min(...gaps);\n    const spread = 360 - maxGap;\n\n    const findSingleton = () => {\n        const sorted = gaps.map((g,i) => ({g,i})).sort((a,b) => b.g - a.g);\n        const g1i = sorted[0].i, g2i = sorted[1].i;\n        let setA = [], setB = [];\n        let idx = (g1i + 1) % n;\n        while (idx !== (g2i + 1) % n) { setA.push(pDegs[idx].name); idx = (idx + 1) % n; }\n        idx = (g2i + 1) % n;\n        while (idx !== (g1i + 1) % n) { setB.push(pDegs[idx].name); idx = (idx + 1) % n; }\n        return setA.length <= setB.length ? setA : setB;\n    };\n\n    const findLeading = () => pDegs[(maxGapIdx + 1) % n].name;\n\n    if (spread <= 120) return { shape: \"Bundle (Paquet)\", description: \"Toutes les planètes concentrées dans 120° — spécialiste intensif, vision focalisée mais limitée\" };\n    if (spread <= 180) return { shape: \"Bowl (Bol)\", description: `Planètes dans 180° — une moitié du zodiaque est vide, orientation unilatérale et conscience d'un manque` };\n    if (spread > 180 && maxGap >= 60 && maxGap <= 120) {\n        const singleton = findSingleton();\n        const sName = singleton.join(\" et \");\n        return { shape: \"Bucket (Seau)\", description: `${sName} isolé${singleton.length > 1 ? \"s\" : \"\"} face au groupe — singleton qui focalise et canalise toute l'énergie`, singleton: sName };\n    }\n    if (maxGap <= 40 && minGap >= 15) return { shape: \"Splash (Éclaboussure)\", description: \"Planètes réparties dans tout le zodiaque — polyvalence, dispersion possible, touche-à-tout\" };\n    const largeGaps = gaps.filter(g => g >= 60);\n    if (largeGaps.length === 2 && largeGaps.every(g => g <= 120)) return { shape: \"Seesaw (Balançoire)\", description: \"Deux groupes de planètes opposés — dualité permanente, oscillation entre deux pôles de vie\" };\n    if (maxGap >= 60 && maxGap <= 90) {\n        const leading = findLeading();\n        return { shape: \"Locomotive\", description: `Grand vide de ${maxGap.toFixed(0)}° — élan puissant, ambition motrice. ${leading} en tête tire le train` };\n    }\n    if (spread > 250 && maxGap > 90) return { shape: \"Splay (Éventail)\", description: \"Distribution irrégulière avec accents marqués — individualiste, talents particuliers, résistance au conformisme\" };\n    return { shape: \"Splay (Éventail)\", description: \"Distribution irrégulière — profil individualiste et diversifié\" };\n};\nconst chartShape = computeChartShape();\n\n// 6f. ANTISCIA & CONTRA-ANTISCIA (miroir axe 0°Cancer/0°Capricorne)\n// antiscia_deg = (180 - fullDeg + 360) % 360\nconst ANTISCIA_ORB = 1.5;\nconst antisciaPlanets = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\nconst antiscia = [];\nfor (let i=0; i<antisciaPlanets.length; i++) {\n    for (let j=i+1; j<antisciaPlanets.length; j++) {\n        let pA=planetes.find(p=>p.planet.fr===antisciaPlanets[i]);\n        let pB=planetes.find(p=>p.planet.fr===antisciaPlanets[j]);\n        if (!pA||!pB) continue;\n        let antisciaDegA      = (180 - pA.fullDegree + 360) % 360;\n        let contraAntisciaDegA = (antisciaDegA + 180) % 360;\n        let diffA = angularDiff(antisciaDegA, pB.fullDegree);\n        let diffC = angularDiff(contraAntisciaDegA, pB.fullDegree);\n        if (diffA <= ANTISCIA_ORB) antiscia.push({ p1:antisciaPlanets[i], p2:antisciaPlanets[j], type:\"Antiscia\",        orb:diffA.toFixed(2) });\n        if (diffC <= ANTISCIA_ORB) antiscia.push({ p1:antisciaPlanets[i], p2:antisciaPlanets[j], type:\"Contra-antiscia\", orb:diffC.toFixed(2) });\n    }\n}\n\n// 6g. MIDPOINTS (10 planètes majeures) + détection des activateurs\nconst midpointPlanets = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\nconst midpoints = {};\nfor (let i=0; i<midpointPlanets.length; i++) {\n    for (let j=i+1; j<midpointPlanets.length; j++) {\n        let pA=planetes.find(p=>p.planet.fr===midpointPlanets[i]);\n        let pB=planetes.find(p=>p.planet.fr===midpointPlanets[j]);\n        if (!pA||!pB) continue;\n        let diff = pB.fullDegree - pA.fullDegree;\n        if (diff < 0) diff += 360;\n        if (diff > 180) diff -= 360;\n        let mp = ((pA.fullDegree + diff/2) % 360 + 360) % 360;\n        let mpFar = (mp + 180) % 360;\n        midpoints[`${midpointPlanets[i]}/${midpointPlanets[j]}`] = {\n            near: mp, far: mpFar,\n            sign: signs[Math.floor(mp/30)].fr, deg: (mp%30).toFixed(1)\n        };\n    }\n}\nconst midpointActivations = [];\nObject.entries(midpoints).forEach(([key, mp]) => {\n    let [mpP1, mpP2] = key.split(\"/\");\n    planetes.forEach(p => {\n        let name = p.planet.fr || p.planet.en;\n        if (name === mpP1 || name === mpP2) return;\n        if ([\"Part de Fortune\",\"Lot de l'Esprit\",\"Nœud Sud\",\"Lot de Nécessité\",\"Lot d'Éros\",\"Lot de Courage\",\"Lot de Némésis\",\"Lot de Basis\",\"Lot d'Exaltation\",\"Lot du Daemon\"].includes(name)) return;\n        let dNear = angularDiff(p.fullDegree, mp.near);\n        let dFar  = angularDiff(p.fullDegree, mp.far);\n        let best  = Math.min(dNear, dFar);\n        if (best <= 1.5) {\n            midpointActivations.push({ activator:name, midpoint:key, type:dNear<=dFar?\"direct\":\"miroir\", orb:best.toFixed(2) });\n        }\n    });\n});\n\n// 6h. ÉTOILES FIXES — Conjonctions avec les planètes natales\n// Orbes différenciés :\n//   ±2° — étoiles royales/majeures : Aldébaran, Sirius, Régulus, Spica, Antarès\n//   ±1° — autres étoiles : Algol, Pléiades, Véga, Fomalhaut\nconst ETOILE_ORBS = {\n    \"Aldébaran\": 2.0, \"Sirius\": 2.0, \"Régulus\": 2.0, \"Spica\": 2.0, \"Antarès\": 2.0,\n    \"Algol\": 1.0, \"Pléiades\": 1.0, \"Véga\": 1.0, \"Fomalhaut\": 1.0,\n    \"Rigel\": 1.5, \"Bételgeuse\": 1.5, \"Castor\": 1.0, \"Pollux\": 1.5,\n    \"Procyon\": 1.5, \"Canopus\": 1.5, \"Arcturus\": 1.5, \"Deneb Algedi\": 1.0,\n    \"Vindemiatrix\": 1.0, \"Scheat\": 1.0, \"Zubenelgenubi\": 1.0,\n    \"Zubeneschamali\": 1.0, \"Achernar\": 1.0, \"Deneb\": 1.0,\n    \"Wega\": 1.0, \"Alcyone\": 1.0\n};\nconst ETOILE_DESC = {\n    \"Algol\":     \"Étoile de la Méduse (nature Saturne/Mars) : violence, catastrophe, perte irréversible — mais aussi courage absolu face au danger extrême, capacité à transformer la destruction en renaissance\",\n    \"Pléiades\":  \"Cluster des Pléiades / Alcyone (nature Lune/Mars) : deuil, larmes, mystère, liens ancestraux et spiritualité profonde — sensibilité exacerbée aux cycles et à la mémoire collective\",\n    \"Alcyone\":   \"Cluster des Pléiades / Alcyone (nature Lune/Mars) : deuil, larmes, mystère, liens ancestraux et spiritualité profonde — sensibilité exacerbée aux cycles et à la mémoire collective\",\n    \"Aldébaran\": \"Étoile Royale de l'Est — Œil du Taureau (nature Mars/Mercure) : honneur, intégrité, intelligence vive, vigilance stratégique. L'une des 4 Royales : succès durable si l'intégrité est maintenue\",\n    \"Sirius\":    \"Étoile du Grand Chien (nature Jupiter/Mars) : gloire, richesse, fidélité ardente, passion dévorante — nature solaire intense conférant rayonnement et leadership magnétique\",\n    \"Régulus\":   \"Étoile Royale du Cœur du Lion (nature Mars/Jupiter) : royauté, leadership naturel, succès fulgurant, ambition. L'une des 4 Royales : grandeur et chute si la vengeance supplante la noblesse\",\n    \"Spica\":     \"Épi de la Vierge (nature Vénus/Mars) : don artistique, chance remarquable, raffinement intellectuel, richesse créative — l'une des étoiles les plus bénéfiques du zodiaque\",\n    \"Antarès\":   \"Étoile Royale du Cœur du Scorpion (nature Mars/Jupiter) : courage, témérité, passion dévorante, succès militaire ou compétitif. L'une des 4 Royales : rival de Mars, intensité maximale\",\n    \"Véga\":      \"Étoile de la Lyre (nature Vénus/Mercure) : charisme magnétique irrésistible, dons artistiques et musicaux exceptionnels, raffinement spirituel et sens du beau transcendant\",\n    \"Wega\":      \"Étoile de la Lyre (nature Vénus/Mercure) : charisme magnétique irrésistible, dons artistiques et musicaux exceptionnels, raffinement spirituel et sens du beau transcendant\",\n    \"Fomalhaut\": \"Étoile Royale du Sud (nature Vénus/Mercure) : idéalisme visionnaire, rêve créateur, inspiration mystique, sens du sacré. L'une des 4 Royales : grandeur par la vision hors du commun\",\n    \"Rigel\":     \"Pied d'Orion (nature Jupiter/Saturne) : ambition intellectuelle, enseignement, capacité de construction à grande échelle — fortune par l'effort persistant et la vision à long terme\",\n    \"Bételgeuse\":\"Épaule d'Orion (nature Mars/Mercure) : honneur martial, audace créatrice, succès par l'action directe — énergie colossale mais risque de blessures ou de renversements soudains\",\n    \"Castor\":    \"Alpha Gémeaux (nature Mercure) : brillance intellectuelle, écriture, communication — mais vulnérabilité aux blessures ou violence, dualité créative entre lumière et ombre\",\n    \"Pollux\":    \"Beta Gémeaux (nature Mars) : force sportive, audace, compétitivité — caractère intrépide mais risque de cruauté ou de témérité excessive\",\n    \"Procyon\":   \"Étoile du Petit Chien (nature Mercure/Mars) : activité fébrile, succès rapide mais instable — intelligence vive et capacité d'adaptation, mais attention à la dispersion\",\n    \"Canopus\":   \"Étoile du Navire Argo (nature Saturne/Jupiter) : voyage, navigation de la vie, connaissance ancienne — l'une des plus lumineuses : érudition et sagesse acquise par l'expérience lointaine\",\n    \"Arcturus\":  \"Gardien de l'Ourse (nature Mars/Jupiter) : prospérité par le voyage ou l'innovation, leadership par la voie non conventionnelle — force de caractère et indépendance d'esprit\",\n    \"Deneb Algedi\":\"Queue du Capricorne (nature Saturne/Jupiter) : justice, probité, sens de la loi — réussite par la droiture et la persévérance, mais risque de rigidité morale\",\n    \"Vindemiatrix\":\"La Vendangeuse (nature Saturne/Mercure) : veuvage symbolique, perte, sacrifice nécessaire — mais aussi discernement tranchant et capacité de détachement libérateur\",\n    \"Scheat\":    \"Épaule de Pégase (nature Mars/Mercure) : naufrage, catastrophe maritime (symbolique), extrême sensibilité — mais imagination sans limites et capacité à transcender le réel\",\n    \"Zubenelgenubi\":\"Plateau Sud de la Balance (nature Saturne/Mars) : justice implacable, karma, conséquences inévitables — poids du passé mais capacité de rééquilibrage par l'action juste\",\n    \"Zubeneschamali\":\"Plateau Nord de la Balance (nature Jupiter/Mercure) : fortune sociale, intelligence diplomatique, élévation par le mérite et la finesse relationnelle\",\n    \"Achernar\":  \"Fin du Fleuve Éridan (nature Jupiter) : bonheur spirituel, succès ecclésiastique ou philosophique, sens du sacré — transformation profonde par l'immersion dans le courant de la vie\",\n    \"Deneb\":     \"Queue du Cygne (nature Vénus/Mercure) : don artistique ingénieux, capacité de synthèse entre technique et esthétique — intelligence subtile et charme magnétique\"\n};\n\n// Construire la liste complète des points à vérifier :\n// planètes de naissance + DSC et IC s'ils ne sont pas déjà fournis par l'API\nconst pointsEtoiles = [...planetes];\nconst ANGLES_LABELS = { \"Ascendant\":\"ASC (Cuspide M1)\", \"Milieu du Ciel\":\"MC (Cuspide M10)\", \"Descendant\":\"DSC (Cuspide M7)\", \"Imum Coeli\":\"IC (Cuspide M4)\" };\nif (!pointsEtoiles.find(p => p.planet.fr === \"Descendant\" || p.planet.en === \"Descendant\")) {\n    const m7 = maisons.find(m => m.House === 7);\n    if (m7) pointsEtoiles.push({ planet:{fr:\"Descendant\",en:\"Descendant\"}, fullDegree:m7.degree, normDegree:m7.degree%30, zodiac_sign:{name:{fr:signs[Math.floor(m7.degree/30)%12].fr}} });\n}\nif (!pointsEtoiles.find(p => p.planet.fr === \"Imum Coeli\" || p.planet.en === \"Imum Coeli\")) {\n    const m4 = maisons.find(m => m.House === 4);\n    if (m4) pointsEtoiles.push({ planet:{fr:\"Imum Coeli\",en:\"Imum Coeli\"}, fullDegree:m4.degree, normDegree:m4.degree%30, zodiac_sign:{name:{fr:signs[Math.floor(m4.degree/30)%12].fr}} });\n}\n\nconst LOTS_MATHEMATIQUES = new Set([\"Part de Fortune\",\"Lot de l'Esprit\",\"Lot de Nécessité\",\"Lot d'Éros\",\"Lot de Courage\",\"Lot de Némésis\",\"Lot de Basis\",\"Lot d'Exaltation\",\"Lot du Daemon\",\"Lot de Victoire\",\"Lot du Père\",\"Lot de la Mère\",\"Lot de Maladie\",\"Lot du Mariage\",\"Lot des Enfants\",\"Lot de Voyage\"]);\nconst etoileMatches = [];\npointsEtoiles.forEach(planet => {\n    const pName = planet.planet.fr || planet.planet.en;\n    if (LOTS_MATHEMATIQUES.has(pName)) return;\n    etoilesFixesRaw.forEach(etoile => {\n        const eName = etoile.name?.fr;\n        if (!eName) return;\n        const orbMax = ETOILE_ORBS[eName] ?? 1.0;\n        const diff = angularDiff(planet.fullDegree, etoile.fullDegree);\n        if (diff <= orbMax) {\n            const house = getHouseNumber(planet.fullDegree);\n            etoileMatches.push({\n                planete:   pName,\n                etoile:    eName,\n                etoile_en: etoile.name?.en || eName,\n                orb:       Math.round(diff * 100) / 100,\n                orbMax,\n                precision: diff <= 1.0 ? \"forte (≤1°)\" : \"notable (≤2°)\",\n                maison:    house,\n                signe:     planet.zodiac_sign?.name?.fr,\n                isAngle:   !!ANGLES_LABELS[pName],\n                desc:      ETOILE_DESC[eName] || \"\"\n            });\n        }\n    });\n});\n\n// Conjonctions étoiles fixes sur les 4 angles (M1 ASC / M4 IC / M7 DSC / M10 MC)\nconst ANGULAR_HOUSES = new Set([1, 4, 7, 10]);\nconst ANGLE_LABELS   = { 1:\"ASC\", 4:\"IC\", 7:\"DSC\", 10:\"MC\" };\nconst etoileCuspMatches = [];\nmaisons.filter(m => ANGULAR_HOUSES.has(m.House)).forEach(m => {\n    etoilesFixesRaw.forEach(etoile => {\n        const eName = etoile.name?.fr;\n        if (!eName) return;\n        const orbMax = ETOILE_ORBS[eName] ?? 1.0;\n        const diff = angularDiff(m.degree, etoile.fullDegree);\n        if (diff <= orbMax) {\n            const cuspSign = signs[Math.floor(m.degree / 30) % 12].fr;\n            etoileCuspMatches.push({\n                maison:    m.House,\n                angle:     ANGLE_LABELS[m.House],\n                etoile:    eName,\n                etoile_en: etoile.name?.en || eName,\n                orb:       Math.round(diff * 100) / 100,\n                orbMax,\n                precision: diff <= 1.0 ? \"forte (≤1°)\" : \"notable (≤2°)\",\n                signe:     cuspSign,\n                desc:      ETOILE_DESC[eName] || \"\"\n            });\n        }\n    });\n});\n\n// ─────────────────────────────────────────────────────────────────\n// 6h-bis. PARANS D'ÉTOILES FIXES (méthode Brady — co-angularité)\n// Un paran se forme quand une étoile est sur un angle (lever/coucher/culmination)\n// au même moment qu'une planète est sur un angle, évalué par le RAMC commun.\n// ─────────────────────────────────────────────────────────────────\nconst PARAN_ORB = 1.5;\nconst OBLIQUITY = 23.4393;\nconst DEG = Math.PI / 180;\n\nconst geoLat = parseFloat(perso.latitude) || 0;\nconst paranResults = [];\n\nif (Math.abs(geoLat) > 0.1) {\n    const tanPhi = Math.tan(geoLat * DEG);\n\n    function hourAngle(dec) {\n        const tanDec = Math.tan(dec * DEG);\n        const cosH = -tanPhi * tanDec;\n        if (cosH < -1 || cosH > 1) return null;\n        return Math.acos(cosH) / DEG;\n    }\n\n    function bodyAngles(ra, dec) {\n        const H = hourAngle(dec);\n        const angles = [];\n        angles.push({ type: \"Culmination\", ramc: ((ra % 360) + 360) % 360 });\n        angles.push({ type: \"Anti-culmination\", ramc: ((ra + 180) % 360 + 360) % 360 });\n        if (H !== null) {\n            angles.push({ type: \"Lever\", ramc: ((ra - H) % 360 + 360) % 360 });\n            angles.push({ type: \"Coucher\", ramc: ((ra + H) % 360 + 360) % 360 });\n        }\n        return angles;\n    }\n\n    function eclToEq(lon, lat) {\n        const L = lon * DEG, B = (lat || 0) * DEG, E = OBLIQUITY * DEG;\n        const ra = Math.atan2(Math.sin(L) * Math.cos(E) - Math.tan(B) * Math.sin(E), Math.cos(L));\n        const dec = Math.asin(Math.sin(B) * Math.cos(E) + Math.cos(B) * Math.sin(E) * Math.sin(L));\n        return { ra: ((ra / DEG) % 360 + 360) % 360, dec: dec / DEG };\n    }\n\n    const PARAN_PLANETS = new Set([\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\",\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"]);\n\n    const planetAnglesMap = [];\n    pointsEtoiles.forEach(p => {\n        const pName = p.planet.fr || p.planet.en;\n        if (!PARAN_PLANETS.has(pName)) return;\n        if (LOTS_MATHEMATIQUES.has(pName)) return;\n        let pRa, pDec;\n        if (typeof p.declinaison === \"number\") {\n            pDec = p.declinaison;\n            const lonR = p.fullDegree * DEG, E = OBLIQUITY * DEG;\n            const sinBeta = (Math.sin(pDec * DEG) - Math.sin(E) * Math.sin(lonR)) / Math.cos(E);\n            const beta = Math.abs(sinBeta) <= 1 ? Math.asin(sinBeta) : 0;\n            const raRad = Math.atan2(Math.sin(lonR) * Math.cos(E) - Math.tan(beta) * Math.sin(E), Math.cos(lonR));\n            pRa = ((raRad / DEG) + 360) % 360;\n        } else {\n            const eq = eclToEq(p.fullDegree, 0);\n            pRa = eq.ra;\n            pDec = eq.dec;\n        }\n        const angles = bodyAngles(pRa, pDec);\n        planetAnglesMap.push({ name: pName, ra: pRa, dec: pDec, angles });\n    });\n\n    const PARAN_LABELS = {\n        \"Culmination-Culmination\": \"co-culmination (les deux au MC)\",\n        \"Culmination-Lever\": \"étoile culmine quand la planète se lève\",\n        \"Lever-Lever\": \"co-lever (les deux à l'horizon Est)\",\n        \"Lever-Culmination\": \"planète se lève quand l'étoile culmine\",\n        \"Coucher-Coucher\": \"co-coucher (les deux à l'horizon Ouest)\",\n        \"Culmination-Coucher\": \"étoile culmine quand la planète se couche\",\n        \"Coucher-Culmination\": \"planète se couche quand l'étoile culmine\",\n        \"Lever-Coucher\": \"étoile se lève quand la planète se couche\",\n        \"Coucher-Lever\": \"étoile se couche quand la planète se lève\",\n    };\n\n    etoilesFixesRaw.forEach(star => {\n        const sName = star.name?.fr;\n        if (!sName) return;\n        const sDec = star.declination_j2000;\n        const sRa = star.ra_j2000;\n        if (sDec == null || sRa == null) return;\n        const starAngles = bodyAngles(sRa, sDec);\n\n        planetAnglesMap.forEach(pEntry => {\n            pEntry.angles.forEach(pAngle => {\n                starAngles.forEach(sAngle => {\n                    let diff = Math.abs(pAngle.ramc - sAngle.ramc);\n                    if (diff > 180) diff = 360 - diff;\n                    if (diff <= PARAN_ORB) {\n                        const comboKey = `${sAngle.type}-${pAngle.type}`;\n                        paranResults.push({\n                            planete: pEntry.name,\n                            etoile: sName,\n                            etoile_desc: ETOILE_DESC[sName] || \"\",\n                            angle_etoile: sAngle.type,\n                            angle_planete: pAngle.type,\n                            orb: Math.round(diff * 100) / 100,\n                            interpretation: PARAN_LABELS[comboKey] || `${sAngle.type} de l'étoile / ${pAngle.type} de la planète`,\n                            maison: getHouseNumber(etoilesFixesRaw.find(e => e.name?.fr === sName)?.fullDegree ?? 0),\n                            signe_planete: planetes.find(x => (x.planet?.fr || x.planet?.en) === pEntry.name)?.zodiac_sign?.name?.fr || \"\"\n                        });\n                    }\n                });\n            });\n        });\n    });\n}\n\n// ─────────────────────────────────────────────────────────────────\n// 6i. DÉCLINAISONS — Hors Limites (OOB), Parallèles, Contre-Parallèles\n// ─────────────────────────────────────────────────────────────────\nconst OOB_THRESHOLD      = OBLIQUITY;\nconst DECL_ORB_STANDARD  = 1.0;\nconst DECL_ORB_LUMINAIRE = 1.5;\nconst LUMINAIRES_DECL    = new Set([\"Soleil\", \"Lune\"]);\n\n// Tous les objets ayant un champ declinaison numérique (planètes, Chiron, petits corps, nœuds…)\nconst planetesDeclinees = planetes.filter(p => typeof p.declinaison === 'number');\n\n// A. Planètes / Objets Hors Limites (OOB)\nconst planeteOOB = [];\nplanetesDeclinees.forEach(p => {\n    const name = p.planet.fr || p.planet.en;\n    if (Math.abs(p.declinaison) > OOB_THRESHOLD) {\n        planeteOOB.push({\n            planete:     name,\n            declinaison: p.declinaison,\n            hemisphere:  p.declinaison > 0 ? \"Nord\" : \"Sud\",\n            depassement: parseFloat((Math.abs(p.declinaison) - OOB_THRESHOLD).toFixed(2))\n        });\n    }\n});\n\n// B. Parallèles (//) et Contre-Parallèles (#)\nconst paralleles       = [];\nconst contreParalleles = [];\nfor (let i = 0; i < planetesDeclinees.length; i++) {\n    for (let j = i + 1; j < planetesDeclinees.length; j++) {\n        const pA = planetesDeclinees[i], pB = planetesDeclinees[j];\n        const nameA = pA.planet.fr || pA.planet.en;\n        const nameB = pB.planet.fr || pB.planet.en;\n        const hasLuminaire = LUMINAIRES_DECL.has(nameA) || LUMINAIRES_DECL.has(nameB);\n        const orb = hasLuminaire ? DECL_ORB_LUMINAIRE : DECL_ORB_STANDARD;\n        const sameHemi = Math.sign(pA.declinaison) === Math.sign(pB.declinaison);\n        if (sameHemi) {\n            const diff = Math.abs(pA.declinaison - pB.declinaison);\n            if (diff <= orb) paralleles.push({\n                p1: nameA, decl1: pA.declinaison,\n                p2: nameB, decl2: pB.declinaison,\n                orb: parseFloat(diff.toFixed(2)), hasLuminaire,\n                hemisphere: pA.declinaison > 0 ? \"Nord\" : \"Sud\"\n            });\n        } else {\n            const diff = Math.abs(Math.abs(pA.declinaison) - Math.abs(pB.declinaison));\n            if (diff <= orb) contreParalleles.push({\n                p1: nameA, decl1: pA.declinaison,\n                p2: nameB, decl2: pB.declinaison,\n                orb: parseFloat(diff.toFixed(2)), hasLuminaire\n            });\n        }\n    }\n}\n\n// ─────────────────────────────────────────────────────────────────\n// 6j. SCORE DE PUISSANCE DES CONFIGURATIONS (tri multi-critères)\n// ─────────────────────────────────────────────────────────────────\nconst OOB_NAMES_SET         = new Set(planeteOOB.map(p => p.planete));\nconst ETOILE_CONJ_NAMES_SET = new Set(etoileMatches.map(em => em.planete));\nconst PARA_PAIRS_SET        = new Set([\n    ...paralleles.map(p => [p.p1, p.p2].sort().join(\"|\")),\n    ...contreParalleles.map(p => [p.p1, p.p2].sort().join(\"|\"))\n]);\nconst ANGLES_POWER_SET = new Set([\"Ascendant\", \"Milieu du Ciel\", \"Descendant\", \"Imum Coeli\"]);\nconst HIERARCHY_BASE_SCORE = {\n    \"Stellium\": 30, \"Grand Carré\": 30, \"Grand Trigone\": 30,\n    \"T-Carré\": 20, \"Cerf-Volant (Kite)\": 20, \"Yod — Doigt de Dieu\": 20,\n    \"Croix Cardinal\": 25, \"Croix Fixe\": 25, \"Croix Mutable\": 25\n};\n\nconfigurations.forEach(c => {\n    let score = HIERARCHY_BASE_SCORE[c.type] || 10;\n    const pList = c.planets || [];\n    // Facteur Luminaires\n    if (pList.some(p => LUMINAIRES_DECL.has(p)))        score += 50;\n    // Facteur Angles\n    if (pList.some(p => ANGLES_POWER_SET.has(p)))       score += 40;\n    // Facteur Étoile Fixe conjointe\n    if (pList.some(p => ETOILE_CONJ_NAMES_SET.has(p)))  score += 30;\n    // Facteur OOB\n    if (pList.some(p => OOB_NAMES_SET.has(p)))          score += 20;\n    // Facteur Parallèle/Contre-Parallèle (double validation — max +20 par figure)\n    let paraBonus = false;\n    for (let i = 0; i < pList.length && !paraBonus; i++)\n        for (let j = i + 1; j < pList.length && !paraBonus; j++)\n            if (PARA_PAIRS_SET.has([pList[i], pList[j]].sort().join(\"|\"))) paraBonus = true;\n    if (paraBonus) score += 20;\n    // Facteur d'exactitude : orbe moyen des aspects internes à la figure\n    const figAspects = aspects.filter(a => pList.includes(a.p1) && pList.includes(a.p2));\n    if (figAspects.length > 0) {\n        const orbeMoyen = figAspects.reduce((s, a) => s + parseFloat(a.exactitude), 0) / figAspects.length;\n        score += Math.max(0, Math.round(10 - orbeMoyen * 2));\n    }\n    c.puissanceScore = score;\n    c.prioriteLabel  = score >= 120 ? \"PRIORITÉ ABSOLUE\" : score >= 80 ? \"Majeure\" : score >= 50 ? \"Significative\" : \"Mineure\";\n});\n// Tri par score décroissant — les figures les plus puissantes en premier\nconfigurations.sort((a, b) => (b.puissanceScore || 0) - (a.puissanceScore || 0));\n\n// ─────────────────────────────────────────────────────────────────\n// 6j-bis. DÉDUPLICATION POST-CALCUL (marquage non-destructif)\n// Identifie les sous-configurations géométriquement contenues dans une figure parente.\n// Règles : Grand Carré ⊃ T-Carré | Cerf-Volant ⊃ Grand Trigone\n// N'affecte ni les scores, ni les aspects, ni le calcul — post-processing uniquement.\n// ─────────────────────────────────────────────────────────────────\nconst PARENT_CHILD_RULES = [\n    { parent: \"Grand Carré\",       child: \"T-Carré\" },\n    { parent: \"Cerf-Volant (Kite)\", child: \"Grand Trigone\" }\n];\n// Passe 1 : relations hiérarchiques (T-Carré ⊂ Grand Carré, Grand Trigone ⊂ Cerf-Volant)\nconfigurations.forEach(child => {\n    if (child.subConfigOf) return;\n    configurations.forEach(parent => {\n        if (child === parent || !parent.planets || !child.planets) return;\n        if (!child.planets.every(p => parent.planets.includes(p))) return;\n        const rule = PARENT_CHILD_RULES.find(r => r.parent === parent.type && r.child === child.type);\n        if (rule) { child.subConfigOf = parent.type; child.subConfigType = \"child\"; }\n    });\n});\n\n// Passe 2 : variantes du même type (ex: deux Grand Carrés partageant 3 planètes sur 4)\n// Règles de seuil par type :\n//   Stellium  → threshold = min (sous-ensemble strict : toutes les planètes du plus petit dans le plus grand)\n//   Autres    → threshold = min - 1 (N-1 planètes communes suffisent)\n// Pour Stellium : on garde le PLUS GRAND (plus de planètes). Pour les autres : le mieux scoré.\nconst OVERLAP_TYPES = new Set([\"Stellium\", \"Grand Carré\", \"T-Carré\", \"Grand Trigone\", \"Yod\", \"Cerf-Volant (Kite)\"]);\nconst confByType = {};\nconfigurations.forEach(c => {\n    if (!OVERLAP_TYPES.has(c.type) || c.subConfigOf) return;\n    (confByType[c.type] = confByType[c.type] || []).push(c);\n});\nObject.values(confByType).forEach(group => {\n    if (group.length < 2) return;\n    for (let i = 0; i < group.length; i++) {\n        for (let j = i + 1; j < group.length; j++) {\n            const a = group[i], b = group[j];\n            if (!a.planets || !b.planets || a.subConfigOf || b.subConfigOf) continue;\n            const shared = a.planets.filter(p => b.planets.includes(p));\n            const isStellium = a.type === \"Stellium\";\n            // Stellium : threshold = taille du plus petit (sous-ensemble complet requis)\n            // Autres   : threshold = min - 1\n            const threshold = isStellium\n                ? Math.min(a.planets.length, b.planets.length)\n                : Math.min(a.planets.length, b.planets.length) - 1;\n            if (shared.length >= threshold) {\n                let redundant;\n                if (isStellium) {\n                    // Garder le plus grand Stellium (plus de planètes = plus d'information)\n                    redundant = a.planets.length >= b.planets.length ? b : a;\n                } else {\n                    // Garder le mieux scoré\n                    [, redundant] = (a.puissanceScore || 0) >= (b.puissanceScore || 0) ? [a, b] : [b, a];\n                }\n                redundant.subConfigOf = a.type;\n                redundant.subConfigType = \"variant\";\n                redundant.sharedPlanets = shared.length;\n            }\n        }\n    }\n});\n\n// ─────────────────────────────────────────────────────────────────\n// 6k. SCORE DE PUISSANCE DES ASPECTS INDIVIDUELS (post-enrichissement)\n// Calculé ici (après 6b, 6h, 6i) pour avoir accès à tous les contextes :\n// angularPlanets, etoileMatches, OOB_NAMES_SET, LUMINAIRES_DECL\n// v4.0.0 : modulations rétrogradation, stationnaire, dignité, réception\n// ─────────────────────────────────────────────────────────────────\nconst ASPECT_BASE_SCORES = {\n    \"Conjonction\": 10, \"Opposition\": 9, \"Carré\": 8, \"Trigone\": 7, \"Sextile\": 6,\n    \"Quinconce\": 3, \"Semi-Carré\": 2, \"Quintile\": 2, \"Sesqui-Carré\": 2,\n    \"Semi-Sextile\": 1, \"Biquintile\": 1\n};\nconst _stationarySet = new Set(stationaryPlanets.map(sp => sp.planet));\nconst _receptionPairsAsp = new Set(mutualReceptions.map(mr => [mr.p1, mr.p2].sort().join(\"|\")));\nconst _uniReceptionMap = {};\n[\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"].forEach(name => {\n    const p = planetes.find(x => x.planet.fr === name);\n    if (!p) return;\n    const sign = p.zodiac_sign?.name?.fr;\n    if (!sign) return;\n    Object.entries(dignities).forEach(([otherPlanet, digs]) => {\n        if (oth