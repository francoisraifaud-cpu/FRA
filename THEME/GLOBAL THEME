\"Pollux\",       name_en: \"Pollux\",       lon_j2000: 113.22,  ref_sign: \"Cancer\",       ref_deg: 23, ref_sign_idx: 3 , dec_j2000: 28.03, ra_j2000: 116.33 },\n  { name_fr: \"Procyon\",      name_en: \"Procyon\",      lon_j2000: 115.78,  ref_sign: \"Cancer\",       ref_deg: 26, ref_sign_idx: 3 , dec_j2000: 5.23, ra_j2000: 114.83 },\n  { name_fr: \"Arcturus\",     name_en: \"Arcturus\",     lon_j2000: 204.23,  ref_sign: \"Balance\",      ref_deg: 24, ref_sign_idx: 6 , dec_j2000: 19.18, ra_j2000: 213.92 },\n  { name_fr: \"Vindemiatrix\", name_en: \"Vindemiatrix\", lon_j2000: 189.95,  ref_sign: \"Balance\",      ref_deg: 10, ref_sign_idx: 6 , dec_j2000: 10.96, ra_j2000: 195.54 },\n  { name_fr: \"Zubenelgenubi\", name_en: \"Zubenelgenubi\", lon_j2000: 225.08,  ref_sign: \"Scorpion\",     ref_deg: 15, ref_sign_idx: 7 , dec_j2000: -16.04, ra_j2000: 222.68 },\n  { name_fr: \"Zubeneschamali\", name_en: \"Zubeneschamali\", lon_j2000: 229.37,  ref_sign: \"Scorpion\",     ref_deg: 19, ref_sign_idx: 7 , dec_j2000: -9.38, ra_j2000: 229.25 },\n  { name_fr: \"Deneb Algedi\", name_en: \"Deneb Algedi\", lon_j2000: 323.55,  ref_sign: \"Verseau\",      ref_deg: 24, ref_sign_idx: 10 , dec_j2000: -16.13, ra_j2000: 326.76 },\n  { name_fr: \"Scheat\",       name_en: \"Scheat\",       lon_j2000: 359.37,  ref_sign: \"Poissons\",     ref_deg: 29, ref_sign_idx: 11 , dec_j2000: 28.08, ra_j2000: 346.19 },\n  { name_fr: \"Achernar\",     name_en: \"Achernar\",     lon_j2000: 345.32,  ref_sign: \"Poissons\",     ref_deg: 15, ref_sign_idx: 11 , dec_j2000: -57.24, ra_j2000: 24.43 },\n  { name_fr: \"Deneb\",        name_en: \"Deneb\",        lon_j2000: 335.33,  ref_sign: \"Poissons\",     ref_deg: 5, ref_sign_idx: 11 , dec_j2000: 45.28, ra_j2000: 310.36 }\n];\n\nconst SIGNES_FR = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\nconst SIGNES_EN = [\"Aries\",\"Taurus\",\"Gemini\",\"Cancer\",\"Leo\",\"Virgo\",\"Libra\",\"Scorpio\",\"Sagittarius\",\"Capricorn\",\"Aquarius\",\"Pisces\"];\n\n// ── Parsing de la date ────────────────────────────────────────────────────\n// Compatible avec le format DD/MM/YYYY du nœud Extract Variables N8N\nfunction parseDate(s) {\n  s = (s || \"\").trim();\n  if (s.includes(\"/\")) {\n    const [d, m, y] = s.split(\"/\").map(Number);\n    return { year: y, month: m, day: d, hour: 12 };\n  } else if (s.includes(\"T\")) {\n    const [dp, tp] = s.split(\"T\");\n    const [y, m, d] = dp.split(\"-\").map(Number);\n    const parts = tp.split(\":\").map(Number);\n    return { year: y, month: m, day: d, hour: (parts[0]||0) + (parts[1]||0)/60 + (parts[2]||0)/3600 };\n  } else {\n    const [y, m, d] = s.split(\"-\").map(Number);\n    return { year: y, month: m, day: d, hour: 12 };\n  }\n}\n\n// ── Jour Julien (algorithme standard) ────────────────────────────────────\nfunction julianDay(year, month, day, hour) {\n  let y = year, mo = month;\n  if (mo <= 2) { y -= 1; mo += 12; }\n  const A = Math.floor(y / 100);\n  const B = 2 - A + Math.floor(A / 4);\n  return Math.floor(365.25 * (y + 4716)) + Math.floor(30.6001 * (mo + 1)) + day + (hour / 24) + B - 1524.5;\n}\n\n// ── Précession générale en longitude depuis J2000.0 ───────────────────────\n// Source : IAU 2006 — p = 50.2909\"/an × T + 0.000022\"/an² × T²\nfunction precessionDeg(jd) {\n  const T = (jd - 2451545.0) / 365.25;   // années depuis J2000.0\n  return (50.2909 * T + 0.000022 * T * T) / 3600.0;\n}\n\n// ── Longitude → signe + degré normalisé ──────────────────────────────────\nfunction lonToSign(lon) {\n  const l = ((lon % 360) + 360) % 360;\n  const idx = Math.floor(l / 30);\n  return {\n    fullDegree: Math.round(l * 10000) / 10000,\n    normDegree: Math.round((l - idx * 30) * 10000) / 10000,\n    sign_index: idx,\n    zodiac_sign: { number: idx + 1, name: { fr: SIGNES_FR[idx], en: SIGNES_EN[idx] } }\n  };\n}\n\n// ── Lecture de la date depuis le nœud Extract Variables ──────────────────\nlet dateStr;\ntry {\n  dateStr = $('Extract Variables').first().json.date;\n} catch (e) {\n  // Fallback si ce nœud est exécuté seul (test manuel)\n  dateStr = $input.first()?.json?.date || \"12/11/1987\";\n}\n\nconst dt  = parseDate(dateStr);\nconst jd  = julianDay(dt.year, dt.month, dt.day, dt.hour);\nconst prec = precessionDeg(jd);\n\n// ── Calcul des 23 étoiles ─────────────────────────────────────────────────\nconst output = ETOILES.map(e => {\n  const lon = ((e.lon_j2000 + prec) % 360 + 360) % 360;\n  const pos = lonToSign(lon);\n\n  // Écart par rapport à la position traditionnelle de référence\n  // Calcul sur fullDegree pour éviter les erreurs aux frontières de signes\n  const refFull = e.ref_sign_idx * 30 + e.ref_deg;\n  let ecart = lon - refFull;\n  if (ecart > 180)  ecart -= 360;\n  if (ecart < -180) ecart += 360;\n\n  return {\n    name:             { fr: e.name_fr, en: e.name_en },\n    fullDegree:       pos.fullDegree,\n    normDegree:       pos.normDegree,\n    sign_index:       pos.sign_index,\n    zodiac_sign:      pos.zodiac_sign,\n    methode:          \"precession_j2000\",\n    reference:        { signe: e.ref_sign, degre: e.ref_deg, label: e.ref_deg + \"\\u00b0 \" + e.ref_sign },\n    ecart_reference:  Math.round(ecart * 10000) / 10000,\n    declination_j2000: e.dec_j2000 || null,\n    ra_j2000: e.ra_j2000 || null\n  };\n});\n\nreturn [{\n  json: {\n    date:           dateStr,\n    julian_day:     Math.round(jd * 1000000) / 1000000,\n    precession_deg: Math.round(prec * 10000) / 10000,\n    output:         output\n  }\n}];"},"id":"cae8b407-7c58-47b5-88fb-4c2efb4718e9","name":"3c. Étoiles Fixes","type":"n8n-nodes-base.code","typeVersion":2,"position":[-4272,3248]},{"parameters":{"modelName":"models/gemini-3.1-pro-preview","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[800,2992],"id":"749e8469-1ae1-492e-a693-bfef91e3c18f","name":"Google Gemini Chat Model6","credentials":{"googlePalmApi":{"id":"CYaGbTvdLDOY2t1E","name":"Google Gemini(PaLM) Api account"}}},{"parameters":{"jsCode":"const elementsManquants = [];\n\n// Liste des noms exacts de vos nœuds à vérifier\nconst nodesToVerify = [\n  \"Maison 1\", \"Maison 2\", \"Maison 3\", \"Maison 4\", \n  \"Maison 5\", \"Maison 6\", \"Maison 7\", \"Maison 8\", \n  \"Maison 9\", \"Maison 10\", \"Maison 11\", \"Maison 12\",\n  \"Synthèse Globale1\"\n];\n\nfor (const nodeName of nodesToVerify) {\n  try {\n    // On vérifie si le nœud a généré une sortie\n    const data = $(nodeName).first();\n    if (!data || !data.json) {\n      elementsManquants.push(nodeName);\n    }\n  } catch (e) {\n    elementsManquants.push(nodeName);\n  }\n}\n\n// LOGIQUE DE BLOCAGE\nif (elementsManquants.length > 0) {\n  console.log(\"Attente de : \" + elementsManquants.join(\", \"));\n  // IMPORTANT : Retourner un tableau vide ARRÊTE l'exécution de cette branche\n  return []; \n}\n\n// Si on arrive ici, tout est fini\nreturn [{ \n  json: { \n    status: \"COMPLET\", \n    message: \"Toutes les analyses sont prêtes.\" \n  } \n}];"},"id":"a28eca16-086d-4eb9-a9e0-f5094a7e02de","name":"0. Gatekeeper (Attente)2","type":"n8n-nodes-base.code","typeVersion":2,"position":[-16,2768]},{"parameters":{"jsCode":"const items = [];\n\nfor (let i = 1; i <= 12; i++) {\n  let content = \"\";\n  try { \n      content = $(`Maison ${i}`).first().json.output || $(`Maison ${i}`).first().json.text || \"\"; \n  } catch (e) {}\n  \n  if (content) {\n      items.push({ json: { key: `maison_${i}`, original_text: content } });\n  }\n}\n\nlet synth = \"\";\ntry { \n    synth = $('Synthèse Globale1').first().json.output || $('Synthèse Globale1').first().json.text || \"\"; \n} catch(e) {}\n\nif (synth) {\n    items.push({ json: { key: 'synthese', original_text: synth } });\n}\n\nreturn items;"},"id":"7f6ec3f5-ffb6-49f5-9900-bce38c100043","name":"1. Découpage (Boucle)2","type":"n8n-nodes-base.code","typeVersion":2,"position":[592,2784]},{"parameters":{},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[400,2784],"id":"91daee94-8316-485f-aa7e-b2ef368b0c8d","name":"Merge1"},{"parameters":{"promptType":"define","text":"=Voici un extrait strict de l'analyse astrologique (Maison ou Synthèse) de cette personne :\n\n---\n{{ $json.original_text }}\n---\n\nTon travail : Rendre CE TEXTE PRÉCIS parfaitement compréhensible pour un client qui n'y connaît absolument rien en astrologie.\n\nRÈGLE D'OR ABSOLUE : TU NE DOIS SOUS AUCUN PRÉTEXTE RÉSUMER LE TEXTE.\nTa réponse finale doit comporter EXACTEMENT le même nombre de paragraphes, détailler toutes les mêmes nuances psychologiques, et être AUSSI LONGUE que le texte original.\n\nCONSIGNES STRICTES :\n1. Supprime le jargon purement technique : Cuspide, Décan, Trigone, Carré, Conjonction, Opposition, Sextile, Quinconce, Pérégrin, Exil, Domicile, Chaîne de disposition, Stellium, Aspect, Orbe, Profection, Firdaria, Arc solaire, Transit, Progression.\n2. CONSERVE les éléments intelligibles par un non-initié :\n   - Les NOMS DE PLANÈTES (Soleil, Lune, Mercure, Vénus, Mars, Jupiter, Saturne, Uranus, Neptune, Pluton, Chiron) : ce sont des noms propres universellement compris.\n   - Les NOMS DE SIGNES (Bélier, Taureau, Scorpion, etc.) : ils servent de repères culturels accessibles.\n   - Le mot ÉCLIPSE : universellement compris.\n   - Les ÉTOILES FIXES (Algol, Spica, Antarès, etc.) : noms propres qui apportent de la couleur.\n   - Les termes Maison 1 à 12 doivent être remplacés par leur signification (ex: \"ta sphère relationnelle\" au lieu de \"Maison 7\").\n3. Remplace la technique par l'explication du sens : Au lieu de dire \"Mars carré Jupiter amène une tension\", dis \"Mars et Jupiter s'affrontent dans ton ciel, créant une lutte intérieure entre l'envie de foncer et le besoin de voir plus grand...\".\n4. Garde les titres avec leurs marqueurs markdown (## et ###), garde les puces, garde la poésie et la profondeur psychologique du texte original.\n5. Conserve STRICTEMENT le pronom d'adresse et les accords de genre du texte original. Si le texte original utilise le masculin (motivé, inspiré, né, appelé, fait), ta reformulation DOIT utiliser le masculin. Si le texte original utilise le féminin, ta reformulation DOIT utiliser le féminin. Ne JAMAIS changer le genre.\n6. NE RAJOUTE PAS d'introduction (du type \"Voici la traduction...\") ou de conclusion. Rédige uniquement le texte transformé.\n7. Rédige ta réponse dans la même langue que le texte original. ","options":{"systemMessage":"Tu es un maître absolu en vulgarisation psychologique et astrologique. Ton but est de réécrire un texte technique complexe en un récit fluide, poétique et intelligible, SANS JAMAIS le résumer. Tu agis comme un filtre de jargon technique : tu supprimes les termes géométriques et calculatoires (Trigone, Carré, Cuspide, Orbe, etc.) mais tu CONSERVES les noms de planètes, de signes zodiacaux, d'étoiles fixes et le mot éclipse, car ils sont universellement compris et apportent une couleur essentielle au texte. Le lecteur doit pouvoir tracer le fil astrologique sans avoir besoin d'un dictionnaire. Tu conserves 100% de la longueur, de l'architecture et des détails de l'analyse d'origine.\n\nGARDES DE FIDÉLITÉ ABSOLUES :\n- Ne JAMAIS changer le signe ou la maison d'une planète lors de la reformulation. Si le texte dit 'Mars en Bélier' ou 'Mars en M1', ta reformulation doit conserver Mars, Bélier et la référence au secteur correspondant.\n- Ne JAMAIS ajouter d'information astrologique absente du texte original (pas de nouvelles planètes, aspects, dates ou interprétations).\n- Ne JAMAIS inventer de degrés zodiacaux, de dates ou d'aspects qui ne figurent pas dans le texte source.\n- Ne JAMAIS supprimer un paragraphe entier ou une interprétation — reformuler, pas résumer.\n- Ne JAMAIS changer le genre grammatical : si le texte original est au masculin, ta reformulation DOIT rester au masculin (né, motivé, inspiré, appelé). Si au féminin, rester au féminin.\n- PRÉCISION DES ORBES : si le 