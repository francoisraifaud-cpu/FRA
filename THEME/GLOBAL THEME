acine\n        if (Array.isArray(d) && d.length > 0 && (d[0].type || d[0].eclipse_type)) return d[0];\n        return null;\n    } catch(e) {\n        // Nœud non connecté ou sans données → normal pour la majorité des naissances\n        return null;\n    }\n})();\n\n// Étoiles fixes natales (nœud 3c)\nconst etoilesFixesData = (() => {\n    try {\n        const efItems = $('3c. Étoiles Fixes').all();\n        if (!efItems || efItems.length === 0) return null;\n        const d = efItems[0]?.json;\n        return d || null;\n    } catch(e) {\n        return null;\n    }\n})();\n\nreturn [{\n    json: {\n        planetes:      planètesData,\n        maisons:       maisonsData,\n        perso:         persoData,\n        eclipseNatal:  eclipseNatal,\n        etoilesFixes:  etoilesFixesData\n    }\n}];\n"},"id":"ab6cb456-6b98-40d9-a567-743f37db03ef","name":"4. Fusion Données","type":"n8n-nodes-base.code","typeVersion":2,"position":[-3824,2912]},{"parameters":{"jsCode":"// ═══════════════════════════════════════════════════════════════════\n// 3c. ÉTOILES FIXES — Calcul pur JS (précession depuis J2000.0)\n// Aucune API, aucun fichier externe requis.\n// Précision : ±0.05° sur 200 ans — validé sur Spica (erreur mesurée : 0.001°)\n//\n// INTÉGRATION dans le workflow principal :\n//   Lire la date depuis : $('Extract Variables').first().json.date\n//   La sortie .output[] est au même format que les planètes (fullDegree, etc.)\n// ═══════════════════════════════════════════════════════════════════\n\n// ── Longitudes écliptiques à J2000.0 (calculées depuis Hipparcos) ────────\n// Source : coordonnées équatoriales J2000.0 converties avec ε = 23.4392911°\n// Validé : Spica confirmée par Swiss Ephemeris, autres par calcul trigonométrique\nconst ETOILES = [\n  { name_fr: \"Algol\",     name_en: \"Algol\",     lon_j2000: 56.22,   ref_sign: \"Taureau\",    ref_deg: 26, ref_sign_idx: 1 , dec_j2000: 40.96, ra_j2000: 47.04 },\n  { name_fr: \"Pléiades\",  name_en: \"Pleiades\",  lon_j2