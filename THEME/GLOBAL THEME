       p += `\\n[TOKEN BUDGET : 25-40 lignes — développement standard]`;\n    }\n    const rappelLines = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\"].map(n => {\n        const pl = planetes.find(x => x.planet?.fr === n);\n        return pl ? `${n} M${getHouseNumber(pl.fullDegree)}(${pl.zodiac_sign?.name?.fr || \"?\"})` : null;\n    }).filter(Boolean);\n    p += `\\n\\n[RAPPEL FINAL — POSITIONS : ${rappelLines.join(\" | \")}]\\n⛔ Vérifier chaque mention de maison/signe avant de rédiger.`;\n    prompts[`maison_${m.House}`] = p;\n});\n\n// 6e-quint. SIGNES INTERCEPTÉS — détection explicite (post fiches_maisons)\nconst interceptedSigns = [];\nfiches_maisons.forEach(fm => {\n    fm.segments.forEach(seg => {\n        if (seg.type === \"Intercepté / Suite\" || seg.type === \"Intercepté\") {\n            const planetsInIntercepted = planetes.filter(p => {\n                const pSign = p.zodiac_sign?.name?.fr;\n                const house = getHouseNumber(p.fullDegree);\n                return pSign === seg.signe && house === fm.maison;\n            }).map(p => p.planet?.fr || p.planet?.en || \"\");\n            interceptedSigns.push({\n                sign: seg.signe, house: fm.maison,\n                planets: planetsInIntercepted.filter(Boolean),\n                description: planetsInIntercepted.length > 0\n                    ? `${seg.signe} intercepté en M${fm.maison} — ${planetsInIntercepted.join(\", \")} piégé(s) dans ce signe, énergie bloquée qui demande un effort conscient d'expression`\n                    : `${seg.signe} intercepté en M${fm.maison} — les thématiques de ce signe sont latentes et difficiles d'accès dans cette maison`\n            });\n        }\n    });\n});\n\n// ── Sprint 6 — Module B2 : Profil de sensibilité élémentaire/modale ──\nconst ELEMENT_TRANSIT_MAP = {\n    \"Feu\":[\"Mars\",\"Jupiter\"],\"Terre\":[\"Saturne\",\"Vénus\"],\n    \"Air\":[\"Uranus\",\"Mercure\"],\"Eau\":[\"Neptune\",\"Pluton\"]\n};\nconst computeSensitivityProfile = (elStats, moStats) => {\n    const total = Object.values(elStats).reduce((a,b)=>a+b,0) || 12;\n    const lines = [];\n    Object.entries(elStats).forEach(([element, count]) => {\n        const ratio = count / total;\n        const affiliated = ELEMENT_TRANSIT_MAP[element]?.join(\"/\") || \"\";\n        if (ratio <= 0.15) {\n            lines.push(`VULNÉRABILITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} peuvent être particulièrement déstabilisants car le thème manque de récepteurs naturels dans cet élément. L'intégration demande un effort conscient.`);\n        } else if (ratio >= 0.35) {\n            lines.push(`FAMILIARITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} sont dans la \"langue maternelle\" du thème — leur énergie est reconnue et plus facilement intégrée, même si l'aspect est tendu.`);\n        }\n    });\n    if (moStats.Fixe >= 5) {\n        lines.push(`RÉSISTANCE AU CHANGEMENT (Fixe: ${moStats.Fixe}) : les transits d'Uranus et de Pluton sur les positions fixes seront vécus avec une intensité maximale — la structure résiste avant de céder brusquement.`);\n    }\n    if (moStats.Mutable >= 5) {\n        lines.push(`ADAPTABILITÉ ÉLEVÉE (Mutable: ${moStats.Mutable}) : bonne capacité d'intégration des transits, mais risque de dispersion ou de perte de cap sous Neptune.`);\n    }\n    if (lines.length === 0) return \"\";\n    return `\\n=== PROFIL DE SENSIBILITÉ DU THÈME ===\\n${lines.join(\"\\n\")}\\n→ INSTRUCTION : module ton interprétation en tenant compte de ces sensibilités. Un transit \"harmonique\" dans un élément déficitaire peut quand même déstabiliser. Un transit \"tendu\" dans un élément familier sera mieux intégré que prévu.\\n`;\n};\nconst sensitivityProfileTheme = computeSensitivityProfile(stats.elements, stats.modes);\n\n// ─────────────────────────────────────────────────────────────────\n// 8. PROMPT SYNTHÈSE GLOBALE (Prompt 13)\n// ─────────────────────────────────────────────────────────────────\nlet mc  = planetes.find(p => p.planet.fr === \"Milieu du Ciel\");\nlet ns  = planetes.find(p => p.planet.fr === \"Nœud Sud\");\nlet pof = planetes.find(p => p.planet.fr === \"Part de Fortune\");\nlet pos = planetes.find(p => p.planet.fr === \"Lot de l'Esprit\");\n\nlet ascSign       = asc?.zodiac_sign?.name?.fr || null;\nlet chartRulerName = ascSign ? signs.find(s => s.fr === ascSign)?.ruler : null;\nlet chartRuler    = chartRulerName ? planetes.find(p => p.planet.fr === chartRulerName) : null;\nstats.chart_ruler = chartRulerName || null;\nconst MAITRES_TRAD_THEME = {\n    \"Bélier\":\"Mars\",\"Taureau\":\"Vénus\",\"Gémeaux\":\"Mercure\",\"Cancer\":\"Lune\",\n    \"Lion\":\"Soleil\",\"Vierge\":\"Mercure\",\"Balance\":\"Vénus\",\"Scorpion\":\"Mars\",\n    \"Sagittaire\":\"Jupiter\",\"Capricorne\":\"Saturne\",\"Verseau\":\"Saturne\",\"Poissons\":\"Jupiter\"\n};\nlet chartRulerTradName = ascSign ? MAITRES_TRAD_THEME[ascSign] : null;\nlet chartRulerTrad = (chartRulerTradName && chartRulerTradName !== chartRulerName) ? planetes.find(p => p.planet.fr === chartRulerTradName) : null;\nstats.chart_ruler_trad = (chartRulerTradName && chartRulerTradName !== chartRulerName) ? chartRulerTradName : null;\n\nlet pSynth = `Tu es un astrologue expert. Fais la synthèse globale de ce thème natal en utilisant les maîtrises modernes.\\n\\n`;\n\npSynth += `=== IDENTITÉ DU THÈME ===\\n`;\npSynth += `Type : ${sectStr}.\\n`;\npSynth += `Éléments : Feu(${stats.elements.Feu}) Terre(${stats.elements.Terre}) Air(${stats.elements.Air}) Eau(${stats.elements.Eau}).\\n`;\npSynth += `Modes : Cardinal(${stats.modes.Cardinal}) Fixe(${stats.modes.Fixe}) Mutable(${stats.modes.Mutable}).\\n`;\npSynth += `Secte : Luminaire = ${stats.sectLight}, Bénéfique de secte = ${stats.sectBenefic}, Maléfique tempéré = ${stats.sectMalefic}, Maléfique aggravé (contra-secte) = ${stats.contraSectMalefic}.\\n`;\npSynth += `→ INSTRUCTION : Le ${stats.sectLight} est le luminaire directeur (${sectStr}). ${stats.sectBenefic} agit en pleine puissance bénéfique, ${stats.sectMalefic} est le maléfique tempéré (IN-secte). ${stats.contraSectMalefic} est le maléfique HORS-secte (contra-secte) = le plus nuisible.\\n`;\npSynth += `⛔ TERMINOLOGIE OBLIGATOIRE : ${stats.sectMalefic} = \"maléfique tempéré\" ou \"maléfique de secte\". ${stats.contraSectMalefic} = \"maléfique hors-secte\" ou \"maléfique aggravé (contra-secte)\". Ne JAMAIS dire \"${stats.contraSectMalefic} est le maléfique de ta secte\" — c'est FAUX, ${stats.contraSectMalefic} est HORS de la secte ${sectStr.split(\" \")[0].toLowerCase()}.\\n`;\n\nif (sensitivityProfileTheme) pSynth += sensitivityProfileTheme;\n\nif (configurations.length > 0) {\n    pSynth += `\\n=== CONFIGURATIONS NATALES MAJEURES (triées par Score de Puissance décroissant) ===\\n`;\n    pSynth += `Légende scores : PRIORITÉ ABSOLUE ≥120 | Majeure ≥80 | Significative ≥50 | Mineure <50\\n`;\n    const hasSubs = configurations.some(c => c.subConfigOf);\n    const hasVariants = configurations.some(c => c.subConfigType === \"variant\");\n    if (hasSubs) pSynth += `INSTRUCTION : Les configurations marquées [composante de X] sont géométriquement contenues dans la figure parente — interpréter comme facettes, NON comme événements distincts.\\n`;\n    if (hasVariants) pSynth += `INSTRUCTION : Les configurations marquées [variante de X] partagent la majorité de leurs planètes avec une figure de même type déjà listée — ne pas doubler l'interprétation.\\n`;\n    configurations.forEach(c => {\n        const scoreLabel = c.puissanceScore !== undefined ? ` [Score: ${c.puissanceScore} — ${c.prioriteLabel}]` : \"\";\n        const subNote    = c.subConfigOf\n            ? c.subConfigType === \"variant\"\n                ? ` [variante du ${c.subConfigOf} — ${c.sharedPlanets} planètes communes — ne pas doubler l'interprétation]`\n                : ` [composante du ${c.subConfigOf} — ne pas doubler l'interprétation]`\n            : \"\";\n        pSynth += `  [${c.type}]${scoreLabel} ${c.description}${subNote}\\n`;\n    });\n}\nif (stationaryPlanets.length > 0) {\n    pSynth += `\\n=== PLANÈTES STATIONNAIRES (énergie concentrée, marqueur de premier ordre) ===\\n`;\n    stationaryPlanets.forEach(sp => { pSynth += `  ${sp.planet} ${sp.direction} en ${sp.sign} (M${sp.house}) — vitesse ${sp.speed}°/jour (seuil ${sp.threshold}°/jour)\\n`; });\n}\nif (angularPlanets.length > 0) {\n    pSynth += `\\n=== PLANÈTES ANGULAIRES (priorité maximale d'interprétation) ===\\n`;\n    angularPlanets.forEach(ap => { pSynth += `  ${ap.planet} à ${ap.orb}° de ${ap.angle} (M${ap.house}, ${ap.sign})\\n`; });\n}\nif (criticalPlanets.length > 0) {\n    pSynth += `\\n=== DEGRÉS CRITIQUES ===\\n`;\n    criticalPlanets.forEach(cp => { pSynth += `  ${cp.planet} à ${cp.degree}° ${cp.sign} : ${cp.flags.join(\" | \")}\\n`; });\n}\nif (mutualReceptions.length > 0) {\n    pSynth += `\\n=== RÉCEPTIONS MUTUELLES ===\\n`;\n    mutualReceptions.forEach(mr => {\n        const mrDesc = mr.type === \"exaltation\"\n            ? \"réception mutuelle par EXALTATION — coopération inspirée, élan créateur mutuel\"\n            : \"réception mutuelle par DOMICILE — coopération profonde, échange de ressources structurel\";\n        pSynth += `  ${mr.p1} (${mr.sign1}, M${mr.house1}) ↔ ${mr.p2} (${mr.sign2}, M${mr.house2}) : ${mrDesc}\\n`;\n    });\n}\nif (interceptedSigns.length > 0) {\n    pSynth += `\\n=== SIGNES INTERCEPTÉS (énergie bloquée, latence) ===\\n`;\n    interceptedSigns.forEach(is => { pSynth += `  ${is.description}\\n`; });\n}\npSynth += `\\n=== FORME DU THÈME (Jones Pattern) ===\\n  ${chartShape.shape} : ${chartShape.description}\\n`;\nif (chartShape.singleton) {\n    const singletonPlanet = planetes.find(p => p.planet.fr === chartShape.singleton);\n    const singletonHouse = singletonPlanet ? getHouseNumber(singletonPlanet.fullDegree) : \"?\";\n    const singletonSign = singletonPlanet?.zodiac_sign?.name?.fr || \"?\";\n    const singletonRetro = singletonPlanet?.retroStr || \"\";\n    pSynth += `→ INSTRUCTION PRIORITAIRE : Le singleton ${chartShape.singleton}${singletonRetro} en M${singletonHouse} (${singletonSign}) est le CANAL PRINCIPAL par lequel toute l'énergie planétaire du thème est focalisée et exprimée. Ce singleton doit être traité comme un PILIER INTERPRÉTATIF MAJEUR, au même titre que le Gouverneur et l'Almutem. Sa maison (M${singletonHouse}), son signe, ses aspects et sa dignité déterminent COMMENT le natif distribue et concentre ses forces vitales. Ne JAMAIS omettre le singleton dans la synthèse.\\n`;\n}\nif (antiscia.length > 0) {\n    pSynth += `\\n=== ANTISCIA & CONTRA-ANTISCIA (connexions cachées) ===\\n`;\n    antiscia.slice(0, 10).forEach(a => { pSynth += `  ${a.p1} — ${a.p2} : ${a.type} (orbe ${a.orb}°)\\n`; });\n}\nif (midpointActivations.length > 0) {\n    pSynth += `\\n=== MIDPOINTS ACTIVÉS ===\\n`;\n    midpointActivations.slice(0,12).forEach(ma => { pSynth += `  ${ma.activator} active le midpoint ${ma.midpoint} (${ma.type}, orbe ${ma.orb}°)\\n`; });\n}\nlet helioAlerts = Object.keys(helioConditions).filter(k => helioConditions[k].condition);\nif (helioAlerts.length > 0) {\n    pSynth += `\\n=== CONDITIONS HÉLIOCENTRIQUES (rapport au Soleil natal) ===\\n`;\n    helioAlerts.forEach(k => { pSynth += `  ${k} : ${helioConditions[k].condition}\\n`; });\n}\n\nif (planeteOOB.length > 0) {\n    pSynth += `\\n=== ⚡ PLANÈTES / OBJETS HORS LIMITES (Out of Bounds — OOB) ===\\n`;\n    pSynth += `Seuil : déclinaison > ±${OOB_THRESHOLD}°. Ces objets échappent symboliquement à l'autorité du Soleil.\\n`;\n    planeteOOB.forEach(o => {\n        pSynth += `  ⚡ ${o.planete} : ${o.declinaison.toFixed(2)}° ${o.hemisphere} (dépasse le seuil de +${o.depassement}°) — énergie exacerbée, imprévisible, électron libre\\n`;\n    });\n    pSynth += `→ INSTRUCTION : Interpréter le principe de chaque objet OOB comme amplifié et hors-normes. Son expression peut être géniale, excessive ou disruptive selon le reste du thème. Les OOB sont des marqueurs de singularité psychologique forte.\\n`;\n}\npSynth += `\\n⭐ ÉTOILES ROYALES : seules 4 étoiles portent ce titre — Aldébaran, Régulus, Antarès, Fomalhaut. Toute autre étoile (Bételgeuse, Spica, Sirius, Algol, etc.) est une \"Étoile Fixe majeure\", JAMAIS \"Royale\".\\n`;\n\nif (paralleles.length > 0 || contreParalleles.length > 0) {\n    pSynth += `\\n=== PARALLÈLES & CONTRE-PARALLÈLES DE DÉCLINAISON (3e dimension équatoriale) ===\\n`;\n    pSynth += `Orbes appliqués : ${DECL_ORB_STANDARD}° standard | ${DECL_ORB_LUMINAIRE}° si Luminaire impliqué.\\n`;\n    if (paralleles.length > 0) {\n        const topPar = paralleles.sort((a,b) => (a.hasLuminaire?0:1)-(b.hasLuminaire?0:1) || a.orb-b.orb).slice(0, 10);\n        pSynth += `PARALLÈLES (//) — Top ${topPar.length} (conjonctions profondes) :\\n`;\n        topPar.forEach(p => {\n            const h = p.hemisphere.charAt(0);\n            const lumTag = p.hasLuminaire ? \" ★ LUMINAIRE\" : \"\";\n            pSynth += `  // ${p.p1} (${p.decl1.toFixed(2)}°${h}) // ${p.p2} (${p.decl2.toFixed(2)}°${h}) — orbe ${p.orb}°${lumTag}\\n`;\n        });\n    }\n    if (contreParalleles.length > 0) {\n        const topCP = contreParalleles.sort((a,b) => (a.hasLuminaire?0:1)-(b.hasLuminaire?0:1) || a.orb-b.orb).slice(0, 8);\n        pSynth += `CONTRE-PARALLÈLES (#) — Top ${topCP.length} (oppositions profondes) :\\n`;\n        topCP.forEach(p => {\n            const h1 = p.decl1 > 0 ? \"N\" : \"S\", h2 = p.decl2 > 0 ? \"N\" : \"S\";\n            const lumTag = p.hasLuminaire ? \" ★ LUMINAIRE\" : \"\";\n            pSynth += `  # ${p.p1} (${p.decl1.toFixed(2)}°${h1}) # ${p.p2} (${p.decl2.toFixed(2)}°${h2}) — orbe ${p.orb}°${lumTag}\\n`;\n        });\n    }\n    pSynth += `→ INSTRUCTION : Un parallèle fusionne les principes des deux planètes (comme une conjonction). Un contre-parallèle crée une tension entre eux (comme une opposition). Ces aspects opèrent dans la dimension équatoriale, souvent plus profonds psychologiquement que leurs homologues en longitude. Ils renforcent ou complexifient les aspects en longitude existants entre les mêmes planètes.\\n`;\n}\n\npSynth += `\\n=== PILIERS DU THÈME ===\\n`;\nif (sun) {\n    pSynth += `Cœur (Soleil) en ${sun.zodiac_sign?.name?.fr || \"?\"} (M${sunHouse}). Aspects majeurs : ${getMajorAspectsStr(\"Soleil\")}\\n`;\n    const sunPromo = getPromotedMinorAspectsStr(\"Soleil\");\n    if (sunPromo) pSynth += `   ⚠ Aspects mineurs promus du Soleil :\\n${sunPromo}\\n`;\n}\nif (moon) {\n    pSynth += `Émotion (Lune) en ${moon.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(moon.fullDegree)}). Aspects majeurs : ${getMajorAspectsStr(\"Lune\")}\\n`;\n    const moonPromo = getPromotedMinorAspectsStr(\"Lune\");\n    if (moonPromo) pSynth += `   ⚠ Aspects mineurs promus de la Lune :\\n${moonPromo}\\n`;\n}\nif (asc)       pSynth += `Ascendant en ${ascSign}. Aspects : ${getMajorAspectsStr(\"Ascendant\")}\\n`;\nif (mc)        pSynth += `MC en ${mc.zodiac_sign?.name?.fr || \"?\"}. Aspects : ${getMajorAspectsStr(\"Milieu du Ciel\")}\\n`;\nif (chartRuler) {\n    let cr_sign   = chartRuler.zodiac_sign?.name?.fr || \"?\";\n    let cr_dig    = getDignity(chartRulerName, cr_sign);\n    let cr_digStr = cr_dig !== \"-\" ? ` — ${cr_dig}` : \"\";\n    let cr_helio  = helioConditions[chartRulerName]?.condition ? ` | ☀ ${helioConditions[chartRulerName].condition}` : \"\";\n    pSynth += `GOUVERNEUR DU THÈME (moderne) : ${chartRulerName}${chartRuler.retroStr} en M${getHouseNumber(chartRuler.fullDegree)} (${cr_sign}${cr_digStr})${cr_helio}. Aspects majeurs : ${getMajorAspectsStr(chartRulerName)}.\\n`;\n    const crPromo = getPromotedMinorAspectsStr(chartRulerName);\n    if (crPromo) pSynth += `   ⚠ Aspects mineurs promus du gouverneur :\\n${crPromo}\\n`;\n    if (chartRulerTrad) {\n        let crt_sign   = chartRulerTrad.zodiac_sign?.name?.fr || \"?\";\n        let crt_dig    = getDignity(chartRulerTradName, crt_sign);\n        let crt_digStr = crt_dig !== \"-\" ? ` — ${crt_dig}` : \"\";\n        let crt_helio  = helioConditions[chartRulerTradName]?.condition ? ` | ☀ ${helioConditions[chartRulerTradName].condition}` : \"\";\n        pSynth += `CO-MAÎTRE TRADITIONNEL : ${chartRulerTradName}${chartRulerTrad.retroStr} en M${getHouseNumber(chartRulerTrad.fullDegree)} (${crt_sign}${crt_digStr})${crt_helio}. Aspects : ${getMajorAspectsStr(chartRulerTradName)}.\\n`;\n    }\n}\nif (pof) pSynth += `PART DE FORTUNE (abondance/réussite) : ${pof.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(pof.fullDegree)}). Aspects : ${getMajorAspectsStr(\"Part de Fortune\")}\\n`;\nif (pos) pSynth += `LOT DE L'ESPRIT (vocation/conscience) : ${pos.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(pos.fullDegree)}). Aspects : ${getMajorAspectsStr(\"Lot de l'Esprit\")}\\n`;\n\n// Sprint 7 — Action 6 : Lots hermétiques dans la synthèse\nconst LOTS_META = [\n    {fr:\"Lot de Nécessité\", desc:\"contraintes, épreuves inévitables, karma\"},\n    {fr:\"Lot d'Éros\", desc:\"passion, attraction, élan vital\"},\n    {fr:\"Lot de Courage\", desc:\"audace, initiative, affirmation combative\"},\n    {fr:\"Lot de Némésis\", desc:\"épreuves saturniennes, leçons, limites structurantes\"},\n    {fr:\"Lot de Basis\", desc:\"fondement matériel, socle existentiel\"},\n    {fr:\"Lot d'Exaltation\", desc:\"dignité, ambition, élévation\"},\n    {fr:\"Lot du Daemon\", desc:\"génie personnel, vocation profonde, daimon socratique\"}\n];\nLOTS_META.forEach(lm => {\n    const lotP = planetes.find(p => p.planet.fr === lm.fr);\n    if (lotP) {\n        const h = getHouseNumber(lotP.fullDegree);\n        const asp = getMajorAspectsStr(lm.fr);\n        pSynth += `${lm.fr.toUpperCase()} (${lm.desc}) : ${lotP.zodiac_sign?.name?.fr || \"?\"} (M${h})${asp ? \". Aspects : \" + asp : \"\"}\\n`;\n    }\n});\n\nif (nn && ns)  pSynth += `AXE KARMIQUE : Nœud Sud ${ns.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(ns.fullDegree)}) → Nœud Nord ${nn.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(nn.fullDegree)}).\\n`;\n\nif (etoileMatches.length > 0) {\n    pSynth += `\\n=== ÉTOILES FIXES — CONJONCTIONS PLANÈTES NATALES ===\\n`;\n    etoileMatches.forEach(em => {\n        const angleTag = em.isAngle ? \" [ANGLE]\" : \"\";\n        pSynth += `  ★ ${em.planete}${angleTag} (M${em.maison}, ${em.signe}) conjoint ${em.etoile} — orbe ${em.orb}°, ${em.precision}\\n`;\n    });\n    pSynth += `→ INSTRUCTION : Signatures stellaires permanentes — marqueurs de destin (détail dans les prompts maison).\\n`;\n}\nif (etoileCuspMatches.length > 0) {\n    pSynth += `\\n=== ÉTOILES FIXES — ANGLES (ASC/IC/DSC/MC) ===\\n`;\n    etoileCuspMatches.forEach(ec => {\n        pSynth += `  ★ ${ec.angle} M${ec.maison} conjoint ${ec.etoile} — orbe ${ec.orb}°, ${ec.precision}\\n`;\n    });\n    pSynth += `→ INSTRUCTION : Étoile sur un angle = influence déterminante sur ce pilier du thème.\\n`;\n}\n\nif (paranResults.length > 0) {\n    const topParans = paranResults.sort((a,b) => a.orb - b.orb).slice(0, 10);\n    pSynth += `\\n=== PARANS D'ÉTOILES FIXES — TOP ${topParans.length} (co-angularité — méthode Brady) ===\\n`;\n    pSynth += `Un paran se forme quand une étoile fixe et une planète sont simultanément sur un angle cardinal. Latitude ${geoLat.toFixed(2)}° prise en compte.\\n`;\n    topParans.forEach(pr => {\n        pSynth += `  ★ PARAN : ${pr.etoile} (${pr.angle_etoile}) ↔ ${pr.planete} (${pr.angle_planete}) — orbe ${pr.orb}° RAMC\\n`;\n        pSynth += `    ${pr.interpretation}\\n`;\n    });\n    pSynth += `→ INSTRUCTION : Les parans créent un LIEN SYMBOLIQUE étoile↔planète. Lever = début de vie ; Coucher = maturité ; Culmination = réalisation publique. Interpréter comme des résonances de destin.\\n`;\n}\n\npSynth += `\\nSynthétise ces dynamiques en identifiant les 3 à 5 grandes thématiques de vie de ce thème : les tensions majeures, les talents naturels, la configuration karmique, et l'orientation générale de l'énergie vitale. Intègre la secte, les configurations, les planètes angulaires, les conditions héliocentriques, les étoiles fixes et les parans comme filtres interprétatifs principaux.`;\n\npSynth += `\\n\\n[⛔ CHARTE ANTI-HALLUCINATION — OBLIGATIONS STRICTES]\n1. ORBES & EXACTITUDE : Ne JAMAIS écrire \"conjonction exacte\" si l'orbe est > 0.5°. Utiliser le qualificatif fourni. \"Exactement\" = RÉSERVÉ aux orbes ≤ 0.5°.\n2. ÉTOILES FIXES : Une étoile est conjointe UNIQUEMENT si listée dans les données. Ne JAMAIS inférer une conjonction stellaire non fournie ni attribuer la nature d'une étoile à un point non conjoint.\n3. FIDÉLITÉ AUX DONNÉES : Toute affirmation factuelle DOIT provenir des données. Ne JAMAIS inférer une donnée astronomique absente.\n4. CONFIGURATIONS & MAISONS : Stellium par signe ≠ même maison. Vérifier le MÉMO POSITIONS.\n5. INTERDICTION D'EXTRAPOLATION : Ne PAS combiner des données séparées pour créer un lien non fourni.\\n`;\n\nprompts[\"synthese_globale\"] = pSynth;\n\n// ─────────────────────────────────────────────────────────────────\n// 9. ÉCLIPSE À LA NAISSANCE (données optionnelles depuis Fusion Données)\n// ─────────────────────────────────────────────────────────────────\nconst eclipseNatal = input.eclipseNatal || null;\nlet eclipseNatalData = null;\nif (eclipseNatal && (eclipseNatal.type || eclipseNatal.eclipse_type || eclipseNatal.typeEclipse)) {\n    const eclipseDeg = typeof eclipseNatal.fullDegree === 'number' ? eclipseNatal.fullDegree\n                     : typeof eclipseNatal.degree     === 'number' ? eclipseNatal.degree\n                     : typeof eclipseNatal.degre      === 'number' ? eclipseNatal.degre\n                     : null;\n    if (eclipseDeg !== null) {\n        const normalizedDeg = ((eclipseDeg % 360) + 360) % 360;\n        const eclipseHouse  = getHouseNumber(normalizedDeg);\n        const eclipseSign   = signs[Math.floor(normalizedDeg / 30) % 12].fr;\n        const eclipseType   = eclipseNatal.type || eclipseNatal.eclipse_type || eclipseNatal.typeEclipse || \"Solaire\";\n        const eclipseAstre  = eclipseNatal.astre || (eclipseType.includes(\"Lunaire\") ? \"Lune\" : \"Soleil\");\n        const eclipseLabel  =\n            `⚡ ÉCLIPSE À LA NAISSANCE (${eclipseType} de ${eclipseAstre}) en ${eclipseSign} à ${(normalizedDeg % 30).toFixed(1)}° — Maison ${eclipseHouse}. ` +\n            `Cet individu est né le jour même d'une éclipse : les thèmes de la Maison ${eclipseHouse} sont chargés d'une mission de transformation profonde. ` +\n            `Cette éclipse amplifie toutes les lectures de la Maison ${eclipseHouse} et confère une sensibilité karmatique permanente sur ce degré.`;\n\n        if (eclipseHouse >= 1 && eclipseHouse <= 12) {\n            prompts[`maison_${eclipseHouse}`] +=\n                `\\n\\n=== ⚡ ÉCLIPSE À LA NAISSANCE ===\\n${eclipseLabel}\\n` +\n                `→ INSTRUCTION : Les thèmes de cette maison doivent être traités comme PRIORITAIRES et AMPLIFIÉS. ` +\n                `L'éclipse natale confère une mission, une blessure-catalyseur ou une rupture fondatrice sur ces thèmes. ` +\n                `Tout transit futur sur ce degré (${(normalizedDeg % 30).toFixed(1)}° ${eclipseSign}) réactivera cette éclipse natale.`;\n        }\n        prompts[\"synthese_globale\"] +=\n            `\\n\\n=== ⚡ ÉCLIPSE À LA NAISSANCE ===\\n${eclipseLabel}\\n` +\n            `→ INSTRUCTION : Intégrer cette éclipse natale comme signature karmique centrale du thème. ` +\n            `L'individu porte en lui l'archétype de la rupture/transformation dans les thèmes de la Maison ${eclipseHouse}.`;\n\n        eclipseNatalData = {\n            type: eclipseType, astre: eclipseAstre, sign: eclipseSign,\n            house: eclipseHouse, degree: normalizedDeg, label: eclipseLabel\n        };\n    }\n}\n\n// ─────────────────────────────────────────────────────────────────\n// 10. EMPHASE HÉMISPHÉRIQUE & ORIENTATION DU THÈME\n// ─────────────────────────────────────────────────────────────────\nconst coreForHemis = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\nlet hemisN=0, hemisS=0, hemisE=0, hemisW=0;\ncoreForHemis.forEach(name => {\n    const p = planetes.find(x => x.planet.fr === name); if (!p) return;\n    const house = Number(getHouseNumber(p.fullDegree));\n    if ([1,2,3,4,5,6].includes(house))    hemisN++; else hemisS++;  // M1-M6 = sous l'horizon (privé/intérieur), M7-M12 = au-dessus (public/extérieur)\n    if ([10,11,12,1,2,3].includes(house)) hemisE++; else hemisW++;\n});\nstats.hemispheres = { \"Sous l'horizon (M1-M6)\": hemisN, \"Au-dessus (M7-M12)\": hemisS, Est: hemisE, Ouest: hemisW };\n\n// ─────────────────────────────────────────────────────────────────\n// 11. PLANÈTE DOMINANTE (score multi-critères)\n// ─────────────────────────────────────────────────────────────────\nconst dominanceScore = {};\ncoreForHemis.forEach(name => { dominanceScore[name] = 0; });\nangularPlanets.forEach(ap => { if (dominanceScore[ap.planet] !== undefined) dominanceScore[ap.planet] += 3; });\ncoreForHemis.forEach(name => {\n    const p = planetes.find(x => x.planet.fr === name); if (!p) return;\n    const dig = getDignity(name, p.zodiac_sign?.name?.fr);\n    if (dig === \"Domicile\")   dominanceScore[name] += 2;\n    if (dig === \"Exaltation\") dominanceScore[name] += 1;\n    if (helioConditions[name]?.condition?.includes(\"CAZIMI\")) dominanceScore[name] += 2;\n});\ncoreForHemis.forEach(name => {\n    const count = aspects.filter(a => a.isMajor && (a.p1 === name || a.p2 === name)).length;\n    dominanceScore[name] += Math.min(count, 5);\n});\n// Bonus OOB : planète hors limites = énergie exacerbée (+3 pts)\ncoreForHemis.forEach(name => {\n    if (OOB_NAMES_SET.has(name)) dominanceScore[name] += 3;\n});\n// Bonus Station : planète stationnaire = concentration d'énergie exceptionnelle (+4 pts)\nstationaryPlanets.forEach(sp => {\n    if (dominanceScore[sp.planet] !== undefined) dominanceScore[sp.planet] += 4;\n});\nconst ascSignForDom = asc ? asc.zodiac_sign?.name?.fr : null;\nconst chartRulerForDom = ascSignForDom ? signs.find(s => s.fr === ascSignForDom)?.ruler : null;\nif (chartRulerForDom && dominanceScore[chartRulerForDom] !== undefined) dominanceScore[chartRulerForDom] += 2;\nconst chartRulerTradForDom = ascSignForDom ? MAITRES_TRAD_THEME[ascSignForDom] : null;\nif (chartRulerTradForDom && chartRulerTradForDom !== chartRulerForDom && dominanceScore[chartRulerTradForDom] !== undefined) dominanceScore[chartRulerTradForDom] += 1;\nfiches_maisons.forEach(fm => {\n    fm.segments.forEach(seg => {\n        if (seg.locataires.length > 0 && seg.maitre?.planete && dominanceScore[seg.maitre.planete] !== undefined)\n            dominanceScore[seg.maitre.planete] += 1;\n    });\n});\nconst dominanteSorted = Object.entries(dominanceScore).sort((a,b) => b[1] - a[1]);\nstats.planete_dominante    = dominanteSorted[0]?.[0] || null;\nstats.dominance_scores     = dominanteSorted;\n\n// ─────────────────────────────────────────────────────────────────\n// 12. ALMUTEM FIGURIS (planète avec le plus de dignités essentielles sur ASC, Sol, Lune, Part de Fortune)\n// ─────────────────────────────────────────────────────────────────\nconst keyPoints = [\n    asc   ? { name:\"ASC\",   deg:asc.fullDegree,   sign:asc.zodiac_sign?.name?.fr }   : null,\n    sun   ? { name:\"Sol\",   deg:sun.fullDegree,   sign:sun.zodiac_sign?.name?.fr }   : null,\n    moon  ? { name:\"Lune\",  deg:moon.fullDegree,  sign:moon.zodiac_sign?.name?.fr }  : null,\n    planetes.find(p=>p.planet.fr===\"Part de Fortune\") ? {\n        name:\"PartFort\", deg:planetes.find(p=>p.planet.fr===\"Part de Fortune\").fullDegree,\n        sign:planetes.find(p=>p.planet.fr===\"Part de Fortune\").zodiac_sign?.name?.fr } : null,\n    mc    ? { name:\"MC\",    deg:mc.fullDegree,    sign:mc.zodiac_sign?.name?.fr }    : null\n].filter(Boolean);\n\n// Triplicité (Ptolémée/Dorothée) — seigneurs diurnes et nocturnes par élément\n// Triplicités Ptolémée/Dorothée — tous les signes d'un même élément partagent les mêmes seigneurs\n// Feu: Soleil(J) / Jupiter(N) | Terre: Vénus(J) / Lune(N) | Air: Saturne(J) / Mercure(N) | Eau: Vénus(J) / Mars(N)\nconst TRIPLIC_DAY = {\n    \"Bélier\":\"Soleil\", \"Lion\":\"Soleil\",    \"Sagittaire\":\"Soleil\",\n    \"Taureau\":\"Vénus\", \"Vierge\":\"Vénus\",   \"Capricorne\":\"Vénus\",\n    \"Gémeaux\":\"Saturne\",\"Balance\":\"Saturne\",\"Verseau\":\"Saturne\",\n    \"Cancer\":\"Vénus\",  \"Scorpion\":\"Vénus\", \"Poissons\":\"Vénus\"\n};\nconst TRIPLIC_NIGHT = {\n    \"Bélier\":\"Jupiter\",\"Lion\":\"Jupiter\",   \"Sagittaire\":\"Jupiter\",\n    \"Taureau\":\"Lune\",  \"Vierge\":\"Lune\",    \"Capricorne\":\"Lune\",\n    \"Gémeaux\":\"Mercure\",\"Balance\":\"Mercure\",\"Verseau\":\"Mercure\",\n    \"Cancer\":\"Mars\",   \"Scorpion\":\"Mars\",  \"Poissons\":\"Mars\"\n};\n\nconst almutemScore = {};\ncoreForHemis.forEach(name => {\n    almutemScore[name] = 0;\n    keyPoints.forEach(kp => {\n        const dig = getDignity(name, kp.sign);\n        if (dig === \"Domicile\")   almutemScore[name] += 5;\n        if (dig === \"Exaltation\") almutemScore[name] += 4;\n        if (dig === \"Exil\")       almutemScore[name] -= 5;\n        if (dig === \"Chute\")      almutemScore[name] -= 4;\n        // Triplicité (+3) — seigneur selon la secte du thème\n        const triplRuler = isDayChart ? TRIPLIC_DAY[kp.sign] : TRIPLIC_NIGHT[kp.sign];\n        if (name === triplRuler) almutemScore[name] += 3;\n        // Triplicité participante (+1.5) — 3e seigneur Dorothéen, actif quelle que soit la secte\n        const triplPart = TRIPLIC_PART_EARLY[kp.sign];\n        if (name === triplPart && name !== triplRuler) almutemScore[name] += 1.5;\n        // Terme égyptien (+2)\n        const termRuler = getTermRuler(kp.sign, kp.deg);\n        if (name === termRuler) almutemScore[name] += 2;\n        // Face / Décan chaldéen (+1)\n        const decanIdx  = Math.min(Math.floor((kp.deg % 30) / 10), 2);\n        const faceRuler = CHALDEAN_DECANS[kp.sign]?.[decanIdx];\n        if (name === faceRuler) almutemScore[name] += 1;\n    });\n});\nconst almutemSorted = Object.entries(almutemScore).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);\nstats.almutem_figuris = almutemSorted[0]?.[0] || null;\nstats.almutem_scores  = almutemSorted;\n\n// ─────────────────────────────────────────────────────────────────\n// 12b. TECHNIQUES AVANCÉES — Dispositeur final, Dignité accidentelle, Hayz, Assiégée, VOC Lune\n// ─────────────────────────────────────────────────────────────────\n\n// ── C2 : ARBRE DES DISPOSITIONS & DISPOSITEUR FINAL ──\nconst SIGN_RULER_MAP = {\n    \"Bélier\":\"Mars\",\"Taureau\":\"Vénus\",\"Gémeaux\":\"Mercure\",\"Cancer\":\"Lune\",\n    \"Lion\":\"Soleil\",\"Vierge\":\"Mercure\",\"Balance\":\"Vénus\",\"Scorpion\":\"Pluton\",\n    \"Sagittaire\":\"Jupiter\",\"Capricorne\":\"Saturne\",\"Verseau\":\"Uranus\",\"Poissons\":\"Neptune\"\n};\nconst DISPOSITOR_PLANETS = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\nconst dispositorTree = {};\nDISPOSITOR_PLANETS.forEach(name => {\n    const chain = [];\n    let current = name;\n    const visited = new Set();\n    while (current && !visited.has(current)) {\n        visited.add(current);\n        const p = planetes.find(x => x.planet.fr === current);\n        if (!p) break;\n        const sign = p.zodiac_sign?.name?.fr;\n        if (!sign) break;\n        const ruler = SIGN_RULER_MAP[sign];\n        const isInDomicile = getDignity(current, sign) === \"Domicile\";\n        chain.push({ planet: current, sign, ruler, inDomicile: isInDomicile });\n        if (isInDomicile) break;\n        current = ruler;\n    }\n    dispositorTree[name] = {\n        chain,\n        finalDispositor: chain.find(c => c.inDomicile)?.planet || null,\n        isLoop: !chain.some(c => c.inDomicile)\n    };\n});\nconst finalDispositors = [...new Set(\n    Object.values(dispositorTree).map(d => d.finalDispositor).filter(Boolean)\n)];\nconst dispositorStr = finalDispositors.length > 0\n    ? `Dispositeur(s) final(aux) : ${finalDispositors.join(\", \")} — planète(s) en domicile concentrant le pouvoir de la chaîne de maîtrise. Toute la carte est ultimement « commandée » par ${finalDispositors.length === 1 ? 'cette planète' : 'ces planètes'}.`\n    : `Aucun dispositeur final unique — chaîne(s) de disposition en boucle (réceptions mutuelles ou orbite fermée), indiquant un réseau de pouvoir distribué plutôt qu'une seule planète directrice.`;\n\n// ── C3 : DIGNITÉ ACCIDENTELLE (Table de Lilly simplifiée) ──\nconst ANGULAR_HOUSES_SET = new Set([1, 10]);\nconst STRONG_HOUSES_SET  = new Set([7, 4]);\nconst SUCCEDENT_HOUSES   = new Set([2, 5, 8, 11]);\nconst CADENT_WEAK_HOUSES = new Set([6, 12]);\nconst MASCULINE_SIGNS    = new Set([\"Bélier\",\"Gémeaux\",\"Lion\",\"Balance\",\"Sagittaire\",\"Verseau\"]);\nconst FEMININE_SIGNS     = new Set([\"Taureau\",\"Cancer\",\"Vierge\",\"Scorpion\",\"Capricorne\",\"Poissons\"]);\nconst DIURNAL_PLANETS    = new Set([\"Soleil\",\"Jupiter\",\"Saturne\"]);\nconst NOCTURNAL_PLANETS  = new Set([\"Lune\",\"Vénus\",\"Mars\"]);\nconst MALEFICS_TRAD      = new Set([\"Mars\",\"Saturne\"]);\nconst BENEFICS_TRAD      = new Set([\"Jupiter\",\"Vénus\"]);\n\nconst accidentalDignityScores = {};\nDISPOSITOR_PLANETS.forEach(name => {\n    const p = planetes.find(x => x.planet.fr === name);\n    if (!p) return;\n    const house = getHouseNumber(p.fullDegree);\n    const isRetro = p.isRetro?.toLowerCase?.() === 'true' || p.isRetro === true;\n    const sign = p.zodiac_sign?.name?.fr;\n    let score = 0;\n    const details = [];\n\n    if (ANGULAR_HOUSES_SET.has(house))  { score += 5; details.push(`M${house} angulaire +5`); }\n    else if (STRONG_HOUSES_SET.has(house)) { score += 4; details.push(`M${house} angulaire +4`); }\n    else if (SUCCEDENT_HOUSES.has(house))  { score += 3; details.push(`M${house} succédente +3`); }\n    else if (CADENT_WEAK_HOUSES.has(house)){ score -= 5; details.push(`M${house} cadente faible -5`); }\n    else { score += 2; details.push(`M${house} cadente +2`); }\n\n    if (isRetro) { score -= 5; details.push(\"Rétrograde -5\"); }\n    else         { score += 4; details.push(\"Direct +4\"); }\n\n    const helio = helioConditions[name];\n    if (helio?.condition?.includes(\"CAZIMI\"))    { score += 5; details.push(\"Cazimi +5\"); }\n    else if (helio?.condition?.includes(\"COMBUSTE\")) { score -= 5; details.push(\"Combuste -5\"); }\n    else if (helio?.condition?.includes(\"SOUS LES RAYONS\")) { score -= 4; details.push(\"Sous les rayons -4\"); }\n    else if (name !== \"Soleil\" && name !== \"Lune\") { score += 5; details.push(\"Libre du Soleil +5\"); }\n\n    const inMutualReception = mutualReceptions.some(mr =>\n        (mr.p1 === name || mr.p2 === name) && mr.type === \"domicile\"\n    );\n    if (inMutualReception) { score += 5; details.push(\"Réception mutuelle domicile +5\"); }\n\n    const essentialDig = getDignity(name, sign);\n    const essentialScore = essentialDig === \"Domicile\" ? 5 : essentialDig === \"Exaltation\" ? 4\n        : essentialDig === \"Exil\" ? -5 : essentialDig === \"Chute\" ? -4 : 0;\n    if (essentialScore !== 0) details.push(`${essentialDig} ${essentialScore > 0 ? '+' : ''}${essentialScore}`);\n    score += essentialScore;\n\n    // Bonus/malus aspects reçus de bénéfiques/maléfiques (Lilly)\n    const BENEFICS = new Set([\"Jupiter\",\"Vénus\"]);\n    const MALEFICS = new Set([\"Saturne\",\"Mars\"]);\n    const aspFromBen = aspects.filter(a => a.isMajor && ((a.p1 === name && BENEFICS.has(a.p2)) || (a.p2 === name && BENEFICS.has(a.p1))));\n    const aspFromMal = aspects.filter(a => a.isMajor && ((a.p1 === name && MALEFICS.has(a.p2)) || (a.p2 === name && MALEFICS.has(a.p1))));\n    if (aspFromBen.length > 0) { const b = Math.min(aspFromBen.length, 2) * 2; score += b; details.push(`Aspect(s) bénéfique(s) reçu(s) +${b}`); }\n    if (aspFromMal.length > 0) { const m = Math.min(aspFromMal.length, 2) * -2; score += m; details.push(`Aspect(s) maléfique(s) reçu(s) ${m}`); }\n\n    // Bonus station\n    if (stationaryPlanets.some(sp => sp.planet === name)) { score += 3; details.push(\"Stationnaire +3\"); }\n\n    accidentalDignityScores[name] = { score, details, house, sign, isRetro, essentialDig };\n});\nconst dignityRanking = Object.entries(accidentalDignityScores)\n    .sort((a, b) => b[1].score - a[1].score)\n    .map(([name, data]) => ({ planet: name, ...data }));\n\n// ── C4a : HAYZ (condition de secte optimale) ──\nconst hayzPlanets = [];\nDISPOSITOR_PLANETS.forEach(name => {\n    const p = planetes.find(x => x.planet.fr === name); if (!p) return;\n    const sign = p.zodiac_sign?.name?.fr;\n    const house = getHouseNumber(p.fullDegree);\n    const aboveHorizon = [7,8,9,10,11,12].includes(house);\n    const isMasculine = MASCULINE_SIGNS.has(sign);\n    let inHayz = false, desc = \"\";\n    if (isDayChart && DIURNAL_PLANETS.has(name) && aboveHorizon && isMasculine) {\n        inHayz = true; desc = `${name} diurne, au-dessus de l'horizon, en signe masculin (${sign}) de jour — condition de HAYZ parfaite : la planète opère dans son élément naturel avec une efficacité maximale.`;\n    } else if (!isDayChart && NOCTURNAL_PLANETS.has(name) && !aboveHorizon && !isMasculine) {\n        inHayz = true; desc = `${name} nocturne, sous l'horizon, en signe féminin (${sign}) de nuit — condition de HAYZ parfaite : la planète opère dans son élément naturel avec une efficacité maximale.`;\n    }\n    if (inHayz) hayzPlanets.push({ planet: name, description: desc });\n});\n\n// ── C4b : PLANÈTES ASSIÉGÉES (entre deux maléfiques) ──\nconst besiegedPlanets = [];\nconst sortedByDeg = DISPOSITOR_PLANETS\n    .map(name => ({ name, deg: planetes.find(x => x.planet.fr === name)?.fullDegree }))\n    .filter(p => p.deg !== undefined)\n    .sort((a, b) => a.deg - b.deg);\nsortedByDeg.forEach((p, idx) => {\n    if (MALEFICS_TRAD.has(p.name) || BENEFICS_TRAD.has(p.name)) return;\n    const prev = sortedByDeg[(idx - 1 + sortedByDeg.length) % sortedByDeg.length];\n    const next = sortedByDeg[(idx + 1) % sortedByDeg.length];\n    if (MALEFICS_TRAD.has(prev.name) && MALEFICS_TRAD.has(next.name)) {\n        // Vérifier si un bénéfique intercepte le besiegement (atténuation)\n        const pDeg = p.deg, prevDeg = prev.deg, nextDeg = next.deg;\n        const beneficIntervenes = sortedByDeg.some(bp => {\n            if (!BENEFICS_TRAD.has(bp.name)) return false;\n            if (prevDeg < nextDeg) return bp.deg > prevDeg && bp.deg < nextDeg;\n            return bp.deg > prevDeg || bp.deg < nextDeg;\n        });\n        const severity = beneficIntervenes ? \"ATTÉNUÉE\" : \"STRICTE\";\n        besiegedPlanets.push({\n            planet: p.name,\n            between: [prev.name, next.name],\n            severity,\n            description: beneficIntervenes\n                ? `${p.name} est assiégée entre ${prev.name} et ${next.name}, mais un bénéfique intervient — pression atténuée.`\n                : `${p.name} est ASSIÉGÉE entre ${prev.name} et ${next.name} — contrainte, pression, empêchement. L'énergie de ${p.name} est entravée par les deux maléfiques traditionnels.`\n        });\n    }\n});\n\n// ── C4c : VIDE DE COURSE DE LA LUNE ──\nlet moonVoidOfCourse = null;\nif (moon) {\n    const moonDeg = moon.fullDegree;\n    const moonSign = moon.zodiac_sign?.name?.fr;\n    const moonSignEnd = (Math.floor(moonDeg / 30) + 1) * 30;\n    const majorAspDegs = [0, 60, 90, 120, 180];\n    let hasApplyingAspect = false;\n    DISPOSITOR_PLANETS.filter(n => n !== \"Lune\").forEach(name => {\n        const p = planetes.find(x => x.planet.fr === name); if (!p) return;\n        majorAspDegs.forEach(aspDeg => {\n            const targetDeg = (p.fullDegree + aspDeg) % 360;\n            const targetDeg2 = (p.fullDegree - aspDeg + 360) % 360;\n            [targetDeg, targetDeg2].forEach(td => {\n                if (td > moonDeg && td < moonSignEnd) hasApplyingAspect = true;\n            });\n        });\n    });\n    if (!hasApplyingAspect) {\n        moonVoidOfCourse = {\n            active: true,\n            sign: moonSign,\n            description: `Lune VIDE DE COURSE en ${moonSign} — la Lune ne forme plus d'aspect majeur appliquant avant de quitter le signe. Indique un tempérament qui fonctionne « hors cadre », par intuition pure plutôt que par connexion directe. Les projets initiés peuvent manquer d'écho immédiat mais mûrissent de façon non conventionnelle.`\n        };\n    }\n}\n\n// ── C2 : DEGRÉS SABIAN (symboles pour chaque planète) ──\nconst SABIAN_SYMBOLS = [\n\"Une femme surgit de l'océan ; un phoque l'enlace\",\"Un comédien divertit un groupe\",\"Le camée d'un profil d'homme dans l'ombre d'une pièce\",\"Deux amoureux se promènent dans un chemin isolé\",\n\"Un triangle avec des ailes\",\"Un carré illuminé de côtés\",\"Un homme réussit à exprimer simultanément deux tempéraments\",\"Un chapeau à large bord ventilé par l'est\",\n\"Un cristal dans lequel miroite un monde abstrait\",\"Un professeur regarde ses élèves à travers des verres épais\",\"Le souverain d'une nation\",\"Un troupeau d'oies sauvages\",\n\"Une bombe qui n'a pas explosé révèle une réserve de courage inutilisée\",\"Un serpent enroulé autour d'un homme et d'une femme\",\"Un Indien tisse un panier cérémoniel\",\"Des enfants du quartier jouent avec vivacité\",\n\"Deux dignitaires austères assis côte à côte\",\"Un hamac vide tendu entre deux arbres joyeux\",\"Le filet magique de la chasse donnant du pouvoir\",\"Une jeune fille nourrissant des oiseaux en hiver\",\n\"Un boxeur entre dans le ring\",\"La porte vers le jardin de tous les désirs\",\"Une femme enceinte en robe légère\",\"Le vent d'est gonfle des rideaux d'une chambre ouverte\",\n\"Un enfant potelé chevauchant un cheval de bois\",\"Un homme possédant plus de dons qu'il ne peut développer\",\"À travers l'imagination, la perception de la valeur perdue revient\",\"Un grand jardin public\",\"Deux têtes au-dessus de leurs corps\",\n\"Un canard et ses canetons\",\"La quête en vue d'un savoir inatteignable\",\"Un défilé militaire\",\"Terrain de jeu rempli d'enfants\",\"Une fontaine d'eau dans un jardin tropical\",\n\"La musique des sphères\",\"Un oiseau royal et sa compagne\",\"Un homme tombé du ciel\",\"Le nouveau Rachel\",\"Un soldat en deuil pour un camarade\",\n\"Un enfant du soleil accroupi dans les eaux\",\"Nombreux petits oiseaux sur la branche d'un gros arbre\",\"Un arc-en-ciel sur fond de ciel d'orage\",\"Deux personnes projetées loin par l'électricité\",\"Un homme tondu\",\n\"Un gardien monte la garde\",\"Un vieux maître de sagesse\",\"Un gouffre en formation dans le désert\",\"Un moine porte un sac de riz\",\"Un combattant de taureaux bravant un danger\",\n\"Un rivière charrie du bois\",\"Un garçon sur un hobby-horse\",\"Un vieil arbre cassé au milieu, scié en bûches\",\"Les nains au travail à l'intérieur de la terre\",\"Un paon majestueux se pavane\",\n\"Un peintre face à un tableau vide\",\"Un chien blanc pourchasse un lapin\",\"Une tête coiffée d'un turban divin\",\"Les dix bûches sous un arche\",\"Illuminés par la lumière de la Lune, deux fées\",\n\"Une ligne de téléphone\",\"Le héros d'une parabole\",\"Les jeunes arbres entourés d'un grillage contre le vent\",\"Noël arbre décoré\",\"Des enfants jouent sur la plage, avec des chapeaux en forme de têtes de moustache\",\n\"Le vieux pont de pierre enjambant un cours d'eau sans prétention\",\"Une conversation téléphonique\",\"Un réfugié se rapproche de la terre promise\",\"Révolutions se succédant\",\"Un ruisseau coule, entouré de fleurs sauvages\",\n\"Une famille en voiture\",\"L'extraction du caoutchouc d'un arbre\",\"Un papillon parfait émerge de la chrysalide\",\"Le roi des fées approche ses sujets\",\"Un homme se prépare à écrire un message inspiré à l'humanité\",\n\"Un verre prisme décompose la lumière en arc-