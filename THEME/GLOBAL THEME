=> {\n        for (const h of _mTT) { for (const seg of (h.segments || [])) { if (seg.type === \"Cuspide\") { const start = seg.degre_decimal || 0; const nextH = _mTT.find(hh => hh.maison === (h.maison % 12) + 1); const end = nextH?.segments?.find(s => s.type === \"Cuspide\")?.degre_decimal || (start + 30); let d = deg, s = start, e = end; if (e < s) { if (d < s) d += 360; e += 360; } if (d >= s && d < e) return h.maison; } } }\n        return 1;\n    };\n    const _aTT = _ndTT[\"Ascendant\"], _sTT = _ndTT[\"Soleil\"], _moTT = _ndTT[\"Lune\"];\n    if (_aTT !== undefined && _sTT !== undefined && _moTT !== undefined) {\n        const isDCTT = (((_sTT - _aTT) + 360) % 360) > 180;\n        const lcTT = (a,b,c) => (((a+b-c)%360)+360)%360;\n        const liTT = (a,b,c) => (((a+c-b)%360)+360)%360;\n        const LOT_SET_TT = new Set();\n        _plTT.forEach(p => { const n = p.planet?.fr || p.planet?.en || p.name || \"\"; if (n.startsWith(\"Lot \") || n === \"Part de Fortune\") LOT_SET_TT.add(n); });\n        _mTT.forEach(h => { (h.segments || []).forEach(seg => { (seg.locataires || []).forEach(l => { const nm = l.planete || \"\"; if (nm.startsWith(\"Lot \") || nm === \"Part de Fortune\") LOT_SET_TT.add(nm); }); }); });\n        const pushTT = (name, deg) => { if (LOT_SET_TT.has(name)) return; const house = _fnhTT(deg); if (!_lotsByHouseTT[house]) _lotsByHouseTT[house] = []; _lotsByHouseTT[house].push(name); };\n        const pofTT = isDCTT ? lcTT(_aTT,_moTT,_sTT) : lcTT(_aTT,_sTT,_moTT);\n        pushTT(\"Part de Fortune\", pofTT);\n        const posTT = isDCTT ? lcTT(_aTT,_sTT,_moTT) : lcTT(_aTT,_moTT,_sTT);\n        pushTT(\"Lot de l'Esprit\", posTT);\n        const _maTT = _ndTT[\"Mars\"], _veTT = _ndTT[\"Vénus\"], _saTT = _ndTT[\"Saturne\"], _meTT = _ndTT[\"Mercure\"], _juTT = _ndTT[\"Jupiter\"];\n        if (_meTT !== undefined) pushTT(\"Lot de Nécessité\", isDCTT ? lcTT(_aTT,pofTT,_meTT) : liTT(_aTT,pofTT,_meTT));\n        if (_veTT !== undefined) pushTT(\"Lot d'Ér