Planètes et Points Sensibles'}</h2>`;\n\nconst signesOrder = [\n    { name:\"Bélier\",glyph:\"♈\" },{ name:\"Taureau\",glyph:\"♉\" },{ name:\"Gémeaux\",glyph:\"♊\" },{ name:\"Cancer\",glyph:\"♋\" },\n    { name:\"Lion\",glyph:\"♌\" },{ name:\"Vierge\",glyph:\"♍\" },{ name:\"Balance\",glyph:\"♎\" },{ name:\"Scorpion\",glyph:\"♏\" },\n    { name:\"Sagittaire\",glyph:\"♐\" },{ name:\"Capricorne\",glyph:\"♑\" },{ name:\"Verseau\",glyph:\"♒\" },{ name:\"Poissons\",glyph:\"♓\" }\n];\n\nconst ANGLE_KEY_MAP = {\"Ascendant\":\"ASC\",\"Descendant\":\"DSC\",\"Milieu du Ciel\":\"MC\",\"Imum Coeli\":\"IC\"};\nlet sortedTablePlanets = [...(input.planetes || [])].map(p => ({ ...p, fullDegree: (((p.fullDegree ?? 0) % 360) + 360) % 360 })).sort((a,b) => a.fullDegree - b.fullDegree);\n\nsignesOrder.forEach((sig, idx) => {\n    let inSign = sortedTablePlanets.filter(p => Math.floor(p.fullDegree / 30) === idx);\n\n    html += `<div class=\"sign-group\">`;\n    html += `<h3><span>${sig.name}</span> <span style=\"font-family:'Segoe UI Symbol', sans-serif; font-weight:normal; color:#ffffff; margin-left:8px;\">${sig.glyph}</span></h3>`;\n\n    if (inSign.length > 0) {\n        html += `<ul>`;\n        inSign.forEach(p => {\n            const name = p.planet?.fr || p.planet?.en || \"?\";\n            const dIndex = Math.min(Math.floor((p.normDegree ?? p.fullDegree ?? 0) / 10), 2);\n            const decanRuler = CHALDEAN_DECANS[sig.name]?.[dIndex] || \"?\";\n\n            let dignite = \"-\";\n            if (dMap[name]) {\n                const d = dMap[name];\n                if (d.dom.includes(sig.name))      dignite = isEN ? \"Domicile\" : \"En Domicile\";\n                else if (d.exa.includes(sig.name)) dignite = isEN ? \"Exalted\" : \"En Exaltation\";\n                else if (d.exi.includes(sig.name)) dignite = isEN ? \"Detriment\" : \"En Exil\";\n                else if (d.chu.includes(sig.name)) dignite = isEN ? \"Fall\" : \"En Chute\";\n                else                               dignite = isEN ? \"Peregrine\" : \"Pérégrine\";\n            }\n\n            let retro    = (p.retroStr && p.retroStr.includes(\"Rétro\")) ? \" [R]\" : \"\";\n            let digStr   = dignite !== \"-\" ? ` — <strong>${dignite}</strong>` : \"\";\n            let isAngle  = [\"Ascendant\",\"Milieu du Ciel\",\"Imum Coeli\",\"Descendant\"].includes(name);\n            let nameDisplay = isAngle ? (name === \"Imum Coeli\" ? \"Imum Coeli (Fond du Ciel)\" : name) : name;\n\n            // Tags enrichis\n            let tags = \"\";\n            const angInfo = getAngularInfo(name);\n            if (angInfo) tags += ` <span class=\"tag tag-ang\">⭐ ${isEN ? 'Angular' : 'Angulaire'} (${angInfo.angle}, ${angInfo.orb}°)</span>`;\n\n            const critInfo = getCriticalInfo(name);\n            if (critInfo) tags += ` <span class=\"tag tag-crit\">⚠ ${critInfo.flags.join(' | ')}</span>`;\n\n            const helioInfo = getHelioInfo(name);\n            if (helioInfo?.condition)   tags += ` <span class=\"tag tag-helio\">☀ ${helioInfo.condition.split('—')[0].trim()}</span>`;\n            if (helioInfo?.orientation && (name === \"Vénus\" || name === \"Mercure\")) {\n                const isMatin = helioInfo.orientation.toLowerCase().includes(\"matin\") || helioInfo.orientation.toLowerCase().includes(\"oriental\");\n                tags += ` <span class=\"tag tag-etoile\">${isMatin ? (isEN ? \"🌅 Morning Star\" : \"🌅 Étoile du Matin\") : (isEN ? \"🌆 Evening Star\" : \"🌆 Étoile du Soir\")}</span>`;\n            }\n\n            if (eclipseNatal?.house && name !== \"Ascendant\") {\n                // Vérifier si la planète est très proche du degré de l'éclipse\n                const eclDiff = Math.abs(((p.fullDegree - eclipseNatal.degree + 540) % 360) - 180);\n                if (eclDiff <= 3) tags += ` <span class=\"tag tag-eclipse\">⚡ ${isEN ? 'Natal eclipse' : 'Éclipse natale'} (${(eclDiff ?? 0).toFixed(1)}°)</span>`;\n            }\n\n            const etoileInfos = getEtoileInfos(name);\n            etoileInfos.forEach(em => {\n                const precLabel = em.precision.includes(\"forte\") ? \"★★\" : \"★\";\n                tags += ` <span class=\"tag tag-etoile\">${precLabel} ${em.etoile} (${em.orb}°)</span>`;\n            });\n            if (ANGLE_KEY_MAP[name]) {\n                const cuspStarsHere = etoileCuspMatches.filter(ec => ec.angle === ANGLE_KEY_MAP[name]);\n                cuspStarsHere.forEach(ec => {\n                    const precLabel = ec.precision.includes(\"forte\") ? \"★★\" : \"★\";\n                    tags += ` <span class=\"tag tag-etoile\">${precLabel} ${ec.etoile} (${ec.orb}°)</span>`;\n                });\n            }\n\n            const oobInfo = getOOBInfo(name);\n            if (oobInfo) tags += ` <span class=\"tag tag-oob\">⚡ ${isEN ? 'Out of Bounds' : 'Hors Limites'} (${(oobInfo.declinaison ?? 0).toFixed(2)}° ${oobInfo.hemisphere})</span>`;\n\n            const paraList = getParaList(name);\n            paraList.forEach(pa => {\n                if (pa.type === \"//\") {\n                    const lumStar = pa.hasLuminaire ? \" ★\" : \"\";\n                    tags += ` <span class=\"tag tag-parallele\">// ${isEN ? 'Parallel' : 'Parallèle'} ${pa.autre} (${pa.orb}°)${lumStar}</span>`;\n                } else {\n                    const lumStar = pa.hasLuminaire ? \" ★\" : \"\";\n                    tags += ` <span class=\"tag tag-contrepara\"># ${isEN ? 'Contra-par.' : 'Contre-par.'} ${pa.autre} (${pa.orb}°)${lumStar}</span>`;\n                }\n            });\n\n            const termRulerName = getTermRuler(sig.name, p.normDegree || 0);\n            const tripRulerName = getTriplicityRulerR(sig.name);\n            const termStr = termRulerName ? ` · ${isEN ? 'Term' : 'Terme'} : ${termRulerName}` : \"\";\n            const tripStr = tripRulerName ? ` · ${isEN ? 'Trip.' : 'Trip.'} : ${tripRulerName}` : \"\";\n            html += `<li><strong>${nameDisplay}${retro}</strong> : ${(p.normDegree || 0).toFixed(2)}° (${isEN ? 'Decan' : 'Décan'} ${dIndex+1} — ${decanRuler}${termStr}${tripStr})${digStr}${tags}</li>`;\n        });\n        html += `</ul>`;\n    } else {\n        html += `<p class=\"empty-msg\">${isEN ? 'No sensitive point in this sign.' : 'Aucun point sensible dans ce signe.'}</p>`;\n    }\n\n    html += `</div>`;\n});\n\n// ── Cascade des maîtrises ──\nconst HOUSE_DESC_THEME_FR = {\n    1: \"Identité, apparence, ego, vitalité, comportement instinctif\",\n    2: \"Ressources personnelles, finances, valeurs, talents innés, rapport à la possession\",\n    3: \"Communication, fratrie, environnement proche, échanges quotidiens\",\n    4: \"Foyer, racines, famille, sécurité intérieure, sentiment de 'chez soi'\",\n    5: \"Créativité, romance, enfants, plaisir, élan amoureux, expression de soi\",\n    6: \"Travail quotidien, santé, service, organisation, habitudes, rythme\",\n    7: \"Partenariats, mariage, contrats, ennemis déclarés, relation d'égal à égal\",\n    8: \"Intimité profonde, sexualité, crises, transformation, héritages, fusion psychologique\",\n    9: \"Voyages, philosophie, enseignement supérieur, spiritualité, quête de sens\",\n    10: \"Carrière, réputation, statut social, autorité, ambitions publiques\",\n    11: \"Amitiés, groupes, idéaux, projets collectifs, vision d'avenir\",\n    12: \"Inconscient, secrets, sacrifice, ennemis cachés, karma, liens invisibles\"\n};\nconst HOUSE_DESC_THEME_EN = {\n    1: \"Identity, appearance, ego, vitality, instinctive behavior\",\n    2: \"Personal resources, finances, values, innate talents, relationship to possessions\",\n    3: \"Communication, siblings, local environment, daily exchanges\",\n    4: \"Home, roots, family, inner security, sense of belonging\",\n    5: \"Creativity, romance, children, pleasure, romantic spark, self-expression\",\n    6: \"Daily work, health, service, organization, habits, routine\",\n    7: \"Partnerships, marriage, contracts, open enemies, equal relationship\",\n    8: \"Deep intimacy, sexuality, crises, transformation, inheritances, psychological fusion\",\n    9: \"Travel, philosophy, higher education, spirituality, quest for meaning\",\n    10: \"Career, reputation, social status, authority, public ambitions\",\n    11: \"Friendships, groups, ideals, collective projects, future vision\",\n    12: \"Unconscious, secrets, sacrifice, hidden enemies, karma, invisible bonds\"\n};\nconst HOUSE_DESC_THEME = isEN ? HOUSE_DESC_THEME_EN : HOUSE_DESC_THEME_FR;\n\nhtml += `<h2 class=\"section-title page-break\">${isEN ? 'Multi-Sign Analysis (Rulership Cascade)' : 'Analyse Multi-Signes (Cascade des Maîtrises)'}</h2>\n<table><tr><th>${isEN ? 'House' : 'Maison'}</th><th>${isEN ? 'Segment' : 'Segment'}</th><th>${isEN ? 'Start Degree' : 'Degré Début'}</th><th>${isEN ? 'Ruler' : 'Maître'}</th><th>${isEN ? 'Tenants' : 'Locataires'}</th></tr>`;\n\ninput.maisons.forEach(m => {\n    const sc = m.segments.length;\n    const hDescTheme = HOUSE_DESC_THEME[m.maison] || '';\n    html += `<tr><td colspan=\"5\" style=\"background:#f0f4fb;font-style:italic;font-size:0.88em;color:#475569;padding:6px 12px;border-bottom:2px solid #2E5FA3\">${isEN ? 'House' : 'Maison'} ${m.maison} — ${escH(hDescTheme)}</td></tr>`;\n    m.segments.forEach((seg, idx) => {\n        const locs = seg.locataires.map(l => {\n            let extra = \"\";\n            const lh = getHelioInfo(l.planete);\n            if (lh?.orientation && (l.planete === \"Vénus\" || l.planete === \"Mercure\")) {\n                const isMatin = lh.orientation.toLowerCase().includes(\"matin\") || lh.orientation.toLowerCase().includes(\"oriental\");\n                extra = ` <span style=\"font-size:0.78em;color:#2E5FA3\">${isMatin ? \"🌅\" : \"🌆\"}</span>`;\n            }\n            if (l.termLord) extra += ` <span style=\"font-size:0.72em;color:#2E5FA3\" title=\"Terme égyptien\">☿${l.termLord.nom} (M${l.termLord.maison})</span>`;\n            return `<span class=\"tag\">${l.planete}${l.retro}${extra}</span>`;\n        }).join(\" \") || `<em style='color:#94a3b8'>${isEN ? 'None' : 'Aucun'}</em>`;\n\n        let mStr = \"-\";\n        if (seg.maitre) {\n            const md = seg.maitre.dignite !== \"-\" ? ` - ${seg.maitre.dignite}` : \"\";\n            // Conditions hélio du maître\n            const mhc = getHelioInfo(seg.maitre.planete);\n            const mhcStr = mhc?.condition ? `<br><small style=\"color:#0369a1\">☀ ${mhc.condition.split('—')[0].trim()}</small>` : \"\";\n            mStr = `<strong>${seg.maitre.planete}</strong>${seg.maitre.retro} (M${seg.maitre.maison}${md})${mhcStr}`;\n            if (seg.maitre.patron) {\n                mStr += `<br><small style='color:#64748b'>↳ ${seg.maitre.patron.planete} (M${seg.maitre.patron.maison})</small>`;\n            } else {\n                mStr += `<br><small style='color:#16a34a'>↳ ${isEN ? 'Absolute domicile' : 'Domicile absolu'}</small>`;\n            }\n        }\n\n        html += `<tr>`;\n        if (idx === 0) {\n            const eclTag   = eclipseNatal?.house === m.maison ? ` <span style=\"color:#ea580c;font-size:0.8em\">⚡</span>` : \"\";\n            const cuspStars = getCuspEtoiles(m.maison);\n            const cuspTag  = cuspStars.length > 0\n                ? ` <span style=\"color:#2E5FA3;font-size:0.8em\" title=\"${cuspStars.map(e=>e.etoile+'('+e.orb+'°)').join(', ')}\">★</span>`\n                : \"\";\n            html += `<td rowspan=\"${sc}\" style=\"background:#f8fafc;vertical-align:top;font-weight:bold;color:#1F3864;\">M${m.maison}${eclTag}${cuspTag}</td>`;\n        }\n        html += `<td>${seg.signe}<br><small style=\"color:#64748b\">(${seg.type})</small></td><td>${(seg.degre_debut ?? 0).toFixed(2)}°</td><td>${mStr}</td><td>${locs}</td></tr>`;\n    });\n});\nhtml += `</table>`;\n\n// ── Configurations natales (si présentes) ──\nif (configurations.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Natal Configurations' : 'Configurations Natales'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 15px;padding:10px 16px;background:#eef2fb;border-radius:8px;border-left:4px solid #2E5FA3;font-size:0.92em;\">\n        ${isEN ? 'Figures sorted by <strong>descending Power Score</strong>. Legend:' : 'Figures triées par <strong>Score de Puissance décroissant</strong>. Légende :'}\n        <span class=\"score-badge score-absolu\">${isEN ? 'ABSOLUTE PRIORITY' : 'PRIORITÉ ABSOLUE'} ≥120</span>\n        <span class=\"score-badge score-majeur\">${isEN ? 'Major' : 'Majeure'} ≥80</span>\n        <span class=\"score-badge score-signif\">${isEN ? 'Significant' : 'Significative'} ≥50</span>\n        <span class=\"score-badge score-mineur\">${isEN ? 'Minor' : 'Mineure'} &lt;50</span>\n    </p>`;\n    const hasSubs = configurations.some(c => c.subConfigOf);\n    if (hasSubs) {\n        html += `<p style=\"font-size:0.82em;color:#64748b;margin:0 0 12px 0;\">\n            <em>${isEN\n              ? 'Indented configurations (dashed line) are geometrically contained within the parent figure — their planets are identical. They are <strong>structural facets</strong> of the higher-ranking figure and should not be counted as independent events.'\n              : 'Les configurations en retrait (trait pointillé) sont géométriquement contenues dans la figure parente — leurs planètes sont identiques. Elles constituent des <strong>facettes structurelles</strong> de la figure de rang supérieur et ne doivent pas être comptées comme des événements indépendants.'}</em></p>`;\n    }\n    // Compteur pour limiter les T-Carrés affichés sous un même Grand Carré à 2 max\n    const tcarreCountByParent = {};\n    const MAX_TCARRE_PER_GRAND_CARRE = 2;\n\n    configurations.forEach(c => {\n        const score = c.puissanceScore !== undefined ? c.puissanceScore : null;\n        const _rawLabel = c.prioriteLabel || \"Mineure\";\n        const _labelEN = {\"Mineure\":\"Minor\",\"Significative\":\"Significant\",\"Majeure\":\"Major\",\"PRIORITÉ ABSOLUE\":\"ABSOLUTE PRIORITY\"};\n        const label = isEN ? (_labelEN[_rawLabel] || _rawLabel) : _rawLabel;\n        const isSub = !!c.subConfigOf;\n\n        // Limiter les T-Carrés indentés sous un même Grand Carré à 2 max.\n        // Clé = planètes du Grand Carré parent (unique par Grand Carré, même s'il y en a plusieurs).\n        if (c.type === \"T-Carré\" && c.subConfigOf === \"Grand Carré\" && c.subConfigType === \"child\") {\n            const parentGC = configurations.find(p =>\n                p.type === \"Grand Carré\" && !p.subConfigOf && c.planets && p.planets &&\n                c.planets.every(pl => p.planets.includes(pl))\n            );\n            const parentKey = parentGC ? parentGC.planets.slice().sort().join(\"|\") : c.planets.slice().sort().join(\"|\");\n            tcarreCountByParent[parentKey] = (tcarreCountByParent[parentKey] || 0) + 1;\n            if (tcarreCountByParent[parentKey] > MAX_TCARRE_PER_GRAND_CARRE) return; // skip\n        }\n\n        let badgeClass = \"score-mineur\";\n        if (score >= 120) badgeClass = \"score-absolu\";\n        else if (score >= 80) badgeClass = \"score-majeur\";\n        else if (score >= 50) badgeClass = \"score-signif\";\n        const scoreBadge = score !== null\n            ? `<span class=\"score-badge ${badgeClass}\">Score ${score} — ${label}</span>`\n            : \"\";\n        const isVariant = isSub && c.subConfigType === \"variant\";\n        const subTag = isVariant\n            ? `<span class=\"tag-variant\">↳ ${isEN ? `variant of ${c.subConfigOf} (${c.sharedPlanets} shared planets)` : `variante du ${c.subConfigOf} (${c.sharedPlanets} planètes communes)`}</span>`\n            : isSub\n                ? `<span class=\"tag-sub-config\">↳ ${isEN ? `component of ${c.subConfigOf}` : `composante du ${c.subConfigOf}`}</span>`\n                : \"\";\n        if (isSub) {\n            html += `<div class=\"config-item-sub\">\n                <div class=\"config-type-sub\">${c.type}${scoreBadge}${subTag}</div>\n                <div style=\"font-size:0.88em;color:#475569;\">${c.description}</div>\n            </div>`;\n        } else {\n            html += `<div class=\"config-item\">\n                <div class=\"config-type\">${c.type}${scoreBadge}</div>\n                <div>${c.description}</div>\n            </div>`;\n        }\n    });\n}\n\n// ── Réceptions mutuelles (si présentes) ──\nif (mutualReceptions.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Mutual Receptions' : 'Réceptions Mutuelles'}</h2>\n    <table><tr><th>${isEN ? 'Planet A' : 'Planète A'}</th><th>${isEN ? 'Sign A' : 'Signe A'}</th><th>${isEN ? 'House A' : 'Maison A'}</th><th>${isEN ? 'Planet B' : 'Planète B'}</th><th>${isEN ? 'Sign B' : 'Signe B'}</th><th>${isEN ? 'House B' : 'Maison B'}</th><th>Type</th></tr>`;\n    mutualReceptions.forEach(mr => {\n        const typeLabel = mr.type === \"exaltation\"\n            ? `<span style=\"color:#2E5FA3;font-size:0.85em;font-weight:bold\">Exaltation</span>`\n            : mr.type === \"mixte\"\n            ? `<span style=\"color:#6d28d9;font-size:0.85em;font-weight:bold\">Mixte (Dom↔Exa)</span>`\n            : `<span style=\"color:#1F3864;font-size:0.85em;font-weight:bold\">Domicile</span>`;\n        html += `<tr><td><strong>${mr.p1}</strong></td><td>${mr.sign1}</td><td>M${mr.house1}</td><td><strong>${mr.p2}</strong></td><td>${mr.sign2}</td><td>M${mr.house2}</td><td style=\"text-align:center\">${typeLabel}</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Aspects majeurs ──\nconst aspectColors = { \"Carré\":\"#ee4400\",\"Trigone\":\"#1155cc\",\"Opposition\":\"#cc0000\",\"Sextile\":\"#009944\",\"Conjonction\":\"#9900dd\" };\n// Ne garder que les aspects majeurs pour ce tableau\nconst majorAspects = (input.aspects || []).filter(a => a.isMajor !== false && aspectColors[a.aspect]);\n\nhtml += `<h2 class=\"section-title page-break\">${isEN ? 'Major Aspects' : 'Aspects Majeurs'}</h2>\n<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:8px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n    ${isEN\n      ? 'Sorted by <strong>descending Weight</strong>. Formula: Base (type) + Exactitude + Luminary (+8) + Angle (+6) + Fixed Star (+5) + OOB (+4).'\n      : 'Triés par <strong>Poids décroissant</strong>. Formule : Base (type) + Exactitude + Luminaire (+8) + Angle (+6) + Étoile Fixe (+5) + OOB (+4).'}\n    <strong style=\"color:#1F3864\">${isEN ? 'Capital' : 'Capital'} ≥30</strong> · <strong style=\"color:#2E5FA3\">${isEN ? 'Strong' : 'Fort'} ≥20</strong> · <strong style=\"color:#5b8ac7\">${isEN ? 'Moderate' : 'Modéré'} ≥12</strong> · <strong style=\"color:#64748b\">${isEN ? 'Minor' : 'Mineur'} &lt;12</strong>\n</p>\n<table><tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th>${isEN ? 'Aspect' : 'Aspect'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th>${isEN ? 'Orb' : 'Orbe'}</th><th style=\"text-align:center\">${isEN ? 'Weight' : 'Poids'}</th></tr>`;\nmajorAspects.forEach(a => {\n    const c     = aspectColors[a.aspect] || \"#1e293b\";\n    const score = a.score;\n    let badgeClass = \"score-mineur\", badgeLabel = isEN ? \"Minor\" : \"Mineur\";\n    if      (score >= 30) { badgeClass = \"score-absolu\"; badgeLabel = \"Capital\"; }\n    else if (score >= 20) { badgeClass = \"score-majeur\"; badgeLabel = isEN ? \"Strong\" : \"Fort\"; }\n    else if (score >= 12) { badgeClass = \"score-signif\"; badgeLabel = isEN ? \"Moderate\" : \"Modéré\"; }\n    const badge = score !== undefined\n        ? `<span class=\"score-badge ${badgeClass}\">${badgeLabel}</span><br><small style=\"color:#94a3b8\">${score} pts</small>`\n        : \"\";\n    html += `<tr>\n        <td><strong>${a.p1}</strong></td>\n        <td style=\"color:${c};font-weight:bold;\">${a.aspect}</td>\n        <td><strong>${a.p2}</strong></td>\n        <td style=\"text-align:center\">${a.exactitude}°</td>\n        <td style=\"text-align:center\">${badge}</td>\n    </tr>`;\n});\nhtml += `</table>`;\n\n// ── Aspects Mineurs Promus (entre Majeurs et Mineurs) ──\nconst promotedMinorAspects = (input.aspects || []).filter(a => a.isMajor === false && a.isPromoted === true);\nconst minorAspectColors = {\n    \"Quintile\":    \"#1155cc\",\n    \"Biquintile\":  \"#1155cc\",\n    \"Semi-Sextile\":\"#6b7280\",\n    \"Semi-Carré\":  \"#dd6600\",\n    \"Sesqui-Carré\":\"#cc4400\",\n    \"Quinconce\":   \"#b45309\"\n};\nconst minorAspectNatures = isEN ? {\n    \"Quintile\":    \"harmonious — creative gift\",\n    \"Biquintile\":  \"harmonious — advanced latent talent\",\n    \"Semi-Sextile\":\"neutral — minor irritant, adjacent signs\",\n    \"Semi-Carré\":  \"tense — slight friction\",\n    \"Sesqui-Carré\":\"tense — constructive friction\",\n    \"Quinconce\":   \"tense — mandatory adjustment\"\n} : {\n    \"Quintile\":    \"harmonieux — don créateur\",\n    \"Biquintile\":  \"harmonieux — talent latent avancé\",\n    \"Semi-Sextile\":\"neutre — irritant mineur, signes adjacents\",\n    \"Semi-Carré\":  \"tensionnel — friction légère\",\n    \"Sesqui-Carré\":\"tensionnel — friction constructive\",\n    \"Quinconce\":   \"tensionnel — ajustement obligatoire\"\n};\n\nif (promotedMinorAspects.length > 0) {\n    html += `<div class=\"promoted-banner\">\n        <div class=\"promoted-banner-title\">⚠ ${isEN ? 'Promoted Minor Aspects — Priority Equivalent to Major Aspects' : 'Aspects Mineurs Promus — Priorité Équivalente aux Aspects Majeurs'}</div>\n        <div style=\"color:#1F3864;font-size:0.9em;font-style:italic;margin-bottom:10px;\">\n            ${isEN\n              ? 'These aspects, although minor in geometric type, reach a high power score due to their exactitude and/or involvement with Luminaries, Angles, or Out-of-Bounds planets. Thresholds: major planets ≥ 20 pts — minor bodies ≥ 28 pts.'\n              : 'Ces aspects, bien que de type géométrique mineur, atteignent un score de puissance élevé en raison de leur exactitude et/ou de leur implication avec des Luminaires, Angles ou planètes Hors Limites. Seuils : planètes majeures ≥ 20 pts — petits corps ≥ 28 pts.'}\n        </div>\n        <table style=\"margin-top:0\">\n            <tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th>${isEN ? 'Aspect' : 'Aspect'}</th><th>${isEN ? 'Nature' : 'Nature'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th style=\"text-align:center\">${isEN ? 'Orb' : 'Orbe'}</th><th style=\"text-align:center\">${isEN ? 'Weight' : 'Poids'}</th></tr>`;\n    promotedMinorAspects.forEach(a => {\n        const c      = minorAspectColors[a.aspect] || \"#64748b\";\n        const nature = minorAspectNatures[a.aspect] || \"\";\n        const score  = a.score;\n        let badgeClass = \"score-signif\", badgeLabel = isEN ? \"Moderate\" : \"Modéré\";\n        if      (score >= 30) { badgeClass = \"score-absolu\"; badgeLabel = \"Capital\"; }\n        else if (score >= 20) { badgeClass = \"score-majeur\"; badgeLabel = isEN ? \"Strong\" : \"Fort\"; }\n        const badge = `<span class=\"score-badge ${badgeClass}\">${badgeLabel}</span><br><small style=\"color:#94a3b8\">${score} pts</small>`;\n        html += `<tr style=\"background:#f0f4ff\">\n            <td><strong>${a.p1}</strong></td>\n            <td style=\"color:${c};font-weight:bold;\">${a.aspect}</td>\n            <td style=\"font-size:0.85em;color:${c};font-style:italic\">${nature}</td>\n            <td><strong>${a.p2}</strong></td>\n            <td style=\"text-align:center\">${a.exactitude}°</td>\n            <td style=\"text-align:center\">${badge}</td>\n        </tr>`;\n    });\n    html += `</table></div>`;\n}\n\n// ── Aspects mineurs (section compacte, si présents) ──\nconst minorAspects = (input.aspects || []).filter(a => a.isMajor === false);\nif (minorAspects.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Minor Aspects' : 'Aspects Mineurs'}</h2>\n    <table><tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th>${isEN ? 'Aspect' : 'Aspect'}</th><th>${isEN ? 'Nature' : 'Nature'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th style=\"text-align:center\">${isEN ? 'Orb' : 'Orbe'}</th><th style=\"text-align:center\">${isEN ? 'Weight' : 'Poids'}</th></tr>`;\n    minorAspects.forEach(a => {\n        const c      = minorAspectColors[a.aspect] || \"#64748b\";\n        const nature = minorAspectNatures[a.aspect] || \"\";\n        const score  = a.score;\n        let badgeClass = \"score-mineur\", badgeLabel = isEN ? \"Minor\" : \"Mineur\";\n        if      (score >= 30) { badgeClass = \"score-absolu\"; badgeLabel = \"Capital\"; }\n        else if (score >= 20) { badgeClass = \"score-majeur\"; badgeLabel = isEN ? \"Strong\" : \"Fort\"; }\n        else if (score >= 12) { badgeClass = \"score-signif\"; badgeLabel = isEN ? \"Moderate\" : \"Modéré\"; }\n        const badge = score !== undefined\n            ? `<span class=\"score-badge ${badgeClass}\">${badgeLabel}</span><br><small style=\"color:#94a3b8\">${score} pts</small>`\n            : \"\";\n        const promoTag = a.isPromoted ? `<span class=\"tag-promo\">★ ${isEN ? 'Promoted' : 'Promu'}</span>` : \"\";\n        const rowStyle = a.isPromoted ? ' style=\"background:#f0f4ff\"' : '';\n        html += `<tr${rowStyle}>\n            <td>${a.p1}${promoTag}</td>\n            <td style=\"color:${c};font-weight:bold;\">${a.aspect}</td>\n            <td style=\"font-size:0.85em;color:${c};font-style:italic\">${nature}</td>\n            <td>${a.p2}</td>\n            <td style=\"text-align:center\">${a.exactitude}°</td>\n            <td style=\"text-align:center\">${badge}</td>\n        </tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Déclinaisons Équatoriales (OOB + Tableau + Parallèles + Contre-Parallèles) ──\n{\n    const declPlanetes = (input.planetes || []).filter(p => typeof p.declinaison === 'number');\n    const hasDecl = declPlanetes.length > 0 || planeteOOB.length > 0 || paralleles.length > 0 || contreParalleles.length > 0;\n\n    if (hasDecl) {\n        html += `<h2 class=\"section-title page-break\">${isEN ? 'Equatorial Declinations' : 'Déclinaisons Équatoriales'}</h2>`;\n        html += `<p class=\"decl-intro\">\n            ${isEN\n              ? 'Declinations measure the angular distance in degrees of each planet from the celestial equator (3D dimension). <strong>Out of Bounds</strong> threshold: <strong>±23.44°</strong> (Sun\\'s ecliptic limit). <strong>Parallel (//):</strong> same hemisphere, ≤1° difference (≤1.5° if Luminary) — acts as a conjunction. <strong>Contra-Parallel (#):</strong> opposite hemispheres, same absolute values ≤1° — acts as an opposition.'\n              : 'Les déclinaisons mesurent l\\'écart en degrés de chaque planète par rapport à l\\'équateur céleste (dimension 3D). Seuil <strong>Hors Limites</strong> : <strong>±23.44°</strong> (limite écliptique du Soleil). <strong>Parallèle (//) :</strong> même hémisphère, ≤1° d\\'écart (≤1.5° si Luminaire) — agit comme une conjonction. <strong>Contre-Parallèle (#) :</strong> hémisphères opposés, mêmes valeurs absolues ≤1° — agit comme une opposition.'}\n        </p>`;\n\n        // ── Tableau global des déclinaisons ──\n        if (declPlanetes.length > 0) {\n            const OOB_THRESH = 23.44;\n            const sortedDecl = [...declPlanetes].sort((a, b) => Math.abs(b.declinaison) - Math.abs(a.declinaison));\n            html += `<h3 class=\"subsection-title\">${isEN ? 'Declinations Table (sorted by descending absolute value)' : 'Tableau des Déclinaisons (trié par valeur absolue décroissante)'}</h3>`;\n            html += `<div class=\"decl-table-wrap\"><table>\n                <tr>\n                    <th>${isEN ? 'Planet / Object' : 'Planète / Objet'}</th>\n                    <th style=\"text-align:center\">${isEN ? 'Declination' : 'Déclinaison'}</th>\n                    <th style=\"text-align:center\">${isEN ? 'Hemisphere' : 'Hémisphère'}</th>\n                    <th>${isEN ? 'Status' : 'Statut'}</th>\n                    <th>${isEN ? 'Declination Aspects' : 'Aspects de Déclinaison'}</th>\n                </tr>`;\n            sortedDecl.forEach(p => {\n                const name   = p.planet?.fr || p.planet?.en || \"?\";\n                const decl   = p.declinaison;\n                const absD   = Math.abs(decl);\n                const hemi   = decl >= 0 ? (isEN ? \"North\" : \"Nord\") : (isEN ? \"South\" : \"Sud\");\n                const isOOB  = absD > OOB_THRESH;\n                const depass = isOOB ? parseFloat((absD - OOB_THRESH).toFixed(2)) : null;\n                const paras  = getParaList(name);\n\n                const statutCell = isOOB\n                    ? `<span class=\"tag tag-oob\" style=\"font-size:0.9em;\">⚡ ${isEN ? 'Out of Bounds' : 'Hors Limites'} (+${depass}°)</span>`\n                    : `<span style=\"color:#64748b;font-size:0.9em;\">${isEN ? 'Within bounds' : 'Dans les limites'}</span>`;\n\n                const paraCell = paras.length > 0\n                    ? paras.map(pa => pa.type === \"//\"\n                        ? `<span class=\"tag tag-parallele\" style=\"font-size:0.85em;\">// ${pa.autre} (${pa.orb}°)${pa.hasLuminaire ? ' ★' : ''}</span>`\n                        : `<span class=\"tag tag-contrepara\" style=\"font-size:0.85em;\"># ${pa.autre} (${pa.orb}°)${pa.hasLuminaire ? ' ★' : ''}</span>`\n                    ).join(\" \")\n                    : `<span style=\"color:#94a3b8;font-size:0.85em;font-style:italic;\">${isEN ? 'None' : 'Aucun'}</span>`;\n\n                const rowStyle = isOOB ? ' style=\"background:#fdf2f8;\"' : '';\n                html += `<tr${rowStyle}>\n                    <td><strong>${name}</strong></td>\n                    <td style=\"text-align:center;font-weight:bold;color:${isOOB ? '#831843' : '#1F3864'}\">${decl >= 0 ? \"+\" : \"\"}${decl.toFixed(4)}°</td>\n                    <td style=\"text-align:center\">${hemi}</td>\n                    <td>${statutCell}</td>\n                    <td>${paraCell}</td>\n                </tr>`;\n            });\n            html += `</table></div>`;\n        }\n\n        // ── Tableau Parallèles ──\n        if (paralleles.length > 0) {\n            html += `<h3 class=\"subsection-title\">${isEN ? '// Declination Parallels — Act as Conjunctions' : '// Parallèles de Déclinaison — Agissent comme des Conjonctions'}</h3>`;\n            html += `<p style=\"margin:0 0 10px;font-size:0.9em;color:#1F3864;font-style:italic;padding:8px 12px;background:#eef2fb;border-radius:6px;\">\n                ${isEN\n                  ? 'Two planets in the same hemisphere (N/N or S/S) within 1° (or 1.5° if Luminary) of declination difference. Their energy fusion is deep and permanent, operating below the level of daily consciousness.'\n                  : 'Deux planètes du même hémisphère (N/N ou S/S) à moins de 1° (ou 1.5° si Luminaire) d\\'écart en déclinaison. Leur fusion d\\'énergie est profonde et permanente, opérant en dessous du niveau de la conscience quotidienne.'}\n            </p>`;\n            html += `<table>\n                <tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th style=\"text-align:center\">${isEN ? 'Decl. 1' : 'Décl. 1'}</th><th style=\"text-align:center\">${isEN ? 'Hemisphere' : 'Hémisphère'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th style=\"text-align:center\">${isEN ? 'Decl. 2' : 'Décl. 2'}</th><th style=\"text-align:center\">${isEN ? 'Orb' : 'Orbe'}</th><th>${isEN ? 'Note' : 'Note'}</th></tr>`;\n            paralleles.forEach(p => {\n                const hemi = p.hemisphere;\n                const lumRow = p.hasLuminaire ? ' style=\"background:#eef2fb;\"' : '';\n                const lumNote = p.hasLuminaire\n                    ? `<span class=\"tag tag-parallele\" style=\"font-size:0.85em;\">★ ${isEN ? 'Luminary (extended orb 1.5°)' : 'Luminaire (orbe étendu 1.5°)'}</span>`\n                    : `<span style=\"color:#64748b;font-size:0.85em;\">Standard</span>`;\n                html += `<tr${lumRow}>\n                    <td><strong>${p.p1}</strong></td>\n                    <td style=\"text-align:center;font-weight:bold;color:#2E5FA3\">${(p.decl1 ?? 0) >= 0 ? \"+\" : \"\"}${(p.decl1 ?? 0).toFixed(4)}°</td>\n                    <td style=\"text-align:center\">${hemi}</td>\n                    <td><strong>${p.p2}</strong></td>\n                    <td style=\"text-align:center;font-weight:bold;color:#2E5FA3\">${(p.decl2 ?? 0) >= 0 ? \"+\" : \"\"}${(p.decl2 ?? 0).toFixed(4)}°</td>\n                    <td style=\"text-align:center\"><strong>${p.orb}°</strong></td>\n                    <td>${lumNote}</td>\n                </tr>`;\n            });\n            html += `</table>`;\n        }\n\n        // ── Tableau Contre-Parallèles ──\n        if (contreParalleles.length > 0) {\n            html += `<h3 class=\"subsection-title\"># ${isEN ? 'Declination Contra-Parallels — Act as Oppositions' : 'Contre-Parallèles de Déclinaison — Agissent comme des Oppositions'}</h3>`;\n            html += `<p style=\"margin:0 0 10px;font-size:0.9em;color:#1F3864;font-style:italic;padding:8px 12px;background:#e8f0fe;border-radius:6px;\">\n                ${isEN\n                  ? 'Two planets in opposite hemispheres (N/S) with close absolute values within 1° (or 1.5° if Luminary). This equatorial tension is often more lasting and intimate than a longitudinal opposition.'\n                  : 'Deux planètes d\\'hémisphères opposés (N/S) avec des valeurs absolues proches à moins de 1° (ou 1.5° si Luminaire). Cette tension équatoriale est souvent plus durable et plus intime qu\\'une opposition en longitude.'}\n            </p>`;\n            html += `<table>\n                <tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th style=\"text-align:center\">${isEN ? 'Decl. 1' : 'Décl. 1'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th style=\"text-align:center\">${isEN ? 'Decl. 2' : 'Décl. 2'}</th><th style=\"text-align:center\">${isEN ? 'Orb' : 'Orbe'}</th><th>${isEN ? 'Note' : 'Note'}</th></tr>`;\n            contreParalleles.forEach(p => {\n                const lumRow = p.hasLuminaire ? ' style=\"background:#e8f0fe;\"' : '';\n                const lumNote = p.hasLuminaire\n                    ? `<span class=\"tag tag-contrepara\" style=\"font-size:0.85em;\">★ ${isEN ? 'Luminary (extended orb 1.5°)' : 'Luminaire (orbe étendu 1.5°)'}</span>`\n                    : `<span style=\"color:#64748b;font-size:0.85em;\">Standard</span>`;\n                html += `<tr${lumRow}>\n                    <td><strong>${p.p1}</strong></td>\n                    <td style=\"text-align:center;font-weight:bold;color:#1F3864\">${(p.decl1 ?? 0) >= 0 ? \"+\" : \"\"}${(p.decl1 ?? 0).toFixed(4)}°</td>\n                    <td><strong>${p.p2}</strong></td>\n                    <td style=\"text-align:center;font-weight:bold;color:#1F3864\">${(p.decl2 ?? 0) >= 0 ? \"+\" : \"\"}${(p.decl2 ?? 0).toFixed(4)}°</td>\n                    <td style=\"text-align:center\"><strong>${p.orb}°</strong></td>\n                    <td>${lumNote}</td>\n                </tr>`;\n            });\n            html += `</table>`;\n        }\n\n        if (paralleles.length === 0 && contreParalleles.length === 0) {\n            html += `<p class=\"empty-msg\">${isEN ? `No parallel or contra-parallel detected within defined orb limits (${1.0}° standard / ${1.5}° Luminaries).` : `Aucun parallèle ni contre-parallèle détecté dans les limites d'orbe définies (${1.0}° standard / ${1.5}° Luminaires).`}</p>`;\n        }\n    }\n}\n\n// ── Étoiles Fixes — Influences stellaires ──\nif (etoileMatches.length > 0 || etoileCuspMatches.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Fixed Stars — Stellar Influences' : 'Étoiles Fixes — Influences Stellaires'}</h2>`;\n    html += `<p style=\"color:#5d4037;font-style:italic;margin:0 0 15px;padding:12px 16px;background:#fff8e1;border-radius:8px;border-left:4px solid #ffb300;font-size:0.95em;\">\n        ${isEN\n          ? 'Orbs applied: <strong>±2°</strong> for Aldebaran, Sirius, Regulus, Spica, Antares (royal/major stars) — <strong>±1°</strong> for Algol, Pleiades, Vega, Fomalhaut. Precision: <strong style=\"color:#5d4037\">★★ strong ≤1°</strong> / <strong style=\"color:#b8860b\">★ notable ≤2°</strong> (only for ±2° stars). A fixed star / natal planet or angle conjunction is a <em>permanent signature</em> of the chart.'\n          : 'Orbes appliqués : <strong>±2°</strong> pour Aldébaran, Sirius, Régulus, Spica, Antarès (étoiles royales/majeures) — <strong>±1°</strong> pour Algol, Pléiades, Véga, Fomalhaut. Précision : <strong style=\"color:#5d4037\">★★ forte ≤1°</strong> / <strong style=\"color:#b8860b\">★ notable ≤2°</strong> (uniquement pour les étoiles à ±2°). Une conjonction étoile fixe / planète ou angle natal est une <em>signature permanente</em> du thème.'}\n    </p>`;\n\n    if (etoileMatches.length > 0) {\n        html += `<h3 class=\"subsection-title\">${isEN ? 'Natal Planet / Fixed Star Conjunctions' : 'Conjonctions Planètes Natales / Étoiles Fixes'}</h3>`;\n        html += `<table>\n            <tr><th>${isEN ? 'Natal Planet' : 'Planète Natale'}</th><th>${isEN ? 'Fixed Star' : 'Étoile Fixe'}</th><th>${isEN ? 'House' : 'Maison'}</th><th>${isEN ? 'Sign' : 'Signe'}</th><th>${isEN ? 'Orb' : 'Orbe'}</th><th>${isEN ? 'Precision' : 'Précision'}</th></tr>`;\n        etoileMatches.forEach(em => {\n            const precColor  = em.precision.includes(\"forte\") ? \"#5d4037\" : \"#b8860b\";\n            const precSymbol = em.precision.includes(\"forte\") ? \"★★\" : \"★\";\n            const angleStyle = em.isAngle ? \" style=\\\"background:#fffbeb\\\"\" : \"\";\n            html += `<tr${angleStyle}>\n                <td><strong>${em.planete}</strong>${em.isAngle ? ' <small style=\"color:#5d4037\">[angle]</small>' : ''}</td>\n                <td>\n                    <strong style=\"color:#5d4037\">${em.etoile}</strong>\n                    <small style=\"color:#94a3b8;display:block\">${em.etoile_en}</small>\n                </td>\n                <td style=\"text-align:center;font-weight:bold;color:#5d4037\">M${em.maison}</td>\n                <td>${em.signe}</td>\n                <td style=\"text-align:center\">${em.orb}°</td>\n                <td style=\"text-align:center;font-weight:bold;color:${precColor}\">${precSymbol} ${em.precision.replace(\"forte (≤1°)\",\"forte\").replace(\"notable (≤2°)\",\"notable\")}</td>\n            </tr>\n            <tr style=\"background:#fffbeb\">\n                <td colspan=\"6\" style=\"font-style:italic;color:#5d4037;font-size:0.88em;padding:6px 12px 10px\">${em.desc}</td>\n            </tr>`;\n        });\n        html += `</table>`;\n    }\n\n    if (etoileCuspMatches.length > 0) {\n        html += `<h3 class=\"subsection-title\">${isEN ? 'Fixed Stars on the 4 Angles (H1 ASC · H4 IC · H7 DSC · H10 MC)' : 'Étoiles Fixes sur les 4 Angles (M1 ASC · M4 IC · M7 DSC · M10 MC)'}</h3>`;\n        html += `<p style=\"margin:0 0 10px;font-size:0.9em;color:#64748b;font-style:italic;\">\n            ${isEN\n              ? 'A fixed star on an angle colors the fundamental identity of this chart pillar, regardless of any tenant. Its influence is decisive for the overall expression of the chart.'\n              : 'Une étoile fixe sur un angle teinte l\\'identité fondamentale de ce pilier du thème, indépendamment de tout locataire. Son influence est déterminante pour l\\'expression globale du thème.'}\n        </p>`;\n        html += `<table>\n            <tr><th>${isEN ? 'Angle' : 'Angle'}</th><th>${isEN ? 'Fixed Star' : 'Étoile Fixe'}</th><th>${isEN ? 'Cusp Sign' : 'Signe de la Cuspide'}</th><th>${isEN ? 'Orb' : 'Orbe'}</th><th>${isEN ? 'Precision' : 'Précision'}</th></tr>`;\n        etoileCuspMatches.forEach(ec => {\n            const precColor  = ec.precision.includes(\"forte\") ? \"#5d4037\" : \"#b8860b\";\n            const precSymbol = ec.precision.includes(\"forte\") ? \"★★\" : \"★\";\n            html += `<tr style=\"background:#fffbeb\">\n                <td><strong style=\"color:#5d4037\">M${ec.maison} — ${ec.angle}</strong></td>\n                <td>\n                    <strong style=\"color:#5d4037\">${ec.etoile}</strong>\n                    <small style=\"color:#94a3b8;display:block\">${ec.etoile_en}</small>\n                </td>\n                <td>${ec.signe}</td>\n                <td style=\"text-align:center\">${ec.orb}°</td>\n                <td style=\"text-align:center;font-weight:bold;color:${precColor}\">${precSymbol} ${ec.precision.replace(\"forte (≤1°)\",\"forte\").replace(\"notable (≤2°)\",\"notable\")}</td>\n            </tr>\n            <tr style=\"background:#fffbeb\">\n                <td colspan=\"5\" style=\"font-style:italic;color:#5d4037;font-size:0.88em;padding:6px 12px 10px\">${ec.desc}</td>\n            </tr>`;\n        });\n        html += `</table>`;\n    }\n\n    if (paranResults.length > 0) {\n        html += `<h3 class=\"subsection-title\">${isEN ? 'Parans — Fixed Stars Co-Angularity (Brady Method)' : 'Parans — Co-angularité d\\'Étoiles Fixes (méthode Brady)'}</h3>`;\n        html += `<p style=\"margin:0 0 10px;font-size:0.9em;color:#64748b;font-style:italic;\">\n            ${isEN\n              ? 'A paran forms when a fixed star and a planet are simultaneously on a cardinal angle (rising, setting, culmination, or anti-culmination). It is a deep and permanent link, calculated according to geographic latitude.'\n              : 'Un paran se forme quand une étoile fixe et une planète se trouvent simultanément sur un angle cardinal (lever, coucher, culmination ou anti-culmination). C\\'est un lien profond et permanent, calculé selon la latitude géographique.'}\n        </p>`;\n        html += `<table>\n            <tr><th>${isEN ? 'Fixed Star' : 'Étoile Fixe'}</th><th>${isEN ? 'Star Angle' : 'Angle Étoile'}</th><th>${isEN ? 'Planet' : 'Planète'}</th><th>${isEN ? 'Planet Angle' : 'Angle Planète'}</th><th>${isEN ? 'RAMC Orb' : 'Orbe RAMC'}</th><th>${isEN ? 'Interpretation' : 'Interprétation'}</th></tr>`;\n        paranResults.forEach(pr => {\n            const orbColor = pr.orb <= 0.5 ? \"#5d4037\" : pr.orb <= 1.0 ? \"#b8860b\" : \"#94a3b8\";\n            html += `<tr style=\"background:#fffbeb\">\n                <td><strong style=\"color:#5d4037\">${pr.etoile}</strong></td>\n                <td style=\"text-align:center\">${pr.angle_etoile}</td>\n                <td><strong style=\"color:#5d4037\">${pr.planete}</strong> <small style=\"color:#94a3b8\">${pr.signe_planete || ''}</small></td>\n                <td style=\"text-align:center\">${pr.angle_planete}</td>\n                <td style=\"text-align:center;color:${orbColor};font-weight:bold\">${pr.orb}°</td>\n                <td style=\"font-size:0.88em;color:#5d4037;font-style:italic\">${pr.interpretation}</td>\n            </tr>`;\n            if (pr.etoile_desc) {\n                html += `<tr style=\"background:#fff8e1\">\n                    <td colspan=\"6\" style=\"font-size:0.85em;color:#5d4037;padding:4px 12px 8px;border-top:none\">${pr.etoile_desc.substring(0, 200)}</td>\n                </tr>`;\n            }\n        });\n        html += `</table>`;\n    }\n}\n\n// ── Antiscia et Contra-Antiscia (si présents) ──\nif (antiscia.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Antiscia and Contra-Antiscia' : 'Antiscia et Contra-Antiscia'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'Antiscia are solar declination mirrors on the solstice axis (0° Cancer / 0° Capricorn). Two planets in antiscia share the same day length — a hidden connection acting as a subtle conjunction. Contra-Antiscia (mirror on the equinox axis) act as a discreet opposition. Orb applied: <strong>±1.5°</strong>.'\n          : 'Les Antiscia sont des miroirs de déclinaison solaire sur l\\'axe des solstices (0° Cancer / 0° Capricorne). Deux planètes en antiscia partagent la même durée de jour — connexion cachée agissant comme une conjonction subtile. Les Contra-Antiscia (miroir sur l\\'axe des équinoxes) agissent comme une opposition discrète. Orbe appliqué : <strong>±1.5°</strong>.'}\n    </p>`;\n    html += `<table>\n        <tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th>Type</th><th style=\"text-align:center\">${isEN ? 'Orb' : 'Orbe'}</th></tr>`;\n    antiscia.forEach(a => {\n        const isContra = a.type === \"Contra-antiscia\";\n        const typeStyle = isContra ? \"color:#1F3864;font-weight:bold\" : \"color:#2E5FA3;font-weight:bold\";\n        const rowBg = isContra ? ' style=\"background:#e8f0fe\"' : ' style=\"background:#eef2fb\"';\n        html += `<tr${rowBg}>\n            <td><strong>${a.p1}</strong></td>\n            <td><strong>${a.p2}</strong></td>\n            <td><span style=\"${typeStyle}\">${a.type}</span></td>\n            <td style=\"text-align:center\">${a.orb}°</td>\n        </tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Midpoints Activés (si présents) ──\nconst midpointActivations = input.midpointActivations || [];\nif (midpointActivations.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Activated Midpoints' : 'Midpoints Activés'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'A midpoint is the median point between two planets. When a third planet transits or is natally on this midpoint (±1.5°), it <strong>activates</strong> the combination of the two planets and catalyzes their expression. Type <strong>direct</strong> = conjunction to midpoint; type <strong>mirror</strong> = opposition (same axis).'\n          : 'Un midpoint est le point médian entre deux planètes. Quand une troisième planète transite ou se trouve natalement sur ce midpoint (±1.5°), elle <strong>active</strong> la combinaison des deux planètes et en catalyse l\\'expression. Type <strong>direct</strong> = conjonction au midpoint ; type <strong>miroir</strong> = opposition (même axe).'}\n    </p>`;\n    html += `<table>\n        <tr><th>${isEN ? 'Activator' : 'Activateur'}</th><th>Midpoint</th><th>Type</th><th style=\"text-align:center\">${isEN ? 'Orb' : 'Orbe'}</th></tr>`;\n    midpointActivations.slice(0, 20).forEach(ma => {\n        const typeColor = ma.type === \"direct\" ? \"#1F3864\" : \"#2E5FA3\";\n        html += `<tr>\n            <td><strong>${ma.activator}</strong></td>\n            <td style=\"font-weight:bold;color:#1F3864\">${ma.midpoint}</td>\n            <td><span style=\"color:${typeColor};font-weight:bold\">${ma.type === \"direct\" ? (isEN ? \"Direct (conjunction)\" : \"Direct (conjonction)\") : (isEN ? \"Mirror (opposition)\" : \"Miroir (opposition)\")}</span></td>\n            <td style=\"text-align:center\">${ma.orb}°</td>\n        </tr>`;\n    });\n    if (midpointActivations.length > 20) {\n        html += `<tr><td colspan=\"4\" style=\"text-align:center;color:#94a3b8;font-style:italic\">${isEN ? `... and ${midpointActivations.length - 20} other activations` : `... et ${midpointActivations.length - 20} autres activations`}</td></tr>`;\n    }\n    html += `</table>`;\n}\n\n// ── Lots Hermétiques (Sprint 7) ──\nconst SIGNS_ORDER = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\nconst lotHouseCusps = (input.maisons || []).map(h => {\n    const csp = h.segments?.[0] || { signe: \"Bélier\", degre_debut: 0 };\n    return { house: h.maison, deg: (SIGNS_ORDER.indexOf(csp.signe) * 30 + csp.degre_debut) % 360 };\n}).sort((a,b) => a.deg - b.deg);\nconst findLotHouse = (fd) => {\n    for (let i = 0; i < 12; i++) {\n        const h1 = lotHouseCusps[i].deg, h2 = lotHouseCusps[(i+1)%12].deg;\n        if (h1 < h2) { if (fd >= h1 && fd < h2) return lotHouseCusps[i].house; }\n        else         { if (fd >= h1 || fd < h2) return lotHouseCusps[i].house; }\n    }\n    return \"?\";\n};\nconst LOTS_DISPLAY = [\n    {fr:\"Part de Fortune\",     en:\"Part of Fortune\",    desc: isEN ? \"Abundance, material success, positive flow\"          : \"Abondance, réussite matérielle, flux positif\", glyph:\"⊕\"},\n    {fr:\"Lot de l'Esprit\",     en:\"Lot of Spirit\",      desc: isEN ? \"Vocation, consciousness, soul path\"                  : \"Vocation, conscience, chemin de l'âme\", glyph:\"⊗\"},\n    {fr:\"Lot de Nécessité\",    en:\"Lot of Necessity\",   desc: isEN ? \"Constraints, unavoidable trials, karma\"              : \"Contraintes, épreuves inévitables, karma\", glyph:\"⊖\"},\n    {fr:\"Lot d'Éros\",          en:\"Lot of Eros\",        desc: isEN ? \"Passion, attraction, vital drive\"                    : \"Passion, attraction, élan vital\", glyph:\"♡\"},\n    {fr:\"Lot de Courage\",      en:\"Lot of Courage\",     desc: isEN ? \"Boldness, initiative, combative assertion\"           : \"Audace, initiative, affirmation combative\", glyph:\"⚔\"},\n    {fr:\"Lot de Némésis\",      en:\"Lot of Nemesis\",     desc: isEN ? \"Saturnian trials, lessons, limits\"                   : \"Épreuves saturniennes, leçons, limites\", glyph:\"⚖\"},\n    {fr:\"Lot de Basis\",        en:\"Lot of Basis\",       desc: isEN ? \"Material foundation, existential base\"               : \"Fondement matériel, socle existentiel\", glyph:\"⬡\"},\n    {fr:\"Lot d'Exaltation\",    en:\"Lot of Exaltation\",  desc: isEN ? \"Dignity, ambition, elevation\"                        : \"Dignité, ambition, élévation\", glyph:\"△\"},\n    {fr:\"Lot du Daemon\",       en:\"Lot of the Daemon\",  desc: isEN ? \"Personal genius, deep vocation, daimon\"              : \"Génie personnel, vocation profonde, daimon\", glyph:\"☿̦\"},\n    {fr:\"Lot de Victoire\",     en:\"Lot of Victory\",     desc: isEN ? \"Success, triumph, accomplishment (Nike)\"             : \"Succès, triomphe, accomplissement (Nikè)\", glyph:\"⚜\"},\n    {fr:\"Lot du Père\",         en:\"Lot of the Father\",  desc: isEN ? \"Father image, authority, paternal legacy\"            : \"Image paternelle, autorité, héritage paternel\", glyph:\"⚑\"},\n    {fr:\"Lot de la Mère\",      en:\"Lot of the Mother\",  desc: isEN ? \"Mother image, nurturing, maternal legacy\"            : \"Image maternelle, nourriture, héritage maternel\", glyph:\"⚘\"},\n    {fr:\"Lot de Maladie\",      en:\"Lot of Disease\",     desc: isEN ? \"Physical vulnerability, fragility points\"            : \"Vulnérabilité physique, points de fragilité\", glyph:\"⚕\"},\n    {fr:\"Lot du Mariage\",      en:\"Lot of Marriage\",    desc: isEN ? \"Union, commitment, life partnership\"                 : \"Union, engagement, partenariat de vie\", glyph:\"♥\"},\n    {fr:\"Lot des Enfants\",     en:\"Lot of Children\",    desc: isEN ? \"Offspring, creativity, progeny\"                      : \"Descendance, créativité, progéniture\", glyph:\"✦\"},\n    {fr:\"Lot de Voyage\",       en:\"Lot of Travel\",      desc: isEN ? \"Displacement, distant quest, exploration\"            : \"Déplacement, quête lointaine, exploration\", glyph:\"✢\"}\n];\nconst lotsInChart = LOTS_DISPLAY.filter(ld => (input.planetes || []).some(p => p.planet?.fr === ld.fr));\nif (lotsInChart.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Hermetic Lots (Arabic Parts)' : 'Lots Hermétiques (Parts Arabes)'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'Hermetic Lots are mathematical points calculated from the Ascendant, Sun, Moon, and other planets. Each Lot activates a specific existential theme in the house and sign where it falls. Formulas: <strong>Fortune</strong> = ASC + Moon − Sun (diurnal); <strong>Spirit</strong> = inverse.'\n          : 'Les Lots hermétiques sont des points mathématiques calculés à partir de l\\'Ascendant, du Soleil, de la Lune et d\\'autres planètes. Chaque Lot active un thème existentiel spécifique dans la maison et le signe où il se trouve. Formules : <strong>Fortune</strong> = ASC + Lune − Soleil (diurne) ; <strong>Esprit</strong> = inverse.'}\n    </p>`;\n    html += `<table><tr><th>Lot</th><th style=\"text-align:center\">${isEN ? 'Glyph' : 'Glyphe'}</th><th>${isEN ? 'Sign' : 'Signe'}</th><th style=\"text-align:center\">${isEN ? 'Degree' : 'Degré'}</th><th style=\"text-align:center\">${isEN ? 'House' : 'Maison'}</th><th>${isEN ? 'Meaning' : 'Signification'}</th></tr>`;\n    lotsInChart.forEach(ld => {\n        const pObj = (input.planetes || []).find(p => p.planet?.fr === ld.fr);\n        if (!pObj) return;\n        const sign = pObj.zodiac_sign?.name?.fr || \"?\";\n        const deg = ((pObj.normDegree ?? pObj.fullDegree ?? 0) % 30).toFixed(2);\n        const house = findLotHouse(pObj.fullDegree);\n        html += `<tr>\n            <td><strong>${isEN ? (ld.en || ld.fr) : ld.fr}</strong></td>\n            <td style=\"text-align:center;font-size:1.3em\">${ld.glyph}</td>\n            <td>${sign}</td>\n            <td style=\"text-align:center\">${deg}°</td>\n            <td style=\"text-align:center;font-weight:bold;color:#1F3864\">M${house}</td>\n            <td style=\"font-size:0.9em;color:#64748b;font-style:italic\">${ld.desc}</td>\n        </tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Arbre des Dispositions et Dispositeur Final ──\nif (dispositorTree?.finalDispositors?.length > 0 || Object.keys(dispositorTree?.tree || {}).length > 0) {\n    const tree = dispositorTree.tree || {};\n    const finals = dispositorTree.finalDispositors || [];\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Dispositor Tree' : 'Arbre des Dispositions'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'The dispositor tree traces the rulership chain: each planet is \"commanded\" by the ruler of its sign. The final dispositor is the planet in domicile that concentrates the power of the entire chain.'\n          : 'L\\'arbre des dispositions trace la chaîne de maîtrise : chaque planète est « commandée » par le maître de son signe. Le dispositeur final est la planète en domicile qui concentre le pouvoir de toute la chaîne.'}\n    </p>`;\n    if (finals.length > 0) {\n        html += `<div style=\"background:#dbeafe;padding:10px 14px;border-radius:6px;margin-bottom:12px;font-weight:bold;color:#1e40af;font-size:1.05em\">\n            ${isEN ? 'Final Dispositor(s)' : 'Dispositeur(s) final(aux)'} : ${finals.join(\", \")}\n        </div>`;\n    }\n    html += `<table><tr><th>${isEN ? 'Planet' : 'Planète'}</th><th>${isEN ? 'Rulership Chain' : 'Chaîne de maîtrise'}</th><th>${isEN ? 'Final Dispositor' : 'Dispositeur final'}</th></tr>`;\n    Object.entries(tree).forEach(([name, data]) => {\n        const chainStr = data.chain.map(c => c.inDomicile ? `<strong style=\"color:#1e40af\">${c.planet}</strong>` : c.planet).join(\" → \");\n        html += `<tr><td><strong>${name}</strong></td><td>${chainStr}</td><td style=\"text-align:center;font-weight:bold;color:#1e40af\">${data.finalDispositor || `<span style=\"color:#94a3b8\">∞ ${isEN ? 'loop' : 'boucle'}</span>`}</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Dignité Accidentelle (Lilly) ──\nif (accidentalDignity.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Accidental Dignity (Lilly)' : 'Force Planétaire — Dignité Accidentelle (Lilly)'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'Score combining essential dignity (domicile, exaltation, detriment, fall) and accidental dignity (house, motion, heliocentric conditions, receptions). A high score (&gt;15) = major chart actor. A negative score = impeded planet.'\n          : 'Score combinant dignité essentielle (domicile, exaltation, exil, chute) et accidentelle (maison, mouvement, conditions héliocentriques, réceptions). Un score élevé (&gt;15) = acteur majeur du thème. Un score négatif = planète empêchée.'}\n    </p>`;\n    html += `<table><tr><th>${isEN ? 'Planet' : 'Planète'}</th><th style=\"text-align:center\">Score</th><th>${isEN ? 'Details' : 'Détail'}</th></tr>`;\n    accidentalDignity.forEach(d => {\n        const color = d.score >= 15 ? '#166534' : d.score >= 8 ? '#1e40af' : d.score >= 0 ? '#475569' : '#991b1b';\n        html += `<tr><td><strong>${d.planet}</strong></td><td style=\"text-align:center;font-weight:bold;color:${color};font-size:1.1em\">${d.score}</td>\n        <td style=\"font-size:0.85em;color:#64748b\">${(d.details || []).join(\" · \")}</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Conditions spéciales : Hayz, Assiégées, VOC Lune ──\nif (hayzPlanets.length > 0 || besiegedPlanets.length > 0 || moonVOC) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Special Conditions' : 'Conditions Spéciales'}</h2>`;\n    if (hayzPlanets.length > 0) {\n        html += `<div class=\"subsection-title\">✦ ${isEN ? 'Hayz (optimal sect condition)' : 'Hayz (condition de secte optimale)'}</div>`;\n        hayzPlanets.forEach(h => {\n            html += `<div style=\"padding:6px 12px;margin:4px 0;background:#eef2fb;border-left:3px solid #2E5FA3;border-radius:4px;font-size:0.92em\">${h.description}</div>`;\n        });\n    }\n    if (besiegedPlanets.length > 0) {\n        html += `<div class=\"subsection-title\">⚠ ${isEN ? 'Besieged Planets' : 'Planètes Assiégées'}</div>`;\n        besiegedPlanets.forEach(b => {\n            html += `<div style=\"padding:6px 12px;margin:4px 0;background:#fef2f2;border-left:3px solid #dc2626;border-radius:4px;font-size:0.92em\">${b.description}</div>`;\n        });\n    }\n    if (moonVOC) {\n        html += `<div class=\"subsection-title\">◯ ${isEN ? 'Void of Course Moon' : 'Lune Vide de Course'}</div>`;\n        html += `<div style=\"padding:6px 12px;margin:4px 0;background:#eef2fb;border-left:3px solid #2E5FA3;border-radius:4px;font-size:0.92em\">${moonVOC.description}</div>`;\n    }\n    const stationaryPlanetsR = input.stationaryPlanets || [];\n    if (stationaryPlanetsR.length > 0) {\n        html += `<div class=\"subsection-title\">⏸ ${isEN ? 'Stationary Planets (concentrated energy)' : 'Planètes Stationnaires (énergie concentrée)'}</div>`;\n        stationaryPlanetsR.forEach(sp => {\n            html += `<div style=\"padding:6px 12px;margin:4px 0;background:#eef2fb;border-left:3px solid #2E5FA3;border-radius:4px;font-size:0.92em\">\n                <strong>${sp.planet}</strong> — ${sp.direction} ${isEN ? 'in' : 'en'} ${sp.sign} (${isEN ? 'H' : 'M'}${sp.house}) — ${isEN ? 'speed' : 'vitesse'} ${sp.speed}°/${isEN ? 'day' : 'jour'} (${isEN ? 'threshold' : 'seuil'} ${sp.threshold}°/${isEN ? 'day' : 'jour'}).\n                ${isEN ? 'A stationary planet concentrates its energy exceptionally — first-order marker.' : 'Une planète stationnaire concentre son énergie de manière exceptionnelle — marqueur de premier ordre.'}\n            </div>`;\n        });\n    }\n}\n\n// ── Degrés Sabian ──\nif (Object.keys(sabianData).length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Sabian Degrees' : 'Degrés Sabian'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'Each degree of the zodiac has an image symbol (Marc Edmund Jones / Dane Rudhyar). These images offer a poetic and symbolic nuance of the planetary position.'\n          : 'Chaque degré du zodiaque possède un symbole imagé (Marc Edmund Jones / Dane Rudhyar). Ces images offrent une nuance poétique et symbolique de la position planétaire.'}\n    </p>`;\n    html += `<table><tr><th>${isEN ? 'Planet' : 'Planète'}</th><th style=\"text-align:center\">${isEN ? 'Degree' : 'Degré'}</th><th>${isEN ? 'Sign' : 'Signe'}</th><th>${isEN ? 'Sabian Symbol' : 'Symbole Sabian'}</th></tr>`;\n    Object.entries(sabianData).forEach(([name, data]) => {\n        html += `<tr><td><strong>${name}</strong></td><td style=\"text-align:center\">${data.degree}°</td><td>${data.sign}</td>\n        <td style=\"font-style:italic;color:#475569\">« ${data.symbol} »</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Profil de sensibilité ──\nif (sensitivityProfileR) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Chart Sensitivity Profile' : 'Profil de Sensibilité du Thème'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:10px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n        ${isEN\n          ? 'This profile identifies the elemental vulnerabilities and familiarities of the chart, as well as the modal dispositions that condition receptivity to transits.'\n          : 'Ce profil identifie les vulnérabilités et familiarités élémentaires du thème, ainsi que les dispositions modales qui conditionnent la réceptivité aux transits.'}\n    </p>`;\n    sensitivityProfileR.split('\\n').filter(Boolean).forEach(line => {\n        const isVuln = line.includes('VULNÉRABILITÉ');\n        const isFam = line.includes('FAMILIARITÉ');\n        const bg = isVuln ? '#fef2f2' : isFam ? '#eef2fb' : '#e8f0fe';\n        const border = isVuln ? '#dc2626' : isFam ? '#2E5FA3' : '#1F3864';\n        html += `<div style=\"padding:8px 14px;margin:4px 0;background:${bg};border-left:3px solid ${border};border-radius:4px;font-size:0.92em\">${line}</div>`;\n    });\n}\n\nhtml += `</div></body></html>`;\n\nreturn [{\n    json: { success: true },\n    binary: {\n        html_file: {\n            data: Buffer.from(html, 'utf8').toString('base64'),\n            mimeType: 'text/html',\n            fileName: `index.html`\n        }\n    }\n}];\n} catch (_globalErr) {\n    const errHtml = `<html><body style=\"font-family:sans-serif;padding:40px\"><h1 style=\"color:#dc2626\">${isEN ? 'Report generation error' : 'Erreur de génération du rapport'}</h1><p>${_globalErr.message}</p><pre>${_globalErr.stack}</pre></body></html>`;\n    return [{ json: { error: true, message: _globalErr.message }, binary: { html_file: { data: Buffer.from(errHtml,'utf8').toString('base64'), mimeType:'text/html', fileName:'error.html' } } }];\n}"},"id":"ffd05647-4937-4317-b0c0-85d45f0c758e","name":"5. Générer Fichier HTML1","type":"n8n-nodes-base.code","typeVersion":2,"position":[-3328,3792]},{"parameters":{"numberInputs":6},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[-1152,2896],"id":"e337db31-c252-49fd-bf16-6ce3914f11bc","name":"Merge3"},{"parameters":{"numberInputs":6},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[-1152,3296],"id":"d929403e-e7b3-481d-999e-0445ae87aefc","name":"Merge5"},{"parameters":{"numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[-592,3120],"id":"d14f149b-4348-4075-8dae-64736d5bf20a","name":"Merge6"},{"parameters":{"jsCode":"// ══════════════════════════════════════════════════════════════════════\n// VALIDATEUR POST-LLM — THÈME NATAL (noeud silencieux)\n// ══════════════════════════════════════════════════════════════════════\n// Ce noeud vérifie la cohérence des textes LLM avec les données natales.\n// Il ne produit AUCUN affichage — son output JSON est consultable\n// dans les logs d'exécution n8n et peut alimenter un noeud d'alerte\n// (Slack, email, webhook) si des anomalies sont détectées.\n// ══════════════════════════════════════════════════════════════════════\n\nconst items = $input.all();\nconst astroData = $(\"Enrichissement Astrologique\").first().json;\n\n// ── 1. CARTE DE RÉFÉRENCE DES POSITIONS NATALES ──\nconst natalPlanets = (astroData.planetes || []);\nconst natalMaisons = (astroData.maisons || []);\nconst planetHouseMap = {};\nconst planetSignMap  = {};\n\nnatalPlanets.forEach(p => {\n    const name = p.planet?.fr;\n    if (!name) return;\n    const sign = p.zodiac_sign?.name?.fr;\n    if (sign) planetSignMap[name] = sign;\n    const house = natalMaisons.find(m =>\n        (m.segments || []).some(s => s.locataires?.some(l => l.planete === name))\n    );\n    if (house) planetHouseMap[name] = house.maison;\n});\n\n// ── 2. VOCABULAIRE D'EXCLUSION (contexte transit / rhétorique) ──\nconst TRANSIT_VERBS = [\n    \"transite\", \"traverse\", \"entre en\", \"arrive en\", \"quitte la\",\n    \"passage de\", \"passage en\", \"passage du\", \"transit de\", \"transit du\",\n    \"se déplace en\", \"progresse en\", \"arc solaire\",\n    \"contrairement à\", \"tandis que\", \"alors que\", \"par opposition à\",\n    \"à la différence de\", \"en comparaison\", \"imaginons\",\n    \"en général\", \"généralement\", \"traditionnellement\", \"dans l'absolu\",\n    \"l'entrée\", \"entre dans\", \"éclipse\", \"saros\", \"en transit\",\n    \"transit \", \"progression de\", \"lunation\", \"pleine lune\", \"nouvelle lune\",\n    \"sera en\", \"serait en\", \"entrera en\", \"ira en\", \"retour de\",\n    \"ingress\", \"entrée en\", \"passage vers\", \"quand il entre\", \"quand elle entre\"\n];\n\nconst CORE_PLANETS = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\n\n// ── 3. VALIDATION CONTEXTUELLE (phrase par phrase) ──\nconst splitSentences = (text) => {\n    return text.replace(/\\n/g, '. ').split(/(?<=[.!?…])\\s+/).filter(s => s.length > 5);\n};\n\nconst isTransitContext = (sentence) => {\n    const lc = sentence.toLowerCase();\n    return TRANSIT_VERBS.some(v => lc.includes(v));\n};\n\nconst matchWithBoundary = (text, pattern) => {\n    const idx = text.indexOf(pattern);\n    if (idx === -1) return false;\n    const after = text[idx + pattern.length];\n    if (after && /\\d/.test(after)) return false;\n    return true;\n};\n\nconst validateHouseText = (text, houseNum) => {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    CORE_PLANETS.forEach(name => {\n        const correctHouse = planetHouseMap[name];\n        if (!correctHouse) return;\n        const nameLc = name.toLowerCase();\n\n        sentences.forEach(sentence => {\n            if (isTransitContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            for (let h = 1; h <= 12; h++) {\n                if (h === correctHouse) continue;\n                const patterns = [\n                    `${nameLc} en maison ${h}`,\n                    `${nameLc} dans la maison ${h}`,\n                    `${nameLc} en m${h}`,\n                    `${nameLc} (m${h}`,\n                    `${nameLc}, planète de la maison ${h}`,\n                    `${nameLc} réside en m${h}`,\n                    `${nameLc} se trouve en m${h}`,\n                    `${nameLc} natal en m${h}`,\n                    `${nameLc} natale en m${h}`\n                ];\n                if (patterns.some(pat => matchWithBoundary(lc, pat))) {\n                    warnings.push({\n                        planet: name,\n                        claimedHouse: h,\n                        correctHouse: correctHouse,\n                        excerpt: sentence.substring(0, 120),\n                        type: \"house_mismatch\"\n                    });\n                }\n            }\n        });\n    });\n    return warnings;\n};\n\nconst validateSignText = (text) => {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    CORE_PLANETS.forEach(name => {\n        const correctSign = planetSignMap[name];\n        if (!correctSign) return;\n        const nameLc = name.toLowerCase();\n        const signLc = correctSign.toLowerCase();\n        const allSigns = [\"bélier\",\"taureau\",\"gémeaux\",\"cancer\",\"lion\",\"vierge\",\"balance\",\"scorpion\",\"sagittaire\",\"capricorne\",\"verseau\",\"poissons\"];\n\n        sentences.forEach(sentence => {\n            if (isTransitContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            allSigns.forEach(sign => {\n                if (sign === signLc) return;\n                const patterns = [\n                    `${nameLc} en ${sign}`,\n                    `${nameLc} dans le ${sign}`,\n                    `${nameLc} dans la ${sign}`,\n                    `${nameLc} dans les ${sign}`\n                ];\n                if (patterns.some(pat => lc.includes(pat))) {\n                    if (!lc.includes(\"transite\") && !lc.includes(\"transit\") && !lc.includes(\"progresse\")) {\n                        warnings.push({\n                            planet: name,\n                            claimedSign: sign,\n                            correctSign: correctSign,\n                            excerpt: sentence.substring(0, 120),\n                            type: \"sign_mismatch\"\n                        });\n                    }\n                }\n            });\n        });\n    });\n    return warnings;\n};\n\n// ── 4. EXÉCUTION SUR CHAQUE MAISON ──\nconst results = { timestamp: new Date().toISOString(), totalWarnings: 0, houses: {}, signWarnings: [] };\nlet vars = {};\ntry { vars = $('Extract Variables').first()?.json || {}; } catch(e) {}\nresults.subject = `${vars.prenom || ''} ${vars.nom || ''}`.trim();\n\nitems.forEach((item, index) => {\n    const txt = item.json.output || item.json.text || \"\";\n    if (index < 12) {\n        const hNum = index + 1;\n        const houseWarnings = validateHouseText(txt, hNum);\n        const signWarnings  = validateSignText(txt);\n        if (houseWarnings.length > 0 || signWarnings.length > 0) {\n            results.houses[`M${hNum}`] = { houseWarnings, signWarnings };\n            results.totalWarnings += houseWarnings.length + signWarnings.length;\n        }\n    } else {\n        const synthWarnings = validateHouseText(txt, 0);\n        const synthSignWarn = validateSignText(txt);\n        if (synthWarnings.length > 0 || synthSignWarn.length > 0) {\n            results.houses[\"synthese\"] = { houseWarnings: synthWarnings, signWarnings: synthSignWarn };\n            results.totalWarnings += synthWarnings.length + synthSignWarn.length;\n        }\n    }\n});\n\nresults.status = results.totalWarnings === 0 ? \"CLEAN\" : \"WARNINGS_DETECTED\";\nresults.summary = results.totalWarnings === 0\n    ? \"Aucune incohérence détectée entre les textes LLM et les données natales.\"\n    : `${results.totalWarnings} incohérence(s) potentielle(s) détectée(s). Vérifier les détails dans houses.`;\n\nreturn [{ json: results }];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-16,2336],"id":"0cb48c05-d6e4-4b5a-9a9a-2d45a8f0c8d2","name":"Theme Logs"},{"parameters":{"amount":2,"unit":"seconds"},"id":"54d79a65-57d9-49e2-aa53-ae8451010029","name":"Wait 2s","type":"n8n-nodes-base.wait","typeVersion":1,"position":[-4528,2800],"webhookId":"c3d62306-7622-43f7-adb5-b80326364844"},{"parameters":{"method":"POST","url":"http://46.225.174.155:8000/western/planets","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"contentType":"raw","rawContentType":"application/json","body":"={{ $json.body }}","options":{}},"id":"4aecce18-3c17-41eb-8bc9-39e38da6ddef","name":"3a. Calcul Planètes1","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[-4528,2576]},{"parameters":{"method":"POST","url":"http://46.225.174.155:8000/western/houses","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Content-Type","value":"appli