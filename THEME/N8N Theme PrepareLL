        "jsCode": "const geo = $json;\n\n// Recherche sécurisée des variables (gère les cas où n8n renomme le noeud)\nlet vars;\ntry {\n  vars = $('Extract Variables1').first()?.json || $('Extract Variables1').first()?.json;\n} catch (e) {\n  throw new Error(\"⚠️ Lancez le test depuis le tout premier noeud ! n8n a perdu la mémoire des variables.\");\n}\n\nif (!geo || !geo.lat) {\n  throw new Error(\"Coordonnées GPS introuvables. geo=\" + JSON.stringify(geo));\n}\nif (!vars || !vars.date) {\n  throw new Error(\"Variables introuvables. vars=\" + JSON.stringify(vars));\n}\n\nconst d = vars.date.split('/');\nconst h = vars.heure.split(/[:Hh]/);\n\nconst birthDate = new Date(Date.UTC(parseInt(d[2]), parseInt(d[1]) - 1, parseInt(d[0]), parseInt(h[0]), parseInt(h[1]) || 0));\nconst timestamp = Math.floor(birthDate.getTime() / 1000);\n\nreturn [{ json: { lat: geo.lat, lon: geo.lon, timestamp: timestamp } }];"
