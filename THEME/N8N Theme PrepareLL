        "jsCode": "// THÈME — remplace l’ancienne chaîne « 1c Get Timezone » + logique fuseau dans le nœud « 2. Préparation dynamique1 ».\n// Connexions attendues : « 1b. Prepare Timezone1 » → CE nœud → « 3a. Calcul Planètes1 » (plus de « 1c. Get Timezone1 »).\n// Interprète date + heure comme heure CIVILE au lieu de naissance ; affine l’offset TimeZoneDB par itérations (DST / historique).\n// Nécessite typeVersion ≥ 2.\n\nconst vars = $(\"Extract Variables\").first().json;\nconst geo = $(\"1b. Prepare Timezone1\").first().json;\n\nif (!geo || geo.lat === undefined || geo.lat === null || String(geo.lat).trim() === \"\") {\n  throw new Error(\"Coordonnées GPS introuvables.\");\n}\nif (!vars || !vars.date) {\n  throw new Error(\"Variables introuvables.\");\n}\n\nconst lat = parseFloat(geo.lat);\nconst lon = parseFloat(geo.lon);\nif (!Number.isFinite(lat) || !Number.isFinite(lon)) {\n  throw new Error(\"Coordonnées GPS invalides.\");\n}\n\nconst d = vars.date.split(\"/\");\nconst h = vars.heure.split(/[:Hh]/);\nconst yy = parseInt(d[2], 10);\nconst mo = parseInt(d[1], 10);\nconst da = parseInt(d[0], 10);\nconst hh = parseInt(h[0], 10);\nconst mi = parseInt(h[1] || \"0\", 10);\n\nconst localNaiveUtcSec = Math.floor(Date.UTC(yy, mo - 1, da, hh, mi, 0) / 1000);\n\nconst TZ_KEY = \"UV443YWQRYUC\";\nlet U = localNaiveUtcSec;\nlet gmtOff = 0;\n\nfor (let iter = 0; iter < 4; iter++) {\n  const tzData = await this.helpers.httpRequest({\n    method: \"GET\",\n    url: \"http://api.timezonedb.com/v2.1/get-time-zone\",\n    qs: {\n      key: TZ_KEY,\n      format: \"json\",\n      by: \"position\",\n      lat: String(lat),\n      lng: String(lon),\n      time: String(U),\n    },\n    json: true,\n  });\n\n  if (!tzData || tzData.gmtOffset === undefined) {\n    throw new Error(\"Fuseau horaire introuvable. tzData=\" + JSON.stringify(tzData));\n  }\n  gmtOff = tzData.gmtOffset;\n  const nextU = localNaiveUtcSec - gmtOff;\n  if (Math.abs(nextU - U) <= 1) {\n    U = nextU;\n    break;\n  }\n  U = nextU;\n}\n\nconst tz = gmtOff / 3600;\n\nconst payload = {\n  year: yy,\n  month: mo,\n  date: da,\n  hours: hh,\n  minutes: mi,\n  seconds: 0,\n  latitude: lat,\n  longitude: lon,\n  timezone: tz,\n  config: {\n    observation_point: \"geocentric\",\n    ayanamsha: \"tropical\",\n    language: \"fr\",\n  },\n};\n\nreturn [{ json: { body: JSON.stringify(payload) } }];\n"
