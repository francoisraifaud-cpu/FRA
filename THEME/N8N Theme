    for (let i=0; i<confPlanets.length; i++) {
        const candidates = [confPlanets[i]];
        let lastDeg = confPlanets[i].fullDegree;
        const sorted = confPlanets.filter((_,idx)=>idx!==i).sort((a,b) => {
            const da = ((a.fullDegree - lastDeg + 360) % 360);
            const db = ((b.fullDegree - lastDeg + 360) % 360);
            return da - db;
        });
        for (const p of sorted) {
            const dFromLast = angularDiff(candidates[candidates.length-1].fullDegree, p.fullDegree);
            if (Math.abs(dFromLast - 60) <= 6) candidates.push(p);
            if (candidates.length === 6) break;
        }
        if (candidates.length === 6) {
            const dClose = angularDiff(candidates[5].fullDegree, candidates[0].fullDegree);
            if (Math.abs(dClose - 60) <= 6) {
                const names = candidates.map(p => p.planet.fr);
