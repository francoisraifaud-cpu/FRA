// ── Sprint 6 — Module A : Qualificatif d'orbe calculé ──
const orbQualifier = (orb) => {
    const o = typeof orb === "string" ? parseFloat(orb) : orb;
    if (o < 1)   return "exact";
    if (o < 3)   return "serré";
    if (o < 5)   return "moyen";
    return "large";
};

// ── Sprint 6 — Module B1+E2 : Natures planétaires ──
const PLANET_NATURES = {
    "Soleil":"luminaire","Lune":"luminaire",
    "Mercure":"neutre","Vénus":"bénéfique","Mars":"maléfique",
    "Jupiter":"bénéfique","Saturne":"maléfique",
    "Uranus":"maléfique","Neptune":"dissolvant","Pluton":"maléfique",
    "Chiron":"neutre","Nœud Nord":"neutre","Nœud Sud":"neutre",
    "Lilith":"maléfique","Cérès":"neutre","Ceres":"neutre",
    "Junon":"neutre","Juno":"neutre","Vesta":"neutre","Pallas":"neutre",
    "Ascendant":"neutre","Milieu du Ciel":"neutre","Descendant":"neutre","Imum Coeli":"neutre"
};

const getNatureTag = (p1, p2) => {
    const n1 = PLANET_NATURES[p1], n2 = PLANET_NATURES[p2];
    if (!n1 || !n2 || n1 === "neutre" && n2 === "neutre") return "";
    if (n1 === "dissolvant" || n2 === "dissolvant") {
        const otherN = n1 === "dissolvant" ? n2 : n1;
        if (otherN === "maléfique")  return " [Nature: dissolution de la tension — transcendance possible mais risque de confusion]";
        if (otherN === "bénéfique")  return " [Nature: sublimation — inspiration élevée mais risque d'idéalisation]";
        if (otherN === "luminaire")  return " [Nature: voile sur le luminaire — intuition amplifiée mais identité potentiellement floue]";
        return "";
    }
    if (n1 === "bénéfique" && n2 === "bénéfique")  return " [Nature: synergie bénéfique — énergies qui s'emboîtent harmonieusement]";
    if (n1 === "maléfique" && n2 === "maléfique")  return " [Nature: friction maléfique — tension intensifiée, potentiel d'obstacle]";
    if ((n1==="bénéfique"&&n2==="maléfique")||(n1==="maléfique"&&n2==="bénéfique"))
        return " [Nature: mixte — le bénéfique tempère le maléfique, mais sous tension]";
    if (n1 === "luminaire" || n2 === "luminaire") {
        const otherN = n1 === "luminaire" ? n2 : n1;
        if (otherN === "bénéfique")  return " [Nature: luminaire + bénéfique — vitalité amplifiée et soutenue]";
        if (otherN === "maléfique")  return " [Nature: luminaire + maléfique — vitalité mise au défi]";
        if (otherN === "dissolvant") return " [Nature: voile sur le luminaire — intuition amplifiée mais identité potentiellement floue]";
    }
    return "";
};

// ── Sprint 6 — Module E1 : Appliquant / Séparant (aspects nataux) ──
const PLANET_SPEED_RANK = {
    "Lune":1,"Mercure":2,"Vénus":3,"Soleil":4,"Mars":5,
    "Jupiter":6,"Saturne":7,"Uranus":8,"Neptune":9,"Pluton":10,
    "Chiron":7.5,"Lilith":4.5,"Cérès":5.5,"Ceres":5.5,"Junon":5.2,"Juno":5.2,"Vesta":5.3,"Pallas":5.4,
    "Nœud Nord":7.2,"Nœud Sud":7.2
};
const getAppSepTag = (pFaster, pSlower, aspDeg, exactitude) => {
    const r1 = PLANET_SPEED_RANK[pFaster], r2 = PLANET_SPEED_RANK[pSlower];
    if (!r1 || !r2) return "";
    const fast = r1 < r2 ? pFaster : pSlower;
    const slow = r1 < r2 ? pSlower : pFaster;
    const pFast = planetes.find(p => p.planet.fr === fast);
    const pSlow = planetes.find(p => p.planet.fr === slow);
    if (!pFast || !pSlow) return "";
    const fastRetro = pFast.isRetro === "True" || pFast.isRetro === true;
    const diff = ((pFast.fullDegree - pSlow.fullDegree) + 360) % 360;
    let approaching, separating;
    if (aspDeg === 0) {
        approaching = diff > 180;
        separating  = diff <= 180 && diff > 0;
    } else {
        approaching = diff > aspDeg && diff < aspDeg + 15;
        separating  = diff < aspDeg || diff > aspDeg + 345;
    }
    if (fastRetro) {
        const tmp = approaching;
        approaching = separating;
        separating = tmp;
    }
    if (approaching) return " [appliquant]";
    if (separating)  return " [séparant]";
    return "";
};
const ASP_DEG_MAP = {"Conjonction":0,"Opposition":180,"Carré":90,"Trigone":120,"Sextile":60,"Quinconce":150,"Semi-Sextile":30,"Semi-Carré":45,"Quintile":72,"Biquintile":144,"Sesqui-Carré":135};

const MINOR_ASPECT_MEANINGS = {
    "Quintile":     "harmonie créatrice, don structurel",
    "Biquintile":   "harmonie créatrice avancée, talent latent",
    "Semi-Sextile": "irritant mineur, ajustement progressif entre signes adjacents",
    "Semi-Carré":   "friction légère, micro-tension de développement",
    "Sesqui-Carré": "tension de friction constructive",
    "Quinconce":    "ajustement obligatoire, tension inconsciente"
};

const getMajorAspectsStr = (pName) => {
    let asps = aspects.filter(a => a.isMajor && (a.p1===pName || a.p2===pName));
    if (!asps.length) return "Aucun aspect majeur";
    return asps.map(a => {
        const partner = a.p1===pName ? a.p2 : a.p1;
        const prefix  = a.prioriteEmoji ? `${a.prioriteEmoji} ${a.prioriteLabel} — ` : "";
        const oq = orbQualifier(a.exactitude);
        const nt = getNatureTag(pName, partner);
        const aspDeg = ASP_DEG_MAP[a.aspect] ?? 0;
        const appSep = getAppSepTag(a.p1, a.p2, aspDeg, parseFloat(a.exactitude));
        return `${prefix}${a.aspect} avec ${partner} (${a.exactitude}° — ${oq})${appSep}${nt}`;
    }).join(" | ");
};

// Aspects mineurs promus (score ≥ seuil Option B) — traités comme des aspects majeurs par le LLM
const getPromotedMinorAspectsStr = (pName) => {
    let asps = aspects.filter(a => !a.isMajor && a.isPromoted && (a.p1===pName || a.p2===pName));
    if (!asps.length) return null;
    return asps.map(a => {
        const partner  = a.p1===pName ? a.p2 : a.p1;
        const meaning  = MINOR_ASPECT_MEANINGS[a.aspect] ? ` — nature : ${MINOR_ASPECT_MEANINGS[a.aspect]}` : "";
        const oq = orbQualifier(a.exactitude);
        const nt = getNatureTag(pName, partner);
        const aspDeg = ASP_DEG_MAP[a.aspect] ?? 0;
        const appSep = getAppSepTag(a.p1, a.p2, aspDeg, parseFloat(a.exactitude));
        return `   ${a.prioriteEmoji} ${a.prioriteLabel} — ${a.aspect} avec ${partner} (${a.exactitude}° — ${oq})${appSep}${meaning}${nt}`;
    }).join("\n");
};

// Aspects mineurs non promus (tous les autres aspects mineurs)
const getMinorAspectsStr = (pName) => {
    let asps = aspects.filter(a => !a.isMajor && !a.isPromoted && (a.p1===pName || a.p2===pName))
        .sort((a,b) => parseFloat(a.exactitude) - parseFloat(b.exactitude)).slice(0, 5);
    if (!asps.length) return null;
    return asps.map(a => {
        const partner = a.p1===pName ? a.p2 : a.p1;
        const prefix  = a.prioriteEmoji ? `${a.prioriteEmoji} ${a.prioriteLabel} — ` : "";
        return `${prefix}${a.aspect} avec ${partner} (${a.exactitude}°)`;
    }).join(" | ");
};

