if (asc && sun) {
    const arcSoleilDepuisAsc = ((sun.fullDegree - asc.fullDegree) + 360) % 360;
    isDayChart = arcSoleilDepuisAsc > 180;
} else {
    isDayChart = [7,8,9,10,11,12].includes(Number(sunHouse)); // fallback par maison
}
