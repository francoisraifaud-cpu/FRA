function getHouseNumber(deg) {
    deg = ((deg % 360) + 360) % 360;
    for(let i=0; i<12; i++){
        let h1=maisons[i].degree, h2=maisons[(i+1)%12].degree;
        if((h1<h2 && deg>=h1 && deg<h2) || (h1>=h2 && (deg>=h1 || deg<h2))) return maisons[i].House;
    }
    return 1;
}

function angularDiff(a, b) {
