if (asc && sun && moon) {
    // Part de Fortune : diurne = ASC + Lune - Soleil ; nocturne = inverse
    let pofDeg = isDayChart
        ? (asc.fullDegree + moon.fullDegree - sun.fullDegree)
        : (asc.fullDegree + sun.fullDegree  - moon.fullDegree);
