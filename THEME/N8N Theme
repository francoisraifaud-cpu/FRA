    const total = Object.values(elStats).reduce((a,b)=>a+b,0) || 12;
    const lines = [];
    Object.entries(elStats).forEach(([element, count]) => {
        const ratio = count / total;
        const affiliated = ELEMENT_TRANSIT_MAP[element]?.join("/") || "";
        if (ratio <= 0.15) {
            lines.push(`VULNÉRABILITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} peuvent être particulièrement déstabilisants car le thème manque de récepteurs naturels dans cet élément. L'intégration demande un effort conscient.`);
        } else if (ratio >= 0.35) {
            lines.push(`FAMILIARITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} sont dans la "langue maternelle" du thème — leur énergie est reconnue et plus facilement intégrée, même si l'aspect est tendu.`);
        }
    });
    if (moStats.Fixe >= 5) {
        lines.push(`RÉSISTANCE AU CHANGEMENT (Fixe: ${moStats.Fixe}) : les transits d'Uranus et de Pluton sur les positions fixes seront vécus avec une intensité maximale — la structure résiste avant de céder brusquement.`);
