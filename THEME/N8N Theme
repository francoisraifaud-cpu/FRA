        if (!pA||!pB) continue;
        let diff = pB.fullDegree - pA.fullDegree;
        if (diff < 0) diff += 360;
        if (diff > 180) diff -= 360;
        let mp = ((pA.fullDegree + diff/2) % 360 + 360) % 360;
        let mpFar = (mp + 180) % 360;
        midpoints[`${midpointPlanets[i]}/${midpointPlanets[j]}`] = {
            near: mp, far: mpFar,
            sign: signs[Math.floor(mp/30)].fr, deg: (mp%30).toFixed(1)
        };
    }
}
