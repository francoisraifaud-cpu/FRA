    "Taureau":"Mars","Vierge":"Mars","Capricorne":"Mars",
    "Gémeaux":"Jupiter","Balance":"Jupiter","Verseau":"Jupiter",
    "Cancer":"Lune","Scorpion":"Lune","Poissons":"Lune"
};
