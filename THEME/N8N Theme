});

// ─────────────────────────────────────────────────────────────────
// 6h-bis. PARANS D'ÉTOILES FIXES (méthode Brady — co-angularité)
// Un paran se forme quand une étoile est sur un angle (lever/coucher/culmination)
// au même moment qu'une planète est sur un angle, évalué par le RAMC commun.
// ─────────────────────────────────────────────────────────────────
const PARAN_ORB = 1.5;
const OBLIQUITY = 23.4393;
const DEG = Math.PI / 180;

const geoLat = parseFloat(perso.latitude) || 0;
const paranResults = [];

if (Math.abs(geoLat) > 0.1) {
    const tanPhi = Math.tan(geoLat * DEG);

    function hourAngle(dec) {
        const tanDec = Math.tan(dec * DEG);
        const cosH = -tanPhi * tanDec;
        if (cosH < -1 || cosH > 1) return null;
        return Math.acos(cosH) / DEG;
    }

    function bodyAngles(ra, dec) {
        const H = hourAngle(dec);
        const angles = [];
        angles.push({ type: "Culmination", ramc: ((ra % 360) + 360) % 360 });
        angles.push({ type: "Anti-culmination", ramc: ((ra + 180) % 360 + 360) % 360 });
        if (H !== null) {
            angles.push({ type: "Lever", ramc: ((ra - H) % 360 + 360) % 360 });
            angles.push({ type: "Coucher", ramc: ((ra + H) % 360 + 360) % 360 });
        }
        return angles;
    }

    function eclToEq(lon, lat) {
        const L = lon * DEG, B = (lat || 0) * DEG, E = OBLIQUITY * DEG;
        const ra = Math.atan2(Math.sin(L) * Math.cos(E) - Math.tan(B) * Math.sin(E), Math.cos(L));
        const dec = Math.asin(Math.sin(B) * Math.cos(E) + Math.cos(B) * Math.sin(E) * Math.sin(L));
        return { ra: ((ra / DEG) % 360 + 360) % 360, dec: dec / DEG };
    }

    const PARAN_PLANETS = new Set(["Soleil","Lune","Mercure","Vénus","Mars","Jupiter","Saturne","Uranus","Neptune","Pluton","Chiron","Ascendant","Milieu du Ciel","Descendant","Imum Coeli"]);

    const planetAnglesMap = [];
    pointsEtoiles.forEach(p => {
        const pName = p.planet.fr || p.planet.en;
        if (!PARAN_PLANETS.has(pName)) return;
        if (LOTS_MATHEMATIQUES.has(pName)) return;
        let pRa, pDec;
        if (typeof p.declinaison === "number") {
            pDec = p.declinaison;
            const lonR = p.fullDegree * DEG, E = OBLIQUITY * DEG;
            const sinBeta = (Math.sin(pDec * DEG) - Math.sin(E) * Math.sin(lonR)) / Math.cos(E);
            const beta = Math.abs(sinBeta) <= 1 ? Math.asin(sinBeta) : 0;
            const raRad = Math.atan2(Math.sin(lonR) * Math.cos(E) - Math.tan(beta) * Math.sin(E), Math.cos(lonR));
            pRa = ((raRad / DEG) + 360) % 360;
        } else {
            const eq = eclToEq(p.fullDegree, 0);
            pRa = eq.ra;
            pDec = eq.dec;
        }
        const angles = bodyAngles(pRa, pDec);
        planetAnglesMap.push({ name: pName, ra: pRa, dec: pDec, angles });
    });

    const PARAN_LABELS = {
        "Culmination-Culmination": "co-culmination (les deux au MC)",
        "Culmination-Lever": "étoile culmine quand la planète se lève",
        "Lever-Lever": "co-lever (les deux à l'horizon Est)",
        "Lever-Culmination": "planète se lève quand l'étoile culmine",
        "Coucher-Coucher": "co-coucher (les deux à l'horizon Ouest)",
        "Culmination-Coucher": "étoile culmine quand la planète se couche",
        "Coucher-Culmination": "planète se couche quand l'étoile culmine",
        "Lever-Coucher": "étoile se lève quand la planète se couche",
        "Coucher-Lever": "étoile se couche quand la planète se lève",
    };

    etoilesFixesRaw.forEach(star => {
        const sName = star.name?.fr;
        if (!sName) return;
        const sDec = star.declination_j2000;
        const sRa = star.ra_j2000;
        if (sDec == null || sRa == null) return;
        const starAngles = bodyAngles(sRa, sDec);

        planetAnglesMap.forEach(pEntry => {
            pEntry.angles.forEach(pAngle => {
                starAngles.forEach(sAngle => {
                    let diff = Math.abs(pAngle.ramc - sAngle.ramc);
                    if (diff > 180) diff = 360 - diff;
                    if (diff <= PARAN_ORB) {
                        const comboKey = `${sAngle.type}-${pAngle.type}`;
                        paranResults.push({
                            planete: pEntry.name,
                            etoile: sName,
                            etoile_desc: ETOILE_DESC[sName] || "",
                            angle_etoile: sAngle.type,
                            angle_planete: pAngle.type,
                            orb: Math.round(diff * 100) / 100,
                            interpretation: PARAN_LABELS[comboKey] || `${sAngle.type} de l'étoile / ${pAngle.type} de la planète`,
                            maison: getHouseNumber(etoilesFixesRaw.find(e => e.name?.fr === sName)?.fullDegree ?? 0),
                            signe_planete: planetes.find(x => (x.planet?.fr || x.planet?.en) === pEntry.name)?.zodiac_sign?.name?.fr || ""
                        });
                    }
                });
            });
        });
    });
}

// ─────────────────────────────────────────────────────────────────
// 6i. DÉCLINAISONS — Hors Limites (OOB), Parallèles, Contre-Parallèles
// ─────────────────────────────────────────────────────────────────
const OOB_THRESHOLD      = OBLIQUITY;
const DECL_ORB_STANDARD  = 1.0;
const DECL_ORB_LUMINAIRE = 1.5;
const LUMINAIRES_DECL    = new Set(["Soleil", "Lune"]);

// Tous les objets ayant un champ declinaison numérique (planètes, Chiron, petits corps, nœuds…)
const planetesDeclinees = planetes.filter(p => typeof p.declinaison === 'number');

// A. Planètes / Objets Hors Limites (OOB)
const planeteOOB = [];
planetesDeclinees.forEach(p => {
    const name = p.planet.fr || p.planet.en;
    if (Math.abs(p.declinaison) > OOB_THRESHOLD) {
        planeteOOB.push({
            planete:     name,
            declinaison: p.declinaison,
            hemisphere:  p.declinaison > 0 ? "Nord" : "Sud",
            depassement: parseFloat((Math.abs(p.declinaison) - OOB_THRESHOLD).toFixed(2))
        });
    }
});

// B. Parallèles (//) et Contre-Parallèles (#)
const paralleles       = [];
const contreParalleles = [];
for (let i = 0; i < planetesDeclinees.length; i++) {
    for (let j = i + 1; j < planetesDeclinees.length; j++) {
        const pA = planetesDeclinees[i], pB = planetesDeclinees[j];
        const nameA = pA.planet.fr || pA.planet.en;
        const nameB = pB.planet.fr || pB.planet.en;
        const hasLuminaire = LUMINAIRES_DECL.has(nameA) || LUMINAIRES_DECL.has(nameB);
        const orb = hasLuminaire ? DECL_ORB_LUMINAIRE : DECL_ORB_STANDARD;
        const sameHemi = Math.sign(pA.declinaison) === Math.sign(pB.declinaison);
        if (sameHemi) {
            const diff = Math.abs(pA.declinaison - pB.declinaison);
            if (diff <= orb) paralleles.push({
                p1: nameA, decl1: pA.declinaison,
                p2: nameB, decl2: pB.declinaison,
                orb: parseFloat(diff.toFixed(2)), hasLuminaire,
                hemisphere: pA.declinaison > 0 ? "Nord" : "Sud"
            });
        } else {
            const diff = Math.abs(Math.abs(pA.declinaison) - Math.abs(pB.declinaison));
            if (diff <= orb) contreParalleles.push({
                p1: nameA, decl1: pA.declinaison,
                p2: nameB, decl2: pB.declinaison,
                orb: parseFloat(diff.toFixed(2)), hasLuminaire
            });
        }
    }
}

