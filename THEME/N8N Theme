// Facteur d'orbe planète-spécifique (Solar Fire standard)
const PLANET_ORB_FACTOR = {
    "Soleil":1.0, "Lune":1.0, "Ascendant":1.0, "Milieu du Ciel":1.0,
    "Descendant":1.0, "Imum Coeli":1.0,
    "Mercure":0.75, "Vénus":0.75, "Mars":0.75,
    "Jupiter":0.65, "Saturne":0.65,
    "Uranus":0.55, "Neptune":0.55, "Pluton":0.55,
    "Chiron":0.55, "Nœud Nord":0.6, "Nœud Sud":0.6
};

const AXIS_PAIRS = [
    new Set(["Milieu du Ciel", "Imum Coeli"]),
    new Set(["Ascendant", "Descendant"]),
    new Set(["Nœud Nord", "Nœud Sud"])
];
const isAxisPair = (n1, n2) => AXIS_PAIRS.some(pair => pair.has(n1) && pair.has(n2));

let aspects = [];
for(let i=0; i<planetes.length; i++) {
    for(let j=i+1; j<planetes.length; j++) {
        let p1=planetes[i], p2=planetes[j];
        let name1 = p1.planet.fr || p1.planet.en;
        let name2 = p2.planet.fr || p2.planet.en;
        if (isAxisPair(name1, name2)) continue;
        let isSmall  = smallBodies.includes(name1) || smallBodies.includes(name2);
        let isNodal  = nodalBodies.includes(name1) || nodalBodies.includes(name2);
        let activeType = isSmall ? "smallOrb" : (isNodal ? "nodalOrb" : "orb");
        const f1 = PLANET_ORB_FACTOR[name1] ?? 0.5;
        const f2 = PLANET_ORB_FACTOR[name2] ?? 0.5;
        const orbModulator = Math.max(f1, f2);
        let diff = Math.abs(p1.fullDegree - p2.fullDegree);
        if(diff > 180) diff = 360 - diff;
        aspectTypes.forEach(a => {
            let activeOrb  = a[activeType] * orbModulator;
            let exactitude = Math.abs(diff - a.deg);
            if(exactitude <= activeOrb) {
                aspects.push({ p1:name1, p2:name2, aspect:a.name, exactitude:exactitude.toFixed(2), isMajor:a.major });
            }
        });
    }
}

