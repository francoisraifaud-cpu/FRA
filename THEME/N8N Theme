    // Lot de Courage (Tolma) : diurne = ASC + Fortune - Mars ; nocturne = inverse
    if (mars) {
        const courDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, mars.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, mars.fullDegree);
        pushLot("Lot de Courage", "Lot of Courage", courDeg);
    }
    // Lot de Némésis : diurne = ASC + Fortune - Saturne ; nocturne = inverse
    if (saturn) {
        const nemDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, saturn.fullDegree);
        pushLot("Lot de Némésis", "Lot of Nemesis", nemDeg);
    }
    // Lot de Basis : ASC + Fortune - Esprit (invariant sect)
    const basisDeg = lotCalc(asc.fullDegree, pofDeg, posDeg);
    pushLot("Lot de Basis", "Lot of Basis", basisDeg);

    // Lot d'Exaltation : ASC + (degré exalt Soleil 19°Bélier) - Soleil
    const exaltSunDeg = 19; // 19° Bélier
    const exaltDeg = lotCalc(asc.fullDegree, exaltSunDeg, sun.fullDegree);
    pushLot("Lot d'Exaltation", "Lot of Exaltation", exaltDeg);

    // Lot du Daemon : diurne = ASC + Soleil - Esprit ; nocturne = inverse
    const daemonDeg = isDayChart ? lotCalc(asc.fullDegree, sun.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, sun.fullDegree, posDeg);
    pushLot("Lot du Daemon", "Lot of Daemon", daemonDeg);

    // ── C7 : Parts Arabes élargies (Vettius Valens, Paulus Alexandrinus, Firmicus Maternus) ──
    // Lot de Victoire (Nikè) : diurne = ASC + Jupiter - Esprit ; nocturne = inverse
    if (jupiter) {
        const vicDeg = isDayChart ? lotCalc(asc.fullDegree, jupiter.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, jupiter.fullDegree, posDeg);
        pushLot("Lot de Victoire", "Lot of Victory", vicDeg);
    }
    // Lot du Père : diurne = ASC + Saturne - Soleil ; nocturne = inverse
    if (saturn) {
        const pereDeg = isDayChart ? lotCalc(asc.fullDegree, saturn.fullDegree, sun.fullDegree) : lotCalcInverse(asc.fullDegree, saturn.fullDegree, sun.fullDegree);
        pushLot("Lot du Père", "Lot of Father", pereDeg);
    }
    // Lot de la Mère : diurne = ASC + Lune - Vénus ; nocturne = inverse
    if (venus) {
        const mereDeg = isDayChart ? lotCalc(asc.fullDegree, moon.fullDegree, venus.fullDegree) : lotCalcInverse(asc.fullDegree, moon.fullDegree, venus.fullDegree);
        pushLot("Lot de la Mère", "Lot of Mother", mereDeg);
    }
    // Lot de Maladie (Valens) : diurne = ASC + Mars - Saturne ; nocturne = inverse
    if (mars && saturn) {
        const malDeg = isDayChart ? lotCalc(asc.fullDegree, mars.fullDegree, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, mars.fullDegree, saturn.fullDegree);
        pushLot("Lot de Maladie", "Lot of Illness", malDeg);
    }
    // Lot du Mariage : diurne = ASC + DSC - Vénus ; nocturne = inverse (formule universelle Valens)
    const dsc = maisons.find(m => m.House === 7);
    if (venus && dsc) {
        const mariDeg = isDayChart ? lotCalc(asc.fullDegree, dsc.degree, venus.fullDegree) : lotCalcInverse(asc.fullDegree, dsc.degree, venus.fullDegree);
        pushLot("Lot du Mariage", "Lot of Marriage", mariDeg);
    }
    // Lot des Enfants (Valens) : diurne = ASC + Jupiter - Saturne ; nocturne = inverse
    if (jupiter && saturn) {
        const enfDeg = isDayChart ? lotCalc(asc.fullDegree, jupiter.fullDegree, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, jupiter.fullDegree, saturn.fullDegree);
        pushLot("Lot des Enfants", "Lot of Children", enfDeg);
    }
    // Lot de Voyage (Firmicus) : diurne = ASC + Mars - Saturne renversé pour cette formule ≠ maladie
    // → Firmicus : ASC + 9e cuspide - maître du 9e ; simplifié → ASC + Saturne - Jupiter (éloignement)
    if (jupiter && saturn) {
        const voyDeg = isDayChart ? lotCalc(asc.fullDegree, saturn.fullDegree, jupiter.fullDegree) : lotCalcInverse(asc.fullDegree, saturn.fullDegree, jupiter.fullDegree);
        pushLot("Lot de Voyage", "Lot of Travel", voyDeg);
