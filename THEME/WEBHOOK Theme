im() : null,\n    pays: typeof b.pays === \"string\" && b.pays.trim() ? b.pays.trim() : null,\n    mail,\n    langue:\n      typeof b.langue === \"string\" && b.langue.trim() ? b.langue.trim() : \"Français\",\n    consigne_redaction:\n      typeof b.consigne_redaction === \"string\" && b.consigne_redaction.trim()\n        ? b.consigne_redaction.trim()\n        : \"Tu\",\n    genre: b.genre === \"F\" ? \"F\" : \"M\",\n    orderId:\n      typeof b.orderId === \"string\" && b.orderId.trim() ? b.orderId.trim() : null,\n  };\n\n  const blat = numOpt(b.birth_place_lat);\n  const blng = numOpt(b.birth_place_lng);\n  const pid =\n    typeof b.birth_place_place_id === \"string\" && b.birth_place_place_id.trim()\n      ? b.birth_place_place_id.trim()\n      : null;\n  const fa =\n    typeof b.birth_place_formatted_address === \"string\" && b.birth_place_formatted_address.trim()\n      ? b.birth_place_formatted_address.trim()\n      : null;\n  const btr =\n    typeof b.birth_time_reference === \"string\" && b.birth_time_reference.trim()\n      ? b.birth_time_reference.trim()\n      : \"civil_at_birth_place\";\n\n  if (blat !== null && blng !== null && Math.abs(blat) <= 90 && Math.abs(blng) <= 180) {\n    row.birth_place_lat = blat;\n    row.birth_place_lng = blng;\n    if (pid) row.birth_place_place_id = pid;\n    if (fa) row.birth_place_formatted_address = fa;\n    row.birth_time_reference = btr;\n  }\n\n  return [{ json: row }];\n}\n\n// B) Gmail / formulaire (ancien flux)\nconst item = j;\n\nfunction findPlainText(payload) {\n  if (!payload) return null;\n  if (payload.mimeType === \"text/plain\" && payload.body && payload.body.data) return payload.body.data;\n  if (payload.parts) {\n    for (const part of payload.parts) {\n      const found = findPlainText(part);\n      if (found) return found;\n    }\n  }\n  return null;\n}\n\nconst b64 = findPlainText(item.payload);\nlet text = b64\n  ? Buffer.from(b64.replace(/-/g, \"+\").replace(/_/g, \"/\"), \"base64\").toString(\"utf