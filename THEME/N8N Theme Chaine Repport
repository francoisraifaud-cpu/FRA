: 15px; overflow: hidden; }\n    .sign-group ul { list-style: none; padding: 15px 20px 15px 35px; margin: 0; }\n    .sign-group li { margin-bottom: 8px; font-size: 1.05em; position: relative; }\n    .sign-group li:before { content: \"•\"; position: absolute; left: -15px; color: #1F3864; font-weight: bold; }\n    .empty-msg { padding: 15px 20px; margin: 0; color: #94a3b8; font-size: 1.05em; font-style: italic; }\n    /* Éclipse bannière */\n    .eclipse-banner { background: linear-gradient(135deg, #fff0e6, #fff8f5); border: 2px solid #ea580c; border-radius: 10px; padding: 16px 20px; margin-bottom: 20px; }\n    .eclipse-banner-title { color: #7c2d12; font-family: 'Playfair Display', Georgia, serif; font-size: 1.15em; font-weight: 700; margin-bottom: 6px; }\n    /* Configurations et Réceptions */\n    .config-item { background: #eef2fb; border-left: 4px solid #2E5FA3; border-radius: 0 6px 6px 0; padding: 10px 14px; margin-bottom: 8px; }\n    .config-item-sub { background: #f0f4ff; border-left: 3px dashed #94a3b8; border-radius: 0 6px 6px 0; padding: 8px 14px 8px 22px; margin-bottom: 6px; margin-left: 18px; opacity: 0.85; }\n    .config-type { color: #5b21b6; font-weight: 700; font-size: 0.9em; text-transform: uppercase; letter-spacing: 0.5px; }\n    .config-type-sub { color: #64748b; font-weight: 600; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.5px; }\n    .tag-sub-config { display: inline-block; background: #e2e8f0; color: #475569; font-size: 0.7em; font-weight: 600; border-radius: 4px; padding: 1px 6px; margin-left: 6px; vertical-align: middle; }\n    .tag-variant { display: inline-block; background: #e8f0fe; color: #1F3864; font-size: 0.7em; font-weight: 600; border-radius: 4px; padding: 1px 6px; margin-left: 6px; vertical-align: middle; }\n    @media print {\n        @page { size: A4 portrait; margin: 10mm 15mm 20mm; @bottom-center { content: counter(page) \" / \" counter(pages); font-size: 9pt; color: #888; } }\n        body { padding: 0; background: white; font-size: 12pt; color: #000; }\n        .container { padding: 0; box-shadow: none; border: none; max-width: 100%; margin: 0; }\n        .main-header { padding: 35px 25px; margin-bottom: 20px; }\n        .main-header h1 { font-size: 32px; }\n        h2.section-title, .stat-card-header, .legend-title, .sign-group h3 { height: 40px !important; font-size: 15px !important; padding: 0 12px !important; }\n        h2.section-title { margin: 20px 0 15px 0 !important; page-break-after: avoid; break-after: avoid; }\n        .legend-title { margin: 0 0 10px 0 !important; }\n        .wheel-container { page-break-inside: avoid; margin-top: 0; padding: 0; }\n        .wheel-page-break { page-break-before: always; break-before: page; margin-top: 0; padding-top: 10px; }\n        .svg-container svg { height: auto !important; width: 100% !important; max-width: 850px !important; max-height: 950px !important; margin: 0 auto; display: block; }\n        .force-page-break-legend { page-break-before: always; break-before: page; margin-top: 0; padding-top: 10px; }\n        .legend-grid { margin-top: 0; padding-top: 10px; border: none; }\n        .page-break { page-break-before: always; break-before: page; margin-top: 0 !important; padding-top: 0 !important; }\n        .sign-group { page-break-inside: avoid; break-inside: avoid; }\n        .subsection-title { font-size: 14px !important; padding: 6px 12px !important; margin: 0 0 8px !important; }\n        table { page-break-inside: auto; }\n        tr { page-break-inside: avoid; page-break-after: auto; }\n    }\n</style>\n</head>\n<body>\n<div class=\"container\">\n\n<div class=\"main-header\">\n    <h1>${headerTitle}</h1>\n    <p class=\"subtitle\">${escH(_lumHeaderDT)}</p>\n    <p class=\"details\">${infosNaissance}</p>\n</div>`;\n\n// ── Bannière éclipse natale ──\nif (eclipseNatal) {\n    html += `<div class=\"eclipse-banner\">\n        <div class=\"eclipse-banner-title\">⚡ ${isEN ? 'Eclipse at Birth' : 'Éclipse à la Naissanc