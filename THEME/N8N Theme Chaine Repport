    {
      "parameters": {
        "jsCode": "const input = $input.first()?.json;\nif (!input?.maisons) {\n    return [{ json: { error: \"Missing data / Données manquantes\" } }];\n}\n\ntry {\n// EXTRACTION DYNAMIQUE DES VARIABLES\nlet perso = input.perso || {};\ntry {\n    if (!perso.nom) perso = $(\"Extract Variables\").first()?.json || $(\"Extract Variables4\").first()?.json || {};\n} catch(e) {}\n\nconst vars = $(\"Extract Variables\").first()?.json || $(\"Extract Variables4\").first()?.json || perso || {};\nconst langue = vars.langue || 'Français';\nconst isEN = langue !== 'Français';\n\nconst prenom = perso.prenom || '';\nconst nom    = perso.nom    || '';\nconst escH   = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n\nconst EGYPTIAN_TERMS = {\n    \"Bélier\":[[\"Jupiter\",6],[\"Vénus\",12],[\"Mercure\",20],[\"Mars\",25],[\"Saturne\",30]],\n    \"Taureau\":[[\"Vénus\",8],[\"Mercure\",14],[\"Jupiter\",22],[\"Saturne\",27],[\"Mars\",30]],\n    \"Gémeaux\":[[\"Mercure\",6],[\"Jupiter\",12],[\"Vénus\",17],[\"Mars\",24],[\"Saturne\",30]],\n    \"Cancer\":[[\"Mars\",7],[\"Vénus\",13],[\"Mercure\",19],[\"Jupiter\",26],[\"Saturne\",30]],\n    \"Lion\":[[\"Jupiter\",6],[\"Vénus\",11],[\"Saturne\",18],[\"Mercure\",24],[\"Mars\",30]],\n    \"Vierge\":[[\"Mercure\",7],[\"Vénus\",17],[\"Jupiter\",21],[\"Mars\",28],[\"Saturne\",30]],\n    \"Balance\":[[\"Saturne\",6],[\"Mercure\",14],[\"Jupiter\",21],[\"Vénus\",28],[\"Mars\",30]],\n    \"Scorpion\":[[\"Mars\",7],[\"Vénus\",11],[\"Mercure\",19],[\"Jupiter\",24],[\"Saturne\",30]],\n    \"Sagittaire\":[[\"Jupiter\",12],[\"Vénus\",17],[\"Mercure\",21],[\"Saturne\",26],[\"Mars\",30]],\n    \"Capricorne\":[[\"Mercure\",7],[\"Jupiter\",14],[\"Vénus\",22],[\"Saturne\",26],[\"Mars\",30]],\n    \"Verseau\":[[\"Mercure\",7],[\"Vénus\",13],[\"Jupiter\",20],[\"Mars\",25],[\"Saturne\",30]],\n    \"Poissons\":[[\"Vénus\",12],[\"Jupiter\",16],[\"Mercure\",19],[\"Mars\",28],[\"Saturne\",30]]\n};\nconst getTermRuler = (sign, deg) => {\n    const terms = EGYPTIAN_TERMS[sign];\n    if (!terms) return null;\n    const d = deg % 30;\n    for (const [ruler, boundary] of terms) { if (d < boundary) return ruler; }\n    return terms[terms.length - 1][0];\n};\n\nconst TRIPLIC_DAY_R = {\n    \"Bélier\":\"Soleil\",\"Lion\":\"Soleil\",\"Sagittaire\":\"Soleil\",\n    \"Taureau\":\"Vénus\",\"Vierge\":\"Vénus\",\"Capricorne\":\"Vénus\",\n    \"Gémeaux\":\"Saturne\",\"Balance\":\"Saturne\",\"Verseau\":\"Saturne\",\n    \"Cancer\":\"Vénus\",\"Scorpion\":\"Vénus\",\"Poissons\":\"Vénus\"\n};\nconst TRIPLIC_NIGHT_R = {\n    \"Bélier\":\"Jupiter\",\"Lion\":\"Jupiter\",\"Sagittaire\":\"Jupiter\",\n    \"Taureau\":\"Lune\",\"Vierge\":\"Lune\",\"Capricorne\":\"Lune\",\n    \"Gémeaux\":\"Mercure\",\"Balance\":\"Mercure\",\"Verseau\":\"Mercure\",\n    \"Cancer\":\"Mars\",\"Scorpion\":\"Mars\",\"Poissons\":\"Mars\"\n};\nconst statsEarly = input.stats || {};\nconst isDayChartR = (statsEarly.sect || \"\").includes(\"Diurne\");\nconst getTriplicityRulerR = (sign) => isDayChartR ? (TRIPLIC_DAY_R[sign] || null) : (TRIPLIC_NIGHT_R[sign] || null);\n\nconst CHALDEAN_DECANS = {\n    \"Bélier\":[\"Mars\",\"Soleil\",\"Vénus\"],\"Taureau\":[\"Mercure\",\"Lune\",\"Saturne\"],\n    \"Gémeaux\":[\"Jupiter\",\"Mars\",\"Soleil\"],\"Cancer\":[\"Vénus\",\"Mercure\",\"Lune\"],\n    \"Lion\":[\"Saturne\",\"Jupiter\",\"Mars\"],\"Vierge\":[\"Soleil\",\"Vénus\",\"Mercure\"],\n    \"Balance\":[\"Lune\",\"Saturne\",\"Jupiter\"],\"Scorpion\":[\"Mars\",\"Soleil\",\"Vénus\"],\n    \"Sagittaire\":[\"Mercure\",\"Lune\",\"Saturne\"],\"Capricorne\":[\"Jupiter\",\"Mars\",\"Soleil\"],\n    \"Verseau\":[\"Vénus\",\"Mercure\",\"Lune\"],\"Poissons\":[\"Saturne\",\"Jupiter\",\"Mars\"]\n};\n\nconst nomUpper = (nom || \"\").toUpperCase();\nlet headerTitle = `${isEN ? 'Technical Birth Chart Report' : 'Données Techniques Thème Astral'} —<br>Inconnu`;\nif (prenom && nom)   headerTitle = `${isEN ? 'Technical Birth Chart Report' : 'Données Techniques Thème Astral'} —<br>${escH(prenom)}<br>${escH(nomUpper)}`;\nelse if (prenom || nom) headerTitle = `${isEN ? 'Technical Birth Chart Report' : 'Données Techniques Thème Astral'} —<br>${escH(prenom || nomUpper)}`;\n\nconst _plDT = input.planetes || [];\nconst _solSignDT = _plDT.find(p => (p.planet?.fr || p.planet?.en) === \"Soleil\")?.zodiac_sign?.name?.fr || \"\";\nconst _lunSignDT = _plDT.find(p => (p.planet?.fr || p.planet?.en) === \"Lune\")?.zodiac_sign?.name?.fr || \"\";\nconst _ascSignDT = (input.maisons || []).find(h => h.maison === 1)?.segments?.find(s => s.type === \"Cuspide\")?.signe || \"\";\nconst _lumHeaderDT = isEN\n    ? `Sun: ${_solSignDT} / Ascendant: ${_ascSignDT} / Moon: ${_lunSignDT}`\n    : `Soleil : ${_solSignDT} / Ascendant : ${_ascSignDT} / Lune : ${_lunSignDT}`;\n\nconst dateNaissance  = escH(perso.date  || (isEN ? 'Unknown date' : 'Date inconnue'));\nconst heureNaissance = perso.heure ? escH(perso.heure.replace(':', 'H')) : (isEN ? 'Unknown time' : 'Heure inconnue');\nconst lieuNaissance  = escH(perso.lieu  || (isEN ? 'Unknown place' : 'Lieu inconnu'));\nconst tzStr = perso.timezone || perso.fuseau || '';\nconst latStr = perso.latitude != null ? `${parseFloat(perso.latitude).toFixed(4)}°` : '';\nconst lonStr = perso.longitude != null ? `${parseFloat(perso.longitude).toFixed(4)}°` : '';\nconst hsStr = perso.house_system || perso.systeme_maisons || 'Placidus';\nconst coordParts = [latStr && lonStr ? `${latStr}N / ${lonStr}E` : '', tzStr].filter(Boolean).join(' · ');\nconst infosNaissance = `${dateNaissance} · ${heureNaissance} · ${lieuNaissance}` + (coordParts ? `<br><span style=\"font-size:0.85em;opacity:0.8\">${coordParts}</span>` : '');\n\nconst stats          = statsEarly;\nconst configurations = input.configurations || [];\nconst angularPlanets = input.angularPlanets || [];\nconst criticalPlanets= input.criticalPlanets|| [];\nconst mutualReceptions=input.mutualReceptions||[];\nconst antiscia       = input.antiscia       || [];\nconst helioConditions= input.helioConditions|| {};\nconst eclipseNatal   = input.eclipseNatal   || null;\nconst etoileMatches      = input.etoileMatches     || [];\nconst etoileCuspMatches  = input.etoileCuspMatches || [];\nconst planeteOOB         = input.planeteOOB         || [];\nconst paralleles         = input.paralleles         || [];\nconst contreParalleles   = input.contreParalleles   || [];\nconst dispositorTree     = input.dispositorTree     || {};\nconst accidentalDignity  = input.accidentalDignity  || [];\nconst hayzPlanets        = input.hayzPlanets        || [];\nconst besiegedPlanets    = input.besiegedPlanets    || [];\nconst moonVOC            = input.moonVOC            || null;\nconst sabianData         = input.sabianData         || {};\nconst paranResults       = input.paranResults       || [];\nconst sensitivityProfileR = input.sensitivityProfile || \"\";\n\n// Helpers\nconst getAngularInfo  = pName => angularPlanets.find(ap => ap.planet === pName) || null;\nconst getCriticalInfo = pName => criticalPlanets.find(cp => cp.planet === pName) || null;\nconst getHelioInfo    = pName => helioConditions[pName] || null;\nconst getEtoileInfos  = pName => etoileMatches.filter(em => em.planete === pName && !em.isAngle);\nconst getCuspEtoiles  = hNum  => etoileCuspMatches.filter(ec => ec.maison === hNum);\nconst getOOBInfo      = pName => planeteOOB.find(o => o.planete === pName) || null;\nconst getParaList     = pName => [\n    ...paralleles.filter(p => p.p1 === pName || p.p2 === pName).map(p => ({\n        type: \"//\", autre: p.p1 === pName ? p.p2 : p.p1, orb: p.orb, hasLuminaire: p.hasLuminaire\n    })),\n    ...contreParalleles.filter(p => p.p1 === pName || p.p2 === pName).map(p => ({\n        type: \"#\", autre: p.p1 === pName ? p.p2 : p.p1, orb: p.orb, hasLuminaire: p.hasLuminaire\n    }))\n];\n\n// ─────────────────────────────────────────────────────────────────\n// GÉNÉRATION DE LA ROUE SVG — Améliorations v2 :\n//  • Tick proéminent + point coloré à la position réelle exacte\n//  • Ligne de liaison plus visible entre position réelle et glyphe déplacé\n//  • Algorithme de spreading avec rappel élastique vers la position réelle\n//    (limite la dérive max à ~18°)\n//  • MIN_GAP réduit de 8.5° à 7.0° pour un meilleur ancrage\n// ─────────────────────────────────────────────────────────────────\nconst generateWheelSVG = (planetes, maisons) => {\n\n    const pGlyphs = {\n        \"Soleil\":\"☉\",\"Lune\":\"☽\",\"Mercure\":\"☿\",\"Vénus\":\"♀\",\"Mars\":\"♂\",\n        \"Jupiter\":\"♃\",\"Saturne\":\"♄\",\"Uranus\":\"♅\",\"Neptune\":\"♆\",\"Pluton\":\"♇\",\n        \"Chiron\":\"⚷\",\"Nœud Nord\":\"☊\",\"Nœud Sud\":\"☋\",\"Part de Fortune\":\"⊕\",\n        \"Lot de l'Esprit\":\"⊗\",\"Lilith\":\"⚸\",\"Cérès\":\"⚳\",\"Vesta\":\"⚶\",\"Junon\":\"⚵\",\"Pallas\":\"⚴\",\n        \"Lot de Nécessité\":\"⊖\",\"Lot d'Éros\":\"♡\",\"Lot de Courage\":\"⚔\",\"Lot de Némésis\":\"⚖\",\n        \"Lot de Basis\":\"⬡\",\"Lot d'Exaltation\":\"△\",\"Lot du Daemon\":\"☿̦\",\n        \"Lot de Victoire\":\"⚜\",\"Lot du Père\":\"⚑\",\"Lot de la Mère\":\"⚘\",\n        \"Lot de Maladie\":\"⚕\",\"Lot du Mariage\":\"♥\",\"Lot des Enfants\":\"✦\",\"Lot de Voyage\":\"✢\"\n    };\n    const signGlyphs = [\"♈\",\"♉\",\"♊\",\"♋\",\"♌\",\"♍\",\"♎\",\"♏\",\"♐\",\"♑\",\"♒\",\"♓\"];\n    const baseColors = [\n        \"#C62828\", // Aries - Fire (deep red)\n        \"#2E7D32\", // Taurus - Earth (forest green)\n        \"#F9A825\", // Gemini - Air (golden amber)\n        \"#1565C0\", // Cancer - Water (deep blue)\n        \"#C62828\", // Leo - Fire\n        \"#2E7D32\", // Virgo - Earth\n        \"#F9A825\", // Libra - Air\n        \"#1565C0\", // Scorpio - Water\n        \"#C62828\", // Sagittarius - Fire\n        \"#2E7D32\", // Capricorn - Earth\n        \"#F9A825\", // Aquarius - Air\n        \"#1565C0\", // Pisces - Water\n    ];\n\n    const CX=400, CY=400;\n    const R_OUT=372, R_SG=350, R_SI=325;\n    const R_PO=292;\n    const R_HN=198, R_HI=168, R_AS=160;\n    const R_GLYPH=16;\n\n    const ascObj = planetes.find(p => p.planet?.fr === \"Ascendant\");\n    const ascDeg = ascObj ? ascObj.fullDegree : 0;\n\n    const e2s = d => ((180 - (d - ascDeg)) % 360 + 360) % 360;\n    const d2r = d => d * Math.PI / 180;\n    const pol = (a, r) => ({ x: CX + r * Math.cos(d2r(a)), y: CY + r * Math.sin(d2r(a)) });\n    const angDiff = (a, b) => { let d = ((a - b) % 360 + 360) % 360; return d > 180 ? d - 360 : d; };\n\n    const SIGNES = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\n    const cuspides = maisons.map(m => {\n        const seg = m.segments.find(s => s.type === \"Cuspide\");\n        if (!seg) return 0;\n        const si = SIGNES.indexOf(seg.signe);\n        return (si >= 0 ? si * 30 : 0) + seg.degre_debut;\n    });\n\n    let s = [];\n\n    s.push(`<defs><radialGradient id=\"houseGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\"><stop offset=\"0%\" stop-color=\"#ffffff\"/><stop offset=\"100%\" stop-color=\"#f4f6fa\"/></radialGradient></defs>`);\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R_OUT+8}\" fill=\"white\" stroke=\"#c0c0cc\" stroke-width=\"1.5\"/>`);\n\n    for (let i = 0; i < 12; i++) {\n        for (let d = 0; d < 3; d++) {\n            const eclStart = i*30 + d*10, eclEnd = i*30 + (d+1)*10;\n            const a1 = e2s(eclStart), a2 = e2s(eclEnd);\n            const o1 = pol(a1,R_OUT), o2 = pol(a2,R_OUT), i1 = pol(a1,R_SI), i2 = pol(a2,R_SI);\n            s.push(`<path d=\"M${i1.x.toFixed(2)},${i1.y.toFixed(2)} L${o1.x.toFixed(2)},${o1.y.toFixed(2)} A${R_OUT},${R_OUT} 0 0,0 ${o2.x.toFixed(2)},${o2.y.toFixed(2)} L${i2.x.toFixed(2)},${i2.y.toFixed(2)} A${R_SI},${R_SI} 0 0,1 ${i1.x.toFixed(2)},${i1.y.toFixed(2)} Z\" fill=\"${baseColors[i]}\" stroke=\"#ffffff\" stroke-width=\"0.5\"/>`);\n            if (d > 0) s.push(`<line x1=\"${i1.x.toFixed(2)}\" y1=\"${i1.y.toFixed(2)}\" x2=\"${o1.x.toFixed(2)}\" y2=\"${o1.y.toFixed(2)}\" stroke=\"#ffffff\" stroke-width=\"0.8\" stroke-dasharray=\"3,3\" opacity=\"0.6\"/>`);\n        }\n        const sBorder = e2s(i*30);\n        const b1 = pol(sBorder, R_SI), b2 = pol(sBorder, R_OUT);\n        s.push(`<line x1=\"${b1.x.toFixed(2)}\" y1=\"${b1.y.toFixed(2)}\" x2=\"${b2.x.toFixed(2)}\" y2=\"${b2.y.toFixed(2)}\" stroke=\"#ffffff\" stroke-width=\"1.5\"/>`);\n        const midA = e2s(i*30 + 15), gPos = pol(midA, R_SG);\n        const glyphFill = baseColors[i] === \"#F9A825\" ? \"#1a1a1a\" : \"#ffffff\";\n        s.push(`<text x=\"${gPos.x.toFixed(2)}\" y=\"${gPos.y.toFixed(2)}\" font-size=\"22\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"${glyphFill}\" font-family=\"serif\" font-weight=\"bold\">${signGlyphs[i]}</text>`);\n    }\n\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R_SI}\" fill=\"white\" stroke=\"#707080\" stroke-width=\"1.8\"/>`);\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R_HI}\" fill=\"url(#houseGrad)\" stroke=\"#909090\" stroke-width=\"1.2\"/>`);\n\n    const axMap = { 0:\"AC\", 3:\"IC\", 6:\"DC\", 9:\"MC\" };\n    for (let i = 0; i < 12; i++) {\n        const cEcl = cuspides[i], svgA = e2s(cEcl);\n        const isAxis = [0,3,6,9].includes(i);\n        const pOut = pol(svgA, R_SI), pIn = pol(svgA, R_HI);\n        s.push(`<line x1=\"${pOut.x.toFixed(2)}\" y1=\"${pOut.y.toFixed(2)}\" x2=\"${pIn.x.toFixed(2)}\" y2=\"${pIn.y.toFixed(2)}\" stroke=\"${isAxis ? \"#1a237e\" : \"#b0b0c8\"}\" stroke-width=\"${isAxis ? 2.8 : 0.9}\" ${isAxis ? \"\" : 'stroke-dasharray=\"4,4\"'}/>`);\n        const nxEcl = cuspides[(i+1)%12], span = (nxEcl - cEcl + 360) % 360;\n        const midEcl = (cEcl + span/2 + 360) % 360, nPos = pol(e2s(midEcl), R_HN);\n        s.push(`<text x=\"${nPos.x.toFixed(2)}\" y=\"${nPos.y.toFixed(2)}\" font-size=\"24\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#1F3864\" font-weight=\"900\" font-family=\"Arial,sans-serif\">${i+1}</text>`);\n        if (isAxis) {\n            const axPos = pol(svgA, R_OUT+24);\n            s.push(`<text x=\"${axPos.x.toFixed(2)}\" y=\"${axPos.y.toFixed(2)}\" font-size=\"18\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#1a237e\" font-weight=\"900\" font-family=\"Arial,sans-serif\">${axMap[i]}</text>`);\n        }\n    }\n\n    // Aspects\n    const aspDef = {\n        \"Sextile\":   { col:\"#009944\", w:1.0, op:0.6, z:1 },\n        \"Trigone\":   { col:\"#1155cc\", w:1.4, op:0.7, z:2 },\n        \"Carré\":     { col:\"#ee4400\", w:1.7, op:0.78, z:3 },\n        \"Opposition\":{ col:\"#cc0000\", w:2.0, op:0.83, z:4 },\n        \"Conjonction\":{ col:\"#9900dd\", w:2.3, op:0.88, z:5 }\n    };\n    const posMap = {};\n    planetes.forEach(p => { if (p.planet?.fr) posMap[p.planet.fr] = p.fullDegree; });\n    // Filtrer uniquement les aspects majeurs (isMajor ou aspect reconnu dans aspDef)\n    [...(input.aspects || [])].filter(a => aspDef[a.aspect] && (a.isMajor !== false) && posMap[a.p1] !== undefined && posMap[a.p2] !== undefined)\n        .sort((a,b) => (aspDef[a.aspect]?.z||0) - (aspDef[b.aspect]?.z||0))\n        .forEach(asp => {\n            const st = aspDef[asp.aspect];\n            const a1 = d2r(e2s(posMap[asp.p1])), a2 = d2r(e2s(posMap[asp.p2]));\n            s.push(`<line x1=\"${(CX + R_AS*Math.cos(a1)).toFixed(1)}\" y1=\"${(CY + R_AS*Math.sin(a1)).toFixed(1)}\" x2=\"${(CX + R_AS*Math.cos(a2)).toFixed(1)}\" y2=\"${(CY + R_AS*Math.sin(a2)).toFixed(1)}\" stroke=\"${st.col}\" stroke-width=\"${st.w}\" opacity=\"${st.op}\"/>`);\n        });\n\n    // ── PLANÈTES avec algorithme de spreading amélioré ──\n    const skipPl = [\"Descendant\",\"Imum Coeli\",\"Ascendant\",\"Milieu du Ciel\"];\n    let validPlanets = planetes\n        .filter(p => p.planet?.fr && !skipPl.includes(p.planet.fr))\n        .map(p => ({\n            name: p.planet?.fr,\n            fullDeg: p.fullDegree,\n            a: p.fullDegree,\n            retro: !!(p.retroStr && p.retroStr.includes(\"Rétro\"))\n        }))\n        .sort((a,b) => a.fullDeg - b.fullDeg);\n\n    let nPlanets = validPlanets.length;\n    if (nPlanets > 0) {\n        const LAYER_R = [R_PO, R_PO - 30, R_PO - 56];\n        const LAYER_GAP = 5.5;\n        const aDiff = (a, b) => Math.abs(((a - b + 540) % 360) - 180);\n\n        validPlanets.sort((a,b) => ((a.fullDeg%360+360)%360) - ((b.fullDeg%360+360)%360));\n        const placed = [];\n        validPlanets.forEach(p => {\n            const realA = ((p.fullDeg % 360) + 360) % 360;\n            let assigned = false;\n            for (let layer = 0; layer < LAYER_R.length && !assigned; layer++) {\n                const sameL = placed.filter(q => q.layer === layer);\n                if (!sameL.some(q => aDiff(realA, q.a) < LAYER_GAP)) {\n                    p.layer = layer; p.radius = LAYER_R[layer]; p.displayA = realA;\n                    placed.push({ a: realA, layer });\n                    assigned = true;\n                }\n            }\n            if (!assigned) {\n                const deep = LAYER_R.length - 1;\n                for (let nudge = 1; nudge <= 4 && !assigned; nudge++) {\n                    for (const sign of [1, -1]) {\n                        const testA = ((realA + sign * nudge) % 360 + 360) % 360;\n                        const sameL = placed.filter(q => q.layer === deep);\n                        if (!sameL.some(q => aDiff(testA, q.a) < LAYER_GAP)) {\n                            p.layer = deep; p.radius = LAYER_R[deep]; p.displayA = testA;\n                            placed.push({ a: testA, layer: deep });\n                            assigned = true; break;\n                        }\n                    }\n                }\n                if (!assigned) {\n                    p.layer = LAYER_R.length - 1; p.radius = LAYER_R[LAYER_R.length - 1]; p.displayA = realA;\n                    placed.push({ a: realA, layer: LAYER_R.length - 1 });\n                }\n            }\n        });\n\n        let svgLines = \"\", svgBgs = \"\", svgGlyphs = \"\";\n\n        validPlanets.forEach(p => {\n            const svgA = e2s(p.displayA);\n            const pos  = pol(svgA, p.radius);\n            const glyph = pGlyphs[p.name] || \"?\";\n\n            const rimP   = pol(svgA, R_SI - 1);\n            const glyphE = pol(svgA, p.radius + R_GLYPH + 2);\n            svgLines += `<line x1=\"${rimP.x.toFixed(1)}\" y1=\"${rimP.y.toFixed(1)}\" x2=\"${glyphE.x.toFixed(1)}\" y2=\"${glyphE.y.toFixed(1)}\" stroke=\"#9aa8c4\" stroke-width=\"0.55\" opacity=\"0.5\"/>`;\n\n            svgBgs += `<circle cx=\"${pos.x.toFixed(1)}\" cy=\"${pos.y.toFixed(1)}\" r=\"${R_GLYPH + 1}\" fill=\"white\" fill-opacity=\"0.97\" stroke=\"#c0c0cc\" stroke-width=\"0.5\"/>`;\n\n            const isMarsOrVenus = (glyph === \"♀\" || glyph === \"♂\");\n            const strokeAttr = isMarsOrVenus ? 'stroke=\"#1F3864\" stroke-width=\"1.2\"' : 'stroke=\"none\"';\n            svgGlyphs += `<text x=\"${pos.x.toFixed(1)}\" y=\"${pos.y.toFixed(1)}\" font-size=\"26\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#1F3864\" ${strokeAttr} font-weight=\"bold\" font-family=\"'Segoe UI Symbol', 'Apple Symbols', 'Symbola', 'Arial Unicode MS', serif\">${glyph}</text>`;\n\n            if (p.retro) {\n                svgGlyphs += `<text x=\"${(pos.x+11).toFixed(1)}\" y=\"${(pos.y+11).toFixed(1)}\" font-size=\"10\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#cc0000\" font-weight=\"900\" font-family=\"Arial,sans-serif\">R</text>`;\n            }\n        });\n\n        s.push(svgLines);\n        s.push(svgBgs);\n        s.push(svgGlyphs);\n    }\n\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"7\" fill=\"#1a237e\" stroke=\"white\" stroke-width=\"2\"/>`);\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"2.5\" fill=\"white\"/>`);\n\n    return `<svg viewBox=\"-20 -20 840 840\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%; max-width:850px; height:auto; display:block; margin:auto;\">${s.join('')}</svg>`;\n};\n\n// ─────────────────────────────────────────────────────────────────\n// CONSTRUCTION DU DOCUMENT HTML\n// ─────────────────────────────────────────────────────────────────\nlet html = `<!DOCTYPE html>\n<html lang=\"${isEN ? 'en' : 'fr'}\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>${isEN ? 'Technical Birth Chart Report' : 'Données Techniques Thème Astral'}</title>\n<style>\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&family=Noto+Sans+Symbols+2:wght@400;700&display=swap');\n    * { box-sizing: border-box; }\n    body { font-family: 'Source Sans 3', 'Segoe UI', sans-serif; background: #ffffff; color: #2c2c3a; padding: 20px; font-size: 16px; line-height: 1.6; }\n    .container { max-width: 1000px; margin: auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,.05); }\n    .main-header { background: #1F3864; padding: 52px 44px 48px; color: white; text-align: center; border-radius: 14px; margin-bottom: 20px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    .main-header h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; font-weight: 700; letter-spacing: 0.3px; color: #ffffff; margin: 0 0 10px; line-height: 1.35; }\n    .main-header p.subtitle { font-size: 14px; font-weight: 400; letter-spacing: 1px; color: #8ab4f8; margin: 0 0 6px; }\n    .main-header p.details { font-size: 15.5px; font-weight: 400; color: #aac4ff; letter-spacing: 0.5px; margin: 8px 0 0; }\n    h2.section-title, .stat-card-header, .legend-title { background: #1F3864 !important; color: white !important; font-family: 'Playfair Display', Georgia, serif !important; font-size: 1.2em !important; font-weight: 600 !important; padding: 0 15px !important; border-radius: 8px !important; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; margin: 0 !important; height: 48px !important; letter-spacing: 0.2px !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    h2.section-title { margin: 30px 0 15px 0 !important; }\n    .stat-card-header { border-bottom-left-radius: 0 !important; border-bottom-right-radius: 0 !important; }\n    .legend-title { margin: 0 0 15px 0 !important; }\n    .sign-group h3 { background: #2E5FA3 !important; color: white !important; font-family: 'Playfair Display', Georgia, serif !important; font-size: 1.2em !important; font-weight: 600 !important; padding: 0 15px !important; margin: 0 !important; display: flex !important; align-items: center !important; height: 48px !important; letter-spacing: 0.2px !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 25px; font-size: 1em; }\n    th, td { padding: 12px; text-align: left; border: 1px solid #cbd5e1; }\n    th { background: #2E5FA3 !important; color: white !important; font-size: 0.95em; text-transform: uppercase; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    tr:nth-child(even) { background: #f8fafc; }\n    .tag { font-size: 0.9em; background: #e8f0fe; color: #1F3864; padding: 4px 10px; border-radius: 4px; margin-right: 4px; font-weight: bold; display: inline-block; margin-bottom: 4px; }\n    .tag-ang  { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }\n    .tag-crit { background: #fde8e8; color: #9b1c1c; border: 1px solid #f87171; }\n    .tag-helio { background: #e0f7fa; color: #006064; border: 1px solid #00acc1; }\n    .tag-etoile { background: #fff8e1; color: #5d4037; border: 1px solid #ffb300; }\n    .tag-eclipse    { background: #fff0e6; color: #7c2d12; border: 1px solid #ea580c; }\n    .tag-oob        { background: #fce7f3; color: #831843; border: 1px solid #ec4899; }\n    .tag-parallele  { background: #e