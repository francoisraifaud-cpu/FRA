"' : '';\n        html += `<tr${rowStyle}>\n            <td>${a.p1}${promoTag}</td>\n            <td style=\"color:${c};font-weight:bold;\">${a.aspect}</td>\n            <td style=\"font-size:0.85em;color:${c};font-style:italic\">${nature}</td>\n            <td>${a.p2}</td>\n            <td style=\"text-align:center\">${a.exactitude}°</td>\n            <td style=\"text-align:center\">${badge}</td>\n        </tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Déclinaisons Équatoriales (OOB + Tableau + Parallèles + Contre-Parallèles) ──\n{\n    const declPlanetes = (input.planetes || []).filter(p => typeof p.declinaison === 'number');\n    const hasDecl = declPlanetes.length > 0 || planeteOOB.length > 0 || paralleles.length > 0 || contreParalleles.length > 0;\n\n    if (hasDecl) {\n        html += `<h2 class=\"section-title page-break\">${isEN ? 'Equatorial Declinations' : 'Déclinaisons Équatoriales'}</h2>`;\n        html += `<p class=\"decl-intro\">\n            ${isEN\n              ? 'Declinations measure the angular distance in degrees of each planet from the celestial equator (3D dimension). <strong>Out of Bounds</strong> threshold: <strong>±23.44°</strong> (Sun\\'s ecliptic limit). <strong>Parallel (//):</strong> same hemisphere, ≤1° difference (≤1.5° if Luminary) — acts as a conjunction. <strong>Contra-Parallel (#):</strong> opposite hemispheres, same absolute values ≤1° — acts as an opposition.'\n              : 'Les déclinaisons mesurent l\\'écart en degrés de chaque planète par rapport à l\\'équateur céleste (dimension 3D). Seuil <strong>Hors Limites</strong> : <strong>±23.44°</strong> (limite écliptique du Soleil). <strong>Parallèle (//) :</strong> même hémisphère, ≤1° d\\'écart (≤1.5° si Luminaire) — agit comme une conjonction. <strong>Contre-Parallèle (#) :</strong> hémisphères opposés, mêmes valeurs absolues ≤1° — agit comme une opposition.'}\n        </p>`;\n\n        // ── Tableau global des déclinaisons ──\n        if (declPlanetes.length > 0) {\n   