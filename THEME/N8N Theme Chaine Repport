       const name = p.planet?.fr || p.planet?.en || \"?\";\n            const dIndex = Math.min(Math.floor((p.normDegree ?? p.fullDegree ?? 0) / 10), 2);\n            const decanRuler = CHALDEAN_DECANS[sig.name]?.[dIndex] || \"?\";\n\n            let dignite = \"-\";\n            if (dMap[name]) {\n                const d = dMap[name];\n                if (d.dom.includes(sig.name))      dignite = isEN ? \"Domicile\" : \"En Domicile\";\n                else if (d.exa.includes(sig.name)) dignite = isEN ? \"Exalted\" : \"En Exaltation\";\n                else if (d.exi.includes(sig.name)) dignite = isEN ? \"Detriment\" : \"En Exil\";\n                else if (d.chu.includes(sig.name)) dignite = isEN ? \"Fall\" : \"En Chute\";\n                else                               dignite = isEN ? \"Peregrine\" : \"Pérégrine\";\n            }\n\n            let retro    = (p.retroStr && p.retroStr.includes(\"Rétro\")) ? \" [R]\" : \"\";\n            let digStr   = dignite !== \"-\" ? ` — <strong>${dignite}</strong>` : \"\";\n            let isAngle  = [\"Ascendant\",\"Milieu du Ciel\",\"Imum Coeli\",\"Descendant\"].includes(name);\n            let nameDisplay = isAngle ? (name === \"Imum Coeli\" ? \"Imum Coeli (Fond du Ciel)\" : name) : name;\n\n            // Tags enrichis\n            let tags = \"\";\n            const angInfo = getAngularInfo(name);\n            if (angInfo) tags += ` <span class=\"tag tag-ang\">⭐ ${isEN ? 'Angular' : 'Angulaire'} (${angInfo.angle}, ${angInfo.orb}°)</span>`;\n\n            const critInfo = getCriticalInfo(name);\n            if (critInfo) tags += ` <span class=\"tag tag-crit\">⚠ ${critInfo.flags.join(' | ')}</span>`;\n\n            const helioInfo = getHelioInfo(name);\n            if (helioInfo?.condition)   tags += ` <span class=\"tag tag-helio\">☀ ${helioInfo.condition.split('—')[0].trim()}</span>`;\n            if (helioInfo?.orientation && (name === \"Vénus\" || name === \"Mercure\")) {\n                const isMatin = helioInfo.orientation.toLowerCase().includes(\"matin\") || helioInfo.orientation.toLowerCase().includes(\"oriental\");\n                tags += ` <span class=\"tag tag-etoile\">${isMatin ? (isEN ? \"🌅 Morning Star\" : \"🌅 Étoile du Matin\") : (isEN ? \"🌆 Evening Star\" : \"🌆 Étoile du Soir\")}</span>`;\n            }\n\n            if (eclipseNatal?.house && name !== \"Ascendant\") {\n                // Vérifier si la planète est très proche du degré de l'éclipse\n                const eclDiff = Math.abs(((p.fullDegree - eclipseNatal.degree + 540) % 360) - 180);\n                if (eclDiff <= 3) tags += ` <span class=\"tag tag-eclipse\">⚡ ${isEN ? 'Natal eclipse' : 'Éclipse natale'} (${(eclDiff ?? 0).toFixed(1)}°)</span>`;\n            }\n\n            const etoileInfos = getEtoileInfos(name);\n            etoileInfos.forEach(em => {\n                const precLabel = em.precision.includes(\"forte\") ? \"★★\" : \"★\";\n                tags += ` <span class=\"tag tag-etoile\">${precLabel} ${em.etoile} (${em.orb}°)</span>`;\n            });\n            if (ANGLE_KEY_MAP[name]) {\n                const cuspStarsHere = etoileCuspMatches.filter(ec => ec.angle === ANGLE_KEY_MAP[name]);\n                cuspStarsHere.forEach(ec => {\n                    const precLabel = ec.precision.includes(\"forte\") ? \"★★\" : \"★\";\n                    tags += ` <span class=\"tag tag-etoile\">${precLabel} ${ec.etoile} (${ec.orb}°)</span>`;\n                });\n            }\n\n            const oobInfo = getOOBInfo(name);\n            if (oobInfo) tags += ` <span class=\"tag tag-oob\">⚡ ${isEN ? 'Out of Bounds' : 'Hors Limites'} (${(oobInfo.declinaison ?? 0).toFixed(2)}° ${oobInfo.hemisphere})</span>`;\n\n            const paraList = getParaList(name);\n            paraList.forEach(pa => {\n                if (pa.type === \"//\") {\n                    const lumStar = pa.hasLuminaire ? \" ★\" : \"\";\n                    tags += ` <span class=\"tag tag-parallele\">// ${isEN ? 'Parallel' : 'Parallèle'} ${pa.autre} (${pa.orb}°)${lumStar}</span>`;\n                } else {\n                    const lumStar = pa.hasLuminaire ? \" ★\" : \"\";\n                    tags += ` <span class=\"tag tag-contrepara\"># ${isEN ? 'Contra-par.' : 'Contre-par.'} ${pa.autre} (${pa.orb}°)${lumStar}</span>`;\n                }\n            });\n\n            const termRulerName = getTermRuler(sig.name, p.normDegree || 0);\n            const tripRulerName = getTriplicityRulerR(sig.name);\n            const termStr = termRulerName ? ` · ${isEN ? 'Term' : 'Terme'} : ${termRulerName}` : \"\";\n            const tripStr = tripRulerName ? ` · ${isEN ? 'Trip.' : 'Trip.'} : ${tripRulerName}` : \"\";\n            html += `<li><strong>${nameDisplay}${retro}</strong> : ${(p.normDegree || 0).toFixed(2)}° (${isEN ? 'Decan' : 'Décan'} ${dIndex+1} — ${decanRuler}${termStr}${tripStr})${digStr}${tags}</li>`;\n        });\n        html += `</ul>`;\n    } else {\n        html += `<p class=\"empty-msg\">${isEN ? 'No sensitive point in this sign.' : 'Aucun point sensible dans ce signe.'}</p>`;\n    }\n\n    html += `</div>`;\n});\n\n// ── Cascade des maîtrises ──\nconst HOUSE_DESC_THEME_FR = {\n    1: \"Identité, apparence, ego, vitalité, comportement instinctif\",\n    2: \"Ressources personnelles, finances, valeurs, talents innés, rapport à la possession\",\n    3: \"Communication, fratrie, environnement proche, échanges quotidiens\",\n    4: \"Foyer, racines, famille, sécurité intérieure, sentiment de 'chez soi'\",\n    5: \"Créativité, romance, enfants, plaisir, élan amoureux, expression de soi\",\n    6: \"Travail quotidien, santé, service, organisation, habitudes, rythme\",\n    7: \"Partenariats, mariage, contrats, ennemis déclarés, relation d'égal à égal\",\n    8: \"Intimité profonde, sexualité, crises, transformation, héritages, fusion psychologique\",\n    9: \"Voyages, philosophie, enseignement supérieur, spiritualité, quête de sens\",\n    10: \"Carrière, réputation, statut social, autorité, ambitions publiques\",\n    11: \"Amitiés, groupes, idéaux, projets collectifs, vision d'avenir\",\n    12: \"Inconscient, secrets, sacrifice, ennemis cachés, karma, liens invisibles\"\n};\nconst HOUSE_DESC_THEME_EN = {\n    1: \"Identity, appearance, ego, vitality, instinctive behavior\",\n    2: \"Personal resources, finances, values, innate talents, relationship to possessions\",\n    3: \"Communication, siblings, local environment, daily exchanges\",\n    4: \"Home, roots, family, inner security, sense of belonging\",\n    5: \"Creativity, romance, children, pleasure, romantic spark, self-expression\",\n    6: \"Daily work, health, service, organization, habits, routine\",\n    7: \"Partnerships, marriage, contracts, open enemies, equal relationship\",\n    8: \"Deep intimacy, sexuality, crises, transformation, inheritances, psychological fusion\",\n    9: \"Travel, philosophy, higher education, spirituality, quest for meaning\",\n    10: \"Career, reputation, social status, authority, public ambitions\",\n    11: \"Friendships, groups, ideals, collective projects, future vision\",\n    12: \"Unconscious, secrets, sacrifice, hidden enemies, karma, invisible bonds\"\n};\nconst HOUSE_DESC_THEME = isEN ? HOUSE_DESC_THEME_EN : HOUSE_DESC_THEME_FR;\n\nhtml += `<h2 class=\"section-title page-break\">${isEN ? 'Multi-Sign Analysis (Rulership Cascade)' : 'Analyse Multi-Signes (Cascade des Maîtrises)'}</h2>\n<table><tr><th>${isEN ? 'House' : 'Maison'}</th><th>${isEN ? 'Segment' : 'Segment'}</th><th>${isEN ? 'Start Degree' : 'Degré Début'}</th><th>${isEN ? 'Ruler' : 'Maître'}</th><th>${isEN ? 'Tenants' : 'Locataires'}</th></tr>`;\n\ninput.maisons.forEach(m => {\n    const sc = m.segments.length;\n    const hDescTheme = HOUSE_DESC_THEME[m.maison] || '';\n    html += `<tr><td colspan=\"5\" style=\"background:#f0f4fb;font-style:italic;font-size:0.88em;color:#475569;padding:6px 12px;border-bottom:2px solid #2E5FA3\">${isEN ? 'House' : 'Maison'} ${m.maison} — ${escH(hDescTheme)}</td></tr>`;\n    m.segments.forEach((seg, idx) => {\n        const locs = seg.locataires.map(l => {\n            let extra = \"\";\n            const lh = getHelioInfo(l.planete);\n            if (lh?.orientation && (l.planete === \"Vénus\" || l.planete === \"Mercure\")) {\n                const isMatin = lh.orientation.toLowerCase().includes(\"matin\") || lh.orientation.toLowerCase().includes(\"oriental\");\n                extra = ` <span style=\"font-size:0.78em;color:#2E5FA3\">${isMatin ? \"🌅\" : \"🌆\"}</span>`;\n            }\n            if (l.termLord) extra += ` <span style=\"font-size:0.72em;color:#2E5FA3\" title=\"Terme égyptien\">☿${l.termLord.nom} (M${l.termLord.maison})</span>`;\n            return `<span class=\"tag\">${l.planete}${l.retro}${extra}</span>`;\n        }).join(\" \") || `<em style='color:#94a3b8'>${isEN ? 'None' : 'Aucun'}</em>`;\n\n        let mStr = \"-\";\n        if (seg.maitre) {\n            const md = seg.maitre.dignite !== \"-\" ? ` - ${seg.maitre.dignite}` : \"\";\n            // Conditions hélio du maître\n            const mhc = getHelioInfo(seg.maitre.planete);\n            const mhcStr = mhc?.condition ? `<br><small style=\"color:#0369a1\">☀ ${mhc.condition.split('—')[0].trim()}</small>` : \"\";\n            mStr = `<strong>${seg.maitre.planete}</strong>${seg.maitre.retro} (M${seg.maitre.maison}${md})${mhcStr}`;\n            if (seg.maitre.patron) {\n                mStr += `<br><small style='color:#64748b'>↳ ${seg.maitre.patron.planete} (M${seg.maitre.patron.maison})</small>`;\n            } else {\n                mStr += `<br><small style='color:#16a34a'>↳ ${isEN ? 'Absolute domicile' : 'Domicile absolu'}</small>`;\n            }\n        }\n\n        html += `<tr>`;\n        if (idx === 0) {\n            const eclTag   = eclipseNatal?.house === m.maison ? ` <span style=\"color:#ea580c;font-size:0.8em\">⚡</span>` : \"\";\n            const cuspStars = getCuspEtoiles(m.maison);\n            const cuspTag  = cuspStars.length > 0\n                ? ` <span style=\"color:#2E5FA3;font-size:0.8em\" title=\"${cuspStars.map(e=>e.etoile+'('+e.orb+'°)').join(', ')}\">★</span>`\n                : \"\";\n            html += `<td rowspan=\"${sc}\" style=\"background:#f8fafc;vertical-align:top;font-weight:bold;color:#1F3864;\">M${m.maison}${eclTag}${cuspTag}</td>`;\n        }\n        html += `<td>${seg.signe}<br><small style=\"color:#64748b\">(${seg.type})</small></td><td>${(seg.degre_debut ?? 0).toFixed(2)}°</td><td>${mStr}</td><td>${locs}</td></tr>`;\n    });\n});\nhtml += `</table>`;\n\n// ── Configurations natales (si présentes) ──\nif (configurations.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Natal Configurations' : 'Configurations Natales'}</h2>`;\n    html += `<p style=\"color:#1F3864;font-style:italic;margin:0 0 15px;padding:10px 16px;background:#eef2fb;border-radius:8px;border-left:4px solid #2E5FA3;font-size:0.92em;\">\n        ${isEN ? 'Figures sorted by <strong>descending Power Score</strong>. Legend:' : 'Figures triées par <strong>Score de Puissance décroissant</strong>. Légende :'}\n        <span class=\"score-badge score-absolu\">${isEN ? 'ABSOLUTE PRIORITY' : 'PRIORITÉ ABSOLUE'} ≥120</span>\n        <span class=\"score-badge score-majeur\">${isEN ? 'Major' : 'Majeure'} ≥80</span>\n        <span class=\"score-badge score-signif\">${isEN ? 'Significant' : 'Significative'} ≥50</span>\n        <span class=\"score-badge score-mineur\">${isEN ? 'Minor' : 'Mineure'} &lt;50</span>\n    </p>`;\n    const hasSubs = configurations.some(c => c.subConfigOf);\n    if (hasSubs) {\n        html += `<p style=\"font-size:0.82em;color:#64748b;margin:0 0 12px 0;\">\n            <em>${isEN\n              ? 'Indented configurations (dashed line) are geometrically contained within the parent figure — their planets are identical. They are <strong>structural facets</strong> of the higher-ranking figure and should not be counted as independent events.'\n              : 'Les configurations en retrait (trait pointillé) sont géométriquement contenues dans la figure parente — leurs planètes sont identiques. Elles constituent des <strong>facettes structurelles</strong> de la figure de rang supérieur et ne doivent pas être comptées comme des événements indépendants.'}</em></p>`;\n    }\n    // Compteur pour limiter les T-Carrés affichés sous un même Grand Carré à 2 max\n    const tcarreCountByParent = {};\n    const MAX_TCARRE_PER_GRAND_CARRE = 2;\n\n    configurations.forEach(c => {\n        const score = c.puissanceScore !== undefined ? c.puissanceScore : null;\n        const _rawLabel = c.prioriteLabel || \"Mineure\";\n        const _labelEN = {\"Mineure\":\"Minor\",\"Significative\":\"Significant\",\"Majeure\":\"Major\",\"PRIORITÉ ABSOLUE\":\"ABSOLUTE PRIORITY\"};\n        const label = isEN ? (_labelEN[_rawLabel] || _rawLabel) : _rawLabel;\n        const isSub = !!c.subConfigOf;\n\n        // Limiter les T-Carrés indentés sous un même Grand Carré à 2 max.\n        // Clé = planètes du Grand Carré parent (unique par Grand Carré, même s'il y en a plusieurs).\n        if (c.type === \"T-Carré\" && c.subConfigOf === \"Grand Carré\" && c.subConfigType === \"child\") {\n            const parentGC = configurations.find(p =>\n                p.type === \"Grand Carré\" && !p.subConfigOf && c.planets && p.planets &&\n                c.planets.every(pl => p.planets.includes(pl))\n            );\n            const parentKey = parentGC ? parentGC.planets.slice().sort().join(\"|\") : c.planets.slice().sort().join(\"|\");\n            tcarreCountByParent[parentKey] = (tcarreCountByParent[parentKey] || 0) + 1;\n            if (tcarreCountByParent[parentKey] > MAX_TCARRE_PER_GRAND_CARRE) return; // skip\n        }\n\n        let badgeClass = \"score-mineur\";\n        if (score >= 120) badgeClass = \"score-absolu\";\n        else if (score >= 80) badgeClass = \"score-majeur\";\n        else if (score >= 50) badgeClass = \"score-signif\";\n        const scoreBadge = score !== null\n            ? `<span class=\"score-badge ${badgeClass}\">Score ${score} — ${label}</span>`\n            : \"\";\n        const isVariant = isSub && c.subConfigType === \"variant\";\n        const subTag = isVariant\n            ? `<span class=\"tag-variant\">↳ ${isEN ? `variant of ${c.subConfigOf} (${c.sharedPlanets} shared planets)` : `variante du ${c.subConfigOf} (${c.sharedPlanets} planètes communes)`}</span>`\n            : isSub\n                ? `<span class=\"tag-sub-config\">↳ ${isEN ? `component of ${c.subConfigOf}` : `composante du ${c.subConfigOf}`}</span>`\n                : \"\";\n        if (isSub) {\n            html += `<div class=\"config-item-sub\">\n                <div class=\"config-type-sub\">${c.type}${scoreBadge}${subTag}</div>\n                <div style=\"font-size:0.88em;color:#475569;\">${c.description}</div>\n            </div>`;\n        } else {\n            html += `<div class=\"config-item\">\n                <div class=\"config-type\">${c.type}${scoreBadge}</div>\n                <div>${c.description}</div>\n            </div>`;\n        }\n    });\n}\n\n// ── Réceptions mutuelles (si présentes) ──\nif (mutualReceptions.length > 0) {\n    html += `<h2 class=\"section-title page-break\">${isEN ? 'Mutual Receptions' : 'Réceptions Mutuelles'}</h2>\n    <table><tr><th>${isEN ? 'Planet A' : 'Planète A'}</th><th>${isEN ? 'Sign A' : 'Signe A'}</th><th>${isEN ? 'House A' : 'Maison A'}</th><th>${isEN ? 'Planet B' : 'Planète B'}</th><th>${isEN ? 'Sign B' : 'Signe B'}</th><th>${isEN ? 'House B' : 'Maison B'}</th><th>Type</th></tr>`;\n    mutualReceptions.forEach(mr => {\n        const typeLabel = mr.type === \"exaltation\"\n            ? `<span style=\"color:#2E5FA3;font-size:0.85em;font-weight:bold\">Exaltation</span>`\n            : mr.type === \"mixte\"\n            ? `<span style=\"color:#6d28d9;font-size:0.85em;font-weight:bold\">Mixte (Dom↔Exa)</span>`\n            : `<span style=\"color:#1F3864;font-size:0.85em;font-weight:bold\">Domicile</span>`;\n        html += `<tr><td><strong>${mr.p1}</strong></td><td>${mr.sign1}</td><td>M${mr.house1}</td><td><strong>${mr.p2}</strong></td><td>${mr.sign2}</td><td>M${mr.house2}</td><td style=\"text-align:center\">${typeLabel}</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Aspects majeurs ──\nconst aspectColors = { \"Carré\":\"#ee4400\",\"Trigone\":\"#1155cc\",\"Opposition\":\"#cc0000\",\"Sextile\":\"#009944\",\"Conjonction\":\"#9900dd\" };\n// Ne garder que les aspects majeurs pour ce tableau\nconst majorAspects = (input.aspects || []).filter(a => a.isMajor !== false && aspectColors[a.aspect]);\n\nhtml += `<h2 class=\"section-title page-break\">${isEN ? 'Major Aspects' : 'Aspects Majeurs'}</h2>\n<p style=\"color:#1F3864;font-style:italic;margin:0 0 12px;padding:8px 14px;background:#eef2fb;border-radius:6px;border-left:4px solid #2E5FA3;font-size:0.9em;\">\n    ${isEN\n      ? 'Sorted by <strong>descending Weight</strong>. Formula: Base (type) + Exactitude + Luminary (+8) + Angle (+6) + Fixed Star (+5) + OOB (+4).'\n      : 'Triés par <strong>Poids décroissant</strong>. Formule : Base (type) + Exactitude + Luminaire (+8) + Angle (+6) + Étoile Fixe (+5) + OOB (+4).'}\n    <strong style=\"color:#1F3864\">${isEN ? 'Capital' : 'Capital'} ≥30</strong> · <strong style=\"color:#2E5FA3\">${isEN ? 'Strong' : 'Fort'} ≥20</strong> · <strong style=\"color:#5b8ac7\">${isEN ? 'Moderate' : 'Modéré'} ≥12</strong> · <strong style=\"color:#64748b\">${isEN ? 'Minor' : 'Mineur'} &lt;12</strong>\n</p>\n<table><tr><th>${isEN ? 'Planet 1' : 'Planète 1'}</th><th>${isEN ? 'Aspect' : 'Aspect'}</th><th>${isEN ? 'Planet 2' : 'Planète 2'}</th><th>${isEN ? 'Orb' : 'Orbe'}</th><th style=\"text-align:center\">${isEN ? 'Weight' : 'Poids'}</th></tr>`;\nmajorAspects.forEach(a => {\n    const c     = aspectColors[a.aspect] || \"#1e293b\";\n    const score = a.score;\n    let badgeClass = \"score-mineur\", badgeLabel = isEN ? \"Minor\" : \"Mi