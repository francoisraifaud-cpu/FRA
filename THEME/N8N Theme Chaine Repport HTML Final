        "jsCode": "const items = $input.all();\nconst validItems = [];\n\nlet nomFichierCible = \"Rapport Thème Astral\";\ntry {\n  const perso = $('Extract Variables').first().json;\n  const prenom = (perso.prenom || '').trim();\n  const nom = (perso.nom || '').toUpperCase().trim();\n  const nomAffiche = prenom ? `${prenom} ${nom}` : nom;\n  const safeNom = nomAffiche.trim().replace(/[^a-zA-ZÀ-ÿ0-9 \\-]/g, '_');\n  nomFichierCible = `Rapport Thème Astral - ${safeNom}`;\n} catch(e) {}\n\nfor (const item of items) {\n  if (!item.binary) continue;\n  const binaryKey = Object.keys(item.binary)[0];\n  if (!binaryKey) continue;\n\n  item.binary[binaryKey].fileName = `${nomFichierCible}.pdf`;\n  item.binary[binaryKey].mimeType = 'application/pdf';\n  item.binary[binaryKey].fileExtension = 'pdf';\n\n  validItems.push(item);\n}\n\nreturn validItems;"
