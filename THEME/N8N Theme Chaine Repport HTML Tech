        "jsCode": "const items = $input.all();\nconst newItems = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const json = items[i].json;\n  const htmlContent = json.html || \"<html><body>Erreur: Aucun HTML généré</body></html>\";\n  \n  // 1. Récupération des variables pour le nom du fichier\n  const nom = json.nom || \"\";\n  const prenom = json.prenom || \"\";\n  const dateBrute = json.date || \"\";\n  \n  // 2. Formatage du nom et de la date (ex: 12/11/1987 devient 12-11-1987)\n  const nomAffiche = prenom && nom ? `${prenom} ${nom}` : (prenom || nom || \"Inconnu\");\n  const dateFormatee = dateBrute.replace(/\\//g, '-');\n  \n  // 3. Création du nom de fichier final\n  let fileName = `index.html`;\n  \n  // 4. Création du binaire avec le nom personnalisé\n  const binaryData = await this.helpers.prepareBinaryData(Buffer.from(htmlContent), fileName, 'text/html');\n  \n  newItems.push({\n    json: json,\n    binary: {\n      data: binaryData\n    }\n  });\n}\n\nreturn newItems;"
