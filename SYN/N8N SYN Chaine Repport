        "jsCode": "const items = $input.all();\n\nlet persoAStr = '', persoBStr = '', typoLabel = '';\ntry {\n  const synVars = $('Extract Variables SYN').first()?.json || {};\n  const pa = synVars.personne_a || {};\n  const pb = synVars.personne_b || {};\n  if (pa.prenom || pa.nom) persoAStr = `${pa.prenom || ''} ${(pa.nom || '').toUpperCase()}`.trim();\n  if (pb.prenom || pb.nom) persoBStr = `${pb.prenom || ''} ${(pb.nom || '').toUpperCase()}`.trim();\n  typoLabel = synVars.typologie || '';\n} catch(e) {}\nif (!persoAStr || !persoBStr || !typoLabel) {\n  try {\n    const prep = $('Super noeud Syn').first()?.json?._meta || {};\n    if (!persoAStr && prep.persoA) persoAStr = prep.persoA;\n    if (!persoBStr && prep.persoB) persoBStr = prep.persoB;\n    if (!typoLabel && prep.typo) typoLabel = prep.typo;\n  } catch(e) {}\n}\nconst safe = s => s.replace(/[<>:\\\"/|?*]/g, '_').trim();\npersoAStr = safe(persoAStr || 'Personne 1');\npersoBStr = safe(persoBStr || 'Personne 2');\ntypoLabel = safe(typoLabel || 'Synastrie');\nconst nomFichierCible = `Données Techniques Synastrie - ${typoLabel} - ${persoAStr} - ${persoBStr}`;\n\nfor (const item of items) {\n  if (!item.binary) continue;\n  if (item.binary.data) {\n    item.binary.data.fileName = `${nomFichierCible}.pdf`;\n    item.binary.data.mimeType = 'application/pdf';\n    item.binary.data.fileExtension = 'pdf';\n  }\n  if (item.binary.html_file) {\n    delete item.binary.html_file;\n  }\n}\n\nreturn items;"
