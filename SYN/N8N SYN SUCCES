        "jsCode": "/**\n * SYNASTRIE (SYN) — 3 PDF depuis le merge, sans renommage des PJ.\n * Classement par fileName = chaînes amont (doc SYN §10).\n * orderId : Webhook / Extract Variables SYN (commande site).\n */\nfunction pickPdfBinary(item) {\n  const bin = item.binary || {};\n  for (const key of Object.keys(bin)) {\n    const b = bin[key];\n    if (!b) continue;\n    const mime = String(b.mimeType || \"\").toLowerCase();\n    const ext = String(b.fileExtension || \"\").toLowerCase();\n    if (mime.includes(\"pdf\") || ext === \"pdf\") return b;\n  }\n  const keys = Object.keys(bin);\n  if (keys.length) return bin[keys[0]];\n  return null;\n}\n\nfunction normName(s) {\n  return String(s || \"\")\n    .toLowerCase()\n    .normalize(\"NFD\")\n    .replace(/\\p{M}/gu, \"\");\n}\n\nfunction bucketForFileName(fileName) {\n  const n = normName(fileName);\n  if (n.includes(\"rapport technique synastrie\")) return \"tech\";\n  if (n.includes(\"donnees techniques synastrie\")) return \"donnees\";\n  if (n.includes(\"rapport synastrie\") && !n.includes(\"technique\")) return \"main\";\n  return null;\n}\n\nconst items = $input.all();\nif (items.length === 0) return [];\n\nconst buckets = { main: null, tech: null, donnees: null };\nconst orphans = [];\n\nfor (const item of items) {\n  const pdf = pickPdfBinary(item);\n  if (!pdf) continue;\n  const b = bucketForFileName(pdf.fileName);\n  if (b && !buckets[b]) buckets[b] = pdf;\n  else orphans.push(pdf);\n}\n\nfor (const o of orphans) {\n  if (!buckets.main) buckets.main = o;\n  else if (!buckets.tech) buckets.tech = o;\n  else if (!buckets.donnees) buckets.donnees = o;\n}\n\nif (!buckets.main || !buckets.tech || !buckets.donnees) {\n  throw new Error(\n    \"Prépare email 3 PDF SYN : 3 PDF attendus (données, technique, rapport final). \" +\n      \"Reçu : \" +\n      [buckets.main, buckets.tech, buckets.donnees].filter(Boolean).length +\n      \". Vérifie les fileName : \" +\n      items\n        .map((i) => pickPdfBinary(i)?.fileName || \"(sans pdf)\")\n        .join(\" | \"),\n  );\n}\n\nlet extract = {};\ntry {\n  extract = $(\"Extract Variables SYN\").first().json || {};\n} catch (e) {\n  /* nœud absent en test isolé */\n}\n\nconst WEBHOOK_NAMES = [\"Webhook\", \"Webhook Syn\", \"Webhook SYN\", \"Webhook1\"];\nfunction readOrderIdFromWebhook() {\n  for (const name of WEBHOOK_NAMES) {\n    try {\n      const j = $(name).first().json;\n      const b =\n        j?.body !== undefined && j?.body !== null && typeof j.body === \"object\" && !Array.isArray(j.body)\n          ? j.body\n          : j;\n      let id = typeof b?.orderId === \"string\" ? b.orderId.trim() : \"\";\n      if (!id && typeof j?.orderId === \"string\") id = j.orderId.trim();\n      if (id) return id;\n    } catch (e) {}\n  }\n  return null;\n}\nconst EXTRACT_NAMES = [\n  \"Extract Variables\",\n  \"Extract Variables SYN\",\n  \"Extract Variables DHN\",\n  \"Extract Variables DHN1\",\n  \"Extract Variables1\",\n];\nfunction readOrderIdFromExtracts() {\n  for (const n of EXTRACT_NAMES) {\n    try {\n      const v = $(n).first()?.json?.orderId;\n      if (typeof v === \"string\" && v.trim()) return v.trim();\n    } catch (e) {}\n  }\n  return null;\n}\nfunction readOrderIdFromInputItems(items) {\n  for (const it of items) {\n    const id = it?.json?.orderId;\n    if (typeof id === \"string\" && id.trim()) return id.trim();\n  }\n  return null;\n}\n\nconst orderId =\n  readOrderIdFromInputItems(items) || readOrderIdFromWebhook() || readOrderIdFromExtracts();\nif (!orderId) {\n  throw new Error(\n    \"Prépare email 3 PDF SYN : orderId introuvable. Vérifiez Extract Variables SYN / Webhook (orderId).\",\n  );\n}\n\nconst mailClient =\n  extract.mail ||\n  items.find((i) => i.json?.mail)?.json?.mail ||\n  items[0].json?.mailClient ||\n  items[0].json?.mail ||\n  null;\n\nfunction personDisplayName(p) {\n  if (!p || typeof p !== \"object\") return \"\";\n  const pre = String(p.prenom ?? \"\").trim();\n  const no = String(p.nom ?? \"\").trim();\n  return [pre, no].filter(Boolean).join(\" \").trim();\n}\n\nconst nameA = personDisplayName(extract.personne_a);\nconst nameB = personDisplayName(extract.personne_b);\n\nfunction isEnglishLang(raw) {\n  const s = String(raw ?? \"\")\n    .trim()\n    .toLowerCase()\n    .normalize(\"NFD\")\n    .replace(/\\p{M}/gu, \"\");\n  if (!s) return false;\n  if (s === \"en\" || s === \"english\" || s === \"anglais\") return true;\n  if (s.includes(\"english\") || s.includes(\"anglais\")) return true;\n  return false;\n}\n\nconst en = isEnglishLang(extract.langue);\nconst typoFr = String(extract.typologie || \"\").trim() || \"—\";\nconst typoEnMap = {\n  Amour: \"Love\",\n  Business: \"Business\",\n  \"Parent / Enfant\": \"Parent & Child\",\n  Fratrie: \"Siblings\",\n  Ami: \"Friendship\",\n  Mentorat: \"Mentorship\",\n  Colocataire: \"Roommates\",\n  Rivalité: \"Rivalry\",\n};\nconst typoEn = typoEnMap[typoFr] || typoFr;\nconst labelA = nameA || \"Person A\";\nconst labelB = nameB || \"Person B\";\nconst subjectPieces = en\n  ? [\"🌟 Synastry\", typoEn, labelA, labelB]\n  : [\"🌟 Synastrie\", typoFr, labelA, labelB];\nconst emailSubject = subjectPieces.filter(Boolean).join(\" — \");\n\nconst greetHtml = en ? \"<p>Hello,</p>\" : \"<p>Bonjour,</p>\";\n\nconst emailHtml = en\n  ? `${greetHtml}<p>Your three synastry documents (<strong>${typoEn}</strong>) are attached as PDFs: technical data, professional analysis report, and client-facing narrative.</p><p>Clear skies! 🌟</p>`\n  : `${greetHtml}<p>Vos trois documents de synastrie (<strong>${typoFr}</strong>) sont en pièces jointes au format PDF : données techniques, rapport d'analyse et rapport de synthèse.</p><p>Bonnes étoiles ! 🌟</p>`;\n\nreturn [\n  {\n    json: {\n      orderId,\n      mailClient: mailClient || \"votre.adresse.test@gmail.com\",\n      typologie: typoFr,\n      langue: extract.langue ?? null,\n      emailSubject,\n      emailHtml,\n    },\n    binary: {\n      data: buckets.main,\n      data1: buckets.tech,\n      data2: buckets.donnees,\n    },\n  },\n];\n"
