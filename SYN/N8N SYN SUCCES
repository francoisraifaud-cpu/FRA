n  \"Extract Variables DHN\",\n  \"Extract Variables DHN1\",\n  \"Extract Variables1\",\n];\nfunction readOrderIdFromExtracts() {\n  for (const n of EXTRACT_NAMES) {\n    try {\n      const v = $(n).first()?.json?.orderId;\n      if (typeof v === \"string\" && v.trim()) return v.trim();\n    } catch (e) {}\n  }\n  return null;\n}\nconst buckets = { main: null, tech: null, donnees: null };\nconst orphans = [];\nlet items = [];\nfunction readPdfTripletFromBinary(b) {\n  if (!b?.data || !b?.data1 || !b?.data2) return null;\n  return { main: b.data, tech: b.data1, donnees: b.data2 };\n}\nconst triple =\n  readPdfTripletFromBinary($input.first()?.binary) ||\n  (() => {\n    try {\n      return readPdfTripletFromBinary($(\"Prépare email 3 PDF\").first()?.binary);\n    } catch (e) {\n      return null;\n    }\n  })();\nif (triple) {\n  buckets.main = triple.main;\n  buckets.tech = triple.tech;\n  buckets.donnees = triple.donnees;\n} else {\n  items = (() => {\n    try {\n      const g = $(\"Envoi Email avec PDF1\").all();\n      if (g && g.length) return g;\n    } catch (e) {}\n    return $input.all();\n  })();\n  if (items.length === 0) return [];\n  for (const item of items) {\n    const pdf = pickPdfBinary(item);\n    if (!pdf) continue;\n    const b = bucketForFileName(pdf.fileName);\n    if (b && !buckets[b]) buckets[b] = pdf;\n    else orphans.push(pdf);\n  }\n  for (const o of orphans) {\n    if (!buckets.main) buckets.main = o;\n    else if (!buckets.tech) buckets.tech = o;\n    else if (!buckets.donnees) buckets.donnees = o;\n  }\n}\nif (!buckets.main || !buckets.tech || !buckets.donnees) {\n  throw new Error(\n    \"SYN SITE 3 PDF tiers : 3 PDF requis. Reçu : \" +\n      [buckets.main, buckets.tech, buckets.donnees].filter(Boolean).length +\n      \". Sur n8n Cloud : branche ce nœud depuis « Prépare email 3 PDF » (même branche que Gmail).\",\n  );\n}\nconst orderId =\n  readOrderIdFromInputItems($input.all()) ||\n  readOrderIdFromInputItems(items) ||\n  readOrderIdFromWebhook() ||\n  readOrderIdFromExtracts();\nif (!orderId) {\n  throw new Error(\n    \"SYN SITE 3 PDF tiers : orderId introuvable. Vérifiez Extract Variables SYN / Webhook (orderId).\",\n  );\n}\nlet extractSynMeta = {};\ntry {\n  extractSynMeta = $(\"Extract Variables SYN\").first().json || {};\n} catch (e) {}\nconst _synMap = {\n  Amour: \"love\",\n  Business: \"business\",\n  \"Parent / Enfant\": \"parent_child\",\n  Fratrie: \"sibling\",\n  Ami: \"friend\",\n  Mentorat: \"mentorship\",\n  Colocataire: \"roommate\",\n  Rivalité: \"rivalry\",\n};\nconst _typ = String(extractSynMeta.typologie || \"\").trim();\nconst synTypology = _synMap[_typ] || null;\n\nconst execId =\n  typeof $execution !== \"undefined\" && $execution && $execution.id !== undefined && $execution.id !== null\n    ? String($execution.id)\n    : \"\";\nconst seq = [\n  { documentTier: \"narrative_final\", bin: buckets.main },\n  { documentTier: \"narrative_tech\", bin: buckets.tech },\n  { documentTier: \"data_technical\", bin: buckets.donnees },\n];\nreturn seq.map((s) => ({\n  json: {\n    orderId,\n    documentTier: s.documentTier,\n    n8nExecutionId: execId,\n    synTypology,\n  },\n  binary: { data: s.bin },\n}));\n"
