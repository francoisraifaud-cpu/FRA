    {
      "parameters": {
        "jsCode": "// ==========================================\n// REASSEMBLE TRAD SYN v3.0\n// Reconstruit la structure perspective_a / perspective_b / synthese\n// à partir des items traduits par le Traducteur SYN\n// FIX v3: matching par key + gestion erreurs + label propagé\n// ==========================================\n\nconst items = $input.all();\n\nlet originalItems = [];\ntry { originalItems = $('1. Découpage SYN Trad').all(); } catch(e) {}\n\nlet synDataPassThrough = {};\ntry { synDataPassThrough = $('Reassemble SYN').first()?.json?.synData || {}; } catch(e) {\n    try { synDataPassThrough = $('5. Calcul SYN').first()?.json || {}; } catch(e2) {\n        try { synDataPassThrough = $('Calcul SYN').first()?.json || {}; } catch(e3) {}\n    }\n}\n\nconst result = {\n    perspective_a: {}, perspective_b: {}, synthese: null,\n    synData: synDataPassThrough,\n    _meta: { total_items: items.length, total_originals: originalItems.length, errors: [], translated: 0 }\n};\n\nif (items.length !== originalItems.length) {\n    result._meta.warning = `Attendu ${originalItems.length} traductions, reçu ${items.length}`;\n}\n\nitems.forEach((item, idx) => {\n    if (item.json?.error || item.json?.errorMessage) {\n        result._meta.errors.push({ idx, error: item.json?.errorMessage || item.json?.error });\n        return;\n    }\n\n    const translated = item.json?.output || item.json?.text || '';\n    if (!translated || translated.includes('skipped')) return;\n\n    const orig = originalItems[idx]?.json || {};\n    const key = orig.key || '';\n    const house = orig.house;\n    const score = orig.score;\n    const is_principale = orig.is_principale;\n    const label = orig.label || '';\n\n    if (!key) {\n        result._meta.errors.push({ idx, error: 'Aucune clé originale trouvée pour cet index' });\n        return;\n    }\n\n    result._meta.translated++;\n\n    if (key === 'synthese') {\n        result.synthese = { label, llm_text: translated };\n    } else if (key.startsWith('perspective_a_')) {\n        const h = key.replace('perspective_a_', '');\n        result.perspective_a[h] = { label, llm_text: translated, house, score, is_principale };\n    } else if (key.startsWith('perspective_b_')) {\n        const h = key.replace('perspective_b_', '');\n        result.perspective_b[h] = { label, llm_text: translated, house, score, is_principale };\n    }\n});\n\nreturn [{ json: result }];"
      },
