aw = persoB.prenom || \"\";\nlet nomA_raw = persoA.nom || \"\";\nlet nomB_raw = persoB.nom || \"\";\n\nif (!prenomA_raw && reassembled.meta?.personne_a?.prenom) {\n    prenomA_raw = reassembled.meta.personne_a.prenom;\n    nomA_raw = reassembled.meta.personne_a.nom || nomA_raw;\n}\nif (!prenomB_raw && reassembled.meta?.personne_b?.prenom) {\n    prenomB_raw = reassembled.meta.personne_b.prenom;\n    nomB_raw = reassembled.meta.personne_b.nom || nomB_raw;\n}\n\nconst prenomA = prenomA_raw.toLowerCase();\nconst prenomB = prenomB_raw.toLowerCase();\nconst nomA = nomA_raw.toLowerCase();\nconst nomB = nomB_raw.toLowerCase();\n\nconst MIN_NAME_LEN = 2;\nconst canMatchA = prenomA.length >= MIN_NAME_LEN;\nconst canMatchB = prenomB.length >= MIN_NAME_LEN;\n\nfunction matchPersonName(lc, prenom, nom) {\n    if (!prenom || prenom.length < MIN_NAME_LEN) return false;\n    const wordBoundary = (text, word) => {\n        const idx = text.indexOf(word);\n        if (idx === -1) return false;\n        const before = idx > 0 ? text[idx - 1] : ' ';\n        const after = idx + word.length < text.length ? text[idx + word.length] : ' ';\n        return /[\\s,.:;!?'\"()\\-—–]/.test(before) || idx === 0\n            ? (/[\\s,.:;!?'\"()\\-—–]/.test(after) || idx + word.length === text.length)\n            : false;\n    };\n    if (wordBoundary(lc, prenom)) return true;\n    if (nom && nom.length >= MIN_NAME_LEN && wordBoundary(lc, nom)) return true;\n    return false;\n}\n\n// ── 1. CARTES DE RÉFÉRENCE DES POSITIONS NATALES (A & B) ──\n\nfunction buildPlanetMaps(enrichedKey) {\n    const signMap = {};\n    const houseMap = {};\n    let enriched = {};\n    try { enriched = $(enrichedKey).first()?.json || {}; } catch(e) { return { signMap, houseMap }; }\n\n    let planets = enriched.planetes;\n    if (!Array.isArray(planets)) {\n        if (planets?.output && Array.isArray(planets.output)) planets = planets.output;\n        else planets = [];\n    }\n\n    planets.forEach(p => {\n        const name = p.planet?.fr || p.planet?.en || p.name;\n        if (!name) return;\n        const sign = p.zodiac_sign?.name?.fr;\n        if (sign) signMap[name] = sign;\n        const house = p.house || p.maison;\n        if (house) houseMap[name] = parseInt(house);\n    });\n\n    const maisons = enriched.maisons;\n    if (Array.isArray(maisons)) {\n        maisons.forEach(m => {\n            const hNum = m.maison || m.House;\n            if (!hNum) return;\n            (m.segments || []).forEach(s => {\n                (s.locataires || []).forEach(l => {\n                    if (l.planete && !houseMap[l.planete]) {\n                        houseMap[l.planete] = parseInt(hNum);\n                    }\n                });\n            });\n        });\n    }\n    return { signMap, houseMap };\n}\n\nconst mapsA = buildPlanetMaps(\"Enrichissement A\");\nconst mapsB = buildPlanetMaps(\"Enrichissement B\");\n\n// ── 2. CARTE DES OVERLAYS (référence) ──\n\nconst overlayBinA = synData.overlay_b_in_a || {};\nconst overlayAinB = synData.overlay_a_in_b || {};\n\nfunction buildOverlayRef(overlay) {\n    const ref = {};\n    Object.entries(overlay).forEach(([house, planets]) => {\n        if (!Array.isArray(planets)) return;\n        planets.forEach(p => {\n            const name = p.planet || p.planete || p.name;\n            if (name) ref[name] = parseInt(house);\n        });\n    });\n    return ref;\n}\n\nconst overlayRefBinA = buildOverlayRef(overlayBinA);\nconst overlayRefAinB = buildOverlayRef(overlayAinB);\n\n// ── 3. CARTE DES INTER-ASPECTS (référence) ──\n\nfunction buildAspectRef(aspects) {\n    const ref = new Set();\n    if (!Array.isArray(aspects)) return ref;\n    aspects.forEach(a => {\n        const from = (a.from || a.planete_source || \"\").toLowerCase();\n        const to = (a.to || a.planete_cible || \"\").toLowerCase();\n        const type = (a.aspect || a.type || \"\").toLowerCase();\n        if (from && to && type) {\n            ref.add(`${from}|${to}|${type}`);\n            ref.add(`${to}|${from}|${type}`);\n        }\n    });\n    return ref;\n}\n\nconst aspectRefBtoA = buildAspectRef([\n    ...(synData.inter_aspects_tier1_b_to_a || []),\n    ...(synData.inter_aspects_tier2_b_to_a || [])\n]);\nconst aspectRefAtoB = buildAspectRef([\n    ...(synData.inter_aspects_tier1_a_to_b || []),\n    ...(synData.inter_aspects_tier2_a_to_b || [])\n]);\n\n// ── 4. VOCABULAIRE D'EXCLUSION ──\n\nconst TRANSIT_VERBS = [\n    \"transite\", \"traverse\", \"entre en\", \"arrive en\", \"quitte la\",\n    \"passage de\", \"passage en\", \"passage du\", \"transit de\", \"transit du\",\n    \"se déplace en\", \"progresse en\", \"arc solaire\",\n    \"sera en\", \"serait en\", \"entrera en\", \"ira en\", \"retour de\",\n    \"ingress\", \"entrée en\", \"passage vers\", \"quand il entre\", \"quand elle entre\",\n    \"éclipse\", \"saros\", \"en transit\", \"transit \", \"progression de\",\n    \"lunation\", \"pleine lune\", \"nouvelle lune\",\n    \"direction primaire\", \"arc dirigé\", \"révolution solaire\",\n    \"profection\", \"firdaria\"\n];\n\nconst RHETORIC_EXCLUSIONS = [\n    \"contrairement à\", \"tandis que\", \"alors que\", \"par opposition à\",\n    \"à la différence de\", \"en comparaison\", \"imaginons\",\n    \"en général\", \"généralement\", \"traditionnellement\", \"dans l'absolu\"\n];\n\nconst CORE_PLANETS = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\nconst ALL_SIGNS_FR = [\"bélier\",\"taureau\",\"gémeaux\",\"cancer\",\"lion\",\"vierge\",\"balance\",\"scorpion\",\"sagittaire\",\"capricorne\",\"verseau\",\"poissons\"];\nconst ALL_SIGNS_EN = [\"aries\",\"taurus\",\"gemini\",\"cancer\",\"leo\",\"virgo\",\"libra\",\"scorpio\",\"sagittarius\",\"capricorn\",\"aquarius\",\"pisces\"];\nconst SIGN_EN_TO_FR = { \"aries\":\"bélier\",\"taurus\":\"taureau\",\"gemini\":\"gémeaux\",\"cancer\":\"cancer\",\"leo\":\"lion\",\"virgo\":\"vierge\",\"libra\":\"balance\",\"scorpio\":\"scorpion\",\"sagittarius\":\"sagittaire\",\"capricorn\":\"capricorne\",\"aquarius\":\"verseau\",\"pisces\":\"poissons\" };\nconst ALL_SIGNS = [...ALL_SIGNS_FR, ...ALL_SIGNS_EN];\nconst normSign = (s) => SIGN_EN_TO_FR[s] || s;\n\nconst COMPOSITE_KEYWORDS = [\n    \"composite\", \"thème composite\", \"composite chart\",\n    \"davison\", \"thème davison\", \"davison chart\",\n    \"thème de la relation\", \"chart of the relationship\",\n    \"mi-point\", \"midpoint chart\", \"relationship chart\"\n];\nconst isCompositeContext = (lc) => COMPOSITE_KEYWORDS.some(kw => lc.includes(kw));\n\n// ── 5. FONCTIONS UTILITAIRES ──\n\nconst splitSentences = (text) => {\n    return text.replace(/\\n/g, '. ').split(/(?<=[.!?…])\\s+/).filter(s => s.length > 5);\n};\n\nconst isExcludedContext = (sentence) => {\n    const lc = sentence.toLowerCase();\n    return TRANSIT_VERBS.some(v => lc.includes(v)) ||\n           RHETORIC_EXCLUSIONS.some(v => lc.includes(v));\n};\n\nconst matchWithBoundary = (text, pattern) => {\n    const idx = text.indexOf(pattern);\n    if (idx === -1) return false;\n    const after = text[idx + pattern.length];\n    if (after && /\\d/.test(after)) return false;\n    return true;\n};\n\n// ── 5b. DÉSAMBIGUÏSATION PRONOMS POSSESSIFS & RÔLES ──\n// En synastrie, le LLM écrit \"le Soleil de Samy ... ton Mars en Balance\".\n// \"ton/ta/tes\" = l'interlocuteur (A en perspective_a, A en synthese, B en perspective_b).\n// Gère aussi les planètes entre parenthèses après un possessif ou un rôle :\n//   \"tes besoins d'expansion (Jupiter en Bélier)\" → Jupiter = addressee\n//   \"le besoin de l'enfant (Lune en Lion)\" → Lune = personne ayant role=enfant\n\nconst _roleA = (meta.personne_a?.role || '').toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\nconst _roleB = (meta.personne_b?.role || '').toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n\nconst CHILD_TERMS = /\\b(l'enfant|de l'enfant|du fils|de la fille|cet enfant|son enfant|the child|l['']enfant)\\b/;\nconst PARENT_TERMS = /\\b(le parent|la m[eè]re|le p[eè]re|du parent|de la m[eè]re|du p[eè]re|the parent|the mother|the father|son parent|sa m[eè]re|son p[eè]re)\\b/;\nconst MENTOR_TERMS = /\\b(le mentor|du mentor|son mentor|the mentor)\\b/;\nconst MENTEE_TERMS = /\\b(le prot[eé]g[eé]|du prot[eé]g[eé]|l'[eé]l[eè]ve|de l'[eé]l[eè]ve|the mentee|the prot[eé]g[eé])\\b/;\n\nfunction findParenOpen(lc, planetIdx) {\n    const searchStart = Math.max(0, planetIdx - 8);\n    const slice = lc.substring(searchStart, planetIdx);\n    const p = slice.lastIndexOf('(');\n    return p !== -1 ? searchStart + p : -1;\n}\n\nfunction isPossessiveOfAddressee(lc, planetLc) {\n    const idx = lc.indexOf(planetLc);\n    if (idx === -1) return false;\n    const before = lc.substring(Math.max(0, idx - 40), idx).trimEnd();\n    if (/\\b(ton|ta|tes|your)\\s*$/.test(before) ||\n        /\\b(ton|ta|tes|your)\\s+\\w+\\s*$/.test(before) ||\n        /\\b(ton|ta|tes|your)\\s+\\w+\\s+\\w+\\s*$/.test(before)) return true;\n\n    const parenOpen = findParenOpen(lc, idx);\n    if (parenOpen !== -1) {\n        const beforeParen = lc.substring(Math.max(0, parenOpen - 80), parenOpen).trimEnd();\n        if (/\\b(ton|ta|tes|your)\\b/.test(beforeParen)) return true;\n    }\n    return false;\n}\n\nfunction detectRoleContext(lc, planetLc) {\n    const idx = lc.indexOf(planetLc);\n    if (idx === -1) return null;\n\n    const parenOpen = findParenOpen(lc, idx);\n    if (parenOpen === -1) return null;\n    const beforeParen = lc.substring(Math.max(0, parenOpen - 70), parenOpen).trimEnd();\n\n    const isChild  = CHILD_TERMS.test(beforeParen);\n    const isParent = PARENT_TERMS.test(beforeParen);\n    const isMentor = MENTOR_TERMS.test(beforeParen);\n    const isMentee = MENTEE_TERMS.test(beforeParen);\n\n    if (isChild) {\n        if (_roleA === 'enfant') return 'A';\n        if (_roleB === 'enfant') return 'B';\n    }\n    if (isParent) {\n        if (['parent','mere','pere','mère','père'].includes(_roleA)) return 'A';\n        if (['parent','mere','pere','mère','père'].includes(_roleB)) return 'B';\n    }\n    if (isMentor) {\n        if (_roleA === 'mentor') return 'A';\n        if (_roleB === 'mentor') return 'B';\n    }\n    if (isMentee) {\n        if (['protege','eleve','protégé','élève'].includes(_roleA)) return 'A';\n        if (['protege','eleve','protégé','élève'].includes(_roleB)) return 'B';\n    }\n    return null;\n}\n\nfunction isExplicitOwner(lc, planetLc, personPrenom) {\n    if (!personPrenom || personPrenom.length < MIN_NAME_LEN) return false;\n    return lc.includes(`${planetLc} de ${personPrenom}`) ||\n           lc.includes(`le ${planetLc} de ${personPrenom}`) ||\n           lc.includes(`la ${planetLc} de ${personPrenom}`) ||\n           lc.includes(`l'${planetLc} de ${personPrenom}`);\n}\n\nfunction isDignityForThisPlanet(lc, planetLc, dignityTerm) {\n    const planetIdx = lc.indexOf(planetLc);\n    const dignityIdx = lc.indexOf(dignityTerm);\n    if (planetIdx === -1 || dignityIdx === -1) return true;\n    const distance = Math.abs(dignityIdx - planetIdx);\n    for (const other of CORE_PLANETS) {\n        const otherLc = other.toLowerCase();\n        if (otherLc === planetLc) continue;\n        const otherIdx = lc.indexOf(otherLc);\n        if (otherIdx !== -1 && Math.abs(dignityIdx - otherIdx) < distance) return false;\n    }\n    return true;\n}\n\nfunction resolveEffectivePerson(lc, nameLc, mentionsA, mentionsB, perspective) {\n    const addresseeIsA = (perspective === \"perspective_a\" || perspective === \"synthese\");\n    const ownedByA = isExplicitOwner(lc, nameLc, prenomA);\n    const ownedByB = isExplicitOwner(lc, nameLc, prenomB);\n    const possessive = isPossessiveOfAddressee(lc, nameLc);\n    const roleCtx = detectRoleContext(lc, nameLc);\n\n    if (ownedByA) return \"A\";\n    if (ownedByB) return \"B\";\n    if (possessive) return addresseeIsA ? \"A\" : \"B\";\n    if (roleCtx) return roleCtx;\n    if (mentionsA && !mentionsB) return \"A\";\n    if (mentionsB && !mentionsA) return \"B\";\n    return null;\n}\n\n// ── 6. VALIDATIONS ──\n\nfunction validateSignText(text, perspective) {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    const overlaySignMap = perspective === \"perspective_a\" ? mapsB.signMap\n        : perspective === \"perspective_b\" ? mapsA.signMap\n        : Object.assign({}, mapsA.signMap, mapsB.signMap);\n    const natalSignMap = perspective === \"perspective_a\" ? mapsA.signMap\n        : perspective === \"perspective_b\" ? mapsB.signMap\n        : Object.assign({}, mapsA.signMap, mapsB.signMap);\n\n    CORE_PLANETS.forEach(name => {\n        const correctSignOverlay = overlaySignMap[name];\n        const correctSignNatal = natalSignMap[name];\n        const nameLc = name.toLowerCase();\n\n        sentences.forEach(sentence => {\n            if (isExcludedContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            if (isCompositeContext(lc)) return;\n\n            const mentionsA = canMatchA && matchPersonName(lc, prenomA, nomA);\n            const mentionsB = canMatchB && matchPersonName(lc, prenomB, nomB);\n\n            ALL_SIGNS.forEach(rawSign => {\n                const signFr = normSign(rawSign);\n                const patterns = [\n                    `${nameLc} en ${rawSign}`,\n                    `${nameLc} dans le ${rawSign}`,\n                    `${nameLc} dans la ${rawSign}`,\n                    `${nameLc} dans les ${rawSign}`,\n                    `${nameLc} (${rawSign})`,\n                    `${nameLc} in ${rawSign}`\n                ];\n                if (!patterns.some(pat => lc.includes(pat))) return;\n\n                const effectivePerson = resolveEffectivePerson(lc, nameLc, mentionsA, mentionsB, perspective);\n\n                if (effectivePerson === \"A\") {\n                    const correctA = mapsA.signMap[name];\n                    if (correctA && signFr !== correctA.toLowerCase()) {\n                        warnings.push({\n                            person: prenomA_raw || \"A\", planet: name,\n                            claimedSign: signFr, correctSign: correctA,\n                            excerpt: sentence.substring(0, 150), type: \"sign_mismatch_A\"\n                        });\n                    }\n                } else if (effectivePerson === \"B\") {\n                    const correctB = mapsB.signMap[name];\n                    if (correctB && signFr !== correctB.toLowerCase()) {\n                        warnings.push({\n                            person: prenomB_raw || \"B\", planet: name,\n                            claimedSign: signFr, correctSign: correctB,\n                            excerpt: sentence.substring(0, 150), type: \"sign_mismatch_B\"\n                        });\n                    }\n                } else if (!mentionsA && !mentionsB) {\n                    const correctOverlay = correctSignOverlay;\n                    const correctNatal = correctSignNatal;\n                    const overlayOK = correctOverlay ? signFr === correctOverlay.toLowerCase() : false;\n                    const natalOK = correctNatal ? signFr === correctNatal.toLowerCase() : false;\n                    if (!overlayOK && !natalOK) {\n                        warnings.push({\n                            planet: name, claimedSign: signFr,\n                            expectedOverlay: correctOverlay || \"?\", expectedNatal: correctNatal || \"?\",\n                            perspective,\n                            excerpt: sentence.substring(0, 150), type: \"sign_mismatch_context\"\n                        });\n                    }\n                }\n            });\n        });\n    });\n    return warnings;\n}\n\nfunction validateHouseText(text, perspective, houseNum) {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    CORE_PLANETS.forEach(name => {\n        const correctHouseA = mapsA.houseMap[name];\n        const correctHouseB = mapsB.houseMap[name];\n        const nameLc = name.toLowerCase();\n\n        sentences.forEach(sentence => {\n            if (isExcludedContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            if (isCompositeContext(lc)) return;\n\n            for (let h = 1; h <= 12; h++) {\n                const natalPatterns = [\n                    `${nameLc} natal en maison ${h}`,\n                    `${nameLc} natale en maison ${h}`,\n                    `${nameLc} natal en m${h}`,\n                    `${nameLc} natale en m${h}`,\n                    `natal ${nameLc} in house ${h}`,\n                    `${nameLc} in natal house ${h}`\n                ];\n                if (!natalPatterns.some(pat => matchWithBoundary(lc, pat))) continue;\n\n                const mentionsA = canMatchA && matchPersonName(lc, prenomA, nomA);\n                const mentionsB = canMatchB && matchPersonName(lc, prenomB, nomB);\n\n                if (mentionsA && correctHouseA && h !== correctHouseA) {\n                    warnings.push({\n                        person: prenomA_raw || \"A\", planet: name,\n                        claimedHouse: h, correctHouse: correctHouseA,\n                        excerpt: sentence.substring(0, 150), type: \"natal_house_mismatch_A\"\n                    });\n                }\n                if (mentionsB && correctHouseB && h !== correctHouseB) {\n                    warnings.push({\n                        person: prenomB_raw || \"B\", planet: name,\n                        claimedHouse: h, correctHouse: correctHouseB,\n                        excerpt: sentence.substring(0, 150), type: \"natal_house_mismatch_B\"\n                    });\n                }\n            }\n        });\n    });\n    return warnings;\n}\n\nfunction validateOverlayText(text, perspective, houseNum) {\n    const warnings = [];\n    if (!text || !houseNum) return warnings;\n    const sentences = splitSentences(text);\n\n    const overlayRef = perspective === \"perspective_a\" ? overlayRefBinA : overlayRefAinB;\n    const natalHouseMap = perspective === \"perspective_a\" ? mapsA.houseMap : mapsB.houseMap;\n\n    CORE_PLANETS.forEach(name => {\n        const refHouse = overlayRef[name];\n        if (!refHouse) return;\n        const nameLc = name.toLowerCase();\n\n        sentences.forEach(sentence => {\n            if (isExcludedContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            if (isCompositeContext(lc)) return;\n\n            if (isPossessiveOfAddressee(lc, nameLc)) return;\n\n            for (let h = 1; h <= 12; h++) {\n                if (h === refHouse) continue;\n                const overlayPatterns = [\n                    `${nameLc} en maison ${h}`,\n                    `${nameLc} dans la maison ${h}`,\n                    `${nameLc} dans ta maison ${h}`,\n                    `${nameLc} dans votre maison ${h}`,\n                    `${nameLc} se pose en maison ${h}`,\n                    `${nameLc} tombe en maison ${h}`,\n                    `${nameLc} active la maison ${h}`,\n                    `${nameLc} in house ${h}`,\n                    `${nameLc} activates house ${h}`\n                ];\n                if (overlayPatterns.some(pat => matchWithBoundary(lc, pat))) {\n                    if (!lc.includes(\"natal\")) {\n                        const natalH = natalHouseMap[name];\n                        if (natalH && h === natalH) continue;\n                        warnings.push({\n                            planet: name, claimedHouse: h, correctOverlayHouse: refHouse,\n                            perspective, analyzedHouse: houseNum,\n                            excerpt: sentence.substring(0, 150), type: \"overlay_mismatch\"\n                        });\n                    }\n                }\n            }\n        });\n    });\n    return warnings;\n}\n\nfunction validatePredictiveVocabulary(text, sectionLabel) {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n    const PREDICTIVE_TERMS = [\n        \"cette année\", \"l'année prochaine\",\n        \"dans les mois\", \"prochainement\", \"bientôt\",\n        \"transit de\", \"transit du\", \"progression de\", \"profection\",\n        \"révolution solaire\", \"direction primaire\", \"arc dirigé\",\n        \"firdaria\", \"rétrogradation de transit\"\n    ];\n    const PREDICTIVE_PATTERNS = [/\\ben 20\\d{2}\\b/i, /\\bin 20\\d{2}\\b/i];\n\n    sentences.forEach(sentence => {\n        const lc = sentence.toLowerCase();\n        PREDICTIVE_TERMS.forEach(term => {\n            if (lc.includes(term)) {\n                warnings.push({\n                    term, section: sectionLabel,\n                    excerpt: sentence.substring(0, 150), type: \"predictive_vocabulary\"\n                });\n            }\n        });\n        PREDICTIVE_PATTERNS.forEach(rx => {\n            if (rx.test(sentence)) {\n                warnings.push({\n                    term: sentence.match(rx)?.[0] || \"year_ref\", section: sectionLabel,\n                    excerpt: sentence.substring(0, 150), type: \"predictive_vocabulary\"\n                });\n            }\n        });\n    });\n    return warnings;\n}\n\nfunction validatePersonSwap(text, perspective, sectionLabel) {\n    const warnings = [];\n    if (!text || !canMatchA || !canMatchB) return warnings;\n    const sentences = splitSentences(text);\n    const addresseeIsA = (perspective === \"perspective_a\" || perspective === \"synthese\");\n\n    CORE_PLANETS.forEach(name => {\n        const nameLc = name.toLowerCase();\n        const signA = mapsA.signMap[name] ? mapsA.signMap[name].toLowerCase() : null;\n        const signB = mapsB.signMap[name] ? mapsB.signMap[name].toLowerCase() : null;\n        if (!signA || !signB || signA === signB) return;\n\n        sentences.forEach(sentence => {\n            if (isExcludedContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            if (isCompositeContext(lc)) return;\n\n            const mentionsA = matchPersonName(lc, prenomA, nomA);\n            const mentionsB = matchPersonName(lc, prenomB, nomB);\n            const possessive = isPossessiveOfAddressee(lc, nameLc);\n            const roleCtx = detectRoleContext(lc, nameLc);\n\n            if (mentionsA && !mentionsB && lc.includes(`${nameLc} en ${signB}`)) {\n                if (!addresseeIsA && possessive) return;\n                if (roleCtx === \"B\") return;\n                warnings.push({\n                    planet: name, claimedForA: mapsB.signMap[name], correctForA: mapsA.signMap[name],\n                    section: sectionLabel, excerpt: sentence.substring(0, 150),\n                    type: \"person_swap_sign\"\n                });\n            }\n            if (mentionsB && !mentionsA && lc.includes(`${nameLc} en ${signA}`)) {\n                if (addresseeIsA && possessive) return;\n                if (roleCtx === \"A\") return;\n                warnings.push({\n                    planet: name, claimedForB: mapsA.signMap[name], correctForB: mapsB.signMap[name],\n                    section: sectionLabel, excerpt: sentence.substring(0, 150),\n                    type: \"person_swap_sign\"\n                });\n            }\n        });\n    });\n    return warnings;\n}\n\nfunction validateDignityText(text, perspective, sectionLabel) {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    const DIGNITY_RULES = {\n        \"Domicile\": {\n            \"Soleil\": [\"Lion\"], \"Lune\": [\"Cancer\"], \"Mercure\": [\"Gémeaux\", \"Vierge\"],\n            \"Vénus\": [\"Taureau\", \"Balance\"], \"Mars\": [\"Bélier\", \"Scorpion\"],\n            \"Jupiter\": [\"Sagittaire\", \"Poissons\"], \"Saturne\": [\"Capricorne\", \"Verseau\"],\n            \"Uranus\": [\"Verseau\"], \"Neptune\": [\"Poissons\"], \"Pluton\": [\"Scorpion\"]\n        },\n        \"Exaltation\": {\n            \"Soleil\": [\"Bélier\"], \"Lune\": [\"Taureau\"], \"Mercure\": [\"Vierge\"],\n            \"Vénus\": [\"Poissons\"], \"Mars\": [\"Capricorne\"], \"Jupiter\": [\"Cancer\"],\n            \"Saturne\": [\"Balance\"], \"Uranus\": [\"Scorpion\"], \"Neptune\": [\"Cancer\"], \"Pluton\": [\"Lion\"]\n        },\n        \"Exil\": {\n            \"Soleil\": [\"Verseau\"], \"Lune\": [\"Capricorne\"], \"Mercure\": [\"Sagittaire\", \"Poissons\"],\n            \"Vénus\": [\"Bélier\", \"Scorpion\"], \"Mars\": [\"Taureau\", \"Balance\"],\n            \"Jupiter\": [\"Gémeaux\", \"Vierge\"], \"Saturne\": [\"Cancer\", \"Lion\"],\n            \"Uranus\": [\"Lion\"], \"Neptune\": [\"Vierge\"], \"Pluton\": [\"Taureau\"]\n        },\n        \"Chute\": {\n            \"Soleil\": [\"Balance\"], \"Lune\": [\"Scorpion\"], \"Mercure\": [\"Poissons\"],\n            \"Vénus\": [\"Vierge\"], \"Mars\": [\"Cancer\"], \"Jupiter\": [\"Capricorne\"],\n            \"Saturne\": [\"Bélier\"], \"Uranus\": [\"Taureau\"], \"Neptune\": [\"Capricorne\"], \"Pluton\": [\"Verseau\"]\n        }\n    };\n\n    const DIGNITY_DETECT = [\n        { terms: [\"en domicile\", \"domicile\", \"in domicile\", \"in rulership\"], dignity: \"Domicile\" },\n        { terms: [\"en exaltation\", \"exalté\", \"exaltée\", \"exalted\", \"in exaltation\"], dignity: \"Exaltation\" },\n        { terms: [\"en exil\", \"exilé\", \"exilée\", \"in detriment\", \"in exile\"], dignity: \"Exil\" },\n        { terms: [\"en chute\", \"in fall\"], dignity: \"Chute\" }\n    ];\n\n    CORE_PLANETS.forEach(name => {\n        const nameLc = name.toLowerCase();\n        const signA = mapsA.signMap[name];\n        const signB = mapsB.signMap[name];\n\n        sentences.forEach(sentence => {\n            const lc = sentence.toLowerCase();\n            if (!lc.includes(nameLc)) return;\n            if (isCompositeContext(lc)) return;\n\n            const mentionsA = canMatchA && matchPersonName(lc, prenomA, nomA);\n            const mentionsB = canMatchB && matchPersonName(lc, prenomB, nomB);\n\n            for (const dd of DIGNITY_DETECT) {\n                const matchedTerm = dd.terms.find(t => lc.includes(t));\n                if (!matchedTerm) continue;\n                if (!isDignityForThisPlanet(lc, nameLc, matchedTerm)) continue;\n\n                const validSigns = (DIGNITY_RULES[dd.dignity] || {})[name] || [];\n                if (validSigns.length === 0) continue;\n\n                const effectivePerson = resolveEffectivePerson(lc, nameLc, mentionsA, mentionsB, perspective);\n\n                if (effectivePerson === \"A\") {\n                    if (signA && !validSigns.some(r => r.toLowerCase() === signA.toLowerCase())) {\n                        warnings.push({\n                            planet: name, person: prenomA_raw, claimed: dd.dignity,\n                            actualSign: signA, expectedSigns: validSigns.join(\"/\"),\n                            section: sectionLabel, excerpt: sentence.substring(0, 150),\n                            type: \"dignity_error\"\n                        });\n                    }\n                } else if (effectivePerson === \"B\") {\n                    if (signB && !validSigns.some(r => r.toLowerCase() === signB.toLowerCase())) {\n                        warnings.push({\n                            planet: name, person: prenomB_raw, claimed: dd.dignity,\n                            actualSign: signB, expectedSigns: validSigns.join(\"/\"),\n                            section: sectionLabel, excerpt: sentence.substring(0, 150),\n                            type: \"dignity_error\"\n                        });\n                    }\n                }\n            }\n        });\n    });\n    return warnings;\n}\n\n// ── 7. EXÉCUTION ──\n\nconst results = {\n    timestamp: new Date().toISOString(),\n    totalWarnings: 0,\n    subjects: `${prenomA_raw || 'A'} ${(persoA.nom || '').toUpperCase()} et ${prenomB_raw || 'B'} ${(persoB.nom || '').toUpperCase()}`.trim(),\n    typologie: meta.typologie || \"?\",\n    perspective_a: {},\n    perspective_b: {},\n    synthese: null,\n    ref_counts: {\n        planetsA_signs: Object.keys(mapsA.signMap).length,\n        planetsA_houses: Object.keys(mapsA.houseMap).length,\n        planetsB_signs: Object.keys(mapsB.signMap).length,\n        planetsB_houses: Object.keys(mapsB.houseMap).length,\n        overlayBinA_planets: Object.keys(overlayRefBinA).length,\n        overlayAinB_planets: Object.keys(overlayRefAinB).length,\n        aspectsBtoA: aspectRefBtoA.size / 2,\n        aspectsAtoB: aspectRefAtoB.size / 2,\n        synData_loaded: !!synData.meta,\n        prenomA: prenomA_raw || \"(vide)\",\n        prenomB: prenomB_raw || \"(vide)\"\n    }\n};\n\nfunction runValidation(text, perspective, houseNum, label) {\n    const signW = validateSignText(text, perspective);\n    const houseW = validateHouseText(text, perspective, houseNum);\n    const overlayW = validateOverlayText(text, perspective, houseNum);\n    const predictW = validatePredictiveVocabulary(text, label);\n    const swapW = validatePersonSwap(text, perspective, label);\n    const dignityW = validateDignityText(text, perspective, label);\n\n    const total = signW.length + houseW.length + overlayW.length + predictW.length + swapW.length + dignityW.length;\n    return { signW, houseW, overlayW, predictW, swapW, dignityW, total };\n}\n\nconst perspA = reassembled.perspective_a || {};\nObject.entries(perspA).forEach(([houseNum, data]) => {\n    const txt = data.llm_text || \"\";\n    const hNum = parseInt(houseNum);\n    const label = `Perspective A — Maison ${hNum}`;\n    const v = runValidation(txt, \"perspective_a\", hNum, label);\n    if (v.total > 0) {\n        results.perspective_a[`M${hNum}`] = v;\n        results.totalWarnings += v.total;\n    }\n});\n\nconst perspB = reassembled.perspective_b || {};\nObject.entries(perspB).forEach(([houseNum, data]) => {\n    const txt = data.llm_text || \"\";\n    const hNum = parseInt(houseNum);\n    const label = `Perspective B — Maison ${hNum}`;\n    const v = runValidation(txt, \"perspective_b\", hNum, label);\n    if (v.total > 0) {\n        results.perspective_b[`M${hNum}`] = v;\n        results.totalWarnings += v.total;\n    }\n});\n\nconst synthTxt = reassembled.synthese?.llm_text || \"\";\nif (synthTxt) {\n    const label = \"Synthèse\";\n    const signW = validateSignText(synthTxt, \"synthese\");\n    const houseW = validateHouseText(synthTxt, \"synthese\", 0);\n    const _rawOverlayW = [];\n    for (let h = 1; h <= 12; h++) {\n        _rawOverlayW.push(...validateOverlayText(synthTxt, \"perspective_a\", h));\n        _rawOverlayW.push(...validateOverlayText(synthTxt, \"perspective_b\", h));\n    }\n    const _seenOverlay = new Set();\n    const overlayW = _rawOverlayW.filter(w => {\n        const key = `${w.planet || ''}|${w.claimedHouse || ''}|${w.excerpt?.substring(0,80) || ''}`;\n        if (_seenOverlay.has(key)) return false;\n        _seenOverlay.add(key);\n        return true;\n    });\n    const predictW = validatePredictiveVocabulary(synthTxt, label);\n    const swapW = validatePersonSwap(synthTxt, \"synthese\", label);\n    const dignityW = validateDignityText(synthTxt, \"synthese\", label);\n    const total = signW.length + houseW.length + overlayW.length + predictW.length + swapW.length + dignityW.length;\n    if (total > 0) {\n        results.synthese = { signW, houseW, overlayW, predictW, swapW, dignityW, total };\n        results.totalWarnings += total;\n    }\n}\n\n// ── 8. VERDICT ──\n\nresults.status = results.totalWarnings === 0 ? \"CLEAN\" : \"WARNINGS_DETECTED\";\n\nif (results.totalWarnings === 0) {\n    results.summary = \"Aucune incohérence détectée entre les textes LLM et les données synastrie.\";\n} else {\n    const categories = {};\n    const countType = (obj) => {\n        if (!obj) return;\n        Object.values(obj).forEach(section => {\n            if (!section || typeof section !== 'object') return;\n            Object.entries(section).forEach(([key, arr]) => {\n                if (Array.isArray(arr) && arr.length > 0) {\n                    const typeName = key.replace(/W$/, '');\n                    categories[typeName] = (categories[typeName] || 0) + arr.length;\n                }\n            });\n        });\n    };\n    countType(results.perspective_a);\n    countType(results.perspective_b);\n    if (results.synthese && typeof results.synthese === 'object') {\n        Object.entries(results.synthese).forEach(([key, arr]) => {\n            if (Array.isArray(arr) && arr.length > 0) {\n                const typeName = key.replace(/W$/, '');\n                categories[typeName] = (categories[typeName] || 0) + arr.length;\n            }\n        });\n    }\n\n    const detail = Object.entries(categories).map(([k, v]) => `${k}: ${v}`).join(\", \");\n    results.summary = `${results.totalWarnings} incohérence(s) potentielle(s). Répartition: ${detail}.`;\n}\n\nreturn [{ json: results }];\n"
