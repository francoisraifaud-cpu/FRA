        "jsCode": "const varsA = $('Vars A').first().json;\nconst varsB = $('Vars B').first().json;\nconst geoA = $('Timezone A').first().json;\nconst geoB = $('Timezone B').first().json;\nconst tzA = $('Get TZ A').first().json;\nconst tzB = $('Get TZ B').first().json;\n\nconst dA = varsA.date.split('/');\nconst hA = varsA.heure.split(/[:Hh]/);\nconst dateA = new Date(Date.UTC(parseInt(dA[2]), parseInt(dA[1]) - 1, parseInt(dA[0]), parseInt(hA[0]), parseInt(hA[1]) || 0));\n\nconst dB = varsB.date.split('/');\nconst hB = varsB.heure.split(/[:Hh]/);\nconst dateB = new Date(Date.UTC(parseInt(dB[2]), parseInt(dB[1]) - 1, parseInt(dB[0]), parseInt(hB[0]), parseInt(hB[1]) || 0));\n\nconst midTs = Math.floor((dateA.getTime() + dateB.getTime()) / 2);\nconst midDate = new Date(midTs);\n\nconst midLat = (parseFloat(geoA.lat) + parseFloat(geoB.lat)) / 2;\nconst midLon = (parseFloat(geoA.lon) + parseFloat(geoB.lon)) / 2;\n\nlet tzMid = 0;\nif (tzA?.gmtOffset !== undefined && tzB?.gmtOffset !== undefined) {\n  tzMid = ((tzA.gmtOffset + tzB.gmtOffset) / 2) / 3600;\n} else if (tzA?.gmtOffset !== undefined) {\n  tzMid = tzA.gmtOffset / 3600;\n}\n\nconst payload = {\n  year: midDate.getUTCFullYear(),\n  month: midDate.getUTCMonth() + 1,\n  date: midDate.getUTCDate(),\n  hours: midDate.getUTCHours(),\n  minutes: midDate.getUTCMinutes(),\n  seconds: 0,\n  latitude: midLat,\n  longitude: midLon,\n  timezone: tzMid,\n  config: { observation_point: 'geocentric', ayanamsha: 'tropical', language: 'fr' }\n};\n\nconst pad = n => String(n).padStart(2, '0');\nconst dateDavisonStr = `${pad(midDate.getUTCDate())}/${pad(midDate.getUTCMonth()+1)}/${midDate.getUTCFullYear()} ${pad(midDate.getUTCHours())}H${pad(midDate.getUTCMinutes())}`;\n\nreturn [{ json: {\n  body: JSON.stringify(payload),\n  date_davison: dateDavisonStr,\n  lieu_davison: `Lat ${midLat.toFixed(4)} / Lon ${midLon.toFixed(4)}`,\n  lat_davison: midLat,\n  lon_davison: midLon\n} }];"
