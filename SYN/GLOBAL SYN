        "jsCode": "// ==========================================\n// REASSEMBLE SYN LLM v3.0\n// Rassemble les 13 résultats LLM parallèles\n// en structure exploitable pour les rapports HTML\n// Robustifié : gestion erreurs agents, validation\n// ==========================================\n\nconst allItems = $input.all();\nconst prepData = $('Super noeud Syn').first()?.json || {};\n\nlet synDataRef = prepData._synRef || {};\nif (!synDataRef.meta) {\n    try { synDataRef = $('5. Calcul SYN').first()?.json || {}; } catch(e) {\n        try { synDataRef = $('Calcul SYN').first()?.json || {}; } catch(e2) {}\n    }\n}\n\nconst result = {\n    perspective_a: {},\n    perspective_b: {},\n    synthese: null,\n    synData: synDataRef,\n    meta: {\n        total_prompts: allItems.length,\n        total_active: 0,\n        total_errors: 0,\n        total_skipped: 0,\n        errors: [],\n        timestamp: new Date().toISOString()\n    }\n};\n\nconst slotKeys = [\n    ...Array.from({length:6}, (_,i) => ({key: `slot_a_${i+1}`, dir: 'perspective_a'})),\n    ...Array.from({length:6}, (_,i) => ({key: `slot_b_${i+1}`, dir: 'perspective_b'})),\n    {key: 'slot_synth', dir: 'synthese'}\n];\n\nif (allItems.length !== slotKeys.length) {\n    result.meta.warning = `Attendu ${slotKeys.length} items, reçu ${allItems.length} — vérifier les agents LLM`;\n}\n\nfor (let idx = 0; idx < allItems.length && idx < slotKeys.length; idx++) {\n    const item = allItems[idx];\n    const slot = slotKeys[idx];\n    const slotData = prepData[slot.key];\n    if (!slotData || !slotData.active) {\n        result.meta.total_skipped++;\n        continue;\n    }\n\n    if (item.json?.error || item.json?.errorMessage) {\n        result.meta.total_errors++;\n        result.meta.errors.push({\n            slot: slot.key, house: slotData.house, label: slotData.label,\n            error: item.json?.errorMessage || item.json?.error || 'Agent LLM failure'\n        });\n        continue;\n    }\n\n    const llmText = item.json?.output || item.json?.text || item.json?.response || '';\n    if (!llmText || llmText.includes('skipped') || llmText.includes('\\\"skipped\\\"')) {\n        result.meta.total_skipped++;\n        continue;\n    }\n\n    result.meta.total_active++;\n\n    if (slot.dir === 'synthese') {\n        result.synthese = {\n            label: slotData.label,\n            llm_text: llmText\n        };\n    } else {\n        result[slot.dir][slotData.house] = {\n            house: slotData.house,\n            label: slotData.label,\n            score: slotData.score,\n            is_principale: slotData.is_principale,\n            llm_text: llmText\n        };\n    }\n}\n\nreturn [{ json: result }];"
