   interceptedSigns.push({\r\n                sign: seg.signe, house: fm.maison,\r\n                planets: planetsInIntercepted.filter(Boolean),\r\n                description: planetsInIntercepted.length > 0\r\n                    ? `${seg.signe} intercepté en M${fm.maison} — ${planetsInIntercepted.join(\", \")} piégé(s) dans ce signe, énergie bloquée qui demande un effort conscient d'expression`\r\n                    : `${seg.signe} intercepté en M${fm.maison} — les thématiques de ce signe sont latentes et difficiles d'accès dans cette maison`\r\n            });\r\n        }\r\n    });\r\n});\r\n\r\n// ── Sprint 6 — Module B2 : Profil de sensibilité élémentaire/modale ──\r\nconst ELEMENT_TRANSIT_MAP = {\r\n    \"Feu\":[\"Mars\",\"Jupiter\"],\"Terre\":[\"Saturne\",\"Vénus\"],\r\n    \"Air\":[\"Uranus\",\"Mercure\"],\"Eau\":[\"Neptune\",\"Pluton\"]\r\n};\r\nconst computeSensitivityProfile = (elStats, moStats) => {\r\n    const total = Object.values(elStats).reduce((a,b)=>a+b,0) || 12;\r\n    const lines = [];\r\n    Object.entries(elStats).forEach(([element, count]) => {\r\n        const ratio = count / total;\r\n        const affiliated = ELEMENT_TRANSIT_MAP[element]?.join(\"/\") || \"\";\r\n        if (ratio <= 0.15) {\r\n            lines.push(`VULNÉRABILITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} peuvent être particulièrement déstabilisants car le thème manque de récepteurs naturels dans cet élément. L'intégration demande un effort conscient.`);\r\n        } else if (ratio >= 0.35) {\r\n            lines.push(`FAMILIARITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} sont dans la \"langue maternelle\" du thème — leur énergie est reconnue et plus facilement intégrée, même si l'aspect est tendu.`);\r\n        }\r\n    });\r\n    if (moStats.Fixe >= 5) {\r\n        lines.push(`RÉSISTANCE AU CHANGEMENT (Fixe: ${moStats.Fixe}) : les transits d'Uranus et de Pluton sur les positions fixes seront véc