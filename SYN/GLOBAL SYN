iv>\n    <div><strong style=\"color:#64748b\">${isEN ? 'Peregrine' : 'Pérégrin'}</strong> — ${isEN ? 'No essential dignity (neutral)' : 'Aucune dignité essentielle (neutre)'}</div>\n</div>\n</div>`;\n\nhtml += `</div>`;\n\nhtml += `</div></body></html>`;\n\nreturn [{\n    json: { success: true },\n    binary: {\n        html_file: {\n            data: Buffer.from(html, 'utf8').toString('base64'),\n            mimeType: 'text/html',\n            fileName: `index.html`\n        }\n    }\n}];\n} catch (_globalErr) {\n    const errHtml = `<html><body style=\"font-family:sans-serif;padding:40px\"><h1 style=\"color:#dc2626\">Erreur de génération du rapport synastrie</h1><p>${_globalErr.message}</p><pre>${_globalErr.stack}</pre></body></html>`;\n    return [{ json: { error: true, message: _globalErr.message, stack: _globalErr.stack }, binary: { html_file: { data: Buffer.from(errHtml,'utf8').toString('base64'), mimeType:'text/html', fileName:'index.html' } } }];\n}\n"
