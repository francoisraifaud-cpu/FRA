startsWith('perspective_a_')) {\n        const h = key.replace('perspective_a_', '');\n        result.perspective_a[h] = { label, llm_text: translated, house, score, is_principale };\n    } else if (key.startsWith('perspective_b_')) {\n        const h = key.replace('perspective_b_', '');\n        result.perspective_b[h] = { label, llm_text: translated, house, score, is_principale };\n    }\n});\n\nreturn [{ json: result }];"
