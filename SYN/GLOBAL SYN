         penHtml += '</div></div>';\n            return penHtml;\n        })()\n})() : ''}\n\n${execSummary}\n\n<div style=\"background:#1F3864;padding:15px 26px;border-radius:8px;margin:44px 0 22px;\">\n    <h2 style=\"font-family:'Playfair Display',Georgia,serif;font-size:18px;font-weight:600;color:white;letter-spacing:0.2px;margin:0;\">🏠&nbsp; ${isEN ? 'Astrological Houses' : 'Maisons Astrologiques'}</h2>\n</div>\n\n<div style=\"background:#2E5FA3;padding:15px 26px;border-radius:8px;margin:22px 0 22px;\">\n    <h2 style=\"font-family:'Playfair Display',Georgia,serif;font-size:18px;font-weight:600;color:white;letter-spacing:0.2px;margin:0;\">&#9728;&nbsp; ${isEN ? `${esc(persoA)}'s Perspective — Impact of ${esc(persoB)}` : `Perspective de ${esc(persoA)} — Impact de ${esc(persoB)}`}</h2>\n</div>\n${sectionsA}\n\n<div style=\"background:#c2410c;padding:15px 26px;border-radius:8px;margin:44px 0 22px;\">\n    <h2 style=\"font-family:'Playfair Display',Georgia,serif;font-size:18px;font-weight:600;color:white;letter-spacing:0.2px;margin:0;\">☽&nbsp; ${isEN ? `${esc(persoB)}'s Perspective — Impact of ${esc(persoA)}` : `Perspective de ${esc(persoB)} — Impact de ${esc(persoA)}`}</h2>\n</div>\n${sectionsB}\n\n</div>\n</body>\n</html>`;\n\nreturn [{ json: { html: finalHtml, isComplete: true } }];\n"
