= month;\n  if (mo <= 2) { y -= 1; mo += 12; }\n  const A = Math.floor(y / 100);\n  const B = 2 - A + Math.floor(A / 4);\n  return Math.floor(365.25 * (y + 4716)) + Math.floor(30.6001 * (mo + 1)) + day + (hour / 24) + B - 1524.5;\n}\n\n// ── Précession générale en longitude depuis J2000.0 ───────────────────────\n// Source : IAU 2006 — p = 50.2909\"/an × T + 0.000022\"/an² × T²\nfunction precessionDeg(jd) {\n  const T = (jd - 2451545.0) / 365.25;   // années depuis J2000.0\n  return (50.2909 * T + 0.000022 * T * T) / 3600.0;\n}\n\n// ── Longitude → signe + degré normalisé ──────────────────────────────────\nfunction lonToSign(lon) {\n  const l = ((lon % 360) + 360) % 360;\n  const idx = Math.floor(l / 30);\n  return {\n    fullDegree: Math.round(l * 10000) / 10000,\n    normDegree: Math.round((l - idx * 30) * 10000) / 10000,\n    sign_index: idx,\n    zodiac_sign: { number: idx + 1, name: { fr: SIGNES_FR[idx], en: SIGNES_EN[idx] } }\n  };\n}\n\n// ── Lecture de la date depuis le nœud Extract Variables ──────────────────\nlet dateStr;\ntry {\n  dateStr = $('Vars B').first().json.date;\n} catch (e) {\n  // Fallback si ce nœud est exécuté seul (test manuel)\n  dateStr = $input.first()?.json?.date || \"12/11/1987\";\n}\n\nconst dt  = parseDate(dateStr);\nconst jd  = julianDay(dt.year, dt.month, dt.day, dt.hour);\nconst prec = precessionDeg(jd);\n\n// ── Calcul des 23 étoiles ─────────────────────────────────────────────────\nconst output = ETOILES.map(e => {\n  const lon = ((e.lon_j2000 + prec) % 360 + 360) % 360;\n  const pos = lonToSign(lon);\n\n  // Écart par rapport à la position traditionnelle de référence\n  // Calcul sur fullDegree pour éviter les erreurs aux frontières de signes\n  const refFull = e.ref_sign_idx * 30 + e.ref_deg;\n  let ecart = lon - refFull;\n  if (ecart > 180)  ecart -= 360;\n  if (ecart < -180) ecart += 360;\n\n  return {\n    name:             { fr: e.name_fr, en: e.name_en },\n    fullDegree:       pos.fullDegree,\n    normDegree:       pos.normDegree,\n    sign_index:       pos.sign_index,\n    zodiac_sign:      pos.zodiac_sign,\n    methode:          \"precession_j2000\",\n    reference:        { signe: e.ref_sign, degre: e.ref_deg, label: e.ref_deg + \"\\u00b0 \" + e.ref_sign },\n    ecart_reference:  Math.round(ecart * 10000) / 10000,\n    declination_j2000: e.dec_j2000 || null,\n    ra_j2000: e.ra_j2000 || null\n  };\n});\n\nreturn [{\n  json: {\n    date:           dateStr,\n    julian_day:     Math.round(jd * 1000000) / 1000000,\n    precession_deg: Math.round(prec * 10000) / 10000,\n    output:         output\n  }\n}];"
