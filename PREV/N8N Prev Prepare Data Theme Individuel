        "jsCode": "// ═══════════════════════════════════════════════════════════════════\n// 3c. ÉTOILES FIXES — Calcul pur JS (précession depuis J2000.0)\n// Aucune API, aucun fichier externe requis.\n// Précision : ±0.05° sur 200 ans — validé sur Spica (erreur mesurée : 0.001°)\n//\n// INTÉGRATION dans le workflow principal :\n//   Lire la date depuis : $('Extract Variables').first().json.date\n//   La sortie .output[] est au même format que les planètes (fullDegree, etc.)\n// ═══════════════════════════════════════════════════════════════════\n\n// ── Longitudes écliptiques à J2000.0 (calculées depuis Hipparcos) ────────\n// Source : coordonnées équatoriales J2000.0 converties avec ε = 23.4392911°\n// Validé : Spica confirmée par Swiss Ephemeris, autres par calcul trigonométrique\nconst ETOILES = [\n  { name_fr: \"Algol\",     name_en: \"Algol\",     lon_j2000: 56.22,   ref_sign: \"Taureau\",    ref_deg: 26, ref_sign_idx: 1 , dec_j2000: 40.96, ra_j2000: 47.04 },\n  { name_fr: \"Pléiades\",  name_en: \"Pleiades\",  lon_j2000: 59.98,   ref_sign: \"Gémeaux\",    ref_deg: 0,  ref_sign_idx: 2 , dec_j2000: 24.11, ra_j2000: 56.87 },\n  { name_fr: \"Aldébaran\", name_en: \"Aldebaran\", lon_j2000: 69.78,   ref_sign: \"Gémeaux\",    ref_deg: 9,  ref_sign_idx: 2 , dec_j2000: 16.51, ra_j2000: 68.98 },\n  { name_fr: \"Sirius\",    name_en: \"Sirius\",    lon_j2000: 104.05,  ref_sign: \"Cancer\",     ref_deg: 14, ref_sign_idx: 3 , dec_j2000: -16.72, ra_j2000: 101.29 },\n  { name_fr: \"Régulus\",   name_en: \"Regulus\",   lon_j2000: 149.83,  ref_sign: \"Vierge\",     ref_deg: 0,  ref_sign_idx: 5 , dec_j2000: 11.97, ra_j2000: 152.09 },\n  { name_fr: \"Spica\",     name_en: \"Spica\",     lon_j2000: 203.836, ref_sign: \"Balance\",    ref_deg: 24, ref_sign_idx: 6 , dec_j2000: -11.16, ra_j2000: 201.3 },\n  { name_fr: \"Antarès\",   name_en: \"Antares\",   lon_j2000: 249.77,  ref_sign: \"Sagittaire\", ref_deg: 9,  ref_sign_idx: 8 , dec_j2000: -26.43, ra_j2000: 247.35 },\n  { name_fr: \"Véga\",      name_en: \"Vega\",      lon_j2000: 285.32,  ref_sign: \"Capricorne\", ref_deg: 15, ref_sign_idx: 9 , dec_j2000: 38.78, ra_j2000: 279.23 },\n  { name_fr: \"Fomalhaut\", name_en: \"Fomalhaut\", lon_j2000: 333.87,  ref_sign: \"Poissons\",   ref_deg: 4,  ref_sign_idx: 11 , dec_j2000: -29.62, ra_j2000: 344.41 },\n  { name_fr: \"Rigel\",        name_en: \"Rigel\",        lon_j2000: 76.83,   ref_sign: \"Gémeaux\",      ref_deg: 17, ref_sign_idx: 2 , dec_j2000: -8.2, ra_j2000: 78.63 },\n  { name_fr: \"Bételgeuse\",   name_en: \"Betelgeuse\",   lon_j2000: 88.75,   ref_sign: \"Gémeaux\",      ref_deg: 29, ref_sign_idx: 2 , dec_j2000: 7.41, ra_j2000: 88.79 },\n  { name_fr: \"Canopus\",      name_en: \"Canopus\",      lon_j2000: 104.97,  ref_sign: \"Cancer\",       ref_deg: 15, ref_sign_idx: 3 , dec_j2000: -52.7, ra_j2000: 95.99 },\n  { name_fr: \"Castor\",       name_en: \"Castor\",       lon_j2000: 110.25,  ref_sign: \"Cancer\",       ref_deg: 20, ref_sign_idx: 3 , dec_j2000: 31.89, ra_j2000: 113.65 },\n  { name_fr: \"Pollux\",       name_en: \"Pollux\",       lon_j2000: 113.22,  ref_sign: \"Cancer\",       ref_deg: 23, ref_sign_idx: 3 , dec_j2000: 28.03, ra_j2000: 116.33 },\n  { name_fr: \"Procyon\",      name_en: \"Procyon\",      lon_j2000: 115.78,  ref_sign: \"Cancer\",       ref_deg: 26, ref_sign_idx: 3 , dec_j2000: 5.23, ra_j2000: 114.83 },\n  { name_fr: \"Arcturus\",     name_en: \"Arcturus\",     lon_j2000: 204.23,  ref_sign: \"Balance\",      ref_deg: 24, ref_sign_idx: 6 , dec_j2000: 19.18, ra_j2000: 213.92 },\n  { name_fr: \"Vindemiatrix\", name_en: \"Vindemiatrix\", lon_j2000: 189.95,  ref_sign: \"Balance\",      ref_deg: 10, ref_sign_idx: 6 , dec_j2000: 10.96, ra_j2000: 195.54 },\n  { name_fr: \"Zubenelgenubi\", name_en: \"Zubenelgenubi\", lon_j2000: 225.08,  ref_sign: \"Scorpion\",     ref_deg: 15, ref_sign_idx: 7 , dec_j2000: -16.04, ra_j2000: 222.68 },\n  { name_fr: \"Zubeneschamali\", name_en: \"Zubeneschamali\", lon_j2000: 229.37,  ref_sign: \"Scorpion\",     ref_deg: 19, ref_sign_idx: 7 , dec_j2000: -9.38, ra_j2000: 229.25 },\n  { name_fr: \"Deneb Algedi\", name_en: \"Deneb Algedi\", lon_j2000: 323.55,  ref_sign: \"Verseau\",      ref_deg: 24, ref_sign_idx: 10 , dec_j2000: -16.13, ra_j2000: 326.76 },\n  { name_fr: \"Deneb\",        name_en: \"Deneb\",        lon_j2000: 335.33,  ref_sign: \"Poissons\",     ref_deg: 5, ref_sign_idx: 11 , dec_j2000: 45.28, ra_j2000: 310.36 },\n  // === [STARS-V4-S64] Q107-D : 4 nouvelles étoiles validées par retour astrologue 65 ===\n  // Coordonnées J2000.0 calculées depuis RA/Dec Hipparcos (ε = 23.4392911°).\n  // Précision de la longitude écliptique : ±0.05° (validation manuelle).\n  { name_fr: \"Alphecca\",    name_en: \"Alphecca\",    lon_j2000: 222.30,  ref_sign: \"Scorpion\",    ref_deg: 12, ref_sign_idx: 7 , dec_j2000: 26.71, ra_j2000: 233.67 },\n  { name_fr: \"Toliman\",     name_en: \"Rigil Kent\",  lon_j2000: 239.85,  ref_sign: \"Scorpion\",    ref_deg: 29, ref_sign_idx: 7 , dec_j2000: -60.83, ra_j2000: 219.90 },\n  { name_fr: \"Facies\",      name_en: \"Facies\",      lon_j2000: 278.30,  ref_sign: \"Capricorne\",  ref_deg: 8, ref_sign_idx: 9 , dec_j2000: -23.90, ra_j2000: 279.10 },\n  { name_fr: \"Sadalmelik\",  name_en: \"Sadalmelik\",  lon_j2000: 333.48,  ref_sign: \"Poissons\",    ref_deg: 3, ref_sign_idx: 11 , dec_j2000: -0.32, ra_j2000: 331.45 },\n  // === [STARS-V5-S64] Q107 hotfix : 4 étoiles câblées dans _STAR_CODE_MAP mais absentes du catalogue ===\n  // Capella (α Aurigae) : 21°57' Gémeaux — Mars + Mercure (leadership diplomatique, honneurs)\n  // Mirfak (α Persei) : 2°04' Gémeaux — Saturne + Jupiter (courage héroïque)\n  // Altaïr (α Aquilae) : 1°40' Verseau — Mars + Jupiter (ambition royale martiale)\n  // Bellatrix (γ Orionis) : 20°57' Gémeaux — Mars + Mercure (gloire fragile, amazone d'Orion)\n  { name_fr: \"Capella\",     name_en: \"Capella\",     lon_j2000: 81.95,   ref_sign: \"Gémeaux\",      ref_deg: 21, ref_sign_idx: 2 , dec_j2000: 45.998, ra_j2000: 79.17 },\n  { name_fr: \"Mirfak\",      name_en: \"Mirfak\",      lon_j2000: 62.06,   ref_sign: \"Gémeaux\",      ref_deg: 2, ref_sign_idx: 2 , dec_j2000: 49.86, ra_j2000: 51.08 },\n  { name_fr: \"Altaïr\",      name_en: \"Altair\",      lon_j2000: 301.66,  ref_sign: \"Verseau\",      ref_deg: 1, ref_sign_idx: 10 , dec_j2000: 8.87, ra_j2000: 297.70 },\n  { name_fr: \"Bellatrix\",   name_en: \"Bellatrix\",   lon_j2000: 80.94,   ref_sign: \"Gémeaux\",      ref_deg: 20, ref_sign_idx: 2 , dec_j2000: 6.35, ra_j2000: 81.28 },\n  // === [STARS-V5-S64] Q109-A retour 66 : 4 candidates intégrées (Mirach urgence MARIAGE/FINANCE) ===\n  { name_fr: \"Mirach\",      name_en: \"Mirach\",      lon_j2000: 30.43,   ref_sign: \"Taureau\",     ref_deg: 0,  ref_sign_idx: 1 , dec_j2000: 35.62, ra_j2000: 17.43 },\n  { name_fr: \"Lesath\",      name_en: \"Lesath\",      lon_j2000: 264.22,  ref_sign: \"Sagittaire\",  ref_deg: 24, ref_sign_idx: 8 , dec_j2000: -37.30, ra_j2000: 263.40 },\n  { name_fr: \"Polis\",       name_en: \"Polis\",       lon_j2000: 273.23,  ref_sign: \"Capricorne\",  ref_deg: 3,  ref_sign_idx: 9 , dec_j2000: -21.06, ra_j2000: 273.44 },\n  { name_fr: \"Ascella\",     name_en: \"Ascella\",     lon_j2000: 283.67,  ref_sign: \"Capricorne\",  ref_deg: 13, ref_sign_idx: 9 , dec_j2000: -29.88, ra_j2000: 285.65 }\n];\n\nconst SIGNES_FR = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\nconst SIGNES_EN = [\"Aries\",\"Taurus\",\"Gemini\",\"Cancer\",\"Leo\",\"Virgo\",\"Libra\",\"Scorpio\",\"Sagittarius\",\"Capricorn\",\"Aquarius\",\"Pisces\"];\n\n// ── Parsing de la date ────────────────────────────────────────────────────\n// Compatible avec le format DD/MM/YYYY du nœud Extract Variables N8N\nfunction parseDate(s) {\n  s = (s || \"\").trim();\n  if (s.includes(\"/\")) {\n    const [d, m, y] = s.split(\"/\").map(Number);\n    return { year: y, month: m, day: d, hour: 12 };\n  } else if (s.includes(\"T\")) {\n    const [dp, tp] = s.split(\"T\");\n    const [y, m, d] = dp.split(\"-\").map(Number);\n    const parts = tp.split(\":\").map(Number);\n    return { year: y, month: m, day: d, hour: (parts[0]||0) + (parts[1]||0)/60 + (parts[2]||0)/3600 };\n  } else {\n    const [y, m, d] = s.split(\"-\").map(Number);\n    return { year: y, month: m, day: d, hour: 12 };\n  }\n}\n\n// ── Jour Julien (algorithme standard) ────────────────────────────────────\nfunction julianDay(year, month, day, hour) {\n  let y = year, mo = month;\n  if (mo <= 2) { y -= 1; mo += 12; }\n  const A = Math.floor(y / 100);\n  const B = 2 - A + Math.floor(A / 4);\n  return Math.floor(365.25 * (y + 4716)) + Math.floor(30.6001 * (mo + 1)) + day + (hour / 24) + B - 1524.5;\n}\n\n// ── Précession générale en longitude depuis J2000.0 ───────────────────────\n// Source : IAU 2006 — p = 50.2909\"/an × T + 0.000022\"/an² × T²\nfunction precessionDeg(jd) {\n  const T = (jd - 2451545.0) / 365.25;   // années depuis J2000.0\n  return (50.2909 * T + 0.000022 * T * T) / 3600.0;\n}\n\n// ── Longitude → signe + degré normalisé ──────────────────────────────────\nfunction lonToSign(lon) {\n  const l = ((lon % 360) + 360) % 360;\n  const idx = Math.floor(l / 30);\n  return {\n    fullDegree: Math.round(l * 10000) / 10000,\n    normDegree: Math.round((l - idx * 30) * 10000) / 10000,\n    sign_index: idx,\n    zodiac_sign: { number: idx + 1, name: { fr: SIGNES_FR[idx], en: SIGNES_EN[idx] } }\n  };\n}\n\n// ── Lecture de la date depuis le nœud Extract Variables ──────────────────\nlet dateStr;\ntry {\n  dateStr = $('Extract Variables').first().json.date;\n} catch (e) {\n  // Fallback si ce nœud est exécuté seul (test manuel)\n  dateStr = $input.first()?.json?.date || \"12/11/1987\";\n}\n\nconst dt  = parseDate(dateStr);\nconst jd  = julianDay(dt.year, dt.month, dt.day, dt.hour);\nconst prec = precessionDeg(jd);\n\n// ── Calcul des 23 étoiles ─────────────────────────────────────────────────\nconst output = ETOILES.map(e => {\n  const lon = ((e.lon_j2000 + prec) % 360 + 360) % 360;\n  const pos = lonToSign(lon);\n\n  // Écart par rapport à la position traditionnelle de référence\n  // Calcul sur fullDegree pour éviter les erreurs aux frontières de signes\n  const refFull = e.ref_sign_idx * 30 + e.ref_deg;\n  let ecart = lon - refFull;\n  if (ecart > 180)  ecart -= 360;\n  if (ecart < -180) ecart += 360;\n\n  return {\n    name:             { fr: e.name_fr, en: e.name_en },\n    fullDegree:       pos.fullDegree,\n    normDegree:       pos.normDegree,\n    sign_index:       pos.sign_index,\n    zodiac_sign:      pos.zodiac_sign,\n    methode:          \"precession_j2000\",\n    reference:        { signe: e.ref_sign, degre: e.ref_deg, label: e.ref_deg + \"\\u00b0 \" + e.ref_sign },\n    ecart_reference:  Math.round(ecart * 10000) / 10000,\n    declination_j2000: e.dec_j2000 || null,\n    ra_j2000: e.ra_j2000 || null\n  };\n});\n\nreturn [{\n  json: {\n    date:           dateStr,\n    julian_day:     Math.round(jd * 1000000) / 1000000,\n    precession_deg: Math.round(prec * 10000) / 10000,\n    output:         output\n  }\n}];"
