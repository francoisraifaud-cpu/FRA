        "jsCode": "// ── EXTRACTION HEATMAP avant nettoyage (les objets sont partagés avec $()) ──\nlet _heatDataEarly = null;\nfor (const _it of $input.all()) {\n    if (_it.json?.heatmapData) { _heatDataEarly = _it.json.heatmapData; break; }\n}\nif (!_heatDataEarly) {\n    for (const nn of [\"Analyseur Technique v\",\"Super noeud2\",\"N8N Prev\",\"Merge\",\"Merge1\",\"Merge2\"]) {\n        try { const d = $(nn).first()?.json?.heatmapData; if (d) { _heatDataEarly = d; break; } } catch(e) {}\n    }\n}\n\n// ── NETTOYAGE MÉMOIRE — Libérer les items d'entrée inutilisés ──\nfor (const _it of $input.all()) {\n    const j = _it.json;\n    delete j.prompt_user; delete j.prompt_system; delete j.contexte_natal_prompt;\n    delete j.heatmapData; delete j.eventSignatures; delete j.compoundEvents;\n    delete j.ageMilestones; delete j._planetaryReturns; delete j._boundProfection;\n    delete j._lunarReturnsScoring; delete j.reponse_texte; delete j.natalAspects;\n    delete j.natalHouses; delete j.sensitivityProfile; delete j.chartShape;\n    delete j.interceptedSigns; delete j.sabianData; delete j.dispositorTree;\n    delete j.accidentalDignity; delete j.paranResults; delete j.stats;\n    delete j.progressionsRaw; delete j._rsRaw; delete j._rlRaw; delete j._tpRaw;\n    delete j.progressions_planetes; delete j.progressions_texte;\n    delete j.arcs_solaires_texte; delete j.midpoints_texte;\n    delete j.antiscia_texte; delete j.etoiles_texte;\n    delete j.declinaisons_texte_raw; delete j._primaryDirections;\n}\n\n// --- 1. RÉCUPÉRATION DIRECTE ET SÉCURISÉE DES TEXTES ---\nconst getText = (nodeName) => {\n    try {\n        const nodeData = $(nodeName).first()?.json;\n        return nodeData?.output || nodeData?.text || nodeData?.message || \"\";\n    } catch (e) {\n        return \"\";\n    }\n};\n\nconst getHouse = (num) => {\n    if (num === 0) return getText('Synthèse');\n    return getText(`Maison ${num}`);\n};\n\n// --- 2. RÉCUPÉRATION DES VARIABLES ---\nlet vars = {};\ntry {\n    vars = $('Extract Variables').first()?.json || $('Extract Variables').first()?.json || {};\n} catch(e) {}\n\nconst langue = vars.langue || 'Français';\nconst isEN = langue !== 'Français';\n\nlet astroData = { maisons: [] };\ntry {\n    astroData = $(\"Enrichissement Astrologique\").first()?.json || { maisons: [] };\n} catch(e) {}\nconst _astroMaisons = astroData.maisons || [];\nconst _etoileMatches = astroData.etoileMatches || [];\nconst _etoileCuspMatches = astroData.etoileCuspMatches || [];\nconst _stellarByPlanet = {};\n_etoileMatches.forEach(em => { if (em.isAngle) return; if (!_stellarByPlanet[em.planete]) _stellarByPlanet[em.planete] = []; _stellarByPlanet[em.planete].push(em); });\nconst _stellarByCusp = {};\n_etoileCuspMatches.forEach(ec => { const h = ec.maison || ec.house; if (h) { if (!_stellarByCusp[h]) _stellarByCusp[h] = []; _stellarByCusp[h].push(ec); }});\nconst _paranResults = astroData.paranResults || [];\n\nconst _plPT = astroData.planetes || [];\nconst _solSignPT = _plPT.find(p => (p.planet?.fr || p.planet?.en) === \"Soleil\")?.zodiac_sign?.name?.fr || \"\";\nconst _lunSignPT = _plPT.find(p => (p.planet?.fr || p.planet?.en) === \"Lune\")?.zodiac_sign?.name?.fr || \"\";\nconst _ascSignPT = _astroMaisons.find(h => h.maison === 1)?.segments?.find(s => s.type === \"Cuspide\")?.signe || \"\";\nconst _lumHeaderPT = isEN\n    ? `Sun: ${_solSignPT} / Ascendant: ${_ascSignPT} / Moon: ${_lunSignPT}`\n    : `Soleil : ${_solSignPT} / Ascendant : ${_ascSignPT} / Lune : ${_lunSignPT}`;\n\nconst nom = vars.nom || \"Inconnu\";\nconst prenom = vars.prenom || \"\";\nconst nomAffiche = (prenom && nom && nom !== \"Inconnu\") ? `${prenom} ${(nom || \"\").toUpperCase()}`.trim() : (prenom || (nom || \"\").toUpperCase() || \"Client\");\nconst date = vars.date || \"--/--/----\";\nconst heure = vars.heure || \"--H--\";\nconst lieu = vars.lieu || \"Lieu inconnu\";\nconst anneePrevision = vars.annee || String(new Date().getFullYear());\n\nconst typeRapport = (vars.rapport || \"Annuel\").trim();\nconst THEMES = {\n    'Annuel':       { bg:'#1F3864', accent:'#2E5FA3', badge:'#e8f0fe', badgeTxt:'#1F3864' },\n    'Mensuel':      { bg:'#1a4b2e', accent:'#2a7a4e', badge:'#e0f4e8', badgeTxt:'#1a4b2e' },\n    'Hebdomadaire': { bg:'#3d1a5c', accent:'#6b35a0', badge:'#f0e8ff', badgeTxt:'#3d1a5c' },\n    'Journalier':   { bg:'#5c2a0a', accent:'#c05621', badge:'#fff0e8', badgeTxt:'#5c2a0a' }\n};\nconst theme = THEMES[typeRapport] || THEMES['Annuel'];\n\nconst formatDate = (str) => {\n    if (!str) return \"\";\n    str = str.trim();\n    if (str.includes(\"/\")) return str;\n    const [y, m, d] = str.split(\"-\");\n    return `${d}/${m}/${y}`;\n};\nconst dateEntreeStr = formatDate(vars.date_entree || `01/01/${anneePrevision}`);\nconst dateSortieStr = formatDate(vars.date_sortie || `31/12/${anneePrevision}`);\nconst titrePrincipal = isEN\n    ? `Technical Forecast Report - ${typeRapport} - ${dateEntreeStr} - ${dateSortieStr} - ${nomAffiche}`\n    : `Rapport Technique Prévisions - ${typeRapport} - ${dateEntreeStr} - ${dateSortieStr} - ${nomAffiche}`;\nconst _fdfT = (s) => { if (!s) return \"\"; s = s.trim(); if (s.includes(\"/\")) return s.replace(/\\//g, \"_\"); const [y,m,d] = s.split(\"-\"); return `${d}_${m}_${y}`; };\nconst _desiredPdfNameT = isEN\n    ? `Technical Forecast Report - ${typeRapport} - ${_fdfT(vars.date_entree || `01/01/${anneePrevision}`)} - ${_fdfT(vars.date_sortie || `31/12/${anneePrevision}`)} - ${nomAffiche}`\n    : `Rapport Technique Prévisions - ${typeRapport} - ${_fdfT(vars.date_entree || `01/01/${anneePrevision}`)} - ${_fdfT(vars.date_sortie || `31/12/${anneePrevision}`)} - ${nomAffiche}`;\n\nconst sousTitre = [date, heure, lieu].filter(Boolean).join(' · ');\n\n// --- 3. FORMATAGE ET MARKDOWN ---\nconst ZODIAC_MAP = {\n    \"Bélier\": \"♈\", \"Taureau\": \"♉\", \"Gémeaux\": \"♊\", \"Cancer\": \"♋\",\n    \"Lion\": \"♌\", \"Vierge\": \"♍\", \"Balance\": \"♎\", \"Scorpion\": \"♏\",\n    \"Sagittaire\": \"♐\", \"Capricorne\": \"♑\", \"Verseau\": \"♒\", \"Poissons\": \"♓\"\n};\n\nconst esc = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n\nconst inline = (t) => {\n    return esc(t)\n        .replace(/\\*\\*\\*(.*?)\\*\\*\\*/g, '<strong><em>$1</em></strong>')\n        .replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>')\n        .replace(/\\*(.*?)\\*/g, '<em>$1</em>');\n};\n\nconst md = (text) => {\n    if (!text || text.trim() === '') return '<p style=\"color: #aaa; font-style: italic; font-size: 14px;\">' + (isEN ? '⚠️ Analysis not available for this section.' : '⚠️ Analyse non disponible pour cette section.') + '</p>';\n    text = String(text);\n    if (text.includes('\\\\n')) text = text.replace(/\\\\n/g, '\\n');\n    text = text\n        .replace(/^([\\*]{0,3}\\d[\\d.]*[\\.\\)]\\s[^\\n]{4,})\\n([^\\n\\*]{3,80}[\\*]{1,3})/gm, '$1 $2');\n    text = text.replace(\n        /^([\\*]{0,3}\\d[\\d.]*[\\.\\)]\\s[^\\n]*\\([^\\n)]*)\\n([\\wÀ-ÿ\\u2019\\u2018'-]+\\))/gm,\n        '$1 $2');\n    text = text.replace(\n        /^([\\*]{0,3}\\d[\\d.]*[\\.\\)]\\s[^\\n]{30,140})\\n([^\\n\\d\\*\\#\\.]{2,25})\\n/gm,\n        '$1 $2\\n');\n    text = text.replace(/^(#{1,3} .+?)\\s+#{2,}\\s+([^\\n]+)$/gm, '$1\\n$2');\n    const lines = text.split('\\n');\n    const out = [];\n    let inList = false;\n    for (let line of lines) {\n        line = line.replace(/^[\\uFEFF\\u200B]+/, '');\n        if (/^#{1,}[^\\S\\r\\n]/.test(line)) line = line.replace(/^(#{1,})[^\\S\\r\\n]+/, '$1 ');\n        const isBullet = line.match(/^[-*] /);\n        if (!isBullet && inList) { out.push('</ul>'); inList = false; }\n        const stripped = line.replace(/\\*/g, '');\n        let lineHandled = false;\n        if (/^#{1,} /.test(line)) {\n            line = line.replace(/\\*/g, '');\n            if (/^# [^#]/.test(line)) line = '#' + line;\n        } else {\n            const subMatch = stripped.match(/^(\\d+\\.\\d+[.)]\\s+)(.+)$/);\n            if (subMatch) {\n                const prefix = subMatch[1], rest = subMatch[2];\n                const colon = rest.indexOf(' : ');\n                if (colon > 0 && colon <= 90) {\n                    const after = rest.slice(colon + 3);\n                    if (after.length > 60) {\n                        out.push(`<h5 style=\"font-family: 'Source Sans 3', 'Segoe UI', sans-serif; font-size: 15px; font-weight: 700; color: #1a1a2e; margin: 16px 0 4px; line-height: 1.4;\">${esc(prefix + rest.slice(0, colon))}</h5>`);\n                        if (after.trim()) out.push(`<p style=\"font-size: 15.5px; line-height: 1.82; color: #2c2c3a; margin: 4px 0 9px; text-align: justify;\">${inline(after)}</p>`);\n                        lineHandled = true;\n                    } else if ((prefix + rest).length <= 130) { line = '#### ' + prefix + rest; }\n                } else if ((prefix + rest).length <= 130) { line = '#### ' + prefix + rest; }\n            } else {\n                const mainMatch = stripped.match(/^(\\d+[.)]\\s+)(.+)$/);\n                if (mainMatch) {\n                    const prefix = mainMatch[1], rest = mainMatch[2];\n                    if ((prefix + rest).length <= 155) {\n                        line = '### ' + prefix + rest;\n                    } else {\n                        const colon = rest.indexOf(' : ');\n                        if (colon > 0 && colon <= 120) {\n                            const after = rest.slice(colon + 3);\n                            out.push(`<h4 style=\"font-family: 'Source Sans 3', 'Segoe UI', sans-serif; font-size: 16px; font-weight: 700; color: ${theme.accent}; margin: 24px 0 8px; padding-left: 12px; border-left: 3px solid ${theme.accent}; line-height: 1.4;\">${esc(prefix + rest.slice(0, colon))}</h4>`);\n                            if (after.trim()) out.push(`<p style=\"font-size: 15.5px; line-height: 1.82; color: #2c2c3a; margin: 9px 0; text-align: justify;\">${inline(after)}</p>`);\n                            lineHandled = true;\n                        } else { line = '### ' + prefix + rest; }\n                    }\n                } else if (/^\\*{2,3}[^*]{4,120}\\*{2,3}$/.test(line)) {\n                    line = '### ' + stripped;\n                } else if (stripped.length <= 130 && /^[\\p{Emoji_Presentation}\\p{So}A-ZÀ-ÿ][^:\\n]{2,55} : [\\p{Emoji_Presentation}\\p{So}A-ZÀ-ÿ].{2,70}$/u.test(stripped)) {\n                    line = '#### ' + stripped;\n                } else if (stripped.length >= 8 && stripped.length <= 90 && /^[\\p{Emoji_Presentation}\\p{So}A-ZÀ-ÿ]/u.test(stripped) && !/[.!?;:,…]$/.test(stripped.trim())) {\n                    line = '### ' + stripped;\n                }\n            }\n        }\n        if (lineHandled) continue;\n        if (line.startsWith('## ') && !line.startsWith('### ')) {\n            out.push(`<p style=\"font-family:'Source Sans 3','Segoe UI',sans-serif;font-size:16px;font-weight:700;color:${theme.accent};margin:24px 0 8px;padding-left:12px;border-left:3px solid ${theme.accent};line-height:1.4;\"><b>${esc(line.replace(/^## /, ''))}</b></p>`);\n        } else if (line.startsWith('### ')) {\n            out.push(`<p style=\"font-family:'Source Sans 3','Segoe UI',sans-serif;font-size:15px;font-weight:700;color:#1a1a2e;margin:16px 0 6px;line-height:1.4;\"><b>${esc(line.replace(/^### /, ''))}</b></p>`);\n        } else if (line.startsWith('#### ')) {\n            out.push(`<h5 style=\"font-family: 'Source Sans 3', 'Segoe UI', sans-serif; font-size: 15px; font-weight: 700; color: #1a1a2e; margin: 16px 0 6px; line-height: 1.4;\">${esc(line.replace(/^#### /, ''))}</h5>`);\n        } else if (isBullet) {\n            if (!inList) { out.push('<ul style=\"margin: 10px 0 12px 20px; padding: 0;\">'); inList = true; }\n            out.push(`<li style=\"font-size: 15.5px; line-height: 1.82; color: #2c2c3a; margin: 7px 0;\">${inline(line.replace(/^[-*] /, ''))}</li>`);\n        } else if (line.trim() === '') {\n            out.push('<div style=\"height: 10px;\"></div>');\n        } else if (line.startsWith('---')) {\n            out.push('<hr style=\"border: 0; border-top: 1px solid #e8ebf5; margin: 22px 0;\">');\n        } else {\n            out.push(`<p style=\"font-size: 15.5px; line-height: 1.82; color: #2c2c3a; margin: 9px 0; text-align: justify;\">${inline(line)}</p>`);\n        }\n    }\n    if (inList) out.push('</ul>');\n    return out.join('');\n};\n\n// --- 4. DATA DES MAISONS ---\nconst MAISONS_META = [\n  { n:1,  titre:\"Maison 1 — L'Ascendant\", domaines:\"Identité · Apparence · Tempérament inné\", desc:\"Cette maison est le pilier du thème astral de l'individu, elle est la ligne de départ de sa personnalité et définit l'angle de vue de tous les autres secteurs de sa vie (toutes les autres maisons) . Elle incarne sa singularité, son identité extérieure, son image projetée au monde. Elle représente l'apparence physique de l'individu, son tempérament, et la façon dont les autres le perçoivent. Cette maison incarne la vitalité de l'individu, comment il s'affirme face au monde, ainsi que ses premiers réflexes dans les situations de la vie (réflexes perçus au premier abord par les autres, ou 'carapace extérieure' de protection de son identité profonde). En quelques mots, il s'agit de la maison ou : Je suis et j'incarne.\" },\n  { n:2,  titre:\"Maison 2 — Les Possessions\", domaines:\"Argent · Valeurs · Ressources\", desc:\"C'est la maison de l'argent que l'individu gagne, de ses biens matériels, de ses possessions immatérielles, de son estime de lui-même et de ses talents innés. Elle représente ses besoins primaires : se nourrir, se loger, se protéger ainsi que son rapport profond à la stabilité. Cette maison incarne sa chance financière, mais ne concerne que son propre compte en banque ou ses possessions personnelles (contrairement à la maison 8, qui gère, l'argent partagé avec les autres). En quelques mots, il s'agit de la maison du : J'ai.\" },\n  { n:3,  titre:\"Maison 3 — La Communication\", domaines:\"Communication · Études · Proches\", desc:\"C'est la maison qui régit la façon de penser, de raisonner, de parler de l'individu. Elle régit ses petits déplacements (vélo, voiture, train, marche), ses communications techniques (smartphone, e-mails, échanges rapides), ses relations avec ses frères et sœurs, ses voisins, son entourage de proximité (les relations non choisies, ou la communication est informelle et légère). Cette maison commande l'apprentissage quotidien, concret, curieux et horizontal de l'individu (contrairement à la maison 9, qui gère, l'apprentissage des concepts abstraits, les hautes études, et contrairement à la maison 6 qui gère, l'apprentissage au travail). En quelques mots, il s'agit de la maison ou : Je pense.\" },\n  { n:4,  titre:\"Maison 4 — Le Foyer\", domaines:\"Famille · Racines · Enfance\", desc:\"C'est la maison du foyer privé, de la famille, de l'enfance (souvenirs), des origines de l'individu (au sens héréditaires, et patrimoniales). Il s'agit de la \\\"racine de son arbre\\\" : qui incarne pleinement son passé, sa vie privée, son refuge, son \\\"cocon\\\". C'est là où il se sent chez lui (il peut s'agir de sa maison physique, comme de sa ville d'origine). Cette maison régit également l'intimité cachée de l'individu, sa base émotionnelle (relations avec ses parents, en lien avec la sécurité émotionnelle), son \\\"jardin secret\\\". Elle régit aussi les amis considérés comme des frères / sœurs, ainsi que les fins de vie et les fins de cycle (enfance, tout comme vieillesse tranquille). En quelques mots, il s'agit de la maison ou : Je ressens.\" },\n  { n:5,  titre:\"Maison 5 — Les Plaisirs\", domaines:\"Créativité · Amour · Enfants\", desc:\"Il s'agit de la maison des enfants, des amours romantiques (flirts) et des loisirs. Elle régit la création artistique, la prise de risque de l'individu (son rapport aux jeux de hasard, à la spéculation), sa capacité à s'émerveiller et à jouer (sa propre part d'enfant intérieur), son authenticité. Cette maison incarne son côté \\\"artiste\\\" : tout ce qui permet d'exprimer son unicité créatrice & rayonnante, sa différence, sa joie de vivre. Contrairement à la maison 7 (qui gère les relations amoureuses sérieuses), la maison 5 ne traite que la partie \\\"séduction\\\" de la relation amoureuse. En quelques mots, il s'agit de la maison ou : J'aime et je brille.\" },\n  { n:6,  titre:\"Maison 6 — Le Quotidien\", domaines:\"Travail · Santé · Routine\", desc:\"C'est la maison des habitudes (rituels), de la santé (diététique, sommeil, sport, soins), du détail, de la discipline, et de l'environnement de travail quotidien de l'individu. Elle régit son sens du service aux autres, son utilité sociale, ses relations avec ses collègues proches (ou subordonnés), ses rapports avec ses animaux domestiques. Cette maison incarne l'apprentissage par le travail et l'endurance, le perfectionnisme de l'individu. Il s'agit également de la maison de son hygiène de vie, portant le lien entre son corps et son esprit (somatisation). En quelques mots, il s'agit de la maison ou : Je fonctionne au quotidien, je sers les autres.\" },\n  { n:7,  titre:\"Maison 7 — Les Relations\", domaines:\"Partenaire · Associés · Contrats\", desc:\"Il s'agit de la maison du mariage, des partenariats d'affaires, des relations contractuelles (contrat de travail, d'assurance etc..). Elle régit les ennemis déclarés de l'individu, uniquement dans le cadre de conflits ordinaires d'égal à égal, impliquant de la négociation (les conflits psychologiques lourds\\\", les guerres \\\"d'usure\\\" et de pouvoir, étant gérés en maison 8). Cette maison incarne l'Altérité de l'individu, son public / audience, et comment il se définit à travers le regard des autres (en miroir de la maison 1, régissant son \\\"identité projetée\\\" au monde). Cette maison représente aussi le type de partenaire que l'individu attire, ou qu'il admire. En quelques mots, il s'agit de la maison ou : Nous sommes.\" },\n  { n:8,  titre:\"Maison 8 — Les Transformations\", domaines:\"Crises · Sexualité · Héritages\", desc:\"Il s'agit de la maison qui gère la sexualité, la mort (au sens symbolique de la \\\"renaissance du phoenix\\\"), les guerres d'usure, ainsi que les aspects transgressifs de l'individu. Elle porte son environnement occulte : ce qui lui est tabou, caché, refoulé, mais qui peut devenir conscient (par sa volonté). Il possède ainsi la clé de cet univers, mais peut avoir \\\"peur d'ouvrir la porte\\\". Cette maison régit également l'argent des autres (héritages, investissements, finances du conjoint, prêts bancaires, aides sociales) en lien avec l'individu. Elle régit les métamorphoses radicales de sa vie, ses crises de croissance nécessaires (douloureuses, parfois exténuantes sur le plan psychologique), mais qui lui permettent de se reconstruire en profondeur, de renaître plus fort. En quelques mots, il s'agit de la maison du : Nous, dans l'intensité profonde de la confrontation à l'autre, et face aux abysses de la vie.\" },\n  { n:9,  titre:\"Maison 9 — L'Esprit\", domaines:\"Voyages · Philosophie · Quête de sens\", desc:\"Il s'agit de la maison de la quête de sens, des grands voyages transformants pour l'individu (par opposition aux petits voyages, gérés en maison 3). Elle régit sa spiritualité, sa philosophie de vie, son appétence pour les études supérieures, sa soif d'acquisition de savoirs profonds. Elle incarne son ouverture d'esprit, sa volonté d'expansion intellectuelle, sa confrontation à l'étranger (dans le cas d'une expatriation, par exemple). Cette maison gère aussi la loi (prise de hauteur sur les conflits, verdicts) et l'administration officielle (procédures et dossiers). Elle est l'essence même de la morale et de l'éthique de l'individu (par opposition à la maison 8, qui incarne sa transgression). En quelques mots, il s'agit de la maison ou : Je comprends le sens du monde.\" },\n  { n:10, titre:\"Maison 10 — La Réussite\", domaines:\"Carrière · Vocation · Statut\", desc:\"C'est la maison qu