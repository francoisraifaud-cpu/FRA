ding:8px 4px;font-size:0.9rem}\n        @media print{\n            body{padding:0;background:white}\n            .report-container{box-shadow:none;padding:20px}\n            .main-header { padding: 35px 25px; margin-bottom: 30px; }\n            .main-header h1 { font-size: 28px; }\n            .house-block { page-break-after: always; break-after: page; }\n            .house-block:last-child { page-break-after: auto; break-after: auto; }\n            @page { margin-bottom: 20mm; @bottom-center { content: counter(page) \" / \" counter(pages); font-size: 9pt; color: #888; } }\n        }\n        /* C1 Figures natales */\n        .fn-title{color:#1F3864}.fn-title::after{background:#e8f0fe}\n        .fn-group{background:#f0f4ff;border:1px solid #d0daf0;border-radius:8px;padding:12px 15px;margin:6px 0}\n        .fn-header{font-weight:700;color:#1F3864;margin-bottom:8px;font-size:0.92rem}\n        .fn-link{display:flex;align-items:center;gap:6px;padding:4px 0;font-size:0.88rem;color:#374151}\n        .fn-asp{font-size:0.72rem;font-weight:800;text-transform:uppercase;padding:1px 7px;border-radius:4px;border:1px solid currentColor}\n        .fn-meta{color:#94a3b8;font-size:0.78rem}.fn-dig{font-size:0.72rem;font-weight:700;padding:1px 7px;border-radius:8px;border:1px solid currentColor}\n        .dig-fort{color:#15803d;background:#f0fdf4;border-color:#6ee7b7}.dig-faible{color:#b91c1c;background:#fff1f2;border-color:#fca5a5}.dig-chute{color:#7f1d1d;background:#fef2f2;border-color:#f87171}.dig-neutre{color:#94a3b8}\n        /* C2 Axe maîtrises */\n        .axe-title{color:#1e40af;font-size:0.73rem}.axe-title::after{background:#bfdbfe}\n        .axe-chain{display:flex;align-items:center;flex-wrap:wrap;gap:6px;padding:10px 15px;background:#eff6ff;border-radius:8px;border:1px solid #bfdbfe;margin:6px 0}\n        .axe-label{font-weight:700;color:#1e3a8a;font-size:0.82rem}.axe-arrow{color:#93c5fd;font-weight:900}\n        .axe-node{display:flex;align-items:center;gap:4px;background:white;padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;font-size:0.85rem}\n        .axe-planet{font-weight:700;color:#1e3a8a}.axe-retro{color:#2E5FA3;font-weight:900;font-size:0.9rem}.axe-pos{color:#64748b;font-size:0.78rem}\n        .axe-dig{font-size:0.72rem;font-weight:800;padding:1px 8px;border-radius:8px;border:1px solid currentColor}\n        .axe-warnings{padding:8px 15px}.axe-warn{font-size:0.83rem;color:#2E5FA3;margin:3px 0}\n        /* C3 Dignités */\n        .dig-title{color:#b91c1c}.dig-title::after{background:#fee2e2}\n        .dig-item{}.dig-badge{padding:2px 10px;border-radius:6px;font-size:0.78rem;font-weight:800;border:1px solid currentColor;white-space:nowrap}\n        /* C4 Réceptions */\n        .recep-title{color:#2E5FA3}.recep-title::after{background:#eef2fb}\n        .recep-item{}.recep-badge{padding:2px 10px;border-radius:6px;font-size:0.78rem;font-weight:800;border:1px solid currentColor;white-space:nowrap}\n        /* C5 Translations */\n        .tl-title{color:#0891b2}.tl-title::after{background:#cffafe}\n        .tl-item{background:#f0fdfe}.tl-badge{padding:2px 10px;border-radius:6px;font-size:0.72rem;font-weight:800;background:#cffafe;color:#0891b2;border:1px solid #67e8f9;white-space:nowrap}\n        .tl-badge2{color:#67e8f9;border-color:#67e8f9}.recep-badge2{color:#fcd34d;border-color:#fcd34d}\n        /* C7 Degrés critiques */\n        .dc-title{color:#2E5FA3}.dc-title::after{background:#eef2fb}\n        .dc-item{background:#f0f4ff}.dc-badge{padding:2px 9px;border-radius:6px;font-size:0.72rem;font-weight:800;background:#eef2fb;color:#2E5FA3;border:1px solid #a3bfdb;white-space:nowrap;margin-right:6px}\n        .dc-badge2{color:#a3bfdb;border-color:#a3bfdb}\n        /* C8 Profections */\n        .prof-block{display:flex;align-items:flex-start;gap:10px;padding:12px 16px;border-radius:10px;border-left:5px solid;margin:8px 0}\n        .prof-icon{font-size:1.4rem;line-height:1}.prof-text{font-size:0.9rem;color:#1e293b;line-height:1.5}\n        .prof-badge2{color:#2dd4bf;border-color:#2dd4bf}\n        /* C10 Antiscia */\n        .ant-title{color:#1F3864}.ant-title::after{background:#e8f0fe}\n        .ant-item{background:#f0f4ff}.ant-badge{padding:2px 9px;border-radius:6px;font-size:0.72rem;font-weight:800;background:#e8f0fe;color:#1F3864;border:1px solid #a3bfdb;white-space:nowrap;margin-right:6px}\n        .ant-badge2{color:#a3bfdb;border-color:#a3bfdb}\n        /* C9 Ingress */\n        .ing-title{color:#2E5FA3}.ing-title::after{background:#dbeafe}\n        .ing-item{background:#eef2fb}.ing-badge{padding:2px 9px;border-radius:6px;font-size:0.72rem;font-weight:800;background:#dbeafe;color:#2E5FA3;border:1px solid #a3bfdb;white-space:nowrap;margin-right:6px}\n        .ing-badge2{color:#a3bfdb;border-color:#a3bfdb}\n        /* C11 Cycles de vie */\n        .cyc-title{color:#2E5FA3;font-size:0.76rem}.cyc-title::after{background:#dbeafe}\n        .cyc-block{display:flex;align-items:flex-start;gap:10px;padding:10px 16px;border-radius:10px;border-left:5px solid #2E5FA3;background:#eef2fb;margin:6px 0}\n        .cyc-icon{font-size:1.5rem;color:#2E5FA3;line-height:1}.cyc-text{font-size:0.88rem;color:#1e293b;font-weight:600;line-height:1.5}\n        .cyc-badge2{color:#a3bfdb;border-color:#a3bfdb}\n    </style>\n</head>\n<body>\n<div class=\"report-container\">\n    <div class=\"main-header\">\n        <h1>${L.titre} —<br>${prenomNom}</h1>\n        <p class=\"subtitle\">${_lumHeaderDP}</p>\n        <p class=\"details\">${labelType.toUpperCase()} &middot; ${dateEntreeStr} ➔ ${dateSortieStr}</p>\n    </div>\n    ${(() => {\n        const helioLines = [];\n        if (helioConditions) {\n            Object.entries(helioConditions).forEach(([name, v]) => {\n                if (v.condition) {\n                    const orient = v.orientation ? ` · ${v.orientation}` : '';\n                    const isCazimi = v.condition.includes('CAZIMI');\n                    const isCombuste = v.condition.includes('COMBUSTE');\n                    const color = isCazimi ? '#1F3864' : isCombuste ? '#dc2626' : '#6b7280';\n                    const icon = isCazimi ? '☀️' : isCombuste ? '🔥' : '🌤️';\n                    helioLines.push(`<div style=\"display:flex;align-items:center;gap:8px;padding:4px 0\"><span>${icon}</span><span style=\"font-weight:700\">${glyphs[name]||''} ${name}</span> <span style=\"color:${color};font-size:0.9em\">${v.condition}${orient}</span></div>`);\n                }\n            });\n        }\n        if (helioLines.length === 0 && !chartRulerTrad) return '';\n        let html = '<div style=\"background:#eef2fb;border:1px solid #2E5FA3;border-radius:10px;padding:14px 18px;margin:0 0 20px\">';\n        if (chartRulerTrad) {\n            html += `<div style=\"font-weight:700;color:#1F3864;margin-bottom:8px;font-size:1em\">👑 ${L.coMaitre} <strong>${chartRulerTrad}</strong></div>`;\n        }\n        if (helioLines.length > 0) {\n            html += `<div style=\"font-weight:700;color:#1F3864;margin-bottom:6px;font-size:0.95em\">☀ ${L.condHelio}</div>`;\n            html += helioLines.join('');\n        }\n        html += '</div>';\n        return html;\n    })()}\n    ${eclipseNatalH ? `<div style=\"background:linear-gradient(135deg,#fff0e6,#fff8f5);border:2px solid #7c2d12;border-radius:10px;padding:14px 18px;margin:0 0 20px;\"><div style=\"color:#7c2d12;font-weight:700;font-size:1.05em;margin-bottom:6px\">⚡ ${L.neeSousEcl}</div><div>${L.eclipse} <strong>${eclipseNatalH.type}</strong> ${L.de} <strong>${eclipseNatalH.astre}</strong> ${L.en} <strong>${eclipseNatalH.sign}</strong> — ${L.maison} <strong>${eclipseNatalH.house}</strong> (${((eclipseNatalH.degree??0)%30).toFixed(1)}°). ${L.eclNatDesc}${eclipseNatalH.house} ${L.eclNatDesc2}</div></div>` : \"\"}\n    ${(etoileMatchesNatH.length || etoileCuspNatH.length) ? `<div style=\"background:#fff8e1;border:1px solid #ffb300;border-radius:8px;padding:10px 16px;margin:0 0 16px;color:#5d4037\">★ ${L.themeStellair} ${[...new Set([...etoileMatchesNatH.map(e=>e.etoile),...etoileCuspNatH.map(e=>e.etoile)])].join(' · ')} ${L.voirSection}</div>` : \"\"}\n    ${\"\" /* Parans Brady — SUPPRIMÉ du rapport Prévisions (déjà présent dans le DHN) */}\n    ${_primaryDirections && _primaryDirections.length > 0 ? (() => {\n        const aspGlyph = {\"Conjonction\":\"☌\",\"Opposition\":\"☍\",\"Carré\":\"□\",\"Trigone\":\"△\",\"Sextile\":\"⚹\"};\n        const dpRows = _primaryDirections.map((dp, i) => {\n            const bg = i % 2 === 0 ? '#faf5ff' : '#ffffff';\n            const orbCol = dp.orbYears <= 0.3 ? '#991b1b' : dp.orbYears <= 0.7 ? '#b45309' : '#4b5563';\n            const orbBold = dp.orbYears <= 0.5 ? 'font-weight:700' : '';\n            return `<tr style=\"background:${bg}\"><td style=\"padding:7px 12px;font-weight:600\">${glyphs[dp.promissor]||''}  ${dp.promissor}</td><td style=\"padding:7px 12px;text-align:center;font-size:1.1em\">${aspGlyph[dp.aspect]||dp.aspect}</td><td style=\"padding:7px 12px;font-weight:600\">${glyphs[dp.significator]||''} ${dp.significator}</td><td style=\"padding:7px 12px;text-align:center;font-size:0.85em;color:#6b7280\">${dp.direction}</td><td style=\"padding:7px 12px;text-align:center\">${dp.exactAge.toFixed(1)} ans</td><td style=\"padding:7px 12px;text-align:center;color:${orbCol};${orbBold}\">${dp.orbYears.toFixed(2)} an${dp.orbYears >= 2 ? 's' : ''}</td><td style=\"padding:7px 12px;text-align:center;font-size:0.85em\">M${dp.promHouse||'?'} → M${dp.sigHouse||'?'}</td></tr>`;\n        }).join('');\n        return `<div class=\"house-block\" style=\"page-break-before:always;margin-bottom:30px\">\n            <div class=\"house-banner\" style=\"background:linear-gradient(135deg,#4a1d96,#7c3aed)\">\n                <div class=\"house-title\" style=\"color:white\">🔱 ${L.dirPrimaires}</div>\n                <div class=\"house-meta\"><span class=\"type-badge\" style=\"background:#fbbf24;color:#1a1a2e;font-weight:700\">${_primaryDirections.length} ${_primaryDirections.length>1?L.dirsActives:L.dirActive}</span><span class=\"type-badge\" style=\"background:rgba(255,255,255,0.2);color:white;margin-left:6px\">${L.methodeDP}</span></div>\n            </div>\n            <div class=\"house-content\">\n                <div style=\"background:#faf5ff;border:2px solid #7c3aed;border-radius:8px;padding:12px 16px;margin-bottom:14px;color:#4a1d96;font-size:0.9em\">\n                    ${L.dpWarning}\n                </div>\n                <table style=\"width:100%;border-collapse:collapse;font-size:0.9rem\">\n                    <tr style=\"background:linear-gradient(135deg,#4a1d96,#7c3aed);color:white\"><th style=\"padding:8px 12px;text-align:left\">${L.promisseur}</th><th style=\"padding:8px 12px;text-align:center\">${L.aspect}</th><th style=\"padding:8px 12px;text-align:left\">${L.significateur}</th><th style=\"padding:8px 12px;text-align:center\">${L.type}</th><th style=\"padding:8px 12px;text-align:center\">${L.ageExact}</th><th style=\"padding:8px 12px;text-align:center\">${L.orbe}</th><th style=\"padding:8px 12px;text-align:center\">${L.maisons_pl}</th></tr>\n                    ${dpRows}\n                </table>\n                ${firdariaActive ? `<div style=\"margin-top:16px;padding:12px 16px;background:#faf5ff;border:1px solid #c4b5fd;border-radius:8px;font-size:0.88rem;line-height:1.55;color:#5b21b6;text-align:left;hyphens:none\">${L.dpFirdBridge}</div>` : ''}\n            </div>\n        </div>`;\n    })() : ''}\n    ${_solarArcRows.length > 0 ? (() => {\n        const aspGlyphSA = {\"Conjonction\":\"☌\",\"Opposition\":\"☍\",\"Carré\":\"□\",\"Trigone\":\"△\",\"Sextile\":\"⚹\",\"Quinconce\":\"⚻\"};\n        const escSA = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n        const saRows = _solarArcRows.map((row, i) => {\n            if (row.fallback) {\n                return `<tr style=\"background:${i % 2 ? '#ffffff' : '#fff7ed'}\"><td colspan=\"6\" style=\"padding:8px 12px;font-size:0.85rem\">${escSA(row.fallback)}</td></tr>`;\n            }\n            const bg = i % 2 === 0 ? '#fff7ed' : '#ffffff';\n            const orbDisp = (isEN ? row.orbRaw : String(row.orbRaw).replace('.', ',')) + '°';\n            const gDir = glyphs[row.directed] || '';\n            const gTgt = glyphs[row.target] || '';\n            const noteCell = row.note ? escSA(row.note) : '—';\n            return `<tr style=\"background:${bg}\"><td style=\"padding:7px 10px;font-weight:600\">${gDir} ${escSA(row.directed)}<div style=\"font-size:0.72rem;color:#9a3412;font-weight:500\">${escSA(row.dirSign)} · M${row.dirHouse}</div></td><td style=\"padding:7px 10px;text-align:center;font-size:1.05em\">${aspGlyphSA[row.aspect] || row.aspect}</td><td style=\"padding:7px 10px;font-weight:600\">${gTgt} ${escSA(row.target)}</td><td style=\"padding:7px 10px;text-align:center;font-weight:600\">M${row.targetHouse}</td><td style=\"padding:7px 10px;text-align:center;font-weight:600\">${orbDisp}</td><td style=\"padding:7px 10px;font-size:0.82rem;color:#57534e\">${noteCell}</td></tr>`;\n        }).join('');\n        return `<div class=\"house-block\" style=\"page-break-before:always;break-before:page;margin-bottom:30px\">\n            <div class=\"house-banner\" style=\"background:linear-gradient(135deg,#9a3412,#ea580c)\">\n                <div class=\"house-title\" style=\"color:white\">☀ ${L.solarArcTitle}</div>\n                <div class=\"house-meta\"><span class=\"type-badge\" style=\"background:#ffedd5;color:#9a3412;font-weight:700\">${_solarArcRows.length} ${L.solarArcCountLbl}</span><span class=\"type-badge\" style=\"background:rgba(255,255,255,0.22);color:white;margin-left:6px\">${L.solarArcBadge}</span></div>\n            </div>\n            <div class=\"house-content\">\n                <div style=\"background:#fff7ed;border:1px solid #fdba74;border-radius:8px;padding:10px 14px;margin-bottom:12px;color:#7c2d12;font-size:0.88rem;line-height:1.5\">${L.saIntro}</div>\n                <table style=\"width:100%;border-collapse:collapse;font-size:0.88rem\">\n                    <tr style=\"background:linear-gradient(135deg,#9a3412,#ea580c);color:white\"><th style=\"padding:8px 10px;text-align:left\">${L.saDirected}</th><th style=\"padding:8px 10px;text-align:center\">${L.aspect}</th><th style=\"padding:8px 10px;text-align:left\">${L.saTarget}</th><th style=\"padding:8px 10px;text-align:center\">${L.saHouseTgt}</th><th style=\"padding:8px 10px;text-align:center\">${L.saOrb}</th><th style=\"padding:8px 10px;text-align:left\">${L.saNote}</th></tr>\n                    ${saRows}\n                </table>\n            </div>\n        </div>`;\n    })() : ''}\n    ${firdariaActive ? `<div class=\"house-block\" style=\"${((_primaryDirections && _primaryDirections.length > 0) || _solarArcRows.length > 0) ? 'page-break-before:always;break-before:page;' : ''}margin-bottom:30px\">\n        <div class=\"house-banner\" style=\"background:${tc.bg}\">\n            <div class=\"house-title\">⏳ ${L.firdariaTitle}</div>\n            <div class=\"house-meta\"><span class=\"type-badge\" style=\"background:${tc.badge};color:${tc.badgeTxt}\">${L.periodeMaj} ${firdariaActive.major}</span></div>\n        </div>\n        <div class=\"house-content\">\n            <div class=\"timeline-item\" style=\"border-left-color:#2E5FA3;background:#eef2fb\">\n                <div class=\"event-text\" style=\"font-size:0.95rem\">\n                    <strong>${L.chronoMaj}</strong> ${firdariaActive.major} (${L.age} ${firdariaActive.startAge}–${firdariaActive.endAge})<br>\n                    <strong>${L.sousPeriode}</strong> ${firdariaActive.sub}<br>\n                    <span style=\"color:#64748b;font-size:0.9em;margin-top:6px;display:block\">${L.firdariaDesc} <strong>${firdariaActive.major}</strong> ${isEN?'and':'et'} <strong>${firdariaActive.sub}</strong> ${L.firdariaDesc2}</span>\n                </div>\n            </div>\n        </div>\n    </div>` : ''}\n    ${progressionsRaw ? (() => {\n        const progAge = typeof progressionsRaw.age === 'number' ? progressionsRaw.age.toFixed(0) : '?';\n        const progPlanetsHTML = Object.entries(progressionsRaw.planetes || {}).map(([pName, pd], i) => {\n            const bg = i % 2 === 0 ? '#fafafa' : '#ffffff';\n            return `<tr style=\"background:${bg}\"><td style=\"padding:7px 14px;font-weight:700\">${glyphs[pName]||''} ${pName}</td><td style=\"padding:7px 14px\">${pd.deg||'?'}</td><td style=\"padding:7px 14px;text-align:center\">${signGlyphs[pd.sign]||''} ${pd.sign||'?'}</td><td style=\"padding:7px 14px;text-align:center\">M${pd.house||'?'}</td><td style=\"padding:7px 14px;text-align:center\">${pd.retro ? '℞' : '—'}</td></tr>`;\n        }).join('');\n        const _progAspNoSA = (progressionsRaw.aspects || []).filter(a => typeof a !== 'string' || a.indexOf('ARC SOLAIRE') === -1);\n        const progAspectsHTML = _progAspNoSA.length > 0\n            ? `<div class=\"section-title\" style=\"color:#2E5FA3;margin-top:18px;page-break-before:always\">🔮 ${L.aspEvtProg}</div>` +\n              _progAspNoSA.map(a => { const txt = typeof a === 'string' ? a : `${a.pProg || '?'} en ${a.aspect || '?'} à ${a.pNat || '?'} natal (M${a.maisonNat || '?'}) — orbe ${a.exactitude || '?'}°`; return `<div class=\"timeline-item\" style=\"border-left-color:#2E5FA3;background:#eef2fb\"><div class=\"event-text\" style=\"font-size:0.9rem\">${txt}</div></div>`; }).join('')\n            : '';\n        return `<div class=\"house-block\" style=\"margin-bottom:45px\">\n            <div class=\"house-banner\" style=\"background:${tc.bg}\">\n                <div class=\"house-title\">🔮 ${L.progSec}</div>\n                <div class=\"house-meta\"><span class=\"type-badge\" style=\"background:${tc.badge};color:${tc.badgeTxt}\">${L.age} ~${progAge} ${L.ans}</span></div>\n            </div>\n            <div class=\"house-content\">\n                <table style=\"width:100%;border-collapse:collapse;font-size:0.9