 ageMidF % totalCycF; if (ageInCycF < 0) ageInCycF += totalCycF;\n        let cumulF = 0;\n        for (const f of seqF) {\n            if (ageInCycF < cumulF + f.y) {\n                const aip = ageInCycF - cumulF;\n                const isNodeF = f.p === \"Nœud Nord\" || f.p === \"Nœud Sud\";\n                const subCountF = isNodeF ? Math.min(f.y, 3) : 7;\n                const subIdx = Math.min(Math.floor(aip / (f.y / subCountF)), subCountF - 1);\n                let subP;\n                if (isNodeF) { subP = f.p; }\n                else { const mIdx = _CHALD_ORD.indexOf(f.p); subP = mIdx >= 0 ? _CHALD_ORD[(mIdx + subIdx) % 7] : f.p; }\n                _firdFwd = {\n                    major: f.p, sub: subP,\n                    startAge: Math.floor(cumulF), endAge: Math.floor(cumulF + f.y),\n                    label: `Firdaria majeure de ${f.p} (âge ${Math.floor(cumulF)}–${Math.floor(cumulF + f.y)}), sous-période de ${subP}.`\n                };\n                break;\n            }\n            cumulF += f.y;\n        }\n\n        // — Révolution Solaire —\n        const sunNatDegF = natalPlanets.find(p => (p.planet?.fr || p.planet?.en || \"\") === \"Soleil\")?.fullDegree;\n        if (sunNatDegF !== undefined && days.length > 1) {\n            const getOrbF = (a, b) => { let d = Math.abs(a - b); return d > 180 ? 360 - d : d; };\n            let srDayF = null, srMinF = 999;\n            for (const day of days) {\n                if (!day?.planetes?.[\"Soleil\"]?.fullDegree) continue;\n                const dist = getOrbF(day.planetes[\"Soleil\"].fullDegree, sunNatDegF);\n                if (dist < srMinF) { srMinF = dist; srDayF = day; }\n            }\n            // D13 ISO: pas de seuil srMinF (ISO N8N Prev — on prend le jour le plus proche sans condition)\n            if (srDayF?.planetes) {\n                const srLines = [];\n                const srPlanets = [\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\",\"Mars\",\"Vénus\"