      "parameters": {
        "jsCode": "const input = $input.first()?.json;\r\nif (!input?.planetes?.output || !input?.maisons?.output?.Houses) return [{ json: { error: \"Données manquantes\" } }];\r\n\r\n// 0. CAPTURE DES INFOS PERSOS\r\nlet perso = {};\r\ntry { perso = $(\"Extract Variables\").first()?.json || {}; } catch(e){}\r\n\r\n// ---- Sprint 5 — Paramètres forme & accessibilité (v6.4) ----\r\nconst consigneRedaction = perso.consigne_redaction || 'Tu';\r\nconst genreConsultant = perso.genre || 'M';\r\nconst langueRapport = perso.langue || 'Français';\r\n\r\n// Étoiles fixes (transmises depuis 3c. via 4. Fusion Données)\r\nconst etoilesFixesRaw = (input.etoilesFixes?.output || []);\r\n\r\n// 1. FILTRAGE ET NOMMAGE SÉCURISÉ DES NŒUDS\r\nlet rawPlanetes = input.planetes.output;\r\nlet hasTrueNode = rawPlanetes.some(p => {\r\n    let n = (p.planet.en || p.planet.fr || \"\").toLowerCase();\r\n    return n.includes(\"true\") || n.includes(\"vrai\");\r\n});\r\nlet planetes = rawPlanetes.filter(p => {\r\n    let n = (p.planet.en || p.planet.fr || \"\").toLowerCase();\r\n    if (hasTrueNode && (n.includes(\"mean\") || n.includes(\"moyen\"))) return false;\r\n    return true;\r\n});\r\nplanetes = JSON.parse(JSON.stringify(planetes));\r\n\r\nplanetes.forEach(p => {\r\n    let n = (p.planet.en || p.planet.fr || \"\").toLowerCase();\r\n    if ((n.includes(\"node\") || n.includes(\"nœud\") || n.includes(\"noeud\")) && !n.includes(\"anti\")) {\r\n        p.planet.fr = \"Nœud Nord\";\r\n        p.planet.en = \"North Node\";\r\n    }\r\n});\r\n\r\nlet maisons = JSON.parse(JSON.stringify(input.maisons.output.Houses));\r\n\r\nconst signs = [\r\n    {id:0,fr:\"Bélier\",ruler:\"Mars\"},{id:1,fr:\"Taureau\",ruler:\"Vénus\"},{id:2,fr:\"Gémeaux\",ruler:\"Mercure\"},{id:3,fr:\"Cancer\",ruler:\"Lune\"},\r\n    {id:4,fr:\"Lion\",ruler:\"Soleil\"},{id:5,fr:\"Vierge\",ruler:\"Mercure\"},{id:6,fr:\"Balance\",ruler:\"Vénus\"},{id:7,fr:\"Scorpion\",ruler:\"Pluton\"},\r\n    {id:8,fr:\"Sagittaire\",ruler:\"Jupiter\"},{id:9,fr:\"Capricorne\",ruler:\"Saturne\"},{id:10,fr:\"Verseau\",ruler:\"Uranus\"},{id:11,fr:\"Poissons\",ruler:\"Neptune\"}\r\n];\r\n\r\n// Décans Chaldéens — ordre planétaire descendant (Saturne→Jupiter→Mars→Soleil→Vénus→Mercure→Lune)\r\nconst CHALDEAN_DECANS = {\r\n    \"Bélier\":[\"Mars\",\"Soleil\",\"Vénus\"],\"Taureau\":[\"Mercure\",\"Lune\",\"Saturne\"],\r\n    \"Gémeaux\":[\"Jupiter\",\"Mars\",\"Soleil\"],\"Cancer\":[\"Vénus\",\"Mercure\",\"Lune\"],\r\n    \"Lion\":[\"Saturne\",\"Jupiter\",\"Mars\"],\"Vierge\":[\"Soleil\",\"Vénus\",\"Mercure\"],\r\n    \"Balance\":[\"Lune\",\"Saturne\",\"Jupiter\"],\"Scorpion\":[\"Mars\",\"Soleil\",\"Vénus\"],\r\n    \"Sagittaire\":[\"Mercure\",\"Lune\",\"Saturne\"],\"Capricorne\":[\"Jupiter\",\"Mars\",\"Soleil\"],\r\n    \"Verseau\":[\"Vénus\",\"Mercure\",\"Lune\"],\"Poissons\":[\"Saturne\",\"Jupiter\",\"Mars\"]\r\n};\r\n\r\n// Termes Égyptiens (Bounds) — 5 termes par signe [planète, degré_fin]\r\nconst EGYPTIAN_TERMS = {\r\n    \"Bélier\":[[\"Jupiter\",6],[\"Vénus\",12],[\"Mercure\",20],[\"Mars\",25],[\"Saturne\",30]],\r\n    \"Taureau\":[[\"Vénus\",8],[\"Mercure\",14],[\"Jupiter\",22],[\"Saturne\",27],[\"Mars\",30]],\r\n    \"Gémeaux\":[[\"Mercure\",6],[\"Jupiter\",12],[\"Vénus\",17],[\"Mars\",24],[\"Saturne\",30]],\r\n    \"Cancer\":[[\"Mars\",7],[\"Vénus\",13],[\"Mercure\",19],[\"Jupiter\",26],[\"Saturne\",30]],\r\n    \"Lion\":[[\"Jupiter\",6],[\"Vénus\",11],[\"Saturne\",18],[\"Mercure\",24],[\"Mars\",30]],\r\n    \"Vierge\":[[\"Mercure\",7],[\"Vénus\",17],[\"Jupiter\",21],[\"Mars\",28],[\"Saturne\",30]],\r\n    \"Balance\":[[\"Saturne\",6],[\"Mercure\",14],[\"Jupiter\",21],[\"Vénus\",28],[\"Mars\",30]],\r\n    \"Scorpion\":[[\"Mars\",7],[\"Vénus\",11],[\"Mercure\",19],[\"Jupiter\",24],[\"Saturne\",30]],\r\n    \"Sagittaire\":[[\"Jupiter\",12],[\"Vénus\",17],[\"Mercure\",21],[\"Saturne\",26],[\"Mars\",30]],\r\n    \"Capricorne\":[[\"Mercure\",7],[\"Jupiter\",14],[\"Vénus\",22],[\"Saturne\",26],[\"Mars\",30]],\r\n    \"Verseau\":[[\"Mercure\",7],[\"Vénus\",13],[\"Jupiter\",20],[\"Mars\",25],[\"Saturne\",30]],\r\n    \"Poissons\":[[\"Vénus\",12],[\"Jupiter\",16],[\"Mercure\",19],[\"Mars\",28],[\"Saturne\",30]]\r\n};\r\nconst getTermRuler = (sign, deg) => {\r\n    const terms = EGYPTIAN_TERMS[sign];\r\n    if (!terms) return null;\r\n    const d = deg % 30;\r\n    for (const [ruler, boundary] of terms) { if (d < boundary) return ruler; }\r\n    return terms[terms.length - 1][0];\r\n};\r\n\r\nconst planetRulerships = {\r\n    \"Soleil\":[\"Lion\"],\"Lune\":[\"Cancer\"],\"Mercure\":[\"Gémeaux\",\"Vierge\"],\"Vénus\":[\"Taureau\",\"Balance\"],\r\n    \"Mars\":[\"Bélier\",\"Scorpion\"],\"Jupiter\":[\"Sagittaire\",\"Poissons\"],\"Saturne\":[\"Capricorne\",\"Verseau\"],\r\n    \"Uranus\":[\"Verseau\"],\"Neptune\":[\"Poissons\"],\"Pluton\":[\"Scorpion\"]\r\n};\r\n\r\nconst dignities = {\r\n    \"Soleil\":   { dom:[\"Lion\"],                    exa:[\"Bélier\"],    exi:[\"Verseau\"],               chu:[\"Balance\"] },\r\n    \"Lune\":     { dom:[\"Cancer\"],                  exa:[\"Taureau\"],   exi:[\"Capricorne\"],             chu:[\"Scorpion\"] },\r\n    \"Mercure\":  { dom:[\"Gémeaux\",\"Vierge\"],        exa:[\"Vierge\"],    exi:[\"Sagittaire\",\"Poissons\"],  chu:[\"Poissons\"] },\r\n    \"Vénus\":    { dom:[\"Taureau\",\"Balance\"],        exa:[\"Poissons\"],  exi:[\"Scorpion\",\"Bélier\"],      chu:[\"Vierge\"] },\r\n    \"Mars\":     { dom:[\"Bélier\",\"Scorpion\"],        exa:[\"Capricorne\"],exi:[\"Balance\",\"Taureau\"],      chu:[\"Cancer\"] },\r\n    \"Jupiter\":  { dom:[\"Sagittaire\",\"Poissons\"],    exa:[\"Cancer\"],    exi:[\"Gémeaux\",\"Vierge\"],       chu:[\"Capricorne\"] },\r\n    \"Saturne\":  { dom:[\"Capricorne\",\"Verseau\"],     exa:[\"Balance\"],   exi:[\"Cancer\",\"Lion\"],          chu:[\"Bélier\"] },\r\n    \"Uranus\":   { dom:[\"Verseau\"],                  exa:[\"Scorpion\"],  exi:[\"Lion\"],                   chu:[\"Taureau\"] },\r\n    \"Neptune\":  { dom:[\"Poissons\"],                 exa:[\"Cancer\"],    exi:[\"Vierge\"],                 chu:[\"Capricorne\"] },\r\n    \"Pluton\":   { dom:[\"Scorpion\"],                 exa:[\"Lion\"],      exi:[\"Taureau\"],                chu:[\"Verseau\"] }\r\n};\r\n\r\nconst getDignity = (planet, sign) => {\r\n    if (![\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"].includes(planet)) return \"-\";\r\n    let d = dignities[planet]; if (!d) return \"-\";\r\n    if (d.dom.includes(sign)) return \"Domicile\";\r\n    if (d.exa.includes(sign)) return \"Exaltation\";\r\n    if (d.exi.includes(sign)) return \"Exil\";\r\n    if (d.chu.includes(sign)) return \"Chute\";\r\n    return \"Pérégrine\";\r\n};\r\n\r\nconst elements = {\r\n    \"Feu\":   [\"Bélier\",\"Lion\",\"Sagittaire\"],\r\n    \"Terre\": [\"Taureau\",\"Vierge\",\"Capricorne\"],\r\n    \"Air\":   [\"Gémeaux\",\"Balance\",\"Verseau\"],\r\n    \"Eau\":   [\"Cancer\",\"Scorpion\",\"Poissons\"]\r\n};\r\nconst modes = {\r\n    \"Cardinal\": [\"Bélier\",\"Cancer\",\"Balance\",\"Capricorne\"],\r\n    \"Fixe\":     [\"Taureau\",\"Lion\",\"Scorpion\",\"Verseau\"],\r\n    \"Mutable\":  [\"Gémeaux\",\"Vierge\",\"Sagittaire\",\"Poissons\"]\r\n};\r\n\r\n// 2. STATS ÉLÉMENTS & MODES\r\nlet stats = { elements: { Feu:0, Terre:0, Air:0, Eau:0 }, modes: { Cardinal:0, Fixe:0, Mutable:0 } };\r\nlet mainPoints = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Ascendant\",\"Milieu du Ciel\"];\r\nplanetes.forEach(p => {\r\n    p.retroStr = p.isRetro?.toLowerCase().includes('true') ? \" [Rétrograde]\" : \"\";\r\n    let name = p.planet.fr || p.planet.en;\r\n    if (mainPoints.includes(name)) {\r\n        let sign = p.zodiac_sign?.name?.fr;\r\n        if (sign) {\r\n            let el = Object.keys(elements).find(e => elements[e].includes(sign)); if(el) stats.elements[el]++;\r\n            let mo = Object.keys(modes).find(m => modes[m].includes(sign)); if(mo) stats.modes[mo]++;\r\n        }\r\n    }\r\n});\r\n\r\n// 3. MAISONS UTILS\r\nmaisons.sort((a,b) => a.House - b.House);\r\nfunction getHouseNumber(deg) {\r\n    deg = ((deg % 360) + 360) % 360;\r\n    for(let i=0; i<12; i++){\r\n        let h1=maisons[i].degree, h2=maisons[(i+1)%12].degree;\r\n        if((h1<h2 && deg>=h1 && deg<h2) || (h1>=h2 && (deg>=h1 || deg<h2))) return maisons[i].House;\r\n    }\r\n    return 1;\r\n}\r\n\r\nfunction angularDiff(a, b) {\r\n    let d = Math.abs(a - b);\r\n    return d > 180 ? 360 - d : d;\r\n}\r\n\r\n// 4. SECTE, NŒUD SUD, PART DE FORTUNE ET LOT DE L'ESPRIT\r\nlet asc  = planetes.find(p => p.planet.fr === \"Ascendant\");\r\nlet sun  = planetes.find(p => p.planet.fr === \"Soleil\");\r\nlet moon = planetes.find(p => p.planet.fr === \"Lune\");\r\n\r\nlet sunHouse  = sun ? getHouseNumber(sun.fullDegree) : 1;\r\n// Calcul géométrique de la secte (plus précis que par numéro de maison)\r\n// arc = ((sunDeg - ascDeg) + 360) % 360\r\n//   arc < 180° → Soleil entre ASC et DSC (Maisons 1–6) = SOUS l'horizon → Nocturne\r\n//   arc > 180° → Soleil entre DSC et ASC (Maisons 7–12) = AU-DESSUS de l'horizon → Diurne\r\nlet isDayChart;\r\nif (asc && sun) {\r\n    const arcSoleilDepuisAsc = ((sun.fullDegree - asc.fullDegree) + 360) % 360;\r\n    isDayChart = arcSoleilDepuisAsc > 180;\r\n} else {\r\n    isDayChart = [7,8,9,10,11,12].includes(Number(sunHouse)); // fallback par maison\r\n}\r\nlet sectStr = isDayChart ? \"Diurne (Soleil au-dessus de l'horizon)\" : \"Nocturne (Soleil sous l'horizon)\";\r\nstats.sect = sectStr;\r\nstats.sectLight   = isDayChart ? \"Soleil\" : \"Lune\";\r\nstats.sectBenefic = isDayChart ? \"Jupiter\" : \"Vénus\";\r\nstats.sectMalefic = isDayChart ? \"Saturne\" : \"Mars\";\r\nstats.contraSectMalefic = isDayChart ? \"Mars\" : \"Saturne\";\r\n\r\n// Triplicité — seigneurs diurne/nocturne (Ptolémée/Dorothée), utilisé par locataires + Almutem\r\nconst TRIPLIC_DAY_EARLY = {\r\n    \"Bélier\":\"Soleil\",\"Lion\":\"Soleil\",\"Sagittaire\":\"Soleil\",\r\n    \"Taureau\":\"Vénus\",\"Vierge\":\"Vénus\",\"Capricorne\":\"Vénus\",\r\n    \"Gémeaux\":\"Saturne\",\"Balance\":\"Saturne\",\"Verseau\":\"Saturne\",\r\n    \"Cancer\":\"Vénus\",\"Scorpion\":\"Vénus\",\"Poissons\":\"Vénus\"\r\n};\r\nconst TRIPLIC_NIGHT_EARLY = {\r\n    \"Bélier\":\"Jupiter\",\"Lion\":\"Jupiter\",\"Sagittaire\":\"Jupiter\",\r\n    \"Taureau\":\"Lune\",\"Vierge\":\"Lune\",\"Capricorne\":\"Lune\",\r\n    \"Gémeaux\":\"Mercure\",\"Balance\":\"Mercure\",\"Verseau\":\"Mercure\",\r\n    \"Cancer\":\"Mars\",\"Scorpion\":\"Mars\",\"Poissons\":\"Mars\"\r\n};\r\nconst TRIPLIC_PART_EARLY = {\r\n    \"Bélier\":\"Saturne\",\"Lion\":\"Saturne\",\"Sagittaire\":\"Saturne\",\r\n    \"Taureau\":\"Mars\",\"Vierge\":\"Mars\",\"Capricorne\":\"Mars\",\r\n    \"Gémeaux\":\"Jupiter\",\"Balance\":\"Jupiter\",\"Verseau\":\"Jupiter\",\r\n    \"Cancer\":\"Lune\",\"Scorpion\":\"Lune\",\"Poissons\":\"Lune\"\r\n};\r\nconst getTriplicityRuler = (sign) => isDayChart ? (TRIPLIC_DAY_EARLY[sign] || null) : (TRIPLIC_NIGHT_EARLY[sign] || null);\r\nconst getTriplicityParticipant = (sign) => TRIPLIC_PART_EARLY[sign] || null;\r\n\r\nif (asc && sun && moon) {\r\n    // Part de Fortune : diurne = ASC + Lune - Soleil ; nocturne = inverse\r\n    let pofDeg = isDayChart\r\n        ? (asc.fullDegree + moon.fullDegree - sun.fullDegree)\r\n        : (asc.fullDegree + sun.fullDegree  - moon.fullDegree);\r\n    pofDeg = ((pofDeg % 360) + 360) % 360;\r\n    planetes.push({ planet:{fr:\"Part de Fortune\",en:\"Part of Fortune\"}, fullDegree:pofDeg, normDegree:pofDeg%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(pofDeg/30)].fr}} });\r\n\r\n    // Lot de l'Esprit : inverse de Fortune\r\n    let posDeg = isDayChart\r\n        ? (asc.fullDegree + sun.fullDegree  - moon.fullDegree)\r\n        : (asc.fullDegree + moon.fullDegree - sun.fullDegree);\r\n    posDeg = ((posDeg % 360) + 360) % 360;\r\n    planetes.push({ planet:{fr:\"Lot de l'Esprit\",en:\"Lot of Spirit\"}, fullDegree:posDeg, normDegree:posDeg%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(posDeg/30)].fr}} });\r\n\r\n    // Sprint 7 — Action 6 : Lots hermétiques supplémentaires\r\n    const mars = planetes.find(p => p.planet.fr === \"Mars\");\r\n    const venus = planetes.find(p => p.planet.fr === \"Vénus\");\r\n    const jupiter = planetes.find(p => p.planet.fr === \"Jupiter\");\r\n    const saturn = planetes.find(p => p.planet.fr === \"Saturne\");\r\n    const mercury = planetes.find(p => p.planet.fr === \"Mercure\");\r\n\r\n    const lotCalc = (a, b, c) => (((a + b - c) % 360) + 360) % 360;\r\n    const lotCalcInverse = (a, b, c) => (((a + c - b) % 360) + 360) % 360;\r\n    const pushLot = (frName, enName, deg) => {\r\n        planetes.push({ planet:{fr:frName,en:enName}, fullDegree:deg, normDegree:deg%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(deg/30)].fr}} });\r\n    };\r\n\r\n    // Lot de Nécessité (Ananke) : diurne = ASC + Fortune - Mercure ; nocturne = inverse\r\n    if (mercury) {\r\n        const necDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, mercury.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, mercury.fullDegree);\r\n        pushLot(\"Lot de Nécessité\", \"Lot of Necessity\", necDeg);\r\n    }\r\n    // Lot d'Éros : diurne = ASC + Vénus - Esprit ; nocturne = inverse\r\n    if (venus) {\r\n        const erosDeg = isDayChart ? lotCalc(asc.fullDegree, venus.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, venus.fullDegree, posDeg);\r\n        pushLot(\"Lot d'Éros\", \"Lot of Eros\", erosDeg);\r\n    }\r\n    // Lot de Courage (Tolma) : diurne = ASC + Fortune - Mars ; nocturne = inverse\r\n    if (mars) {\r\n        const courDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, mars.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, mars.fullDegree);\r\n        pushLot(\"Lot de Courage\", \"Lot of Courage\", courDeg);\r\n    }\r\n    // Lot de Némésis : diurne = ASC + Fortune - Saturne ; nocturne = inverse\r\n    if (saturn) {\r\n        const nemDeg = isDayChart ? lotCalc(asc.fullDegree, pofDeg, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, pofDeg, saturn.fullDegree);\r\n        pushLot(\"Lot de Némésis\", \"Lot of Nemesis\", nemDeg);\r\n    }\r\n    // Lot de Basis : ASC + Fortune - Esprit (invariant sect)\r\n    const basisDeg = lotCalc(asc.fullDegree, pofDeg, posDeg);\r\n    pushLot(\"Lot de Basis\", \"Lot of Basis\", basisDeg);\r\n\r\n    // Lot d'Exaltation : ASC + (degré exalt Soleil 19°Bélier) - Soleil\r\n    const exaltSunDeg = 19; // 19° Bélier\r\n    const exaltDeg = lotCalc(asc.fullDegree, exaltSunDeg, sun.fullDegree);\r\n    pushLot(\"Lot d'Exaltation\", \"Lot of Exaltation\", exaltDeg);\r\n\r\n    // Lot du Daemon : diurne = ASC + Soleil - Esprit ; nocturne = inverse\r\n    const daemonDeg = isDayChart ? lotCalc(asc.fullDegree, sun.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, sun.fullDegree, posDeg);\r\n    pushLot(\"Lot du Daemon\", \"Lot of Daemon\", daemonDeg);\r\n\r\n    // ── C7 : Parts Arabes élargies (Vettius Valens, Paulus Alexandrinus, Firmicus Maternus) ──\r\n    // Lot de Victoire (Nikè) : diurne = ASC + Jupiter - Esprit ; nocturne = inverse\r\n    if (jupiter) {\r\n        const vicDeg = isDayChart ? lotCalc(asc.fullDegree, jupiter.fullDegree, posDeg) : lotCalcInverse(asc.fullDegree, jupiter.fullDegree, posDeg);\r\n        pushLot(\"Lot de Victoire\", \"Lot of Victory\", vicDeg);\r\n    }\r\n    // Lot du Père : diurne = ASC + Saturne - Soleil ; nocturne = inverse\r\n    if (saturn) {\r\n        const pereDeg = isDayChart ? lotCalc(asc.fullDegree, saturn.fullDegree, sun.fullDegree) : lotCalcInverse(asc.fullDegree, saturn.fullDegree, sun.fullDegree);\r\n        pushLot(\"Lot du Père\", \"Lot of Father\", pereDeg);\r\n    }\r\n    // Lot de la Mère : diurne = ASC + Lune - Vénus ; nocturne = inverse\r\n    if (venus) {\r\n        const mereDeg = isDayChart ? lotCalc(asc.fullDegree, moon.fullDegree, venus.fullDegree) : lotCalcInverse(asc.fullDegree, moon.fullDegree, venus.fullDegree);\r\n        pushLot(\"Lot de la Mère\", \"Lot of Mother\", mereDeg);\r\n    }\r\n    // Lot de Maladie (Valens) : diurne = ASC + Mars - Saturne ; nocturne = inverse\r\n    if (mars && saturn) {\r\n        const malDeg = isDayChart ? lotCalc(asc.fullDegree, mars.fullDegree, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, mars.fullDegree, saturn.fullDegree);\r\n        pushLot(\"Lot de Maladie\", \"Lot of Illness\", malDeg);\r\n    }\r\n    // Lot du Mariage : diurne = ASC + DSC - Vénus ; nocturne = inverse (formule universelle Valens)\r\n    const dsc = maisons.find(m => m.House === 7);\r\n    if (venus && dsc) {\r\n        const mariDeg = isDayChart ? lotCalc(asc.fullDegree, dsc.degree, venus.fullDegree) : lotCalcInverse(asc.fullDegree, dsc.degree, venus.fullDegree);\r\n        pushLot(\"Lot du Mariage\", \"Lot of Marriage\", mariDeg);\r\n    }\r\n    // Lot des Enfants (Valens) : diurne = ASC + Jupiter - Saturne ; nocturne = inverse\r\n    if (jupiter && saturn) {\r\n        const enfDeg = isDayChart ? lotCalc(asc.fullDegree, jupiter.fullDegree, saturn.fullDegree) : lotCalcInverse(asc.fullDegree, jupiter.fullDegree, saturn.fullDegree);\r\n        pushLot(\"Lot des Enfants\", \"Lot of Children\", enfDeg);\r\n    }\r\n    // Lot de Voyage (Firmicus) : diurne = ASC + Mars - Saturne renversé pour cette formule ≠ maladie\r\n    // → Firmicus : ASC + 9e cuspide - maître du 9e ; simplifié → ASC + Saturne - Jupiter (éloignement)\r\n    if (jupiter && saturn) {\r\n        const voyDeg = isDayChart ? lotCalc(asc.fullDegree, saturn.fullDegree, jupiter.fullDegree) : lotCalcInverse(asc.fullDegree, saturn.fullDegree, jupiter.fullDegree);\r\n        pushLot(\"Lot de Voyage\", \"Lot of Travel\", voyDeg);\r\n    }\r\n}\r\n\r\nlet nn = planetes.find(p => p.planet.fr === \"Nœud Nord\");\r\nif (nn) {\r\n    let sd = (nn.fullDegree + 180) % 360;\r\n    const sudDecl = typeof nn.declinaison === 'number' ? -nn.declinaison : undefined;\r\n    planetes.push({ planet:{fr:\"Nœud Sud\",en:\"South Node\"}, fullDegree:sd, normDegree:sd%30, retroStr:nn.retroStr, isRetro:nn.isRetro, zodiac_sign:{name:{fr:signs[Math.floor(sd/30)].fr}}, declinaison:sudDecl });\r\n}\r\n\r\n// 5. ASPECTS MAJEURS + MINEURS\r\nconst aspectTypes = [\r\n    {name:\"Conjonction\", deg:0,   orb:10, nodalOrb:8, smallOrb:8,  major:true},\r\n    {name:\"Sextile\",     deg:60,  orb:6,  nodalOrb:5, smallOrb:3,  major:true},\r\n    {name:\"Carré\",       deg:90,  orb:8,  nodalOrb:7, smallOrb:4,  major:true},\r\n    {name:\"Trigone\",     deg:120, orb:8,  nodalOrb:7, smallOrb:4,  major:true},\r\n    {name:\"Opposition\",  deg:180, orb:10, nodalOrb:8, smallOrb:6,  major:true},\r\n    {name:\"Quinconce\",   deg:150, orb:3,  nodalOrb:2, smallOrb:2,  major:false},\r\n    {name:\"Semi-Sextile\",deg:30,  orb:2,  nodalOrb:1, smallOrb:1,  major:false},\r\n    {name:\"Semi-Carré\",  deg:45,  orb:2,  nodalOrb:2, smallOrb:1,  major:false},\r\n    {name:\"Quintile\",    deg:72,  orb:2,  nodalOrb:2, smallOrb:1,  major:false},\r\n    {name:\"Biquintile\",  deg:144, orb:2,  nodalOrb:1, smallOrb:1,  major:false},\r\n    {name:\"Sesqui-Carré\",deg:135, orb:2,  nodalOrb:2, smallOrb:1,  major:false}\r\n];\r\nconst smallBodies  = [\"Chiron\",\"Vesta\",\"Cérès\",\"Ceres\",\"Pallas\",\"Junon\",\"Juno\",\"Lilith\"];\r\nconst nodalBodies  = [\"Nœud Nord\",\"Nœud Sud\",\"Part de Fortune\",\"Part of Fortune\",\"Lot de l'Esprit\",\"Lot of Spirit\",\"Lot de Nécessité\",\"Lot of Necessity\",\"Lot d'Éros\",\"Lot of Eros\",\"Lot de Courage\",\"Lot of Courage\",\"Lot de Némésis\",\"Lot of Nemesis\",\"Lot de Basis\",\"Lot of Basis\",\"Lot d'Exaltation\",\"Lot of Exaltation\",\"Lot du Daemon\",\"Lot of Daemon\"];\r\n\r\n// Facteur d'orbe planète-spécifique (Solar Fire standard)\r\nconst PLANET_ORB_FACTOR = {\r\n    \"Soleil\":1.0, \"Lune\":1.0, \"Ascendant\":1.0, \"Milieu du Ciel\":1.0,\r\n    \"Descendant\":1.0, \"Imum Coeli\":1.0,\r\n    \"Mercure\":0.75, \"Vénus\":0.75, \"Mars\":0.75,\r\n    \"Jupiter\":0.65, \"Saturne\":0.65,\r\n    \"Uranus\":0.55, \"Neptune\":0.55, \"Pluton\":0.55,\r\n    \"Chiron\":0.55, \"Nœud Nord\":0.6, \"Nœud Sud\":0.6\r\n};\r\n\r\nconst AXIS_PAIRS = [\r\n    new Set([\"Milieu du Ciel\", \"Imum Coeli\"]),\r\n    new Set([\"Ascendant\", \"Descendant\"]),\r\n    new Set([\"Nœud Nord\", \"Nœud Sud\"])\r\n];\r\nconst isAxisPair = (n1, n2) => AXIS_PAIRS.some(pair => pair.has(n1) && pair.has(n2));\r\n\r\nlet aspects = [];\r\nfor(let i=0; i<planetes.length; i++) {\r\n    for(let j=i+1; j<planetes.length; j++) {\r\n        let p1=planetes[i], p2=planetes[j];\r\n        let name1 = p1.planet.fr || p1.planet.en;\r\n        let name2 = p2.planet.fr || p2.planet.en;\r\n        if (isAxisPair(name1, name2)) continue;\r\n        let isSmall  = smallBodies.includes(name1) || smallBodies.includes(name2);\r\n        let isNodal  = nodalBodies.includes(name1) || nodalBodies.includes(name2);\r\n        let activeType = isSmall ? \"smallOrb\" : (isNodal ? \"nodalOrb\" : \"orb\");\r\n        const f1 = PLANET_ORB_FACTOR[name1] ?? 0.5;\r\n        const f2 = PLANET_ORB_FACTOR[name2] ?? 0.5;\r\n        const orbModulator = Math.max(f1, f2);\r\n        let diff = Math.abs(p1.fullDegree - p2.fullDegree);\r\n        if(diff > 180) diff = 360 - diff;\r\n        aspectTypes.forEach(a => {\r\n            let activeOrb  = a[activeType] * orbModulator;\r\n            let exactitude = Math.abs(diff - a.deg);\r\n            if(exactitude <= activeOrb) {\r\n                aspects.push({ p1:name1, p2:name2, aspect:a.name, exactitude:exactitude.toFixed(2), isMajor:a.major });\r\n            }\r\n        });\r\n    }\r\n}\r\n\r\n// Fonctions d'affichage des aspects — utilisent les scores calculés en bloc 6k\r\n// (appelées en bloc 7+ quand les aspects sont déjà enrichis, triés et flaggés isPromoted)\r\n\r\n// ── Sprint 6 — Module A : Qualificatif d'orbe calculé ──\r\nconst orbQualifier = (orb) => {\r\n    const o = typeof orb === \"string\" ? parseFloat(orb) : orb;\r\n    if (o < 1)   return \"exact\";\r\n    if (o < 3)   return \"serré\";\r\n    if (o < 5)   return \"moyen\";\r\n    return \"large\";\r\n};\r\n\r\n// ── Sprint 6 — Module B1+E2 : Natures planétaires ──\r\nconst PLANET_NATURES = {\r\n    \"Soleil\":\"luminaire\",\"Lune\":\"luminaire\",\r\n    \"Mercure\":\"neutre\",\"Vénus\":\"bénéfique\",\"Mars\":\"maléfique\",\r\n    \"Jupiter\":\"bénéfique\",\"Saturne\":\"maléfique\",\r\n    \"Uranus\":\"maléfique\",\"Neptune\":\"dissolvant\",\"Pluton\":\"maléfique\",\r\n    \"Chiron\":\"neutre\",\"Nœud Nord\":\"neutre\",\"Nœud Sud\":\"neutre\",\r\n    \"Lilith\":\"maléfique\",\"Cérès\":\"neutre\",\"Ceres\":\"neutre\",\r\n    \"Junon\":\"neutre\",\"Juno\":\"neutre\",\"Vesta\":\"neutre\",\"Pallas\":\"neutre\",\r\n    \"Ascendant\":\"neutre\",\"Milieu du Ciel\":\"neutre\",\"Descendant\":\"neutre\",\"Imum Coeli\":\"neutre\"\r\n};\r\n\r\nconst getNatureTag = (p1, p2) => {\r\n    const n1 = PLANET_NATURES[p1], n2 = PLANET_NATURES[p2];\r\n    if (!n1 || !n2 || n1 === \"neutre\" && n2 === \"neutre\") return \"\";\r\n    if (n1 === \"dissolvant\" || n2 === \"dissolvant\") {\r\n        const otherN = n1 === \"dissolvant\" ? n2 : n1;\r\n        if (otherN === \"maléfique\")  return \" [Nature: dissolution de la tension — transcendance possible mais risque de confusion]\";\r\n        if (otherN === \"bénéfique\")  return \" [Nature: sublimation — inspiration élevée mais risque d'idéalisation]\";\r\n        if (otherN === \"luminaire\")  return \" [Nature: voile sur le luminaire — intuition amplifiée mais identité potentiellement floue]\";\r\n        return \"\";\r\n    }\r\n    if (n1 === \"bénéfique\" && n2 === \"bénéfique\")  return \" [Nature: synergie bénéfique — énergies qui s'emboîtent harmonieusement]\";\r\n    if (n1 === \"maléfique\" && n2 === \"maléfique\")  return \" [Nature: friction maléfique — tension intensifiée, potentiel d'obstacle]\";\r\n    if ((n1===\"bénéfique\"&&n2===\"maléfique\")||(n1===\"maléfique\"&&n2===\"bénéfique\"))\r\n        return \" [Nature: mixte — le bénéfique tempère le maléfique, mais sous tension]\";\r\n    if (n1 === \"luminaire\" || n2 === \"luminaire\") {\r\n        const otherN = n1 === \"luminaire\" ? n2 : n1;\r\n        if (otherN === \"bénéfique\")  return \" [Nature: luminaire + bénéfique — vitalité amplifiée et soutenue]\";\r\n        if (otherN === \"maléfique\")  return \" [Nature: luminaire + maléfique — vitalité mise au défi]\";\r\n        if (otherN === \"dissolvant\") return \" [Nature: voile sur le luminaire — intuition amplifiée mais identité potentiellement floue]\";\r\n    }\r\n    return \"\";\r\n};\r\n\r\n// ── Sprint 6 — Module E1 : Appliquant / Séparant (aspects nataux) ──\r\nconst PLANET_SPEED_RANK = {\r\n    \"Lune\":1,\"Mercure\":2,\"Vénus\":3,\"Soleil\":4,\"Mars\":5,\r\n    \"Jupiter\":6,\"Saturne\":7,\"Uranus\":8,\"Neptune\":9,\"Pluton\":10,\r\n    \"Chiron\":7.5,\"Lilith\":4.5,\"Cérès\":5.5,\"Ceres\":5.5,\"Junon\":5.2,\"Juno\":5.2,\"Vesta\":5.3,\"Pallas\":5.4,\r\n    \"Nœud Nord\":7.2,\"Nœud Sud\":7.2\r\n};\r\nconst getAppSepTag = (pFaster, pSlower, aspDeg, exactitude) => {\r\n    const r1 = PLANET_SPEED_RANK[pFaster], r2 = PLANET_SPEED_RANK[pSlower];\r\n    if (!r1 || !r2) return \"\";\r\n    const fast = r1 < r2 ? pFaster : pSlower;\r\n    const slow = r1 < r2 ? pSlower : pFaster;\r\n    const pFast = planetes.find(p => p.planet.fr === fast);\r\n    const pSlow = planetes.find(p => p.planet.fr === slow);\r\n    if (!pFast || !pSlow) return \"\";\r\n    const fastRetro = pFast.isRetro === \"True\" || pFast.isRetro === true;\r\n    const diff = ((pFast.fullDegree - pSlow.fullDegree) + 360) % 360;\r\n    let approaching, separating;\r\n    if (aspDeg === 0) {\r\n        approaching = diff > 180;\r\n        separating  = diff <= 180 && diff > 0;\r\n    } else {\r\n        approaching = diff > aspDeg && diff < aspDeg + 15;\r\n        separating  = diff < aspDeg || diff > aspDeg + 345;\r\n    }\r\n    if (fastRetro) {\r\n        const tmp = approaching;\r\n        approaching = separating;\r\n        separating = tmp;\r\n    }\r\n    if (approaching) return \" [appliquant]\";\r\n    if (separating)  return \" [séparant]\";\r\n    return \"\";\r\n};\r\nconst ASP_DEG_MAP = {\"Conjonction\":0,\"Opposition\":180,\"Carré\":90,\"Trigone\":120,\"Sextile\":60,\"Quinconce\":150,\"Semi-Sextile\":30,\"Semi-Carré\":45,\"Quintile\":72,\"Biquintile\":144,\"Sesqui-Carré\":135};\r\n\r\nconst MINOR_ASPECT_MEANINGS = {\r\n    \"Quintile\":     \"harmonie créatrice, don structurel\",\r\n    \"Biquintile\":   \"harmonie créatrice avancée, talent latent\",\r\n    \"Semi-Sextile\": \"irritant mineur, ajustement progressif entre signes adjacents\",\r\n    \"Semi-Carré\":   \"friction légère, micro-tension de développement\",\r\n    \"Sesqui-Carré\": \"tension de friction constructive\",\r\n    \"Quinconce\":    \"ajustement obligatoire, tension inconsciente\"\r\n};\r\n\r\nconst getMajorAspectsStr = (pName) => {\r\n    let asps = aspects.filter(a => a.isMajor && (a.p1===pName || a.p2===pName));\r\n    if (!asps.length) return \"Aucun aspect majeur\";\r\n    return asps.map(a => {\r\n        const partner = a.p1===pName ? a.p2 : a.p1;\r\n        const prefix  = a.prioriteEmoji ? `${a.prioriteEmoji} ${a.prioriteLabel} — ` : \"\";\r\n        const oq = orbQualifier(a.exactitude);\r\n        const nt = getNatureTag(pName, partner);\r\n        const aspDeg = ASP_DEG_MAP[a.aspect] ?? 0;\r\n        const appSep = getAppSepTag(a.p1, a.p2, aspDeg, parseFloat(a.exactitude));\r\n        return `${prefix}${a.aspect} avec ${partner} (${a.exactitude}° — ${oq})${appSep}${nt}`;\r\n    }).join(\" | \");\r\n};\r\n\r\n// Aspects mineurs promus (score ≥ seuil Option B) — traités comme des aspects majeurs par le LLM\r\nconst getPromotedMinorAspectsStr = (pName) => {\r\n    let asps = aspects.filter(a => !a.isMajor && a.isPromoted && (a.p1===pName || a.p2===pName));\r\n    if (!asps.length) return null;\r\n    return asps.map(a => {\r\n        const partner  = a.p1===pName ? a.p2 : a.p1;\r\n        const meaning  = MINOR_ASPECT_MEANINGS[a.aspect] ? ` — nature : ${MINOR_ASPECT_MEANINGS[a.aspect]}` : \"\";\r\n        const oq = orbQualifier(a.exactitude);\r\n        const nt = getNatureTag(pName, partner);\r\n        const aspDeg = ASP_DEG_MAP[a.aspect] ?? 0;\r\n        const appSep = getAppSepTag(a.p1, a.p2, aspDeg, parseFloat(a.exactitude));\r\n        return `   ${a.prioriteEmoji} ${a.prioriteLabel} — ${a.aspect} avec ${partner} (${a.exactitude}° — ${oq})${appSep}${meaning}${nt}`;\r\n    }).join(\"\\n\");\r\n};\r\n\r\n// Aspects mineurs non promus (tous les autres aspects mineurs)\r\nconst getMinorAspectsStr = (pName) => {\r\n    let asps = aspects.filter(a => !a.isMajor && !a.isPromoted && (a.p1===pName || a.p2===pName))\r\n        .sort((a,b) => parseFloat(a.exactitude) - parseFloat(b.exactitude)).slice(0, 5);\r\n    if (!asps.length) return null;\r\n    return asps.map(a => {\r\n        const partner = a.p1===pName ? a.p2 : a.p1;\r\n        const prefix  = a.prioriteEmoji ? `${a.prioriteEmoji} ${a.prioriteLabel} — ` : \"\";\r\n        return `${prefix}${a.aspect} avec ${partner} (${a.exactitude}°)`;\r\n    }).join(\" | \");\r\n};\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 6. NOUVELLES TECHNIQUES\r\n// ─────────────────────────────────────────────────────────────────\r\n\r\n// 6a. CONDITIONS HÉLIOCENTRIQUES (Cazimi / Combuste / Sous les rayons / Oriental / Occidental)\r\nconst helioConditions = {};\r\nif (sun) {\r\n    const inferiorPlanets  = [\"Mercure\",\"Vénus\"];\r\n    const helioTargets     = [\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\"];\r\n    planetes.forEach(p => {\r\n        let name = p.planet.fr || p.planet.en;\r\n        if (!helioTargets.includes(name)) return;\r\n        let diff = p.fullDegree - sun.fullDegree;\r\n        while (diff >  180) diff -= 360;\r\n        while (diff < -180) diff += 360;\r\n        let absDiff = Math.abs(diff);\r\n        let condition = null;\r\n        const isLune = name === \"Lune\";\r\n        if (absDiff <= 0.283)   condition = isLune\r\n            ? \"CAZIMI LUNAIRE — Nouvelle Lune exacte au cœur du Soleil (fusion lumière/émotion, puissance exceptionnelle)\"\r\n            : \"CAZIMI — au cœur du Soleil (force exceptionnelle)\";\r\n        else if (absDiff <= 8)  condition = isLune\r\n            ? `NOUVELLE LUNE (conjonction Soleil-Lune à ${absDiff.toFixed(1)}°) — phase d'ensemencement, intériorisation émotionnelle intense, énergie tournée vers le subconscient`\r\n            : `COMBUSTE — brûlé par le Soleil à ${absDiff.toFixed(1)}° (affaibli, principe planétaire neutralisé)`;\r\n        else if (absDiff <= 15) condition = isLune\r\n            ? (diff > 0\r\n                ? `LUNE CROISSANT (${absDiff.toFixed(1)}° après le Soleil) — début de cycle, émergence émotionnelle progressive, volonté d'action instinctive`\r\n                : `LUNE BALSAMIQUE (${absDiff.toFixed(1)}° avant le Soleil) — fin de cycle, introspection profonde, lâcher-prise et sagesse distillée`)\r\n            : `SOUS LES RAYONS — à ${absDiff.toFixed(1)}° du Soleil (diminué, agit en coulisse)`;\r\n\r\n        let orientation = null;\r\n        if (inferiorPlanets.includes(name)) {\r\n            if (absDiff <= 15) {\r\n                orientation = diff < 0 ? \"Oriental — étoile du matin (se lève avant le Soleil)\" : \"Occidental — étoile du soir (se couche après le Soleil)\";\r\n            } else {\r\n                orientation = diff < 0 ? \"Oriental (élongation Ouest, étoile du matin)\" : \"Occidental (élongation Est, étoile du soir)\";\r\n            }\r\n        }\r\n        if (condition || orientation) helioConditions[name] = { condition, orientation };\r\n    });\r\n}\r\n\r\n// 6a-bis. PLANÈTES STATIONNAIRES (vitesse quotidienne quasi-nulle)\r\n// Seuils en °/jour — sous ce seuil, la planète est considérée stationnaire\r\nconst STATION_THRESHOLDS = {\r\n    \"Mercure\": 0.3, \"Vénus\": 0.15, \"Mars\": 0.08,\r\n    \"Jupiter\": 0.02, \"Saturne\": 0.01, \"Uranus\": 0.005,\r\n    \"Neptune\": 0.003, \"Pluton\": 0.002, \"Chiron\": 0.01\r\n};\r\nconst stationaryPlanets = [];\r\nObject.keys(STATION_THRESHOLDS).forEach(name => {\r\n    const p = planetes.find(x => (x.planet.fr || x.planet.en) === name);\r\n    if (!p) return;\r\n    const speed = p.vitesse_longitude ?? p.speed ?? p.daily_motion ?? null;\r\n    if (speed === null || speed === undefined) return;\r\n    const absSpeed = Math.abs(parseFloat(speed));\r\n    const threshold = STATION_THRESHOLDS[name];\r\n    if (absSpeed <= threshold) {\r\n        const isRetro = p.retroStr || (p.isRetro === \"True\" || p.isRetro === true);\r\n        const direction = isRetro ? \"Station Rétrograde (SR)\" : \"Station Directe (SD)\";\r\n        stationaryPlanets.push({\r\n            planet: name, speed: absSpeed.toFixed(4), threshold,\r\n            direction, house: getHouseNumber(p.fullDegree),\r\n            sign: p.zodiac_sign?.name?.fr\r\n        });\r\n    }\r\n});\r\n\r\n// 6b. PLANÈTES ANGULAIRES (within 5° of ASC / DSC / MC / IC)\r\nconst angleNames    = [\"Ascendant\",\"Descendant\",\"Milieu du Ciel\",\"Imum Coeli\"];\r\nconst corePlanets   = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\"];\r\nconst angularPlanets = [];\r\ncorePlanets.forEach(name => {\r\n    let p = planetes.find(x => x.planet.fr === name); if (!p) return;\r\n    angleNames.forEach(angleName => {\r\n        let angleP = planetes.find(a => a.planet.fr === angleName); if (!angleP) return;\r\n        let diff = angularDiff(p.fullDegree, angleP.fullDegree);\r\n        if (diff <= 5) angularPlanets.push({ planet:name, angle:angleName, orb:diff.toFixed(2), house:getHouseNumber(p.fullDegree), sign:p.zodiac_sign?.name?.fr });\r\n    });\r\n});\r\n\r\n// 6c. DEGRÉS CRITIQUES (29° Anarète, 0° Ingress, degrés critiques par modalité)\r\nconst criticalDegConfig = { cardinal:[0,13,26], fixed:[8,9,21,22], mutable:[4,17] };\r\nconst cardinalSigns = [\"Bélier\",\"Cancer\",\"Balance\",\"Capricorne\"];\r\nconst fixedSigns    = [\"Taureau\",\"Lion\",\"Scorpion\",\"Verseau\"];\r\nconst mutableSigns  = [\"Gémeaux\",\"Vierge\",\"Sagittaire\",\"Poissons\"];\r\nconst criticalPlanets = [];\r\ncorePlanets.forEach(name => {\r\n    let p = planetes.find(x => x.planet.fr === name); if (!p) return;\r\n    let deg  = p.normDegree;\r\n    let sign = p.zodiac_sign?.name?.fr;\r\n    let flags = [];\r\n    if (deg >= 29)    flags.push(\"29° Anarète — degré de fin de cycle, tension et urgence\");\r\n    if (deg < 1)      flags.push(\"0° Ingress — énergie brute non encore filtrée, commencement absolu\");\r\n    if (cardinalSigns.includes(sign)) criticalDegConfig.cardinal.forEach(cd => { if (Math.abs(deg-cd) < 1) flags.push(`Degré critique cardinal ${cd}° (crise et tournant)`); });\r\n    if (fixedSigns.includes(sign))    criticalDegConfig.fixed.forEach(cd   => { if (Math.abs(deg-cd) < 1) flags.push(`Degré critique fixe ${cd}° (tension accumulée)`); });\r\n    if (mutableSigns.includes(sign))  criticalDegConfig.mutable.forEach(cd => { if (Math.abs(deg-cd) < 1) flags.push(`Degré critique mutable ${cd}° (carrefour de choix)`); });\r\n    if (flags.length > 0) criticalPlanets.push({ planet:name, sign, degree:deg.toFixed(2), flags });\r\n});\r\n\r\n// 6d. RÉCEPTIONS MUTUELLES\r\nconst receptionPlanets  = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\r\nconst mutualReceptions  = [];\r\nfor (let i=0; i<receptionPlanets.length; i++) {\r\n    for (let j=i+1; j<receptionPlanets.length; j++) {\r\n        let nA=receptionPlanets[i], nB=receptionPlanets[j];\r\n        let pA=planetes.find(p=>p.planet.fr===nA), pB=planetes.find(p=>p.planet.fr===nB);\r\n        if (!pA || !pB) continue;\r\n        let sA=pA.zodiac_sign?.name?.fr, sB=pB.zodiac_sign?.name?.fr;\r\n        let aInBDom = dignities[nA] && dignities[nB]?.dom?.includes(sA);\r\n        let bInADom = dignities[nB] && dignities[nA]?.dom?.includes(sB);\r\n        if (aInBDom && bInADom) {\r\n            mutualReceptions.push({ p1:nA, sign1:sA, house1:getHouseNumber(pA.fullDegree), p2:nB, sign2:sB, house2:getHouseNumber(pB.fullDegree), type:\"domicile\" });\r\n        }\r\n        let aInBExa = dignities[nA] && dignities[nB]?.exa?.includes(sA);\r\n        let bInAExa = dignities[nB] && dignities[nA]?.exa?.includes(sB);\r\n        if (aInBExa && bInAExa && !(aInBDom && bInADom)) {\r\n            mutualReceptions.push({ p1:nA, sign1:sA, house1:getHouseNumber(pA.fullDegree), p2:nB, sign2:sB, house2:getHouseNumber(pB.fullDegree), type:\"exaltation\" });\r\n        }\r\n        // Réception mixte : A en domicile de B + B en exaltation de A (ou inverse)\r\n        if (!(aInBDom && bInADom) && !(aInBExa && bInAExa)) {\r\n            if ((aInBDom && bInAExa) || (aInBExa && bInADom)) {\r\n                mutualReceptions.push({ p1:nA, sign1:sA, house1:getHouseNumber(pA.fullDegree), p2:nB, sign2:sB, house2:getHouseNumber(pB.fullDegree), type:\"mixte\" });\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// 6e. CONFIGURATIONS NATALES (Stellium, Grand Trigone, T-Carré, Grand Carré, Yod, Cerf-Volant)\r\n// confPlanets inclut les 10 planètes + Chiron + les 4 Angles (ASC, MC, DSC, IC).\r\n// Les Angles sont construits depuis les maisons si absents du payload API.\r\n// Sans cette extension, le bonus +40 \"Si Angle impliqué\" serait du code mort\r\n// et des configurations majeures (ex: T-Carré avec l'ASC comme apex) seraient manquées.\r\nconst CONF_ANGLES_SET = new Set([\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"]);\r\nconst confPlanetsBase = planetes.filter(p => corePlanets.includes(p.planet.fr || p.planet.en));\r\nconst angleObjectsConf = [\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"].map(angleName => {\r\n    let existing = planetes.find(p => p.planet.fr === angleName);\r\n    if (existing) return existing;\r\n    const houseNum = angleName === \"Descendant\" ? 7 : angleName === \"Imum Coeli\" ? 4 : null;\r\n    if (!houseNum) return null;\r\n    const m = maisons.find(m => m.House === houseNum);\r\n    if (!m) return null;\r\n    return { planet:{fr:angleName,en:angleName}, fullDegree:m.degree, normDegree:m.degree%30, retroStr:\"\", isRetro:\"False\", zodiac_sign:{name:{fr:signs[Math.floor(m.degree/30)%12].fr}} };\r\n}).filter(Boolean);\r\nconst confPlanets = [...confPlanetsBase];\r\nangleObjectsConf.forEach(ao => {\r\n    const aoName = ao.planet.fr || ao.planet.en;\r\n    if (!confPlanets.find(p => (p.planet.fr || p.planet.en) === aoName)) confPlanets.push(ao);\r\n});\r\nconst configurations = [];\r\n\r\n// Stellium : 3+ planètes dans le même signe\r\nlet signGroups = {};\r\nconfPlanets.forEach(p => {\r\n    let sign = p.zodiac_sign?.name?.fr;\r\n    if (!signGroups[sign]) signGroups[sign] = [];\r\n    signGroups[sign].push(p.planet.fr || p.planet.en);\r\n});\r\nObject.entries(signGroups).forEach(([sign, pList]) => {\r\n    if (pList.length >= 3 && pList.filter(p => CONF_ANGLES_SET.has(p)).length < 3) {\r\n        configurations.push({ type:\"Stellium\", planets:pList, description:`${pList.join(\", \")} regroupés en ${sign} — concentration d'énergie ${sign} très intense` });\r\n    }\r\n});\r\n\r\n// Stellium par Maison : 3+ planètes dans la même maison (complémentaire du Stellium par signe)\r\n// Pertinent quand un Stellium s'étale sur deux signes dans une maison large ou interceptée.\r\nconst houseGroupsStellium = {};\r\nconfPlanets.forEach(p => {\r\n    const house = getHouseNumber(p.fullDegree);\r\n    if (!houseGroupsStellium[house]) houseGroupsStellium[house] = [];\r\n    const pName = p.planet.fr || p.planet.en;\r\n    if (!houseGroupsStellium[house].includes(pName)) houseGroupsStellium[house].push(pName);\r\n});\r\nObject.entries(houseGroupsStellium).forEach(([house, pList]) => {\r\n    if (pList.length >= 3) {\r\n        const alreadyCovered = configurations.some(c =>\r\n            c.type === \"Stellium\" && c.planets.length === pList.length && c.planets.every(p => pList.includes(p))\r\n        );\r\n        if (!alreadyCovered && pList.filter(p => CONF_ANGLES_SET.has(p)).length < 3) {\r\n            configurations.push({ type:\"Stellium\", planets:pList, description:`${pList.join(\", \")} concentrés en Maison ${house} — Stellium de maison, thématiques de M${house} hyper-activées` });\r\n        }\r\n    }\r\n});\r\n\r\n// Grand Trigone : 3 planètes à ~120° (orbe 8°)\r\nconst grandTrigoneSets = [];\r\nfor (let i=0; i<confPlanets.length; i++) {\r\n    for (let j=i+1; j<confPlanets.length; j++) {\r\n        for (let k=j+1; k<confPlanets.length; k++) {\r\n            let d12=angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree);\r\n            let d23=angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree);\r\n            let d13=angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree);\r\n            if (Math.abs(d12-120)<=8 && Math.abs(d23-120)<=8 && Math.abs(d13-120)<=8) {\r\n                let n1=confPlanets[i].planet.fr, n2=confPlanets[j].planet.fr, n3=confPlanets[k].planet.fr;\r\n                grandTrigoneSets.push([n1,n2,n3]);\r\n                configurations.push({ type:\"Grand Trigone\", planets:[n1,n2,n3], description:`${n1} — ${n2} — ${n3} : grande harmonie et facilité, risque d'inertie sans effort conscient` });\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// T-Carré : 2 planètes en opposition + une troisième en carré aux deux\r\nlet tcarreKeys = new Set();\r\nfor (let i=0; i<confPlanets.length; i++) {\r\n    for (let j=i+1; j<confPlanets.length; j++) {\r\n        if (Math.abs(angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree)-180)>10) continue;\r\n        for (let k=0; k<confPlanets.length; k++) {\r\n            if (k===i||k===j) continue;\r\n            let dik=angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree);\r\n            let djk=angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree);\r\n            if (Math.abs(dik-90)<=8 && Math.abs(djk-90)<=8) {\r\n                let n1=confPlanets[i].planet.fr, n2=confPlanets[j].planet.fr, nk=confPlanets[k].planet.fr;\r\n                let key=[n1,n2,nk].sort().join(\"|\");\r\n                if (!tcarreKeys.has(key) && !isAxisPair(n1, n2) && ![n1,n2,nk].every(n => CONF_ANGLES_SET.has(n))) {\r\n                    tcarreKeys.add(key);\r\n                    configurations.push({ type:\"T-Carré\", planets:[n1,n2,nk], description:`${n1} opposition ${n2}, tous deux en carré à ${nk} (apex) — tension persistante, moteur de dépassement de soi` });\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// Grand Carré : 4 planètes en carré/opposition mutuels\r\nlet grandcarreKeys = new Set();\r\nfor (let i=0; i<confPlanets.length; i++) for (let j=i+1; j<confPlanets.length; j++) for (let k=j+1; k<confPlanets.length; k++) for (let l=k+1; l<confPlanets.length; l++) {\r\n    let ps=[confPlanets[i],confPlanets[j],confPlanets[k],confPlanets[l]];\r\n    let sorted=[...ps].sort((a,b)=>a.fullDegree-b.fullDegree);\r\n    let d01=angularDiff(sorted[0].fullDegree,sorted[1].fullDegree);\r\n    let d12=angularDiff(sorted[1].fullDegree,sorted[2].fullDegree);\r\n    let d23=angularDiff(sorted[2].fullDegree,sorted[3].fullDegree);\r\n    let d30=angularDiff(sorted[3].fullDegree,sorted[0].fullDegree);\r\n    if ([d01,d12,d23,d30].every(d=>Math.abs(d-90)<=10)) {\r\n        let names=ps.map(p=>p.planet.fr); let key=names.slice().sort().join(\"|\");\r\n        if (!grandcarreKeys.has(key) && names.filter(n => CONF_ANGLES_SET.has(n)).length < 3) {\r\n            grandcarreKeys.add(key);\r\n            configurations.push({ type:\"Grand Carré\", planets:names, description:`${names.join(\", \")} : tension quadrilatérale maximale, défi de vie structurant et formateur` });\r\n        }\r\n    }\r\n}\r\n\r\n// Yod : 2 planètes en sextile, toutes deux en quinconce à un apex\r\nlet yodKeys = new Set();\r\nfor (let i=0; i<confPlanets.length; i++) {\r\n    for (let j=i+1; j<confPlanets.length; j++) {\r\n        if (Math.abs(angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree)-60)>6) continue;\r\n        for (let k=0; k<confPlanets.length; k++) {\r\n            if (k===i||k===j) continue;\r\n            let dik=angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree);\r\n            let djk=angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree);\r\n            if (Math.abs(dik-150)<=3 && Math.abs(djk-150)<=3) {\r\n                let n1=confPlanets[i].planet.fr, n2=confPlanets[j].planet.fr, nk=confPlanets[k].planet.fr;\r\n                let key=[n1,n2,nk].sort().join(\"|\");\r\n                if (!yodKeys.has(key)) {\r\n                    yodKeys.add(key);\r\n                    configurations.push({ type:\"Yod — Doigt de Dieu\", planets:[n1,n2,nk], description:`${n1} sextile ${n2}, tous deux en quinconce à ${nk} (apex) — mission de vie, ajustement karmique obligatoire` });\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// Cerf-Volant (Kite) : Grand Trigone + opposition + 2 sextiles depuis un 4e point\r\nlet kiteKeys = new Set();\r\ngrandTrigoneSets.forEach(([n1,n2,n3]) => {\r\n    confPlanets.forEach(p => {\r\n        let pk=p.planet.fr; if ([n1,n2,n3].includes(pk)) return;\r\n        let triPs = [n1,n2,n3].map(tn => confPlanets.find(x=>(x.planet.fr||x.planet.en)===tn)).filter(Boolean);\r\n        let oppIdx = triPs.findIndex(tp => Math.abs(angularDiff(p.fullDegree,tp.fullDegree)-180)<=8);\r\n        if (oppIdx === -1) return;\r\n        let sextileCount = triPs.filter((tp,idx) => idx!==oppIdx && Math.abs(angularDiff(p.fullDegree,tp.fullDegree)-60)<=6).length;\r\n        if (sextileCount >= 2) {\r\n            let key=[n1,n2,n3,pk].sort().join(\"|\");\r\n            if (!kiteKeys.has(key)) {\r\n                kiteKeys.add(key);\r\n                configurations.push({ type:\"Cerf-Volant (Kite)\", planets:[n1,n2,n3,pk], description:`Grand Trigone ${n1}-${n2}-${n3} avec ${pk} en opposition à ${triPs[oppIdx].planet.fr} — talent exceptionnel canalisé, potentiel actionnable` });\r\n            }\r\n        }\r\n    });\r\n});\r\n\r\n// 6e-bis. CROIX MODALE (Cardinale / Fixe / Mutable)\r\n// 4+ planètes dans les 4 signes d'un même mode, reliées par des oppositions et carrés\r\nconst MODE_SIGNS = {\r\n    \"Cardinal\": [\"Bélier\",\"Cancer\",\"Balance\",\"Capricorne\"],\r\n    \"Fixe\":     [\"Taureau\",\"Lion\",\"Scorpion\",\"Verseau\"],\r\n    \"Mutable\":  [\"Gémeaux\",\"Vierge\",\"Sagittaire\",\"Poissons\"]\r\n};\r\nconst crossKeys = new Set();\r\nObject.entries(MODE_SIGNS).forEach(([modeName, mSigns]) => {\r\n    const inMode = confPlanets.filter(p => mSigns.includes(p.zodiac_sign?.name?.fr));\r\n    if (inMode.length < 4) return;\r\n    const signsCovered = new Set(inMode.map(p => p.zodiac_sign?.name?.fr));\r\n    if (signsCovered.size < 3) return;\r\n    const names = inMode.map(p => p.planet.fr);\r\n    let hasOpp = false, hasSq = false;\r\n    for (let i = 0; i < inMode.length && (!hasOpp || !hasSq); i++) {\r\n        for (let j = i+1; j < inMode.length; j++) {\r\n            let diff = Math.abs(inMode[i].fullDegree - inMode[j].fullDegree);\r\n            if (diff > 180) diff = 360 - diff;\r\n            if (Math.abs(diff - 180) <= 10) hasOpp = true;\r\n            if (Math.abs(diff - 90) <= 8) hasSq = true;\r\n        }\r\n    }\r\n    if (hasOpp && hasSq) {\r\n        const key = names.slice().sort().join(\"|\");\r\n        if (!crossKeys.has(key)) {\r\n            crossKeys.add(key);\r\n            const modeDesc = modeName === \"Cardinal\" ? \"action, initiative, crise\" : modeName === \"Fixe\" ? \"persévérance, résistance au changement, endurance\" : \"adaptabilité, dispersion, versatilité\";\r\n            configurations.push({ type:`Croix ${modeName}`, planets:names, description:`${names.join(\", \")} : axe ${modeName} activé (${modeDesc}) — dynamique de tension structurante sur le mode ${modeName}` });\r\n        }\r\n    }\r\n});\r\n\r\n// 6e-ter. RECTANGLE MYSTIQUE : 2 oppositions reliées par 2 sextiles et 2 trigones\r\nlet rectMystiqueKeys = new Set();\r\nfor (let i=0; i<confPlanets.length; i++) {\r\n    for (let j=i+1; j<confPlanets.length; j++) {\r\n        if (Math.abs(angularDiff(confPlanets[i].fullDegree,confPlanets[j].fullDegree)-180)>10) continue;\r\n        for (let k=0; k<confPlanets.length; k++) {\r\n            if (k===i||k===j) continue;\r\n            for (let l=k+1; l<confPlanets.length; l++) {\r\n                if (l===i||l===j) continue;\r\n                if (Math.abs(angularDiff(confPlanets[k].fullDegree,confPlanets[l].fullDegree)-180)>10) continue;\r\n                const ds = [\r\n                    angularDiff(confPlanets[i].fullDegree,confPlanets[k].fullDegree),\r\n                    angularDiff(confPlanets[i].fullDegree,confPlanets[l].fullDegree),\r\n                    angularDiff(confPlanets[j].fullDegree,confPlanets[k].fullDegree),\r\n                    angularDiff(confPlanets[j].fullDegree,confPlanets[l].fullDegree)\r\n                ];\r\n                const sextiles = ds.filter(d => Math.abs(d-60)<=6).length;\r\n                const trigones = ds.filter(d => Math.abs(d-120)<=8).length;\r\n                if (sextiles >= 2 && trigones >= 2) {\r\n                    const names = [confPlanets[i],confPlanets[j],confPlanets[k],confPlanets[l]].map(p=>p.planet.fr);\r\n                    const key = names.slice().sort().join(\"|\");\r\n                    if (!rectMystiqueKeys.has(key)) {\r\n                        rectMystiqueKeys.add(key);\r\n                        configurations.push({ type:\"Rectangle Mystique\", planets:names, description:`${names.join(\", \")} : double opposition harmonisée par sextiles et trigones — talent de médiation, capacité à résoudre les paradoxes` });\r\n                    }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// 6e-quater. GRAND SEXTILE (Étoile de David) : 6 planètes à ~60° l'une de l'autre\r\nlet grandSextileKeys = new Set();\r\nif (confPlanets.length >= 6) {\r\n    for (let i=0; i<confPlanets.length; i++) {\r\n        const candidates = [confPlanets[i]];\r\n        let lastDeg = confPlanets[i].fullDegree;\r\n        const sorted = confPlanets.filter((_,idx)=>idx!==i).sort((a,b) => {\r\n            const da = ((a.fullDegree - lastDeg + 360) % 360);\r\n            const db = ((b.fullDegree - lastDeg + 360) % 360);\r\n            return da - db;\r\n        });\r\n        for (const p of sorted) {\r\n            const dFromLast = angularDiff(candidates[candidates.length-1].fullDegree, p.fullDegree);\r\n            if (Math.abs(dFromLast - 60) <= 6) candidates.push(p);\r\n            if (candidates.length === 6) break;\r\n        }\r\n        if (candidates.length === 6) {\r\n            const dClose = angularDiff(candidates[5].fullDegree, candidates[0].fullDegree);\r\n            if (Math.abs(dClose - 60) <= 6) {\r\n                const names = candidates.map(p => p.planet.fr);\r\n                const key = names.slice().sort().join(\"|\");\r\n                if (!grandSextileKeys.has(key)) {\r\n                    grandSextileKeys.add(key);\r\n                    configurations.push({ type:\"Grand Sextile (Étoile de David)\", planets:names, description:`${names.join(\", \")} : hexagramme parfait — flux d'énergie circulaire, potentiel exceptionnel et multifacette (configuration extrêmement rare)` });\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// 6e-sext. FORME DU THÈME (Jones Patterns)\r\nconst computeChartShape = () => {\r\n    const core10 = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\r\n    const pDegs = core10.map(n => ({ name: n, deg: planetes.find(p => p.planet.fr === n)?.fullDegree })).filter(pd => pd.deg !== undefined).sort((a,b) => a.deg - b.deg);\r\n    const n = pDegs.length;\r\n    if (n < 7) return { shape: \"Indéterminé\", description: \"Pas assez de planètes pour classifier\" };\r\n    const gaps = [];\r\n    for (let i = 0; i < n; i++) {\r\n        gaps.push(((pDegs[(i+1) % n].deg - pDegs[i].deg) + 360) % 360);\r\n    }\r\n    const maxGap = Math.max(...gaps);\r\n    const maxGapIdx = gaps.indexOf(maxGap);\r\n    const minGap = Math.min(...gaps);\r\n    const spread = 360 - maxGap;\r\n\r\n    const findSingleton = () => {\r\n        const sorted = gaps.map((g,i) => ({g,i})).sort((a,b) => b.g - a.g);\r\n        const g1i = sorted[0].i, g2i = sorted[1].i;\r\n        let setA = [], setB = [];\r\n        let idx = (g1i + 1) % n;\r\n        while (idx !== (g2i + 1) % n) { setA.push(pDegs[idx].name); idx = (idx + 1) % n; }\r\n        idx = (g2i + 1) % n;\r\n        while (idx !== (g1i + 1) % n) { setB.push(pDegs[idx].name); idx = (idx + 1) % n; }\r\n        return setA.length <= setB.length ? setA : setB;\r\n    };\r\n\r\n    const findLeading = () => pDegs[(maxGapIdx + 1) % n].name;\r\n\r\n    if (spread <= 120) return { shape: \"Bundle (Paquet)\", description: \"Toutes les planètes concentrées dans 120° — spécialiste intensif, vision focalisée mais limitée\" };\r\n    if (spread <= 180) return { shape: \"Bowl (Bol)\", description: `Planètes dans 180° — une moitié du zodiaque est vide, orientation unilatérale et conscience d'un manque` };\r\n    if (spread > 180 && maxGap >= 60 && maxGap <= 120) {\r\n        const singleton = findSingleton();\r\n        const sName = singleton.join(\" et \");\r\n        return { shape: \"Bucket (Seau)\", description: `${sName} isolé${singleton.length > 1 ? \"s\" : \"\"} face au groupe — singleton qui focalise et canalise toute l'énergie`, singleton: sName };\r\n    }\r\n    if (maxGap <= 40 && minGap >= 15) return { shape: \"Splash (Éclaboussure)\", description: \"Planètes réparties dans tout le zodiaque — polyvalence, dispersion possible, touche-à-tout\" };\r\n    const largeGaps = gaps.filter(g => g >= 60);\r\n    if (largeGaps.length === 2 && largeGaps.every(g => g <= 120)) return { shape: \"Seesaw (Balançoire)\", description: \"Deux groupes de planètes opposés — dualité permanente, oscillation entre deux pôles de vie\" };\r\n    if (maxGap >= 60 && maxGap <= 90) {\r\n        const leading = findLeading();\r\n        return { shape: \"Locomotive\", description: `Grand vide de ${maxGap.toFixed(0)}° — élan puissant, ambition motrice. ${leading} en tête tire le train` };\r\n    }\r\n    if (spread > 250 && maxGap > 90) return { shape: \"Splay (Éventail)\", description: \"Distribution irrégulière avec accents marqués — individualiste, talents particuliers, résistance au conformisme\" };\r\n    return { shape: \"Splay (Éventail)\", description: \"Distribution irrégulière — profil individualiste et diversifié\" };\r\n};\r\nconst chartShape = computeChartShape();\r\n\r\n// 6f. ANTISCIA & CONTRA-ANTISCIA (miroir axe 0°Cancer/0°Capricorne)\r\n// antiscia_deg = (180 - fullDeg + 360) % 360\r\nconst ANTISCIA_ORB = 1.5;\r\nconst antisciaPlanets = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\r\nconst antiscia = [];\r\nfor (let i=0; i<antisciaPlanets.length; i++) {\r\n    for (let j=i+1; j<antisciaPlanets.length; j++) {\r\n        let pA=planetes.find(p=>p.planet.fr===antisciaPlanets[i]);\r\n        let pB=planetes.find(p=>p.planet.fr===antisciaPlanets[j]);\r\n        if (!pA||!pB) continue;\r\n        let antisciaDegA      = (180 - pA.fullDegree + 360) % 360;\r\n        let contraAntisciaDegA = (antisciaDegA + 180) % 360;\r\n        let diffA = angularDiff(antisciaDegA, pB.fullDegree);\r\n        let diffC = angularDiff(contraAntisciaDegA, pB.fullDegree);\r\n        if (diffA <= ANTISCIA_ORB) antiscia.push({ p1:antisciaPlanets[i], p2:antisciaPlanets[j], type:\"Antiscia\",        orb:diffA.toFixed(2) });\r\n        if (diffC <= ANTISCIA_ORB) antiscia.push({ p1:antisciaPlanets[i], p2:antisciaPlanets[j], type:\"Contra-antiscia\", orb:diffC.toFixed(2) });\r\n    }\r\n}\r\n\r\n// 6g. MIDPOINTS (10 planètes majeures) + détection des activateurs\r\nconst midpointPlanets = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\r\nconst midpoints = {};\r\nfor (let i=0; i<midpointPlanets.length; i++) {\r\n    for (let j=i+1; j<midpointPlanets.length; j++) {\r\n        let pA=planetes.find(p=>p.planet.fr===midpointPlanets[i]);\r\n        let pB=planetes.find(p=>p.planet.fr===midpointPlanets[j]);\r\n        if (!pA||!pB) continue;\r\n        let diff = pB.fullDegree - pA.fullDegree;\r\n        if (diff < 0) diff += 360;\r\n        if (diff > 180) diff -= 360;\r\n        let mp = ((pA.fullDegree + diff/2) % 360 + 360) % 360;\r\n        let mpFar = (mp + 180) % 360;\r\n        midpoints[`${midpointPlanets[i]}/${midpointPlanets[j]}`] = {\r\n            near: mp, far: mpFar,\r\n            sign: signs[Math.floor(mp/30)].fr, deg: (mp%30).toFixed(1)\r\n        };\r\n    }\r\n}\r\nconst midpointActivations = [];\r\nObject.entries(midpoints).forEach(([key, mp]) => {\r\n    let [mpP1, mpP2] = key.split(\"/\");\r\n    planetes.forEach(p => {\r\n        let name = p.planet.fr || p.planet.en;\r\n        if (name === mpP1 || name === mpP2) return;\r\n        if ([\"Part de Fortune\",\"Lot de l'Esprit\",\"Nœud Sud\",\"Lot de Nécessité\",\"Lot d'Éros\",\"Lot de Courage\",\"Lot de Némésis\",\"Lot de Basis\",\"Lot d'Exaltation\",\"Lot du Daemon\"].includes(name)) return;\r\n        let dNear = angularDiff(p.fullDegree, mp.near);\r\n        let dFar  = angularDiff(p.fullDegree, mp.far);\r\n        let best  = Math.min(dNear, dFar);\r\n        if (best <= 1.5) {\r\n            midpointActivations.push({ activator:name, midpoint:key, type:dNear<=dFar?\"direct\":\"miroir\", orb:best.toFixed(2) });\r\n        }\r\n    });\r\n});\r\n\r\n// 6h. ÉTOILES FIXES — Conjonctions avec les planètes natales\r\n// Orbes différenciés :\r\n//   ±2° — étoiles royales/majeures : Aldébaran, Sirius, Régulus, Spica, Antarès\r\n//   ±1° — autres étoiles : Algol, Pléiades, Véga, Fomalhaut\r\nconst ETOILE_ORBS = {\r\n    \"Aldébaran\": 2.0, \"Sirius\": 2.0, \"Régulus\": 2.0, \"Spica\": 2.0, \"Antarès\": 2.0,\r\n    \"Algol\": 1.0, \"Pléiades\": 1.0, \"Véga\": 1.0, \"Fomalhaut\": 1.0,\r\n    \"Rigel\": 1.5, \"Bételgeuse\": 1.5, \"Castor\": 1.0, \"Pollux\": 1.5,\r\n    \"Procyon\": 1.5, \"Canopus\": 1.5, \"Arcturus\": 1.5, \"Deneb Algedi\": 1.0,\r\n    \"Vindemiatrix\": 1.0, \"Scheat\": 1.0, \"Zubenelgenubi\": 1.0,\r\n    \"Zubeneschamali\": 1.0, \"Achernar\": 1.0, \"Deneb\": 1.0,\r\n    \"Wega\": 1.0, \"Alcyone\": 1.0\r\n};\r\nconst ETOILE_DESC = {\r\n    \"Algol\":     \"Étoile de la Méduse (nature Saturne/Mars) : violence, catastrophe, perte irréversible — mais aussi courage absolu face au danger extrême, capacité à transformer la destruction en renaissance\",\r\n    \"Pléiades\":  \"Cluster des Pléiades / Alcyone (nature Lune/Mars) : deuil, larmes, mystère, liens ancestraux et spiritualité profonde — sensibilité exacerbée aux cycles et à la mémoire collective\",\r\n    \"Alcyone\":   \"Cluster des Pléiades / Alcyone (nature Lune/Mars) : deuil, larmes, mystère, liens ancestraux et spiritualité profonde — sensibilité exacerbée aux cycles et à la mémoire collective\",\r\n    \"Aldébaran\": \"Étoile Royale de l'Est — Œil du Taureau (nature Mars/Mercure) : honneur, intégrité, intelligence vive, vigilance stratégique. L'une des 4 Royales : succès durable si l'intégrité est maintenue\",\r\n    \"Sirius\":    \"Étoile du Grand Chien (nature Jupiter/Mars) : gloire, richesse, fidélité ardente, passion dévorante — nature solaire intense conférant rayonnement et leadership magnétique\",\r\n    \"Régulus\":   \"Étoile Royale du Cœur du Lion (nature Mars/Jupiter) : royauté, leadership naturel, succès fulgurant, ambition. L'une des 4 Royales : grandeur et chute si la vengeance supplante la noblesse\",\r\n    \"Spica\":     \"Épi de la Vierge (nature Vénus/Mars) : don artistique, chance remarquable, raffinement intellectuel, richesse créative — l'une des étoiles les plus bénéfiques du zodiaque\",\r\n    \"Antarès\":   \"Étoile Royale du Cœur du Scorpion (nature Mars/Jupiter) : courage, témérité, passion dévorante, succès militaire ou compétitif. L'une des 4 Royales : rival de Mars, intensité maximale\",\r\n    \"Véga\":      \"Étoile de la Lyre (nature Vénus/Mercure) : charisme magnétique irrésistible, dons artistiques et musicaux exceptionnels, raffinement spirituel et sens du beau transcendant\",\r\n    \"Wega\":      \"Étoile de la Lyre (nature Vénus/Mercure) : charisme magnétique irrésistible, dons artistiques et musicaux exceptionnels, raffinement spirituel et sens du beau transcendant\",\r\n    \"Fomalhaut\": \"Étoile Royale du Sud (nature Vénus/Mercure) : idéalisme visionnaire, rêve créateur, inspiration mystique, sens du sacré. L'une des 4 Royales : grandeur par la vision hors du commun\",\r\n    \"Rigel\":     \"Pied d'Orion (nature Jupiter/Saturne) : ambition intellectuelle, enseignement, capacité de construction à grande échelle — fortune par l'effort persistant et la vision à long terme\",\r\n    \"Bételgeuse\":\"Épaule d'Orion (nature Mars/Mercure) : honneur martial, audace créatrice, succès par l'action directe — énergie colossale mais risque de blessures ou de renversements soudains\",\r\n    \"Castor\":    \"Alpha Gémeaux (nature Mercure) : brillance intellectuelle, écriture, communication — mais vulnérabilité aux blessures ou violence, dualité créative entre lumière et ombre\",\r\n    \"Pollux\":    \"Beta Gémeaux (nature Mars) : force sportive, audace, compétitivité — caractère intrépide mais risque de cruauté ou de témérité excessive\",\r\n    \"Procyon\":   \"Étoile du Petit Chien (nature Mercure/Mars) : activité fébrile, succès rapide mais instable — intelligence vive et capacité d'adaptation, mais attention à la dispersion\",\r\n    \"Canopus\":   \"Étoile du Navire Argo (nature Saturne/Jupiter) : voyage, navigation de la vie, connaissance ancienne — l'une des plus lumineuses : érudition et sagesse acquise par l'expérience lointaine\",\r\n    \"Arcturus\":  \"Gardien de l'Ourse (nature Mars/Jupiter) : prospérité par le voyage ou l'innovation, leadership par la voie non conventionnelle — force de caractère et indépendance d'esprit\",\r\n    \"Deneb Algedi\":\"Queue du Capricorne (nature Saturne/Jupiter) : justice, probité, sens de la loi — réussite par la droiture et la persévérance, mais risque de rigidité morale\",\r\n    \"Vindemiatrix\":\"La Vendangeuse (nature Saturne/Mercure) : veuvage symbolique, perte, sacrifice nécessaire — mais aussi discernement tranchant et capacité de détachement libérateur\",\r\n    \"Scheat\":    \"Épaule de Pégase (nature Mars/Mercure) : naufrage, catastrophe maritime (symbolique), extrême sensibilité — mais imagination sans limites et capacité à transcender le réel\",\r\n    \"Zubenelgenubi\":\"Plateau Sud de la Balance (nature Saturne/Mars) : justice implacable, karma, conséquences inévitables — poids du passé mais capacité de rééquilibrage par l'action juste\",\r\n    \"Zubeneschamali\":\"Plateau Nord de la Balance (nature Jupiter/Mercure) : fortune sociale, intelligence diplomatique, élévation par le mérite et la finesse relationnelle\",\r\n    \"Achernar\":  \"Fin du Fleuve Éridan (nature Jupiter) : bonheur spirituel, succès ecclésiastique ou philosophique, sens du sacré — transformation profonde par l'immersion dans le courant de la vie\",\r\n    \"Deneb\":     \"Queue du Cygne (nature Vénus/Mercure) : don artistique ingénieux, capacité de synthèse entre technique et esthétique — intelligence subtile et charme magnétique\"\r\n};\r\n\r\n// Construire la liste complè