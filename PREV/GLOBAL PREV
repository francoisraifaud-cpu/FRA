Name,\r\n                etoile_en: etoile.name?.en || eName,\r\n                orb:       Math.round(diff * 100) / 100,\r\n                orbMax,\r\n                precision: diff <= 1.0 ? \"forte (≤1°)\" : \"notable (≤2°)\",\r\n                maison:    house,\r\n                signe:     planet.zodiac_sign?.name?.fr,\r\n                isAngle:   !!ANGLES_LABELS[pName],\r\n                desc:      ETOILE_DESC[eName] || \"\"\r\n            });\r\n        }\r\n    });\r\n});\r\n\r\n// Conjonctions étoiles fixes sur les 4 angles (M1 ASC / M4 IC / M7 DSC / M10 MC)\r\nconst ANGULAR_HOUSES = new Set([1, 4, 7, 10]);\r\nconst ANGLE_LABELS   = { 1:\"ASC\", 4:\"IC\", 7:\"DSC\", 10:\"MC\" };\r\nconst etoileCuspMatches = [];\r\nmaisons.filter(m => ANGULAR_HOUSES.has(m.House)).forEach(m => {\r\n    etoilesFixesRaw.forEach(etoile => {\r\n        const eName = etoile.name?.fr;\r\n        if (!eName) return;\r\n        const orbMax = ETOILE_ORBS[eName] ?? 1.0;\r\n        const diff = angularDiff(m.degree, etoile.fullDegree);\r\n        if (diff <= orbMax) {\r\n            const cuspSign = signs[Math.floor(m.degree / 30) % 12].fr;\r\n            etoileCuspMatches.push({\r\n                maison:    m.House,\r\n                angle:     ANGLE_LABELS[m.House],\r\n                etoile:    eName,\r\n                etoile_en: etoile.name?.en || eName,\r\n                orb:       Math.round(diff * 100) / 100,\r\n                orbMax,\r\n                precision: diff <= 1.0 ? \"forte (≤1°)\" : \"notable (≤2°)\",\r\n                signe:     cuspSign,\r\n                desc:      ETOILE_DESC[eName] || \"\"\r\n            });\r\n        }\r\n    });\r\n});\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 6h-bis. PARANS D'ÉTOILES FIXES (méthode Brady — co-angularité)\r\n// Un paran se forme quand une étoile est sur un angle (lever/coucher/culmination)\r\n// au même moment qu'une planète est sur un angle, évalué par le RAMC commun.\r\n// ─────────────────────────────────────────────────────────────────\r\nconst PARAN_ORB = 1.5;\r\nconst OBLIQUITY = 23.4393;\r\nconst DEG = Math.PI / 180;\r\n\r\nconst geoLat = parseFloat(perso.latitude) || 0;\r\nconst paranResults = [];\r\n\r\nif (Math.abs(geoLat) > 0.1) {\r\n    const tanPhi = Math.tan(geoLat * DEG);\r\n\r\n    function hourAngle(dec) {\r\n        const tanDec = Math.tan(dec * DEG);\r\n        const cosH = -tanPhi * tanDec;\r\n        if (cosH < -1 || cosH > 1) return null;\r\n        return Math.acos(cosH) / DEG;\r\n    }\r\n\r\n    function bodyAngles(ra, dec) {\r\n        const H = hourAngle(dec);\r\n        const angles = [];\r\n        angles.push({ type: \"Culmination\", ramc: ((ra % 360) + 360) % 360 });\r\n        angles.push({ type: \"Anti-culmination\", ramc: ((ra + 180) % 360 + 360) % 360 });\r\n        if (H !== null) {\r\n            angles.push({ type: \"Lever\", ramc: ((ra - H) % 360 + 360) % 360 });\r\n            angles.push({ type: \"Coucher\", ramc: ((ra + H) % 360 + 360) % 360 });\r\n        }\r\n        return angles;\r\n    }\r\n\r\n    function eclToEq(lon, lat) {\r\n        const L = lon * DEG, B = (lat || 0) * DEG, E = OBLIQUITY * DEG;\r\n        const ra = Math.atan2(Math.sin(L) * Math.cos(E) - Math.tan(B) * Math.sin(E), Math.cos(L));\r\n        const dec = Math.asin(Math.sin(B) * Math.cos(E) + Math.cos(B) * Math.sin(E) * Math.sin(L));\r\n        return { ra: ((ra / DEG) % 360 + 360) % 360, dec: dec / DEG };\r\n    }\r\n\r\n    const PARAN_PLANETS = new Set([\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\",\"Ascendant\",\"Milieu du Ciel\",\"Descendant\",\"Imum Coeli\"]);\r\n\r\n    const planetAnglesMap = [];\r\n    pointsEtoiles.forEach(p => {\r\n        const pName = p.planet.fr || p.planet.en;\r\n        if (!PARAN_PLANETS.has(pName)) return;\r\n        if (LOTS_MATHEMATIQUES.has(pName)) return;\r\n        let pRa, pDec;\r\n        if (typeof p.declinaison === \"number\") {\r\n            pDec = p.declinaison;\r\n            const lonR = p.fullDegree * DEG, E = OBLIQUITY * DEG;\r\n            const sinBeta = (Math.sin(pDec * DEG) - Math.sin(E) * Math.sin(lonR)) / Math.cos(E);\r\n            const beta = Math.abs(sinBeta) <= 1 ? Math.asin(sinBeta) : 0;\r\n            const raRad = Math.atan2(Math.sin(lonR) * Math.cos(E) - Math.tan(beta) * Math.sin(E), Math.cos(lonR));\r\n            pRa = ((raRad / DEG) + 360) % 360;\r\n        } else {\r\n            const eq = eclToEq(p.fullDegree, 0);\r\n            pRa = eq.ra;\r\n            pDec = eq.dec;\r\n        }\r\n        const angles = bodyAngles(pRa, pDec);\r\n        planetAnglesMap.push({ name: pName, ra: pRa, dec: pDec, angles });\r\n    });\r\n\r\n    const PARAN_LABELS = {\r\n        \"Culmination-Culmination\": \"co-culmination (les deux au MC)\",\r\n        \"Culmination-Lever\": \"étoile culmine quand la planète se lève\",\r\n        \"Lever-Lever\": \"co-lever (les deux à l'horizon Est)\",\r\n        \"Lever-Culmination\": \"planète se lève quand l'étoile culmine\",\r\n        \"Coucher-Coucher\": \"co-coucher (les deux à l'horizon Ouest)\",\r\n        \"Culmination-Coucher\": \"étoile culmine quand la planète se couche\",\r\n        \"Coucher-Culmination\": \"planète se couche quand l'étoile culmine\",\r\n        \"Lever-Coucher\": \"étoile se lève quand la planète se couche\",\r\n        \"Coucher-Lever\": \"étoile se couche quand la planète se lève\",\r\n    };\r\n\r\n    etoilesFixesRaw.forEach(star => {\r\n        const sName = star.name?.fr;\r\n        if (!sName) return;\r\n        const sDec = star.declination_j2000;\r\n        const sRa = star.ra_j2000;\r\n        if (sDec == null || sRa == null) return;\r\n        const starAngles = bodyAngles(sRa, sDec);\r\n\r\n        planetAnglesMap.forEach(pEntry => {\r\n            pEntry.angles.forEach(pAngle => {\r\n                starAngles.forEach(sAngle => {\r\n                    let diff = Math.abs(pAngle.ramc - sAngle.ramc);\r\n                    if (diff > 180) diff = 360 - diff;\r\n                    if (diff <= PARAN_ORB) {\r\n                        const comboKey = `${sAngle.type}-${pAngle.type}`;\r\n                        paranResults.push({\r\n                            planete: pEntry.name,\r\n                            etoile: sName,\r\n                            etoile_desc: ETOILE_DESC[sName] || \"\",\r\n                            angle_etoile: sAngle.type,\r\n                            angle_planete: pAngle.type,\r\n                            orb: Math.round(diff * 100) / 100,\r\n                            interpretation: PARAN_LABELS[comboKey] || `${sAngle.type} de l'étoile / ${pAngle.type} de la planète`,\r\n                            maison: getHouseNumber(etoilesFixesRaw.find(e => e.name?.fr === sName)?.fullDegree ?? 0),\r\n                            signe_planete: planetes.find(x => (x.planet?.fr || x.planet?.en) === pEntry.name)?.zodiac_sign?.name?.fr || \"\"\r\n                        });\r\n                    }\r\n                });\r\n            });\r\n        });\r\n    });\r\n}\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 6i. DÉCLINAISONS — Hors Limites (OOB), Parallèles, Contre-Parallèles\r\n// ─────────────────────────────────────────────────────────────────\r\nconst OOB_THRESHOLD      = OBLIQUITY;\r\nconst DECL_ORB_STANDARD  = 1.0;\r\nconst DECL_ORB_LUMINAIRE = 1.5;\r\nconst LUMINAIRES_DECL    = new Set([\"Soleil\", \"Lune\"]);\r\n\r\n// Tous les objets ayant un champ declinaison numérique (planètes, Chiron, petits corps, nœuds…)\r\nconst planetesDeclinees = planetes.filter(p => typeof p.declinaison === 'number');\r\n\r\n// A. Planètes / Objets Hors Limites (OOB)\r\nconst planeteOOB = [];\r\nplanetesDeclinees.forEach(p => {\r\n    const name = p.planet.fr || p.planet.en;\r\n    if (Math.abs(p.declinaison) > OOB_THRESHOLD) {\r\n        planeteOOB.push({\r\n            planete:     name,\r\n            declinaison: p.declinaison,\r\n            hemisphere:  p.declinaison > 0 ? \"Nord\" : \"Sud\",\r\n            depassement: parseFloat((Math.abs(p.declinaison) - OOB_THRESHOLD).toFixed(2))\r\n        });\r\n    }\r\n});\r\n\r\n// B. Parallèles (//) et Contre-Parallèles (#)\r\nconst paralleles       = [];\r\nconst contreParalleles = [];\r\nfor (let i = 0; i < planetesDeclinees.length; i++) {\r\n    for (let j = i + 1; j < planetesDeclinees.length; j++) {\r\n        const pA = planetesDeclinees[i], pB = planetesDeclinees[j];\r\n        const nameA = pA.planet.fr || pA.planet.en;\r\n        const nameB = pB.planet.fr || pB.planet.en;\r\n        const hasLuminaire = LUMINAIRES_DECL.has(nameA) || LUMINAIRES_DECL.has(nameB);\r\n        const orb = hasLuminaire ? DECL_ORB_LUMINAIRE : DECL_ORB_STANDARD;\r\n        const sameHemi = Math.sign(pA.declinaison) === Math.sign(pB.declinaison);\r\n        if (sameHemi) {\r\n            const diff = Math.abs(pA.declinaison - pB.declinaison);\r\n            if (diff <= orb) paralleles.push({\r\n                p1: nameA, decl1: pA.declinaison,\r\n                p2: nameB, decl2: pB.declinaison,\r\n                orb: parseFloat(diff.toFixed(2)), hasLuminaire,\r\n                hemisphere: pA.declinaison > 0 ? \"Nord\" : \"Sud\"\r\n            });\r\n        } else {\r\n            const diff = Math.abs(Math.abs(pA.declinaison) - Math.abs(pB.declinaison));\r\n            if (diff <= orb) contreParalleles.push({\r\n                p1: nameA, decl1: pA.declinaison,\r\n                p2: nameB, decl2: pB.declinaison,\r\n                orb: parseFloat(diff.toFixed(2)), hasLuminaire\r\n            });\r\n        }\r\n    }\r\n}\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 6j. SCORE DE PUISSANCE DES CONFIGURATIONS (tri multi-critères)\r\n// ─────────────────────────────────────────────────────────────────\r\nconst OOB_NAMES_SET         = new Set(planeteOOB.map(p => p.planete));\r\nconst ETOILE_CONJ_NAMES_SET = new Set(etoileMatches.map(em => em.planete));\r\nconst PARA_PAIRS_SET        = new Set([\r\n    ...paralleles.map(p => [p.p1, p.p2].sort().join(\"|\")),\r\n    ...contreParalleles.map(p => [p.p1, p.p2].sort().join(\"|\"))\r\n]);\r\nconst ANGLES_POWER_SET = new Set([\"Ascendant\", \"Milieu du Ciel\", \"Descendant\", \"Imum Coeli\"]);\r\nconst HIERARCHY_BASE_SCORE = {\r\n    \"Stellium\": 30, \"Grand Carré\": 30, \"Grand Trigone\": 30,\r\n    \"T-Carré\": 20, \"Cerf-Volant (Kite)\": 20, \"Yod — Doigt de Dieu\": 20,\r\n    \"Croix Cardinal\": 25, \"Croix Fixe\": 25, \"Croix Mutable\": 25\r\n};\r\n\r\nconfigurations.forEach(c => {\r\n    let score = HIERARCHY_BASE_SCORE[c.type] || 10;\r\n    const pList = c.planets || [];\r\n    // Facteur Luminaires\r\n    if (pList.some(p => LUMINAIRES_DECL.has(p)))        score += 50;\r\n    // Facteur Angles\r\n    if (pList.some(p => ANGLES_POWER_SET.has(p)))       score += 40;\r\n    // Facteur Étoile Fixe conjointe\r\n    if (pList.some(p => ETOILE_CONJ_NAMES_SET.has(p)))  score += 30;\r\n    // Facteur OOB\r\n    if (pList.some(p => OOB_NAMES_SET.has(p)))          score += 20;\r\n    // Facteur Parallèle/Contre-Parallèle (double validation — max +20 par figure)\r\n    let paraBonus = false;\r\n    for (let i = 0; i < pList.length && !paraBonus; i++)\r\n        for (let j = i + 1; j < pList.length && !paraBonus; j++)\r\n            if (PARA_PAIRS_SET.has([pList[i], pList[j]].sort().join(\"|\"))) paraBonus = true;\r\n    if (paraBonus) score += 20;\r\n    // Facteur d'exactitude : orbe moyen des aspects internes à la figure\r\n    const figAspects = aspects.filter(a => pList.includes(a.p1) && pList.includes(a.p2));\r\n    if (figAspects.length > 0) {\r\n        const orbeMoyen = figAspects.reduce((s, a) => s + parseFloat(a.exactitude), 0) / figAspects.length;\r\n        score += Math.max(0, Math.round(10 - orbeMoyen * 2));\r\n    }\r\n    c.puissanceScore = score;\r\n    c.prioriteLabel  = score >= 120 ? \"PRIORITÉ ABSOLUE\" : score >= 80 ? \"Majeure\" : score >= 50 ? \"Significative\" : \"Mineure\";\r\n});\r\n// Tri par score décroissant — les figures les plus puissantes en premier\r\nconfigurations.sort((a, b) => (b.puissanceScore || 0) - (a.puissanceScore || 0));\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 6j-bis. DÉDUPLICATION POST-CALCUL (marquage non-destructif)\r\n// Identifie les sous-configurations géométriquement contenues dans une figure parente.\r\n// Règles : Grand Carré ⊃ T-Carré | Cerf-Volant ⊃ Grand Trigone\r\n// N'affecte ni les scores, ni les aspects, ni le calcul — post-processing uniquement.\r\n// ─────────────────────────────────────────────────────────────────\r\nconst PARENT_CHILD_RULES = [\r\n    { parent: \"Grand Carré\",       child: \"T-Carré\" },\r\n    { parent: \"Cerf-Volant (Kite)\", child: \"Grand Trigone\" }\r\n];\r\n// Passe 1 : relations hiérarchiques (T-Carré ⊂ Grand Carré, Grand Trigone ⊂ Cerf-Volant)\r\nconfigurations.forEach(child => {\r\n    if (child.subConfigOf) return;\r\n    configurations.forEach(parent => {\r\n        if (child === parent || !parent.planets || !child.planets) return;\r\n        if (!child.planets.every(p => parent.planets.includes(p))) return;\r\n        const rule = PARENT_CHILD_RULES.find(r => r.parent === parent.type && r.child === child.type);\r\n        if (rule) { child.subConfigOf = parent.type; child.subConfigType = \"child\"; }\r\n    });\r\n});\r\n\r\n// Passe 2 : variantes du même type (ex: deux Grand Carrés partageant 3 planètes sur 4)\r\n// Règles de seuil par type :\r\n//   Stellium  → threshold = min (sous-ensemble strict : toutes les planètes du plus petit dans le plus grand)\r\n//   Autres    → threshold = min - 1 (N-1 planètes communes suffisent)\r\n// Pour Stellium : on garde le PLUS GRAND (plus de planètes). Pour les autres : le mieux scoré.\r\nconst OVERLAP_TYPES = new Set([\"Stellium\", \"Grand Carré\", \"T-Carré\", \"Grand Trigone\", \"Yod\", \"Cerf-Volant (Kite)\"]);\r\nconst confByType = {};\r\nconfigurations.forEach(c => {\r\n    if (!OVERLAP_TYPES.has(c.type) || c.subConfigOf) return;\r\n    (confByType[c.type] = confByType[c.type] || []).push(c);\r\n});\r\nObject.values(confByType).forEach(group => {\r\n    if (group.length < 2) return;\r\n    for (let i = 0; i < group.length; i++) {\r\n        for (let j = i + 1; j < group.length; j++) {\r\n            const a = group[i], b = group[j];\r\n            if (!a.planets || !b.planets || a.subConfigOf || b.subConfigOf) continue;\r\n            const shared = a.planets.filter(p => b.planets.includes(p));\r\n            const isStellium = a.type === \"Stellium\";\r\n            // Stellium : threshold = taille du plus petit (sous-ensemble complet requis)\r\n            // Autres   : threshold = min - 1\r\n            const threshold = isStellium\r\n                ? Math.min(a.planets.length, b.planets.length)\r\n                : Math.min(a.planets.length, b.planets.length) - 1;\r\n            if (shared.length >= threshold) {\r\n                let redundant;\r\n                if (isStellium) {\r\n                    // Garder le plus grand Stellium (plus de planètes = plus d'information)\r\n                    redundant = a.planets.length >= b.planets.length ? b : a;\r\n                } else {\r\n                    // Garder le mieux scoré\r\n                    [, redundant] = (a.puissanceScore || 0) >= (b.puissanceScore || 0) ? [a, b] : [b, a];\r\n                }\r\n                redundant.subConfigOf = a.type;\r\n                redundant.subConfigType = \"variant\";\r\n                redundant.sharedPlanets = shared.length;\r\n            }\r\n        }\r\n    }\r\n});\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 6k. SCORE DE PUISSANCE DES ASPECTS INDIVIDUELS (post-enrichissement)\r\n// Calculé ici (après 6b, 6h, 6i) pour avoir accès à tous les contextes :\r\n// angularPlanets, etoileMatches, OOB_NAMES_SET, LUMINAIRES_DECL\r\n// ─────────────────────────────────────────────────────────────────\r\nconst ASPECT_BASE_SCORES = {\r\n    \"Conjonction\": 10, \"Opposition\": 9, \"Carré\": 8, \"Trigone\": 7, \"Sextile\": 6,\r\n    \"Quinconce\": 3, \"Semi-Carré\": 2, \"Quintile\": 2, \"Sesqui-Carré\": 2,\r\n    \"Semi-Sextile\": 1, \"Biquintile\": 1\r\n};\r\naspects.forEach(a => {\r\n    const base       = ASPECT_BASE_SCORES[a.aspect] || 1;\r\n    const exactBonus = Math.max(0, Math.round(10 - parseFloat(a.exactitude) * 1.5));\r\n    let bonus = 0;\r\n    if (LUMINAIRES_DECL.has(a.p1)         || LUMINAIRES_DECL.has(a.p2))         bonus += 8;\r\n    if (ANGLES_POWER_SET.has(a.p1)        || ANGLES_POWER_SET.has(a.p2))        bonus += 6;\r\n    if (OOB_NAMES_SET.has(a.p1)           || OOB_NAMES_SET.has(a.p2))           bonus += 4;\r\n    if (ETOILE_CONJ_NAMES_SET.has(a.p1)   || ETOILE_CONJ_NAMES_SET.has(a.p2))  bonus += 5;\r\n    // Sprint 6 — B1 : bonus/malus nature planétaire\r\n    const n1 = PLANET_NATURES[a.p1], n2 = PLANET_NATURES[a.p2];\r\n    if (n1 === \"bénéfique\" && n2 === \"bénéfique\") bonus += 2;\r\n    else if (n1 === \"maléfique\" && n2 === \"maléfique\") bonus -= 1;\r\n    a.score        = base + exactBonus + bonus;\r\n    a.prioriteLabel = a.score >= 30 ? \"CAPITAL\" : a.score >= 20 ? \"FORT\" : a.score >= 12 ? \"MODÉRÉ\" : \"MINEUR\";\r\n    a.prioriteEmoji = a.score >= 30 ? \"🔴\" : a.score >= 20 ? \"🟠\" : a.score >= 12 ? \"🟡\" : \"⚪\";\r\n});\r\n// Tri global en place — toutes les fonctions avales héritent de cet ordre\r\naspects.sort((a, b) => b.score - a.score);\r\n\r\n// Flag isPromoted — Option B : seuil différencié petits corps vs planètes majeures\r\n// Si au moins UNE des deux planètes est un corps majeur → seuil 20 (FORT)\r\n// Si les DEUX sont des petits corps → seuil 28 (évite le bruit interprétatif)\r\nconst SMALL_BODIES_PROMO    = new Set([\"Vesta\",\"Cérès\",\"Ceres\",\"Pallas\",\"Junon\",\"Juno\",\"Lilith\"]);\r\nconst PROMO_THRESHOLD_CORE  = 20;\r\nconst PROMO_THRESHOLD_SMALL = 28;\r\naspects.forEach(a => {\r\n    if (a.isMajor !== false) { a.isPromoted = false; return; }\r\n    const bothSmall = SMALL_BODIES_PROMO.has(a.p1) && SMALL_BODIES_PROMO.has(a.p2);\r\n    const threshold = bothSmall ? PROMO_THRESHOLD_SMALL : PROMO_THRESHOLD_CORE;\r\n    a.isPromoted = a.score >= threshold;\r\n});\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 7. MAISONS ET DISPOSITIONS\r\n// ─────────────────────────────────────────────────────────────────\r\nlet signToHouses = {}; signs.forEach(s => signToHouses[s.fr] = []);\r\nmaisons.forEach((m, i) => {\r\n    let end = maisons[(i+1)%12].degree; if (end < m.degree) end += 360;\r\n    for (let s = Math.floor(m.degree/30); s <= Math.floor(end/30); s++) {\r\n        if (!signToHouses[signs[s%12].fr].includes(m.House)) signToHouses[signs[s%12].fr].push(m.House);\r\n    }\r\n});\r\n\r\nlet fiches_maisons = [], prompts = {};\r\nmaisons.forEach((m, i) => {\r\n    let nextM=maisons[(i+1)%12], start=m.degree, end=nextM.degree; if (end<start) end+=360;\r\n    let s_start=Math.floor(start/30), s_end=Math.floor(end/30);\r\n    let segments = [];\r\n\r\n    for (let s=s_start; s<=s_end; s++) {\r\n        let signId  = s % 12;\r\n        let signObj = signs[signId];\r\n        let type    = s===s_start ? \"Cuspide\" : (s===s_end ? \"Fin de Maison\" : \"Intercepté / Suite\");\r\n        let degDebut     = s===s_start ? m.normDegree : 0;\r\n        let decanCuspide = type===\"Cuspide\" ? (Math.min(Math.floor(degDebut/10),2)+1) : null;\r\n\r\n        let rulerP = planetes.find(p => p.planet.fr === signObj.ruler);\r\n        let proprioData = null;\r\n        if (rulerP) {\r\n            let p_sign   = rulerP.zodiac_sign?.name?.fr || \"Bélier\";\r\n            const _signObj = signs.find(sgn=>sgn.fr===p_sign);\r\n            if (!_signObj) continue;\r\n            let patronName = _signObj.ruler;\r\n            let patronP    = planetes.find(p=>p.planet.fr===patronName);\r\n            let patronData = (patronName!==signObj.ruler && patronP) ? { planete:patronName, maison:getHouseNumber(patronP.fullDegree), signe:patronP.zodiac_sign?.name?.fr || \"\" } : null;\r\n            proprioData = {\r\n                planete:signObj.ruler, retro:rulerP.retroStr, signe:p_sign, degre:rulerP.normDegree,\r\n                maison:getHouseNumber(rulerP.fullDegree), patron:patronData,\r\n                dignite:getDignity(signObj.ruler,p_sign),\r\n                helio: helioConditions[signObj.ruler] || null\r\n            };\r\n        }\r\n\r\n        let locs = planetes.filter(p => {\r\n            let inHouse = (start<nextM.degree) ? (p.fullDegree>=start && p.fullDegree<nextM.degree) : (p.fullDegree>=start || p.fullDegree<nextM.degree);\r\n            let inSign  = Math.floor(p.fullDegree/30) === signId;\r\n            return inHouse && inSign;\r\n        });\r\n\r\n        let locatairesData = locs.map(loc => {\r\n            let name    = loc.planet.fr;\r\n            let importH = [];\r\n            (planetRulerships[name]||[]).forEach(rs => (signToHouses[rs]||[]).forEach(h => { if(!importH.includes(h)) importH.push(h); }));\r\n            let dIndex       = Math.min(Math.floor(loc.normDegree/10), 2);\r\n            let p_sign       = signs[signId].fr;\r\n            let patronName   = signObj.ruler;\r\n            let patronP      = planetes.find(p=>p.planet.fr===patronName);\r\n            let patronData   = (patronName!==name && patronP) ? { nom:patronName, maison:getHouseNumber(patronP.fullDegree) } : null;\r\n            let decanRulerName  = CHALDEAN_DECANS[signs[signId].fr][dIndex];\r\n            let decanRulerP     = planetes.find(p=>p.planet.fr===decanRulerName);\r\n            let decanRulerHouse = decanRulerP ? getHouseNumber(decanRulerP.fullDegree) : \"?\";\r\n            let isAngular   = angularPlanets.find(ap=>ap.planet===name);\r\n            let isCritical  = criticalPlanets.find(cp=>cp.planet===name);\r\n            let minorStr    = getMinorAspectsStr(name);\r\n            const oobInfo   = planeteOOB.find(o => o.planete === name) || null;\r\n            const declAspects = [\r\n                ...paralleles.filter(p => p.p1 === name || p.p2 === name).map(p => ({\r\n                    type: \"//\", autre: p.p1 === name ? p.p2 : p.p1, orb: p.orb, hasLuminaire: p.hasLuminaire\r\n                })),\r\n                ...contreParalleles.filter(p => p.p1 === name || p.p2 === name).map(p => ({\r\n                    type: \"#\", autre: p.p1 === name ? p.p2 : p.p1, orb: p.orb, hasLuminaire: p.hasLuminaire\r\n                }))\r\n            ];\r\n            const termLord = getTermRuler(p_sign, loc.normDegree);\r\n            const termLordHouse = termLord ? getHouseNumber(planetes.find(pp => pp.planet.fr === termLord)?.fullDegree ?? 0) : null;\r\n            const triplicityRuler = getTriplicityRuler(p_sign);\r\n            const triplicityHouse = triplicityRuler ? getHouseNumber(planetes.find(pp => pp.planet.fr === triplicityRuler)?.fullDegree ?? 0) : null;\r\n            const triplicityPart = getTriplicityParticipant(p_sign);\r\n            const triplicityPartHouse = triplicityPart ? getHouseNumber(planetes.find(pp => pp.planet.fr === triplicityPart)?.fullDegree ?? 0) : null;\r\n            return {\r\n                planete:name, retro:loc.retroStr, degre:loc.normDegree, dignite:getDignity(name,p_sign),\r\n                sac_a_dos:{ signes:planetRulerships[name]||[], maisons:importH },\r\n                patron:patronData,\r\n                termLord: termLord ? { nom: termLord, maison: termLordHouse } : null,\r\n                triplicityRuler: triplicityRuler ? { nom: triplicityRuler, maison: triplicityHouse } : null,\r\n                triplicityParticipant: triplicityPart ? { nom: triplicityPart, maison: triplicityPartHouse } : null,\r\n                decan:{ num:dIndex+1, maitre:decanRulerName, maitreHouse:decanRulerHouse },\r\n                aspectsStr:         getMajorAspectsStr(name),\r\n                promotedAspectsStr: getPromotedMinorAspectsStr(name),\r\n                minorAspectsStr:    minorStr,\r\n                helio:       helioConditions[name] || null,\r\n                angular:     isAngular  ? `PLANÈTE ANGULAIRE — à ${isAngular.orb}° de ${isAngular.angle} (priorité maximale)` : null,\r\n                criticalDeg: isCritical ? isCritical.flags.join(\" | \") : null,\r\n                oob:         oobInfo,\r\n                declAspects,\r\n                planetName:  name\r\n            };\r\n        });\r\n        segments.push({ signe:signObj.fr, type, degre_debut:degDebut, decan:decanCuspide, maitre:proprioData, locataires:locatairesData });\r\n    }\r\n    fiches_maisons.push({ maison:m.House, segments });\r\n\r\n    // Vérifie si TOUS les segments de cette maison sont sans locataires\r\n    const isMaisonEntierementVide = segments.every(seg => seg.locataires.length === 0);\r\n\r\n    // ── PROMPT IA pour cette maison ──\r\n    const HOUSE_SIGNIF = {\r\n        1:  \"Identité, corps physique, tempérament, vitalité, apparence, comportement instinctif, vie en général\",\r\n        2:  \"Ressources personnelles, argent gagné, valeurs, talents innés, rapport à la matière et à la possession\",\r\n        3:  \"Communication, fratrie, déplacements courts, apprentissage, environnement immédiat, écriture, pensée quotidienne\",\r\n        4:  \"Foyer, famille, racines ancestrales, fin de vie, héritage psychique, parent nocturne (mère tradition moderne)\",\r\n        5:  \"Créativité, enfants, amour romantique, jeux, loisirs, spéculation, expression authentique du Moi\",\r\n        6:  \"Santé, travail quotidien, service rendu, hygiène de vie, animaux domestiques, subordination, routines\",\r\n        7:  \"Partenariat amoureux et professionnel, contrats, l'Autre comme miroir, mariage, adversaires déclarés\",\r\n        8:  \"Transformation, mort, héritage reçu, sexualité, ressources partagées, dette, l'occulte, crises régénératrices\",\r\n        9:  \"Voyages lointains, philosophie, spiritualité, enseignement supérieur, loi, étranger, quête de sens\",\r\n        10: \"Vocation, carrière, statut social, réputation publique, autorité, parent diurne (père tradition moderne), MC\",\r\n        11: \"Collectif, amis et réseaux, projets d'avenir, idéaux sociaux, associations, soutien reçu\",\r\n        12: \"Monde caché, retraite volontaire ou forcée, karma, épreuves, ennemis cachés, institutions, inconscient profond\"\r\n    };\r\n    let p = `Tu es un astrologue expert. Analyse la Maison ${m.House} en respectant strictement cette chronologie d'énergies.\\n`;\r\n    p += `Registre thématique (cadrage interprétatif uniquement — ne pas décrire la maison de façon générique) : ${HOUSE_SIGNIF[m.House]}.\\n`;\r\n    p += `INSTRUCTION : Utilise ce registre comme filtre pour ancrer chaque placement planétaire dans la vie concrète de cet individu. Ne pas expliquer ce que \"représente\" la Maison ${m.House} — les rapports descriptifs existent déjà en aval. Toute phrase doit être personnalisée (ex : \"ta relation à l'autorité est structurée par Saturne...\" plutôt que \"la Maison 10 représente la carrière...\").\\n`;\r\n    p += `Règles : 1) Maîtrises modernes (Pluton=Scorpion). 2) Décans Chaldéens.\\n`;\r\n    p += `\\n[SECT DU THÈME — Filtre interprétatif obligatoire]\\nType : ${sectStr}. Luminaire directeur = ${stats.sectLight}. Bénéfique de secte = ${stats.sectBenefic} (agit en pleine puissance). Maléfique tempéré (IN-secte) = ${stats.sectMalefic}. Maléfique HORS-secte (contra-secte, aggravé) = ${stats.contraSectMalefic}.\\n→ Appliquer ce filtre : si ${stats.sectBenefic} est dans cette maison, il y exerce sa bienveillance maximale. Si ${stats.contraSectMalefic} y est, ses tensions sont exacerbées.\\n⛔ Ne JAMAIS dire \"${stats.contraSectMalefic} est le maléfique de ta secte\" — ${stats.contraSectMalefic} est HORS-secte = aggravé.\\n`;\r\n    const rmHere = mutualReceptions.filter(r => r.house1 === m.House || r.house2 === m.House);\r\n    if (rmHere.length > 0) {\r\n        p += `\\n[RÉCEPTIONS MUTUELLES EN M${m.House}]\\n`;\r\n        rmHere.forEach(r => {\r\n            const typeLabel = r.type === \"domicile\" ? \"par domicile (puissante)\" : r.type === \"exaltation\" ? \"par exaltation\" : \"mixte (domicile/exaltation)\";\r\n            p += `- ${r.p1} (${r.sign1}, M${r.house1}) ↔ ${r.p2} (${r.sign2}, M${r.house2}) : réception mutuelle ${typeLabel} — coopération renforcée entre ces deux planètes, chacune dignifie l'autre.\\n`;\r\n        });\r\n    }\r\n\r\n    // Configurations actives dans cette maison\r\n    let houseConfs = configurations.filter(c => segments.some(seg => seg.locataires.some(l => c.planets && c.planets.includes(l.planete))));\r\n    if (houseConfs.length > 0) {\r\n        p += `\\n=== CONFIGURATIONS NATALES (planètes de cette maison impliquées, triées par Score de Puissance) ===\\n`;\r\n        p += `⚠ Ces configurations sont calculées par ASPECT ou par SIGNE — leurs planètes peuvent résider dans des maisons DIFFÉRENTES. Un \"Stellium ${segments[0]?.signe || \"\"}\" ne signifie PAS que toutes ses planètes sont dans M${m.House}. Seuls les LOCATAIRES listés ci-dessus résident physiquement dans cette maison.\\n`;\r\n        const houseSubConfs = houseConfs.filter(c => c.subConfigOf);\r\n        if (houseSubConfs.length > 0) p += `NOTE : Configurations marquées [composante de X] = planètes partagées avec la figure parente. Ne pas les traiter comme des événements indépendants.\\n`;\r\n        houseConfs.forEach(c => {\r\n            const scoreLabel = c.puissanceScore !== undefined ? ` [Score: ${c.puissanceScore} — ${c.prioriteLabel}]` : \"\";\r\n            const subNote    = c.subConfigOf\r\n                ? c.subConfigType === \"variant\"\r\n                    ? ` [variante du ${c.subConfigOf} — ${c.sharedPlanets} planètes communes — interpréter comme facette, ne pas doubler]`\r\n                    : ` [composante du ${c.subConfigOf} — même planètes, ne pas doubler l'interprétation]`\r\n                : \"\";\r\n            p += `  [${c.type}]${scoreLabel} ${c.description}${subNote}\\n`;\r\n        });\r\n    }\r\n\r\n    segments.forEach((seg, idx) => {\r\n        let mHStr   = seg.maitre?.dignite !== \"-\" ? ` — État: ${seg.maitre.dignite}` : \"\";\r\n        let mHelio  = seg.maitre?.helio?.condition ? ` ⚠ ÉTAT SOLAIRE: ${seg.maitre.helio.condition}` : \"\";\r\n        if (seg.type === \"Cuspide\") {\r\n            p += `\\n1. OUVERTURE (Cuspide) : ${seg.signe} à ${seg.degre_debut.toFixed(2)}°, Décan ${seg.decan} Chaldéen.\\n`;\r\n            // Étoiles fixes sur la pointe (cuspide) de cette maison\r\n            const cuspStars = etoileCuspMatches.filter(ec => ec.maison === m.House);\r\n            if (cuspStars.length > 0) {\r\n                cuspStars.forEach(ec => {\r\n                    p += `   ★ ÉTOILE FIXE SUR L'ANGLE ${ec.angle} (M${m.House}) : ${ec.etoile} (${ec.etoile_en}) — orbe ${ec.orb}°, ${ec.precision}\\n`;\r\n                    p += `     → ${ec.desc}\\n`;\r\n                    p += `     → INSTRUCTION : Cette étoile fixe teinte l'identité FONDAMENTALE de l'angle ${ec.angle} (Maison ${m.House}). Son influence est permanente et structure en profondeur tous les thèmes de cet angle, qu'il y ait ou non des locataires.\\n`;\r\n                });\r\n            }\r\n            p += `   Maître du signe de la cuspide : ${seg.maitre.planete}${seg.maitre.retro} en M${seg.maitre.maison} (${seg.maitre.signe}${mHStr})${mHelio}. [NB : ce \"Maître\" est le ruler du signe ${seg.signe} — à ne PAS confondre avec le Gouverneur du thème ni l'Almutem Figuris]\\n`;\r\n            p += `   Aspects du maître : ${getMajorAspectsStr(seg.maitre.planete)}.\\n`;\r\n            if (seg.maitre.patron) p += `   Chaîne : ${seg.signe} → M${seg.maitre.maison} → finalité M${seg.maitre.patron.maison} (${seg.maitre.patron.planete}).\\n`;\r\n            else                   p += `   Chaîne : énergie de ${seg.signe} trouve sa finalité en M${seg.maitre.maison} (${seg.maitre.planete} en domicile).\\n`;\r\n        } else {\r\n            p += `\\n${idx+1}. SUITE (${seg.type}) : ${seg.signe}. Maître du signe : ${seg.maitre.planete}${seg.maitre.retro} (M${seg.maitre.maison}${mHStr})${mHelio}. Aspects : ${getMajorAspectsStr(seg.maitre.planete)}.\\n`;\r\n        }\r\n        if (seg.locataires.length > 0) {\r\n            p += `   LOCATAIRES EN ${seg.signe.toUpperCase()} :\\n`;\r\n            seg.locataires.forEach(l => {\r\n                const isLot = LOTS_MATHEMATIQUES.has(l.planete);\r\n                let digStr = l.dignite !== \"-\" ? ` (${l.dignite})` : \"\";\r\n                p += `      * ${l.planete}${l.retro} à ${l.degre.toFixed(2)}°${isLot ? \"\" : digStr}`;\r\n                if (isLot) {\r\n                    p += `\\n        - Aspects majeurs : ${l.aspectsStr}.\\n`;\r\n                } else {\r\n                    if (l.angular)     p += `\\n        ⭐ ${l.angular}`;\r\n                    if (l.criticalDeg) p += `\\n        ⚠ DEGRÉ CRITIQUE : ${l.criticalDeg}`;\r\n                    if (l.retro && l.retro.includes(\"Rétrograde\")) p += `\\n        ↩ RÉTROGRADE : principe intériorisé, expression différée ou révisée`;\r\n                    if (l.helio?.condition)   p += `\\n        ☀ ÉTAT SOLAIRE : ${l.helio.condition}`;\r\n                    if (l.helio?.orientation) p += ` | ${l.helio.orientation}`;\r\n                    if (l.oob) p += `\\n        ⚡ OOB : ${l.oob.declinaison.toFixed(2)}° ${l.oob.hemisphere} (+${l.oob.depassement}°)`;\r\n                    if (l.declAspects?.length > 0) l.declAspects.forEach(da => {\r\n                        const typeLabel = da.type === \"//\" ? \"// PARALLÈLE\" : \"# CONTRE-PARALLÈLE\";\r\n                        const lumTag    = da.hasLuminaire ? \" [LUMINAIRE]\" : \"\";\r\n                        p += `\\n        ${typeLabel} avec ${da.autre} (orbe ${da.orb}°)${lumTag}`;\r\n                    });\r\n                    const etoilesLoc = etoileMatches.filter(em => em.planete === l.planete);\r\n                    if (etoilesLoc.length > 0) {\r\n                        etoilesLoc.forEach(em => {\r\n                            p += `\\n        ★ ÉTOILE FIXE : ${em.etoile} (${em.etoile_en}), orbe ${em.orb}°, ${em.precision}`;\r\n                            p += `\\n          → ${em.desc}`;\r\n                        });\r\n                    }\r\n                    p += `\\n`;\r\n                    p += `        - Décan Chaldéen ${l.decan.num}, co-gouverné par ${l.decan.maitre} (M${l.decan.maitreHouse}).\\n`;\r\n                    if (l.termLord) p += `        - Terme : ${l.termLord.nom} (M${l.termLord.maison}).\\n`;\r\n                    if (l.triplicityRuler) p += `        - Triplicité : ${l.triplicityRuler.nom} (M${l.triplicityRuler.maison}).\\n`;\r\n                    if (l.triplicityParticipant) p += `        - Triplicité participante : ${l.triplicityParticipant.nom} (M${l.triplicityParticipant.maison}).\\n`;\r\n                    p += `        - Sac à dos : ${l.sac_a_dos.maisons.length > 0 ? \"M\" + l.sac_a_dos.maisons.join(\" et M\") : \"(aucune maîtrise)\"}.\\n`;\r\n                    p += `        - Patron : ${l.patron ? l.patron.nom+\" en M\"+l.patron.maison : \"Domicile\"}.\\n`;\r\n                    p += `        - Aspects majeurs : ${l.aspectsStr}.\\n`;\r\n                    if (l.promotedAspectsStr) {\r\n                        p += `\\n        ⚠ ASPECTS MINEURS PROMUS :\\n${l.promotedAspectsStr}\\n`;\r\n                    }\r\n                }\r\n            });\r\n        } else {\r\n            p += `   Aucun locataire physique dans ce segment (${seg.signe}).\\n`;\r\n            if (isMaisonEntierementVide) {\r\n                p += `   → INSTRUCTION LLM : Cette maison est entièrement vide. Sa dynamique est régie EXCLUSIVEMENT par le maître du signe de sa cuspide (${seg.maitre.planete}). Pivoter directement vers sa position en M${seg.maitre.maison}${seg.maitre.dignite && seg.maitre.dignite !== \"-\" ? ` (${seg.maitre.dignite})` : \"\"}, ses aspects et son propre maître de signe. Ne pas commenter l'absence de planète.\\n`;\r\n            }\r\n        }\r\n    });\r\n    const locCount = segments.reduce((n,s) => n + (s.locataires?.length || 0), 0);\r\n    const aspCount = segments.reduce((n,s) => n + s.locataires.reduce((a,l) => a + (l.aspectsStr?.split(\",\").length || 0), 0), 0);\r\n    if (isMaisonEntierementVide) {\r\n        p += `\\n[TOKEN BUDGET : 15-25 lignes — maison vide, pivoter sur le Maître]`;\r\n    } else if (locCount >= 3 || aspCount >= 8) {\r\n        p += `\\n[TOKEN BUDGET : 40-60 lignes — maison très chargée, développer en profondeur]`;\r\n    } else {\r\n        p += `\\n[TOKEN BUDGET : 25-40 lignes — développement standard]`;\r\n    }\r\n    const rappelLines = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\"].map(n => {\r\n        const pl = planetes.find(x => x.planet?.fr === n);\r\n        return pl ? `${n} M${getHouseNumber(pl.fullDegree)}(${pl.zodiac_sign?.name?.fr || \"?\"})` : null;\r\n    }).filter(Boolean);\r\n    p += `\\n\\n[RAPPEL FINAL — POSITIONS : ${rappelLines.join(\" | \")}]\\n⛔ Vérifier chaque mention de maison/signe avant de rédiger.`;\r\n    prompts[`maison_${m.House}`] = p;\r\n});\r\n\r\n// 6e-quint. SIGNES INTERCEPTÉS — détection explicite (post fiches_maisons)\r\nconst interceptedSigns = [];\r\nfiches_maisons.forEach(fm => {\r\n    fm.segments.forEach(seg => {\r\n        if (seg.type === \"Intercepté / Suite\" || seg.type === \"Intercepté\") {\r\n            const planetsInIntercepted = planetes.filter(p => {\r\n                const pSign = p.zodiac_sign?.name?.fr;\r\n                const house = getHouseNumber(p.fullDegree);\r\n                return pSign === seg.signe && house === fm.maison;\r\n            }).map(p => p.planet?.fr || p.planet?.en || \"\");\r\n            interceptedSigns.push({\r\n                sign: seg.signe, house: fm.maison,\r\n                planets: planetsInIntercepted.filter(Boolean),\r\n                description: planetsInIntercepted.length > 0\r\n                    ? `${seg.signe} intercepté en M${fm.maison} — ${planetsInIntercepted.join(\", \")} piégé(s) dans ce signe, énergie bloquée qui demande un effort conscient d'expression`\r\n                    : `${seg.signe} intercepté en M${fm.maison} — les thématiques de ce signe sont latentes et difficiles d'accès dans cette maison`\r\n            });\r\n        }\r\n    });\r\n});\r\n\r\n// ── Sprint 6 — Module B2 : Profil de sensibilité élémentaire/modale ──\r\nconst ELEMENT_TRANSIT_MAP = {\r\n    \"Feu\":[\"Mars\",\"Jupiter\"],\"Terre\":[\"Saturne\",\"Vénus\"],\r\n    \"Air\":[\"Uranus\",\"Mercure\"],\"Eau\":[\"Neptune\",\"Pluton\"]\r\n};\r\nconst computeSensitivityProfile = (elStats, moStats) => {\r\n    const total = Object.values(elStats).reduce((a,b)=>a+b,0) || 12;\r\n    const lines = [];\r\n    Object.entries(elStats).forEach(([element, count]) => {\r\n        const ratio = count / total;\r\n        const affiliated = ELEMENT_TRANSIT_MAP[element]?.join(\"/\") || \"\";\r\n        if (ratio <= 0.15) {\r\n            lines.push(`VULNÉRABILITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} peuvent être particulièrement déstabilisants car le thème manque de récepteurs naturels dans cet élément. L'intégration demande un effort conscient.`);\r\n        } else if (ratio >= 0.35) {\r\n            lines.push(`FAMILIARITÉ ${element.toUpperCase()} (${count}/${total}) : les transits de ${affiliated} sont dans la \"langue maternelle\" du thème — leur énergie est reconnue et plus facilement intégrée, même si l'aspect est tendu.`);\r\n        }\r\n    });\r\n    if (moStats.Fixe >= 5) {\r\n        lines.push(`RÉSISTANCE AU CHANGEMENT (Fixe: ${moStats.Fixe}) : les transits d'Uranus et de Pluton sur les positions fixes seront vécus avec une intensité maximale — la structure résiste avant de céder brusquement.`);\r\n    }\r\n    if (moStats.Mutable >= 5) {\r\n        lines.push(`ADAPTABILITÉ ÉLEVÉE (Mutable: ${moStats.Mutable}) : bonne capacité d'intégration des transits, mais risque de dispersion ou de perte de cap sous Neptune.`);\r\n    }\r\n    if (lines.length === 0) return \"\";\r\n    return `\\n=== PROFIL DE SENSIBILITÉ DU THÈME ===\\n${lines.join(\"\\n\")}\\n→ INSTRUCTION : module ton interprétation en tenant compte de ces sensibilités. Un transit \"harmonique\" dans un élément déficitaire peut quand même déstabiliser. Un transit \"tendu\" dans un élément familier sera mieux intégré que prévu.\\n`;\r\n};\r\nconst sensitivityProfileTheme = computeSensitivityProfile(stats.elements, stats.modes);\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 8. PROMPT SYNTHÈSE GLOBALE (Prompt 13)\r\n// ─────────────────────────────────────────────────────────────────\r\nlet mc  = planetes.find(p => p.planet.fr === \"Milieu du Ciel\");\r\nlet ns  = planetes.find(p => p.planet.fr === \"Nœud Sud\");\r\nlet pof = planetes.find(p => p.planet.fr === \"Part de Fortune\");\r\nlet pos = planetes.find(p => p.planet.fr === \"Lot de l'Esprit\");\r\n\r\nlet ascSign       = asc?.zodiac_sign?.name?.fr || null;\r\nlet chartRulerName = ascSign ? signs.find(s => s.fr === ascSign)?.ruler : null;\r\nlet chartRuler    = chartRulerName ? planetes.find(p => p.planet.fr === chartRulerName) : null;\r\nstats.chart_ruler = chartRulerName || null;\r\nconst MAITRES_TRAD_THEME = {\r\n    \"Bélier\":\"Mars\",\"Taureau\":\"Vénus\",\"Gémeaux\":\"Mercure\",\"Cancer\":\"Lune\",\r\n    \"Lion\":\"Soleil\",\"Vierge\":\"Mercure\",\"Balance\":\"Vénus\",\"Scorpion\":\"Mars\",\r\n    \"Sagittaire\":\"Jupiter\",\"Capricorne\":\"Saturne\",\"Verseau\":\"Saturne\",\"Poissons\":\"Jupiter\"\r\n};\r\nlet chartRulerTradName = ascSign ? MAITRES_TRAD_THEME[ascSign] : null;\r\nlet chartRulerTrad = (chartRulerTradName && chartRulerTradName !== chartRulerName) ? planetes.find(p => p.planet.fr === chartRulerTradName) : null;\r\nstats.chart_ruler_trad = (chartRulerTradName && chartRulerTradName !== chartRulerName) ? chartRulerTradName : null;\r\n\r\nlet pSynth = `Tu es un astrologue expert. Fais la synthèse globale de ce thème natal en utilisant les maîtrises modernes.\\n\\n`;\r\n\r\npSynth += `=== IDENTITÉ DU THÈME ===\\n`;\r\npSynth += `Type : ${sectStr}.\\n`;\r\npSynth += `Éléments : Feu(${stats.elements.Feu}) Terre(${stats.elements.Terre}) Air(${stats.elements.Air}) Eau(${stats.elements.Eau}).\\n`;\r\npSynth += `Modes : Cardinal(${stats.modes.Cardinal}) Fixe(${stats.modes.Fixe}) Mutable(${stats.modes.Mutable}).\\n`;\r\npSynth += `Secte : Luminaire = ${stats.sectLight}, Bénéfique de secte = ${stats.sectBenefic}, Maléfique tempéré = ${stats.sectMalefic}, Maléfique aggravé (contra-secte) = ${stats.contraSectMalefic}.\\n`;\r\npSynth += `→ INSTRUCTION : Le ${stats.sectLight} est le luminaire directeur (${sectStr}). ${stats.sectBenefic} agit en pleine puissance bénéfique, ${stats.sectMalefic} est le maléfique tempéré (IN-secte). ${stats.contraSectMalefic} est le maléfique HORS-secte (contra-secte) = le plus nuisible.\\n`;\r\npSynth += `⛔ TERMINOLOGIE OBLIGATOIRE : ${stats.sectMalefic} = \"maléfique tempéré\" ou \"maléfique de secte\". ${stats.contraSectMalefic} = \"maléfique hors-secte\" ou \"maléfique aggravé (contra-secte)\". Ne JAMAIS dire \"${stats.contraSectMalefic} est le maléfique de ta secte\" — c'est FAUX, ${stats.contraSectMalefic} est HORS de la secte ${sectStr.split(\" \")[0].toLowerCase()}.\\n`;\r\n\r\nif (sensitivityProfileTheme) pSynth += sensitivityProfileTheme;\r\n\r\nif (configurations.length > 0) {\r\n    pSynth += `\\n=== CONFIGURATIONS NATALES MAJEURES (triées par Score de Puissance décroissant) ===\\n`;\r\n    pSynth += `Légende scores : PRIORITÉ ABSOLUE ≥120 | Majeure ≥80 | Significative ≥50 | Mineure <50\\n`;\r\n    const hasSubs = configurations.some(c => c.subConfigOf);\r\n    const hasVariants = configurations.some(c => c.subConfigType === \"variant\");\r\n    if (hasSubs) pSynth += `INSTRUCTION : Les configurations marquées [composante de X] sont géométriquement contenues dans la figure parente — interpréter comme facettes, NON comme événements distincts.\\n`;\r\n    if (hasVariants) pSynth += `INSTRUCTION : Les configurations marquées [variante de X] partagent la majorité de leurs planètes avec une figure de même type déjà listée — ne pas doubler l'interprétation.\\n`;\r\n    configurations.forEach(c => {\r\n        const scoreLabel = c.puissanceScore !== undefined ? ` [Score: ${c.puissanceScore} — ${c.prioriteLabel}]` : \"\";\r\n        const subNote    = c.subConfigOf\r\n            ? c.subConfigType === \"variant\"\r\n                ? ` [variante du ${c.subConfigOf} — ${c.sharedPlanets} planètes communes — ne pas doubler l'interprétation]`\r\n                : ` [composante du ${c.subConfigOf} — ne pas doubler l'interprétation]`\r\n            : \"\";\r\n        pSynth += `  [${c.type}]${scoreLabel} ${c.description}${subNote}\\n`;\r\n    });\r\n}\r\nif (stationaryPlanets.length > 0) {\r\n    pSynth += `\\n=== PLANÈTES STATIONNAIRES (énergie concentrée, marqueur de premier ordre) ===\\n`;\r\n    stationaryPlanets.forEach(sp => { pSynth += `  ${sp.planet} ${sp.direction} en ${sp.sign} (M${sp.house}) — vitesse ${sp.speed}°/jour (seuil ${sp.threshold}°/jour)\\n`; });\r\n}\r\nif (angularPlanets.length > 0) {\r\n    pSynth += `\\n=== PLANÈTES ANGULAIRES (priorité maximale d'interprétation) ===\\n`;\r\n    angularPlanets.forEach(ap => { pSynth += `  ${ap.planet} à ${ap.orb}° de ${ap.angle} (M${ap.house}, ${ap.sign})\\n`; });\r\n}\r\nif (criticalPlanets.length > 0) {\r\n    pSynth += `\\n=== DEGRÉS CRITIQUES ===\\n`;\r\n    criticalPlanets.forEach(cp => { pSynth += `  ${cp.planet} à ${cp.degree}° ${cp.sign} : ${cp.flags.join(\" | \")}\\n`; });\r\n}\r\nif (mutualReceptions.length > 0) {\r\n    pSynth += `\\n=== RÉCEPTIONS MUTUELLES ===\\n`;\r\n    mutualReceptions.forEach(mr => {\r\n        const mrDesc = mr.type === \"exaltation\"\r\n            ? \"réception mutuelle par EXALTATION — coopération inspirée, élan créateur mutuel\"\r\n            : \"réception mutuelle par DOMICILE — coopération profonde, échange de ressources structurel\";\r\n        pSynth += `  ${mr.p1} (${mr.sign1}, M${mr.house1}) ↔ ${mr.p2} (${mr.sign2}, M${mr.house2}) : ${mrDesc}\\n`;\r\n    });\r\n}\r\nif (interceptedSigns.length > 0) {\r\n    pSynth += `\\n=== SIGNES INTERCEPTÉS (énergie bloquée, latence) ===\\n`;\r\n    interceptedSigns.forEach(is => { pSynth += `  ${is.description}\\n`; });\r\n}\r\npSynth += `\\n=== FORME DU THÈME (Jones Pattern) ===\\n  ${chartShape.shape} : ${chartShape.description}\\n`;\r\nif (chartShape.singleton) {\r\n    const singletonPlanet = planetes.find(p => p.planet.fr === chartShape.singleton);\r\n    const singletonHouse = singletonPlanet ? getHouseNumber(singletonPlanet.fullDegree) : \"?\";\r\n    const singletonSign = singletonPlanet?.zodiac_sign?.name?.fr || \"?\";\r\n    const singletonRetro = singletonPlanet?.retroStr || \"\";\r\n    pSynth += `→ INSTRUCTION PRIORITAIRE : Le singleton ${chartShape.singleton}${singletonRetro} en M${singletonHouse} (${singletonSign}) est le CANAL PRINCIPAL par lequel toute l'énergie planétaire du thème est focalisée et exprimée. Ce singleton doit être traité comme un PILIER INTERPRÉTATIF MAJEUR, au même titre que le Gouverneur et l'Almutem. Sa maison (M${singletonHouse}), son signe, ses aspects et sa dignité déterminent COMMENT le natif distribue et concentre ses forces vitales. Ne JAMAIS omettre le singleton dans la synthèse.\\n`;\r\n}\r\nif (antiscia.length > 0) {\r\n    pSynth += `\\n=== ANTISCIA & CONTRA-ANTISCIA (connexions cachées) ===\\n`;\r\n    antiscia.slice(0, 10).forEach(a => { pSynth += `  ${a.p1} — ${a.p2} : ${a.type} (orbe ${a.orb}°)\\n`; });\r\n}\r\nif (midpointActivations.length > 0) {\r\n    pSynth += `\\n=== MIDPOINTS ACTIVÉS ===\\n`;\r\n    midpointActivations.slice(0,12).forEach(ma => { pSynth += `  ${ma.activator} active le midpoint ${ma.midpoint} (${ma.type}, orbe ${ma.orb}°)\\n`; });\r\n}\r\nlet helioAlerts = Object.keys(helioConditions).filter(k => helioConditions[k].condition);\r\nif (helioAlerts.length > 0) {\r\n    pSynth += `\\n=== CONDITIONS HÉLIOCENTRIQUES (rapport au Soleil natal) ===\\n`;\r\n    helioAlerts.forEach(k => { pSynth += `  ${k} : ${helioConditions[k].condition}\\n`; });\r\n}\r\n\r\nif (planeteOOB.length > 0) {\r\n    pSynth += `\\n=== ⚡ PLANÈTES / OBJETS HORS LIMITES (Out of Bounds — OOB) ===\\n`;\r\n    pSynth += `Seuil : déclinaison > ±${OOB_THRESHOLD}°. Ces objets échappent symboliquement à l'autorité du Soleil.\\n`;\r\n    planeteOOB.forEach(o => {\r\n        pSynth += `  ⚡ ${o.planete} : ${o.declinaison.toFixed(2)}° ${o.hemisphere} (dépasse le seuil de +${o.depassement}°) — énergie exacerbée, imprévisible, électron libre\\n`;\r\n    });\r\n    pSynth += `→ INSTRUCTION : Interpréter le principe de chaque objet OOB comme amplifié et hors-normes. Son expression peut être géniale, excessive ou disruptive selon le reste du thème. Les OOB sont des marqueurs de singularité psychologique forte.\\n`;\r\n}\r\npSynth += `\\n⭐ ÉTOILES ROYALES : seules 4 étoiles portent ce titre — Aldébaran, Régulus, Antarès, Fomalhaut. Toute autre étoile (Bételgeuse, Spica, Sirius, Algol, etc.) est une \"Étoile Fixe majeure\", JAMAIS \"Royale\".\\n`;\r\n\r\nif (paralleles.length > 0 || contreParalleles.length > 0) {\r\n    pSynth += `\\n=== PARALLÈLES & CONTRE-PARALLÈLES DE DÉCLINAISON (3e dimension équatoriale) ===\\n`;\r\n    pSynth += `Orbes appliqués : ${DECL_ORB_STANDARD}° standard | ${DECL_ORB_LUMINAIRE}° si Luminaire impliqué.\\n`;\r\n    if (paralleles.length > 0) {\r\n        const topPar = paralleles.sort((a,b) => (a.hasLuminaire?0:1)-(b.hasLuminaire?0:1) || a.orb-b.orb).slice(0, 10);\r\n        pSynth += `PARALLÈLES (//) — Top ${topPar.length} (conjonctions profondes) :\\n`;\r\n        topPar.forEach(p => {\r\n            const h = p.hemisphere.charAt(0);\r\n            const lumTag = p.hasLuminaire ? \" ★ LUMINAIRE\" : \"\";\r\n            pSynth += `  // ${p.p1} (${p.decl1.toFixed(2)}°${h}) // ${p.p2} (${p.decl2.toFixed(2)}°${h}) — orbe ${p.orb}°${lumTag}\\n`;\r\n        });\r\n    }\r\n    if (contreParalleles.length > 0) {\r\n        const topCP = contreParalleles.sort((a,b) => (a.hasLuminaire?0:1)-(b.hasLuminaire?0:1) || a.orb-b.orb).slice(0, 8);\r\n        pSynth += `CONTRE-PARALLÈLES (#) — Top ${topCP.length} (oppositions profondes) :\\n`;\r\n        topCP.forEach(p => {\r\n            const h1 = p.decl1 > 0 ? \"N\" : \"S\", h2 = p.decl2 > 0 ? \"N\" : \"S\";\r\n            const lumTag = p.hasLuminaire ? \" ★ LUMINAIRE\" : \"\";\r\n            pSynth += `  # ${p.p1} (${p.decl1.toFixed(2)}°${h1}) # ${p.p2} (${p.decl2.toFixed(2)}°${h2}) — orbe ${p.orb}°${lumTag}\\n`;\r\n        });\r\n    }\r\n    pSynth += `→ INSTRUCTION : Un parallèle fusionne les principes des deux planètes (comme une conjonction). Un contre-parallèle crée une tension entre eux (comme une opposition). Ces aspects opèrent dans la dimension équatoriale, souvent plus profonds psychologiquement que leurs homologues en longitude. Ils renforcent ou complexifient les aspects en longitude existants entre les mêmes planètes.\\n`;\r\n}\r\n\r\npSynth += `\\n=== PILIERS DU THÈME ===\\n`;\r\nif (sun) {\r\n    pSynth += `Cœur (Soleil) en ${sun.zodiac_sign?.name?.fr || \"?\"} (M${sunHouse}). Aspects majeurs : ${getMajorAspectsStr(\"Soleil\")}\\n`;\r\n    const sunPromo = getPromotedMinorAspectsStr(\"Soleil\");\r\n    if (sunPromo) pSynth += `   ⚠ Aspects mineurs promus du Soleil :\\n${sunPromo}\\n`;\r\n}\r\nif (moon) {\r\n    pSynth += `Émotion (Lune) en ${moon.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(moon.fullDegree)}). Aspects majeurs : ${getMajorAspectsStr(\"Lune\")}\\n`;\r\n    const moonPromo = getPromotedMinorAspectsStr(\"Lune\");\r\n    if (moonPromo) pSynth += `   ⚠ Aspects mineurs promus de la Lune :\\n${moonPromo}\\n`;\r\n}\r\nif (asc)       pSynth += `Ascendant en ${ascSign}. Aspects : ${getMajorAspectsStr(\"Ascendant\")}\\n`;\r\nif (mc)        pSynth += `MC en ${mc.zodiac_sign?.name?.fr || \"?\"}. Aspects : ${getMajorAspectsStr(\"Milieu du Ciel\")}\\n`;\r\nif (chartRuler) {\r\n    let cr_sign   = chartRuler.zodiac_sign?.name?.fr || \"?\";\r\n    let cr_dig    = getDignity(chartRulerName, cr_sign);\r\n    let cr_digStr = cr_dig !== \"-\" ? ` — ${cr_dig}` : \"\";\r\n    let cr_helio  = helioConditions[chartRulerName]?.condition ? ` | ☀ ${helioConditions[chartRulerName].condition}` : \"\";\r\n    pSynth += `GOUVERNEUR DU THÈME (moderne) : ${chartRulerName}${chartRuler.retroStr} en M${getHouseNumber(chartRuler.fullDegree)} (${cr_sign}${cr_digStr})${cr_helio}. Aspects majeurs : ${getMajorAspectsStr(chartRulerName)}.\\n`;\r\n    const crPromo = getPromotedMinorAspectsStr(chartRulerName);\r\n    if (crPromo) pSynth += `   ⚠ Aspects mineurs promus du gouverneur :\\n${crPromo}\\n`;\r\n    if (chartRulerTrad) {\r\n        let crt_sign   = chartRulerTrad.zodiac_sign?.name?.fr || \"?\";\r\n        let crt_dig    = getDignity(chartRulerTradName, crt_sign);\r\n        let crt_digStr = crt_dig !== \"-\" ? ` — ${crt_dig}` : \"\";\r\n        let crt_helio  = helioConditions[chartRulerTradName]?.condition ? ` | ☀ ${helioConditions[chartRulerTradName].condition}` : \"\";\r\n        pSynth += `CO-MAÎTRE TRADITIONNEL : ${chartRulerTradName}${chartRulerTrad.retroStr} en M${getHouseNumber(chartRulerTrad.fullDegree)} (${crt_sign}${crt_digStr})${crt_helio}. Aspects : ${getMajorAspectsStr(chartRulerTradName)}.\\n`;\r\n    }\r\n}\r\nif (pof) pSynth += `PART DE FORTUNE (abondance/réussite) : ${pof.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(pof.fullDegree)}). Aspects : ${getMajorAspectsStr(\"Part de Fortune\")}\\n`;\r\nif (pos) pSynth += `LOT DE L'ESPRIT (vocation/conscience) : ${pos.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(pos.fullDegree)}). Aspects : ${getMajorAspectsStr(\"Lot de l'Esprit\")}\\n`;\r\n\r\n// Sprint 7 — Action 6 : Lots hermétiques dans la synthèse\r\nconst LOTS_META = [\r\n    {fr:\"Lot de Nécessité\", desc:\"contraintes, épreuves inévitables, karma\"},\r\n    {fr:\"Lot d'Éros\", desc:\"passion, attraction, élan vital\"},\r\n    {fr:\"Lot de Courage\", desc:\"audace, initiative, affirmation combative\"},\r\n    {fr:\"Lot de Némésis\", desc:\"épreuves saturniennes, leçons, limites structurantes\"},\r\n    {fr:\"Lot de Basis\", desc:\"fondement matériel, socle existentiel\"},\r\n    {fr:\"Lot d'Exaltation\", desc:\"dignité, ambition, élévation\"},\r\n    {fr:\"Lot du Daemon\", desc:\"génie personnel, vocation profonde, daimon socratique\"}\r\n];\r\nLOTS_META.forEach(lm => {\r\n    const lotP = planetes.find(p => p.planet.fr === lm.fr);\r\n    if (lotP) {\r\n        const h = getHouseNumber(lotP.fullDegree);\r\n        const asp = getMajorAspectsStr(lm.fr);\r\n        pSynth += `${lm.fr.toUpperCase()} (${lm.desc}) : ${lotP.zodiac_sign?.name?.fr || \"?\"} (M${h})${asp ? \". Aspects : \" + asp : \"\"}\\n`;\r\n    }\r\n});\r\n\r\nif (nn && ns)  pSynth += `AXE KARMIQUE : Nœud Sud ${ns.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(ns.fullDegree)}) → Nœud Nord ${nn.zodiac_sign?.name?.fr || \"?\"} (M${getHouseNumber(nn.fullDegree)}).\\n`;\r\n\r\nif (etoileMatches.length > 0) {\r\n    pSynth += `\\n=== ÉTOILES FIXES — CONJONCTIONS PLANÈTES NATALES ===\\n`;\r\n    etoileMatches.forEach(em => {\r\n        const angleTag = em.isAngle ? \" [ANGLE]\" : \"\";\r\n        pSynth += `  ★ ${em.planete}${angleTag} (M${em.maison}, ${em.signe}) conjoint ${em.etoile} — orbe ${em.orb}°, ${em.precision}\\n`;\r\n    });\r\n    pSynth += `→ INSTRUCTION : Signatures stellaires permanentes — marqueurs de destin (détail dans les prompts maison).\\n`;\r\n}\r\nif (etoileCuspMatches.length > 0) {\r\n    pSynth += `\\n=== ÉTOILES FIXES — ANGLES (ASC/IC/DSC/MC) ===\\n`;\r\n    etoileCuspMatches.forEach(ec => {\r\n        pSynth += `  ★ ${ec.angle} M${ec.maison} conjoint ${ec.etoile} — orbe ${ec.orb}°, ${ec.precision}\\n`;\r\n    });\r\n    pSynth += `→ INSTRUCTION : Étoile sur un angle = influence déterminante sur ce pilier du thème.\\n`;\r\n}\r\n\r\nif (paranResults.length > 0) {\r\n    const topParans = paranResults.sort((a,b) => a.orb - b.orb).slice(0, 10);\r\n    pSynth += `\\n=== PARANS D'ÉTOILES FIXES — TOP ${topParans.length} (co-angularité — méthode Brady) ===\\n`;\r\n    pSynth += `Un paran se forme quand une étoile fixe et une planète sont simultanément sur un angle cardinal. Latitude ${geoLat.toFixed(2)}° prise en compte.\\n`;\r\n    topParans.forEach(pr => {\r\n        pSynth += `  ★ PARAN : ${pr.etoile} (${pr.angle_etoile}) ↔ ${pr.planete} (${pr.angle_planete}) — orbe ${pr.orb}° RAMC\\n`;\r\n        pSynth += `    ${pr.interpretation}\\n`;\r\n    });\r\n    pSynth += `→ INSTRUCTION : Les parans créent un LIEN SYMBOLIQUE étoile↔planète. Lever = début de vie ; Coucher = maturité ; Culmination = réalisation publique. Interpréter comme des résonances de destin.\\n`;\r\n}\r\n\r\npSynth += `\\nSynthétise ces dynamiques en identifiant les 3 à 5 grandes thématiques de vie de ce thème : les tensions majeures, les talents naturels, la configuration karmique, et l'orientation générale de l'énergie vitale. Intègre la secte, les configurations, les planètes angulaires, les conditions héliocentriques, les étoiles fixes et les parans comme filtres interprétatifs principaux.`;\r\n\r\nprompts[\"synthese_globale\"] = pSynth;\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 9. ÉCLIPSE À LA NAISSANCE (données optionnelles depuis Fusion Données)\r\n// ─────────────────────────────────────────────────────────────────\r\nconst eclipseNatal = input.eclipseNatal || null;\r\nlet eclipseNatalData = null;\r\nif (eclipseNatal && (eclipseNatal.type || eclipseNatal.eclipse_type || eclipseNatal.typeEclipse)) {\r\n    const eclipseDeg = typeof eclipseNatal.fullDegree === 'number' ? eclipseNatal.fullDegree\r\n                     : typeof eclipseNatal.degree     === 'number' ? eclipseNatal.degree\r\n                     : typeof eclipseNatal.degre      === 'number' ? eclipseNatal.degre\r\n                     : null;\r\n    if (eclipseDeg !== null) {\r\n        const normalizedDeg = ((eclipseDeg % 360) + 360) % 360;\r\n        const eclipseHouse  = getHouseNumber(normalizedDeg);\r\n        const eclipseSign   = signs[Math.floor(normalizedDeg / 30) % 12].fr;\r\n        const eclipseType   = eclipseNatal.type || eclipseNatal.eclipse_type || eclipseNatal.typeEclipse || \"Solaire\";\r\n        const eclipseAstre  = eclipseNatal.astre || (eclipseType.includes(\"Lunaire\") ? \"Lune\" : \"Soleil\");\r\n        const eclipseLabel  =\r\n            `⚡ ÉCLIPSE À LA NAISSANCE (${eclipseType} de ${eclipseAstre}) en ${eclipseSign} à ${(normalizedDeg % 30).toFixed(1)}° — Maison ${eclipseHouse}. ` +\r\n            `Cet individu est né le jour même d'une éclipse : les thèmes de la Maison ${eclipseHouse} sont chargés d'une mission de transformation profonde. ` +\r\n            `Cette éclipse amplifie toutes les lectures de la Maison ${eclipseHouse} et confère une sensibilité karmatique permanente sur ce degré.`;\r\n\r\n        if (eclipseHouse >= 1 && eclipseHouse <= 12) {\r\n            prompts[`maison_${eclipseHouse}`] +=\r\n                `\\n\\n=== ⚡ ÉCLIPSE À LA NAISSANCE ===\\n${eclipseLabel}\\n` +\r\n                `→ INSTRUCTION : Les thèmes de cette maison doivent être traités comme PRIORITAIRES et AMPLIFIÉS. ` +\r\n                `L'éclipse natale confère une mission, une blessure-catalyseur ou une rupture fondatrice sur ces thèmes. ` +\r\n                `Tout transit futur sur ce degré (${(normalizedDeg % 30).toFixed(1)}° ${eclipseSign}) réactivera cette éclipse natale.`;\r\n        }\r\n        prompts[\"synthese_globale\"] +=\r\n            `\\n\\n=== ⚡ ÉCLIPSE À LA NAISSANCE ===\\n${eclipseLabel}\\n` +\r\n            `→ INSTRUCTION : Intégrer cette éclipse natale comme signature karmique centrale du thème. ` +\r\n            `L'individu porte en lui l'archétype de la rupture/transformation dans les thèmes de la Maison ${eclipseHouse}.`;\r\n\r\n        eclipseNatalData = {\r\n            type: eclipseType, astre: eclipseAstre, sign: eclipseSign,\r\n            house: eclipseHouse, degree: normalizedDeg, label: eclipseLabel\r\n        };\r\n    }\r\n}\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 10. EMPHASE HÉMISPHÉRIQUE & ORIENTATION DU THÈME\r\n// ─────────────────────────────────────────────────────────────────\r\nconst coreForHemis = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\r\nlet hemisN=0, hemisS=0, hemisE=0, hemisW=0;\r\ncoreForHemis.forEach(name => {\r\n    const p = planetes.find(x => x.planet.fr === name); if (!p) return;\r\n    const house = Number(getHouseNumber(p.fullDegree));\r\n    if ([1,2,3,4,5,6].includes(house))    hemisN++; else hemisS++;  // M1-M6 = sous l'horizon (privé/intérieur), M7-M12 = au-dessus (public/extérieur)\r\n    if ([10,11,12,1,2,3].includes(house)) hemisE++; else hemisW++;\r\n});\r\nstats.hemispheres = { \"Sous l'horizon (M1-M6)\": hemisN, \"Au-dessus (M7-M12)\": hemisS, Est: hemisE, Ouest: hemisW };\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 11. PLANÈTE DOMINANTE (score multi-critères)\r\n// ─────────────────────────────────────────────────────────────────\r\nconst dominanceScore = {};\r\ncoreForHemis.forEach(name => { dominanceScore[name] = 0; });\r\nangularPlanets.forEach(ap => { if (dominanceScore[ap.planet] !== undefined) dominanceScore[ap.planet] += 3; });\r\ncoreForHemis.forEach(name => {\r\n    const p = planetes.find(x => x.planet.fr === name); if (!p) return;\r\n    const dig = getDignity(name, p.zodiac_sign?.name?.fr);\r\n    if (dig === \"Domicile\")   dominanceScore[name] += 2;\r\n    if (dig === \"Exaltation\") dominanceScore[name] += 1;\r\n    if (helioConditions[name]?.condition?.includes(\"CAZIMI\")) dominanceScore[name] += 2;\r\n});\r\ncoreForHemis.forEach(name => {\r\n    const count = aspects.filter(a => a.isMajor && (a.p1 === name || a.p2 === name)).length;\r\n    dominanceScore[name] += Math.min(count, 5);\r\n});\r\n// Bonus OOB : planète hors limites = énergie exacerbée (+3 pts)\r\ncoreForHemis.forEach(name => {\r\n    if (OOB_NAMES_SET.has(name)) dominanceScore[name] += 3;\r\n});\r\n// Bonus Station : planète stationnaire = concentration d'énergie exceptionnelle (+4 pts)\r\nstationaryPlanets.forEach(sp => {\r\n    if (dominanceScore[sp.planet] !== undefined) dominanceScore[sp.planet] += 4;\r\n});\r\nconst ascSignForDom = asc ? asc.zodiac_sign?.name?.fr : null;\r\nconst chartRulerForDom = ascSignForDom ? signs.find(s => s.fr === ascSignForDom)?.ruler : null;\r\nif (chartRulerForDom && dominanceScore[chartRulerForDom] !== undefined) dominanceScore[chartRulerForDom] += 2;\r\nconst chartRulerTradForDom = ascSignForDom ? MAITRES_TRAD_THEME[ascSignForDom] : null;\r\nif (chartRulerTradForDom && chartRulerTradForDom !== chartRulerForDom && dominanceScore[chartRulerTradForDom] !== undefined) dominanceScore[chartRulerTradForDom] += 1;\r\nfiches_maisons.forEach(fm => {\r\n    fm.segments.forEach(seg => {\r\n        if (seg.locataires.length > 0 && seg.maitre?.planete && dominanceScore[seg.maitre.planete] !== undefined)\r\n            dominanceScore[seg.maitre.planete] += 1;\r\n    });\r\n});\r\nconst dominanteSorted = Object.entries(dominanceScore).sort((a,b) => b[1] - a[1]);\r\nstats.planete_dominante    = dominanteSorted[0]?.[0] || null;\r\nstats.dominance_scores     = dominanteSorted;\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 12. ALMUTEM FIGURIS (planète avec le plus de dignités essentielles sur ASC, Sol, Lune, Part de Fortune)\r\n// ─────────────────────────────────────────────────────────────────\r\nconst keyPoints = [\r\n    asc   ? { name:\"ASC\",   deg:asc.fullDegree,   sign:asc.zodiac_sign?.name?.fr }   : null,\r\n    sun   ? { name:\"Sol\",   deg:sun.fullDegree,   sign:sun.zodiac_sign?.name?.fr }   : null,\r\n    moon  ? { name:\"Lune\",  deg:moon.fullDegree,  sign:moon.zodiac_sign?.name?.fr }  : null,\r\n    planetes.find(p=>p.planet.fr===\"Part de Fortune\") ? {\r\n        name:\"PartFort\", deg:planetes.find(p=>p.planet.fr===\"Part de Fortune\").fullDegree,\r\n        sign:planetes.find(p=>p.planet.fr===\"Part de Fortune\").zodiac_sign?.name?.fr } : null,\r\n    mc    ? { name:\"MC\",    deg:mc.fullDegree,    sign:mc.zodiac_sign?.name?.fr }    : null\r\n].filter(Boolean);\r\n\r\n// Triplicité (Ptolémée/Dorothée) — seigneurs diurnes et nocturnes par élément\r\n// Triplicités Ptolémée/Dorothée — tous les signes d'un même élément partagent les mêmes seigneurs\r\n// Feu: Soleil(J) / Jupiter(N) | Terre: Vénus(J) / Lune(N) | Air: Saturne(J) / Mercure(N) | Eau: Vénus(J) / Mars(N)\r\nconst TRIPLIC_DAY = {\r\n    \"Bélier\":\"Soleil\", \"Lion\":\"Soleil\",    \"Sagittaire\":\"Soleil\",\r\n    \"Taureau\":\"Vénus\", \"Vierge\":\"Vénus\",   \"Capricorne\":\"Vénus\",\r\n    \"Gémeaux\":\"Saturne\",\"Balance\":\"Saturne\",\"Verseau\":\"Saturne\",\r\n    \"Cancer\":\"Vénus\",  \"Scorpion\":\"Vénus\", \"Poissons\":\"Vénus\"\r\n};\r\nconst TRIPLIC_NIGHT = {\r\n    \"Bélier\":\"Jupiter\",\"Lion\":\"Jupiter\",   \"Sagittaire\":\"Jupiter\",\r\n    \"Taureau\":\"Lune\",  \"Vierge\":\"Lune\",    \"Capricorne\":\"Lune\",\r\n    \"Gémeaux\":\"Mercure\",\"Balance\":\"Mercure\",\"Verseau\":\"Mercure\",\r\n    \"Cancer\":\"Mars\",   \"Scorpion\":\"Mars\",  \"Poissons\":\"Mars\"\r\n};\r\n\r\nconst almutemScore = {};\r\ncoreForHemis.forEach(name => {\r\n    almutemScore[name] = 0;\r\n    keyPoints.forEach(kp => {\r\n        const dig = getDignity(name, kp.sign);\r\n        if (dig === \"Domicile\")   almutemScore[name] += 5;\r\n        if (dig === \"Exaltation\") almutemScore[name] += 4;\r\n        if (dig === \"Exil\")       almutemScore[name] -= 5;\r\n        if (dig === \"Chute\")      almutemScore[name] -= 4;\r\n        // Triplicité (+3) — seigneur selon la secte du thème\r\n        const triplRuler = isDayChart ? TRIPLIC_DAY[kp.sign] : TRIPLIC_NIGHT[kp.sign];\r\n        if (name === triplRuler) almutemScore[name] += 3;\r\n        // Triplicité participante (+1.5) — 3e seigneur Dorothéen, actif quelle que soit la secte\r\n        const triplPart = TRIPLIC_PART_EARLY[kp.sign];\r\n        if (name === triplPart && name !== triplRuler) almutemScore[name] += 1.5;\r\n        // Terme égyptien (+2)\r\n        const termRuler = getTermRuler(kp.sign, kp.deg);\r\n        if (name === termRuler) almutemScore[name] += 2;\r\n        // Face / Décan chaldéen (+1)\r\n        const decanIdx  = Math.min(Math.floor((kp.deg % 30) / 10), 2);\r\n        const faceRuler = CHALDEAN_DECANS[kp.sign]?.[decanIdx];\r\n        if (name === faceRuler) almutemScore[name] += 1;\r\n    });\r\n});\r\nconst almutemSorted = Object.entries(almutemScore).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);\r\nstats.almutem_figuris = almutemSorted[0]?.[0] || null;\r\nstats.almutem_scores  = almutemSorted;\r\n\r\n// ─────────────────────────────────────────────────────────────────\r\n// 12b. TECHNIQUES AVANCÉES — Dispositeur final, Dignité accidentelle, Hayz, Assiégée, VOC Lune\r\n// ─────────────────────────────────────────────────────────────────\r\n\r\n// ── C2 : ARBRE DES DISPOSITIONS & DISPOSITEUR FINAL ──\r\nconst SIGN_RULER_MAP = {\r\n    \"Bélier\":\"Mars\",\"Taureau\":\"Vénus\",\"Gémeaux\":\"Mercure\",\"Cancer\":\"Lune\",\r\n    \"Lion\":\"Soleil\",\"Vierge\":\"Mercure\",\"Balance\":\"Vénus\",\"Scorpion\":\"Pluton\",\r\n    \"Sagittaire\":\"Jupiter\",\"Capricorne\":\"Saturne\",\"Verseau\":\"Uranus\",\"Poissons\":\"Neptune\"\r\n};\r\nconst DISPOSITOR_PLANETS = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\r\nconst dispositorTree = {};\r\nDISPOSITOR_PLANETS.forEach(name => {\r\n    const chain = [];\r\n    let current = name;\r\n    const visited = new Set();\r\n    while (current && !visited.has(current)) {\r\n        visited.add(current);\r\n        const p = planetes.find(x => x.planet.fr === current);\r\n        if (!p) break;\r\n        const sign = p.zodiac_sign?.name?.fr;\r\n        if (!sign) break;\r\n        const ruler = SIGN_RULER_MAP[sign];\r\n        const isInDomicile = getDignity(current, sign) === \"Domicile\";\r\n        chain.push({ planet: current, sign, ruler, inDomicile: isInDomicile });\r\n        if (isInDomicile) break;\r\n        current = ruler;\r\n    }\r\n    dispositorTree[name] = {\r\n        chain,\r\n        finalDispositor: chain.find(c => c.inDomicile)?.planet || null,\r\n        isLoop: !chain.some(c => c.inDomicile)\r\n    };\r\n});\r\nconst finalDispositors = [...new Set(\r\n    Object.values(dispositorTree).map(d => d.finalDispositor).filter(Boolean)\r\n)];\r\nconst dispositorStr = finalDispositors.length > 0\r\n    ? `Dispositeur(s) final(aux) : ${finalDispositors.join(\", \")} — planète(s) en domicile concentrant le pouvoir de la chaîne de maîtrise. Toute la carte est ultimement « commandée » par ${finalDispositors.length === 1 ? 'cette planète' : 'ces planètes'}.`\r\n    : `Aucun dispositeur final unique — chaîne(s) de disposition en boucle (réceptions mutuelles ou orbite fermée), indiquant un réseau de pouvoir distribué plutôt qu'une seule planète directrice.`;\r\n\r\n// ── C3 : DIGNITÉ ACCIDENTELLE (Table de Lilly simplifiée) ──\r\nconst ANGULAR_HOUSES_SET = new Set([1, 10]);\r\nconst STRONG_HOUSES_SET  = new Set([7, 4]);\r\nconst SUCCEDENT_HOUSES   = new Set([2, 5, 8, 11]);\r\nconst CADENT_WEAK_HOUSES = new Set([6, 12]);\r\nconst MASCULINE_SIGNS    = new Set([\"Bélier\",\"Gémeaux\",\"Lion\",\"Balance\",\"Sagittaire\",\"Verseau\"]);\r\nconst FEMININE_SIGNS     = new Set([\"Taureau\",\"Cancer\",\"Vierge\",\"Scorpion\",\"Capricorne\",\"Poissons\"]);\r\nconst DIURNAL_PLANETS    = new Set([\"Soleil\",\"Jupiter\",\"Saturne\"]);\r\nconst NOCTURNAL_PLANETS  = new Set([\"Lune\",\"Vénus\",\"Mars\"]);\r\nconst MALEFICS_TRAD      = new Set([\"Mars\",\"Saturne\"]);\r\nconst BENEFICS_TRAD      = new Set([\"Jupiter\",\"Vénus\"]);\r\n\r\nconst accidentalDignityScores = {};\r\nDISPOSITOR_PLANETS.forEach(name => {\r\n    const p = planetes.find(x => x.planet.fr === name);\r\n    if (!p) return;\r\n    const house = getHouseNumber(p.fullDegree);\r\n    const isRetro = p.isRetro?.toLowerCase?.() === 'true' || p.isRetro === true;\r\n    const sign = p.zodiac_sign?.name?.fr;\r\n    let score = 0;\r\n    const details = [];\r\n\r\n    if (ANGULAR_HOUSES_SET.has(house))  { score += 5; details.push(`M${house} angulaire +5`); }\r\n    else if (STRONG_HOUSES_SET.has(house)) { score += 4; details.push(`M${house} angulaire +4`); }\r\n    else if (SUCCEDENT_HOUSES.has(house))  { score += 3; details.push(`M${house} succédente +3`); }\r\n    else if (CADENT_WEAK_HOUSES.has(house)){ score -= 5; details.push(`M${house} cadente faible -5`); }\r\n    else { score += 2; details.push(`M${house} cadente +2`); }\r\n\r\n    if (isRetro) { score -= 5; details.push(\"Rétrograde -5\"); }\r\n    else         { score += 4; details.push(\"Direct +4\"); }\r\n\r\n    const helio = helioConditions[name];\r\n    if (helio?.condition?.includes(\"CAZIMI\"))    { score += 5; details.push(\"Cazimi +5\"); }\r\n    else if (helio?.condition?.includes(\"COMBUSTE\")) { score -= 5; details.push(\"Combuste -5\"); }\r\n    else if (helio?.condition?.includes(\"SOUS LES RAYONS\")) { score -= 4; details.push(\"Sous les rayons -4\"); }\r\n    else if (name !== \"Soleil\" && name !== \"Lune\") { score += 5; details.push(\"Libre du Soleil +5\"); }\r\n\r\n    const inMutualReception = mutualReceptions.some(mr =>\r\n        (mr.p1 === name || mr.p2 === name) && mr.type === \"domicile\"\r\n    );\r\n    if (inMutualReception) { score += 5; details.push(\"Réception mutuelle domicile +5\"); }\r\n\r\n    const essentialDig = getDignity(name, sign);\r\n    const essentialScore = essentialDig === \"Domicile\" ? 5 : essentialDig === \"Exaltation\" ? 4\r\n        : essentialDig === \"Exil\" ? -5 : essentialDig === \"Chute\" ? -4 : 0;\r\n    if (essentialScore !== 0) details.push(`${essentialDig} ${essentialScore > 0 ? '+' : ''}${essentialScore}`);\r\n    score += essentialScore;\r\n\r\n    // Bonus/malus aspects reçus de bénéfiques/maléfiques (Lilly)\r\n    const BENEFICS = new Set([\"Jupiter\",\"Vénus\"]);\r\n    const MALEFICS = new Set([\"Saturne\",\"Mars\"]);\r\n    const aspFromBen = aspects.filter(a => a.isMajor && ((a.p1 === name && BENEFICS.has(a.p2)) || (a.p2 === name && BENEFICS.has(a.p1))));\r\n    const aspFromMal = aspects.filter(a => a.isMajor && ((a.p1 === name && MALEFICS.has(a.p2)) || (a.p2 === name && MALEFICS.has(a.p1))));\r\n    if (aspFromBen.length > 0) { const b = Math.min(aspFromBen.length, 2) * 2; score += b; details.push(`Aspect(s) bénéfique(s) reçu(s) +${b}`); }\r\n    if (aspFromMal.length > 0) { const m = Math.min(aspFromMal.length, 2) * -2; score += m; details.push(`Aspect(s) maléfique(s) reçu(s) ${m}`); }\r\n\r\n    // Bonus station\r\n    if (stationaryPlanets.some(sp => sp.planet === name)) { score += 3; details.push(\"Stationnaire +3\"); }\r\n\r\n    accidentalDignityScores[name] = { score, details, house, sign, isRetro, essentialDig };\r\n});\r\nconst dignityRanking = Object.entries(accidentalDignityScores)\r\n    .sort((a, b) => b[1].score - a[1].score)\r\n    .map(([name, data]) => ({ planet: name, ...data }));\r\n\r\n// ── C4a : HAYZ (condition de secte optimale) ──\r\nconst hayzPlanets = [];\r\nDISPOSITOR_PLANETS.forEach(name => {\r\n    const p = planetes.find(x => x.planet.fr === name); if (!p) return;\r\n    const sign = p.zodiac_sign?.name?.fr;\r\n    const house = getHouseNumber(p.fullDegree);\r\n    const aboveHorizon = [7,8,9,10,11,12].includes(house);\r\n    const isMasculine = MASCULINE_SIGNS.has(sign);\r\n    let inHayz = false, desc = \"\";\r\n    if (isDayChart && DIURNAL_PLANETS.has(name) && aboveHorizon && isMasculine) {\r\n        inHayz = true; desc = `${name} diurne, au-dessus de l'horizon, en signe masculin (${sign}) de jour — condition de HAYZ parfaite : la planète opère dans son élément naturel avec une efficacité maximale.`;\r\n    } else if (!isDayChart && NOCTURNAL_PLANETS.has(name) && !aboveHorizon && !isMasculine) {\r\n        inHayz = true; desc = `${name} nocturne, sous l'horizon, en signe féminin (${sign}) de nuit — condition de HAYZ parfaite : la planète opère dans son élément naturel avec une efficacité maximale.`;\r\n    }\r\n    if (inHayz) hayzPlanets.push({ planet: name, description: desc });\r\n});\r\n\r\n// ── C4b : PLANÈTES ASSIÉGÉES (entre deux maléfiques) ──\r\nconst besiegedPlanets = [];\r\nconst sortedByDeg = DISPOSITOR_PLANETS\r\n    .map(name => ({ name, deg: planetes.find(x => x.planet.fr === name)?.fullDegree }))\r\n    .filter(p => p.deg !== undefined)\r\n    .sort((a, b) => a.deg - b.deg);\r\nsortedByDeg.forEach((p, idx) => {\r\n    if (MALEFICS_TRAD.has(p.name) || BENEFICS_TRAD.has(p.name)) return;\r\n    const prev = sortedByDeg[(idx - 1 + sortedByDeg.length) % sortedByDeg.length];\r\n    const next = sortedByDeg[(idx + 1) % sortedByDeg.length];\r\n    if (MALEFICS_TRAD.has(prev.name) && MALEFICS_TRAD.has(next.name)) {\r\n        // Vérifier si un bénéfique intercepte le besiegement (atténuation)\r\n        const pDeg = p.deg, prevDeg = prev.deg, nextDeg = next.deg;\r\n        const beneficIntervenes = sortedByDeg.some(bp => {\r\n            if (!BENEFICS_TRAD.has(bp.name)) return false;\r\n            if (prevDeg < nextDeg) return bp.deg > prevDeg && bp.deg < nextDeg;\r\n            return bp.deg > prevDeg || bp.deg < nextDeg;\r\n        });\r\n        const severity = beneficIntervenes ? \"ATTÉNUÉE\" : \"STRICTE\";\r\n        besiegedPlanets.push({\r\n            planet: p.name,\r\n            between: [prev.name, next.name],\r\n            severity,\r\n            description: beneficIntervenes\r\n                ? `${p.name} est assiégée entre ${prev.name} et ${next.name}, mais un bénéfique intervient — pression atténuée.`\r\n                : `${p.name} est ASSIÉGÉE entre ${prev.name} et ${next.name} — contrainte, pression, empêchement. L'énergie de ${p.name} est entravée par les deux maléfiques traditionnels.`\r\n        });\r\n    }\r\n});\r\n\r\n// ── C4c : VIDE DE COURSE DE LA LUNE ──\r\nlet moonVoidOfCourse = null;\r\nif (moon) {\r\n    const moonDeg = moon.fullDegree;\r\n    const moonSign = moon.zodiac_sign?.name?.fr;\r\n    const moonSignEnd = (Math.floor(moonDeg / 30) + 1) * 30;\r\n    const majorAspDegs = [0, 60, 90, 120, 180];\r\n    let hasApplyingAspect = false;\r\n    DISPOSITOR_PLANETS.filter(n => n !== \"Lune\").forEach(name => {\r\n        const p = planetes.find(x => x.planet.fr === name); if (!p) return;\r\n        majorAspDegs.forEach(aspDeg => {\r\n            const targetDeg = (p.fullDegree + aspDeg) % 360;\r\n            const targetDeg2 = (p.fullDegree - aspDeg + 360) % 360;\r\n            [targetDeg, targetDeg2].forEach(td => {\r\n                if (td > moonDeg && td < moonSignEnd) hasApplyingAspect = true;\r\n            });\r\n        });\r\n    });\r\n    if (!hasApplyingAspect) {\r\n        moonVoidOfCourse = {\r\n            active: true,\r\n            sign: moonSign,\r\n            description: `Lune VIDE DE COURSE en ${moonSign} — la Lune ne forme plus d'aspect majeur appliquant avant de quitter le signe. Indique un tempérament qui fonctionne « hors cadre », par intuition pure plutôt que par connexion directe. Les projets initiés peuvent manquer d'écho immédiat mais mûrissent de façon non conventionnelle.`\r\n        };\r\n    }\r\n}\r\n\r\n// ── C2 : DEGRÉS SABIAN (symboles pour chaque planète) ──\r\nconst SABIAN_SYMBOLS = [\r\n\"Une femme surgit de l'océan ; un phoque l'enlace\",\"Un comédien divertit un groupe\",\"Le camée d'un profil d'homme dans l'ombre d'une pièce\",\"Deux amoureux se promènent dans un chemin isolé\",\r\n\"Un triangle avec des ailes\",\"Un carré illuminé de côtés\",\"Un homme réussit à exprimer simultanément deux tempéraments\",\"Un chapeau à large bord ventilé par l'est\",\r\n\"Un cristal dans lequel miroite un monde abstrait\",\"Un professeur regarde ses élèves à travers des verres épais\",\"Le souverain d'une nation\",\"Un troupeau d'oies sauvages\",\r\n\"Une bombe qui n'a pas explosé révèle une réserve de courage inutilisée\",\"Un serpent enroulé autour d'un homme et d'une femme\",\"Un Indien tisse un panier cérémoniel\",\"Des enfants du quartier jouent avec vivacité\",\r\n\"Deux dignitaires austères assis côte à côte\",\"Un hamac vide tendu entre deux arbres joyeux\",\"Le filet magique de la chasse donnant du pouvoir\",\"Une jeune fille nourrissant des oiseaux en hiver\",\r\n\"Un boxeur entre dans le ring\",\"La porte vers le jardin de tous les désirs\",\"Une femme enceinte en robe légère\",\"Le vent d'est gonfle des rideaux d'une chambre ouverte\",\r\n\"Un enfant potelé chevauchant un cheval de bois\",\"Un homme possédant plus de dons qu'il ne peut développer\",\"À travers l'imagination, la perception de la valeur perdue revient\",\"Un grand jardin public\",\"Deux têtes au-dessus de leurs corps\",\r\n\"Un canard et ses canetons\",\"La quête en vue d'un savoir inatteignable\",\"Un défilé militaire\",\"Terrain de jeu rempli d'enfants\",\"Une fontaine d'eau dans un jardin tropical\",\r\n\"La musique des sphères\",\"Un oiseau royal et sa compagne\",\"Un homme tombé du ciel\",\"Le nouveau Rachel\",\"Un soldat en deuil pour un camarade\",\r\n\"Un enfant du soleil accroupi dans les eaux\",\"Nombreux petits oiseaux sur la branche d'un gros arbre\",\"Un arc-en-ciel sur fond de ciel d'orage\",\"Deux personnes projetées loin par l'électricité\",\"Un homme tondu\",\r\n\"Un gardien monte la garde\",\"Un vieux maître de sagesse\",\"Un gouffre en form