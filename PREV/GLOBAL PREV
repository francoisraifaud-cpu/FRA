      "parameters": {
        "jsCode": "// ==========================================\n// NŒUD ANALYSEUR TECHNIQUE v10.2\n// Enrichissements : Chiron, Lunaisons, Éclipses, Stations Rétro, Angles, Aspects T→T\n// + CORRECTION : Nœud Nord & Nœud Sud en transit (normalisation clés API)\n// + FIX v10.1 : Fenêtres stellaires sorties du bloc if(eclipsesByDate) [Bug #1]\n// + FIX v10.1 : stellarByAngleAT (IC/ASC/MC/DSC) désormais traité [Bug #2]\n// + FIX v10.2 : NODE_ENRICHISSEMENT en constante (robustesse nommage)\n// + FIX v10.2 : orbe Pleine Lune resserrée 170°-190° (cohérence v6)\n// ==========================================\n\n// v10.3 ISO : multi-input (Prepare Data + Super noeud)\n// Nettoyage mémoire : supprimer prompt_user/prompt_system (inutiles ici, très lourds)\nconst _allInputItems = $input.all().map(i => {\n    const j = i.json;\n    delete j.prompt_user;\n    delete j.prompt_system;\n    delete j.contexte_natal_prompt;\n    return j;\n});\nconst prepareOut    = _allInputItems.find(j => j.transitsData || j.data?.length > 0) || _allInputItems[0] || {};\nconst transitsData  = prepareOut.transitsData || prepareOut.data || prepareOut;\nconst luneData      = prepareOut.luneData     || {};\nconst eclipsesData  = prepareOut.eclipsesData || [];\n\n// ISO : récupérer eventSignatures du Super noeud (source unique)\nlet _prevEventSignatures = null;\nfor (const _j of _allInputItems) {\n    if (_j.eventSignatures && _j.eventSignatures.length > 0) {\n        _prevEventSignatures = _j.eventSignatures;\n        break;\n    }\n}\n\nconst NODE_ENRICHISSEMENT = \"Enrichissement Astrologique\";\nconst enrichedData  = $(NODE_ENRICHISSEMENT).first()?.json || {};\nconst natalPlanets  = enrichedData.planetes || [];\nconst natalHouses   = enrichedData.maisons  || [];\nconst perso         = enrichedData.perso || {};\n\n// v6 : données stellaires et éclipse natale\nconst etoileMatchesNatal     = enrichedData.etoileMatches     || [];\nconst etoileCuspMatchesNatal = enrichedData.etoileCuspMatches || [];\nconst eclipseNatalData       = enrichedData.eclipseNatal      || null;\nconst natalDispositorTreeAT  = enrichedData.dispositorTree    || {};\nconst natalAccDignityAT      = enrichedData.accidentalDignity || [];\nconst natalHayzAT            = enrichedData.hayzPlanets       || [];\nconst natalBesiegedAT        = enrichedData.besiegedPlanets   || [];\nconst natalMoonVOCAT         = enrichedData.moonVOC           || null;\nconst natalSabianAT          = enrichedData.sabianData        || {};\nconst natalStatsAT           = enrichedData.stats             || {};\nconst stationaryPlanetsAT    = enrichedData.stationaryPlanets || [];\nlet   chartShapeAT           = enrichedData.chartShape        || {};\n\nconst interceptedSignsAT     = enrichedData.interceptedSigns  || [];\nconst sensitivityProfileAT   = enrichedData.sensitivityProfile || \"\";\nconst paranResultsAT         = enrichedData.paranResults      || [];\nconst stellarByPlanetAT = {};\netoileMatchesNatal.forEach(em => {\n    if (em.isAngle) return; // angles gérés par stellarByAngleAT — évite le double affichage\n    if (!stellarByPlanetAT[em.planete]) stellarByPlanetAT[em.planete] = [];\n    stellarByPlanetAT[em.planete].push(em);\n});\nconst stellarByAngleAT = {};\netoileCuspMatchesNatal.forEach(ec => { if (!stellarByAngleAT[ec.angle]) stellarByAngleAT[ec.angle] = []; stellarByAngleAT[ec.angle].push(ec); });\nconst eclipticNatalAT = eclipseNatalData ? { degree:eclipseNatalData.degree, house:eclipseNatalData.house, sign:eclipseNatalData.sign, label:`ÉCLIPSE NATALE ${eclipseNatalData.type} de ${eclipseNatalData.astre} en ${eclipseNatalData.sign} à ${((eclipseNatalData.degree ?? 0)%30).toFixed(1)}° — M${eclipseNatalData.house}` } : null;\nconst ETOILES_ROY_AT = new Set([\"Aldébaran\",\"Sirius\",\"Régulus\",\"Spica\",\"Antarès\",\"Fomalhaut\"]);\nconst ANGLE_MAIS_AT  = {\"ASC\":1,\"IC\":4,\"DSC\":7,\"MC\":10};\nlet suiviStellairAT = {};\nconst ORBE_STELL_AT = 1.0, ORBE_ECL_RES_AT = 3.0;\n\nconst parseDate = (str) => {\n    if (!str) return null;\n    str = str.trim();\n    if (str.includes(\"/\")) {\n        const [d, m, y] = str.split(\"/\");\n        return new Date(`${y}-${m.padStart(2,\"0\")}-${d.padStart(2,\"0\")}`);\n    }\n    return new Date(str);\n};\n\nconst annee       = perso.annee || String(new Date().getFullYear());\nlet dStart      = parseDate(perso.date_entree);\nif (!dStart || isNaN(dStart.getTime())) dStart = new Date(`${annee}-01-01`);\nlet dEnd        = parseDate(perso.date_sortie);\nif (!dEnd || isNaN(dEnd.getTime())) dEnd = new Date(`${annee}-12-31`);\nconst typeRapport = (perso.rapport || \"Annuel\").trim();\n\nconst allDays = Array.isArray(transitsData) ? transitsData : [transitsData];\nconst days = allDays.filter(day => {\n    if (!day?.date) return false;\n    const d = new Date(day.date);\n    return d >= dStart && d <= dEnd;\n});\nif (days.length === 0) {\n    return [{ json: { error: true, message: `Aucun jour trouvé entre ${perso.date_entree} et ${perso.date_sortie}`, maison: 0 } }];\n}\n\n// ---- NORMALISATION DES CLÉS API ----\n// L'API retourne \"Noeud_Nord\" / \"Noeud_Sud\" (underscore, sans œ)\n// Le code utilise \"Nœud Nord\" / \"Nœud Sud\" (espace, avec œ)\n// On normalise une fois pour toutes ici\ndays.forEach(day => {\n    if (!day?.planetes) return;\n    if (day.planetes[\"Noeud_Nord\"] && !day.planetes[\"Nœud Nord\"]) {\n        day.planetes[\"Nœud Nord\"] = day.planetes[\"Noeud_Nord\"];\n    }\n    if (day.planetes[\"Noeud_Sud\"] && !day.planetes[\"Nœud Sud\"]) {\n        day.planetes[\"Nœud Sud\"] = day.planetes[\"Noeud_Sud\"];\n    }\n});\n\nconst signs = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\n\nconst slowPlanets = [\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Nœud Nord\",\"Nœud Sud\",\"Chiron\",\"Lilith\",\"Ceres\",\"Pallas\",\"Junon\",\"Vesta\"];\nconst fastPlanetsMap = {\n    \"Mensuel\"      : [\"Soleil\",\"Mercure\",\"Vénus\",\"Mars\"],\n    \"Hebdomadaire\" : [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\"],\n    \"Journalier\"   : [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\"]\n};\nconst fastPlanets = fastPlanetsMap[typeRapport] || [];\n// Note : Nœud Nord et Nœud Sud ne sont PAS dans retroPlanets\n// car ils sont toujours en mouvement rétrograde moyen (par définition)\nconst retroPlanets = [\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\",\"Lilith\",\"Ceres\",\"Pallas\",\"Junon\",\"Vesta\"];\n\n// ---- ASPECTS MONDIAUX : paires T→T ----\nconst TT_ASPECTS = { 0:\"Conjonction\", 60:\"Sextile\", 90:\"Carré\", 120:\"Trigone\", 150:\"Quinconce\", 180:\"Opposition\" };\nconst ORBE_TT_LL = 2.0;\nconst ORBE_TT_RL = 1.0;\n\nconst buildTTPairs = () => {\n    const pairs = [];\n    for (let i = 0; i < slowPlanets.length; i++) {\n        for (let j = i + 1; j < slowPlanets.length; j++) {\n            pairs.push({ p1: slowPlanets[i], p2: slowPlanets[j], orbe: ORBE_TT_LL, cat: \"lente_lente\" });\n        }\n    }\n    if (fastPlanets.length > 0) {\n        for (const pr of fastPlanets) {\n            for (const pl of slowPlanets) {\n                if (pr !== pl) pairs.push({ p1: pr, p2: pl, orbe: ORBE_TT_RL, cat: \"rapide_lente\" });\n            }\n        }\n    }\n    return pairs;\n};\nconst ttPairs = buildTTPairs();\n\n// ---- ANGLES NATALS ----\nconst ANGLE_NAMES = {\n    \"Ascendant\"   : { key: \"ASC\", maison: 1 },\n    \"Imum Coeli\"  : { key: \"IC\",  maison: 4 },\n    \"Descendant\"  : { key: \"DSC\", maison: 7 },\n    \"Milieu du Ciel\": { key: \"MC\", maison: 10 }\n};\nconst angleSet = new Set(Object.keys(ANGLE_NAMES));\nconst natalAngles = {};\nnatalPlanets.forEach(p => {\n    const name = p.planet?.fr || p.planet?.en || \"\";\n    if (angleSet.has(name)) natalAngles[name] = p.fullDegree;\n});\n\n// ---- STRUCTURE RAPPORT ----\nlet rapportMaisons = Array.from({length: 12}, (_, i) => ({\n    maison      