    {
      "parameters": {
        "jsCode": "// ══════════════════════════════════════════════════════════════════════\n// VALIDATEUR POST-LLM — PRÉVISIONS (noeud silencieux)\n// ══════════════════════════════════════════════════════════════════════\n// Ce noeud vérifie la cohérence des textes LLM avec les données natales.\n// Il ne produit AUCUN affichage — son output JSON est consultable\n// dans les logs d'exécution n8n et peut alimenter un noeud d'alerte\n// (Slack, email, webhook) si des anomalies sont détectées.\n// ══════════════════════════════════════════════════════════════════════\n\nconst items = $input.all();\n\nlet astroData = { maisons: [] };\ntry { astroData = $('Enrichissement Astrologique').first()?.json || { maisons: [] }; } catch(e) {}\n\n// ── 1. CARTE DE RÉFÉRENCE DES POSITIONS NATALES ──\nconst natalPlanets = (astroData.planetes || []);\nconst natalMaisons = (astroData.maisons || []);\nconst planetHouseMap = {};\nconst planetSignMap  = {};\n\nnatalPlanets.forEach(p => {\n    const name = p.planet?.fr;\n    if (!name) return;\n    const sign = p.zodiac_sign?.name?.fr;\n    if (sign) planetSignMap[name] = sign;\n    const house = natalMaisons.find(m =>\n        (m.segments || []).some(s => s.locataires?.some(l => l.planete === name))\n    );\n    if (house) planetHouseMap[name] = house.maison;\n});\n\n// ── 2. VOCABULAIRE D'EXCLUSION (contexte transit / rhétorique) ──\nconst TRANSIT_VERBS = [\n    \"transite\", \"traverse\", \"traversée\", \"entre en\", \"arrive en\", \"quitte la\",\n    \"passage de\", \"passage en\", \"passage du\", \"transit de\", \"transit du\",\n    \"se déplace en\", \"progresse en\", \"arc solaire\", \"progression de\",\n    \"contrairement à\", \"tandis que\", \"alors que\", \"par opposition à\",\n    \"à la différence de\", \"en comparaison\", \"imaginons\",\n    \"en général\", \"généralement\", \"traditionnellement\", \"dans l'absolu\",\n    \"transit \", \"en transit\",\n    \"l'entrée\", \"entre dans\", \"éclipse\", \"saros\",\n    \"lunation\", \"pleine lune\", \"nouvelle lune\",\n    \"sera en\", \"serait en\", \"entrera en\", \"ira en\", \"retour de\",\n    \"ingress\", \"entrée en\", \"passage vers\", \"quand il entre\", \"quand elle entre\",\n    \"formera\", \"activera\", \"touchera\", \"stimulera\", \"percutera\",\n    \"cette année\", \"en 2026\", \"en 2027\", \"en 2028\", \"en 2029\", \"en 2030\",\n    \"cette période\", \"au cours de\", \"durant l'année\",\n    \"métamorphose\", \"fait son entrée\", \"visite de\",\n    \" sera \", \"il sera\", \"elle sera\", \"d'autant plus\",\n    \"conjonction\", \"opposition\", \"carré\", \"trigone\", \"sextile\", \"quinconce\",\n    \"semi-carré\", \"sesquicarré\", \"semi-sextile\",\n    \"en aspect\", \"aspect à\", \"aspecte\"\n];\n\nconst CORE_PLANETS = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\"];\n\n// ── 3. VALIDATION CONTEXTUELLE (phrase par phrase) ──\nconst splitSentences = (text) => {\n    return text.replace(/\\n/g, '. ').split(/(?<=[.!?…])\\s+/).filter(s => s.length > 5);\n};\n\nconst isTransitContext = (sentence) => {\n    const lc = sentence.toLowerCase();\n    return TRANSIT_VERBS.some(v => lc.includes(v));\n};\n\nconst matchWithBoundary = (text, pattern) => {\n    const idx = text.indexOf(pattern);\n    if (idx === -1) return false;\n    const after = text[idx + pattern.length];\n    if (after && /\\d/.test(after)) return false;\n    return true;\n};\n\nconst validateHouseText = (text) => {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    CORE_PLANETS.forEach(name => {\n        const correctHouse = planetHouseMap[name];\n        if (!correctHouse) return;\n        const nameLc = name.toLowerCase();\n\n        sentences.forEach(sentence => {\n            if (isTransitContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            for (let h = 1; h <= 12; h++) {\n                if (h === correctHouse) continue;\n                const patterns = [\n                    `${nameLc} natal en maison ${h}`,\n                    `${nameLc} natal en m${h}`,\n                    `${nameLc} natal (m${h}`,\n                    `${nameLc} natale en m${h}`,\n                    `${nameLc} natale (m${h}`,\n                    `${nameLc} en maison ${h} natal`,\n                    `${nameLc} réside en m${h}`,\n                    `${nameLc} se trouve en m${h}`,\n                    `${nameLc}, planète de la maison ${h}`,\n                    `${nameLc} en maison ${h}`,\n                    `${nameLc} dans la maison ${h}`,\n                    `${nameLc} en m${h}`\n                ];\n                if (patterns.some(pat => matchWithBoundary(lc, pat))) {\n                    warnings.push({\n                        planet: name,\n                        claimedHouse: h,\n                        correctHouse: correctHouse,\n                        excerpt: sentence.substring(0, 120),\n                        type: \"house_mismatch\"\n                    });\n                }\n            }\n        });\n    });\n    return warnings;\n};\n\nconst validateSignText = (text) => {\n    const warnings = [];\n    if (!text) return warnings;\n    const sentences = splitSentences(text);\n\n    CORE_PLANETS.forEach(name => {\n        const correctSign = planetSignMap[name];\n        if (!correctSign) return;\n        const nameLc = name.toLowerCase();\n        const signLc = correctSign.toLowerCase();\n        const allSigns = [\"bélier\",\"taureau\",\"gémeaux\",\"cancer\",\"lion\",\"vierge\",\"balance\",\"scorpion\",\"sagittaire\",\"capricorne\",\"verseau\",\"poissons\"];\n\n        sentences.forEach(sentence => {\n            if (isTransitContext(sentence)) return;\n            const lc = sentence.toLowerCase();\n            allSigns.forEach(sign => {\n                if (sign === signLc) return;\n                const natalPatterns = [\n                    `${nameLc} natal en ${sign}`,\n                    `${nameLc} natale en ${sign}`,\n                    `${nameLc} natal(e) en ${sign}`\n                ];\n                if (natalPatterns.some(pat => lc.includes(pat))) {\n                    warnings.push({\n                        planet: name,\n                        claimedSign: sign,\n                        correctSign: correctSign,\n                        excerpt: sentence.substring(0, 120),\n                        type: \"sign_mismatch\"\n                    });\n                }\n            });\n        });\n    });\n    return warnings;\n};\n\n// ── 4. EXÉCUTION SUR CHAQUE MAISON ──\nconst results = { timestamp: new Date().toISOString(), totalWarnings: 0, houses: {}, workflow: \"PREV\" };\nlet vars = {};\ntry { vars = $('Extract Variables').first()?.json || {}; } catch(e) {}\nresults.subject = `${vars.prenom || ''} ${vars.nom || ''}`.trim();\nresults.periode = `${vars.date_entree || ''} → ${vars.date_sortie || ''}`;\n\nitems.forEach((item, index) => {\n    const txt = item.json.output || item.json.text || item.json.message || \"\";\n    if (index < 12) {\n        const hNum = index + 1;\n        const houseWarnings = validateHouseText(txt);\n        const signWarnings  = validateSignText(txt);\n        if (houseWarnings.length > 0 || signWarnings.length > 0) {\n            results.houses[`M${hNum}`] = { houseWarnings, signWarnings };\n            results.totalWarnings += houseWarnings.length + signWarnings.length;\n        }\n    } else {\n        const synthWarnings = validateHouseText(txt);\n        const synthSignWarn = validateSignText(txt);\n        if (synthWarnings.length > 0 || synthSignWarn.length > 0) {\n            results.houses[\"synthese\"] = { houseWarnings: synthWarnings, signWarnings: synthSignWarn };\n            results.totalWarnings += synthWarnings.length + synthSignWarn.length;\n        }\n    }\n});\n\nresults.status = results.totalWarnings === 0 ? \"CLEAN\" : \"WARNINGS_DETECTED\";\nresults.summary = results.totalWarnings === 0\n    ? \"Aucune incohérence détectée entre les textes LLM et les données natales.\"\n    : `${results.totalWarnings} incohérence(s) potentielle(s) détectée(s). Vérifier les détails dans houses.`;\n\nreturn [{ json: results }];\n"
      },
