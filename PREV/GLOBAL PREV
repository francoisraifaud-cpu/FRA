n// ── Arcs solaires SA→N ──\ntry {\nif (progressionsRaw?.planetes?.[\"Soleil\"]?.fullDegree && natalDictLoc[\"Soleil\"]?.deg) {\n    const _solarArc = ((progressionsRaw.planetes[\"Soleil\"].fullDegree - natalDictLoc[\"Soleil\"].deg) + 360) % 360;\n    const _SA_ORB = 1.0;\n    const _SA_ASP = { \"Conjonction\":0, \"Sextile\":60, \"Carré\":90, \"Trigone\":120, \"Quinconce\":150, \"Opposition\":180 };\n    const _SA_PL = [\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\",\"Ascendant\",\"Milieu du Ciel\"];\n    const _SA_TGT = new Set([\"Soleil\",\"Lune\",\"Mercure\",\"Vénus\",\"Mars\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\",\"Pluton\",\"Chiron\",\"Nœud Nord\",\"Nœud Sud\",\"Ascendant\",\"Milieu du Ciel\"]);\n    const _SA_PW = {\"Ascendant\":2,\"Milieu du Ciel\":2,\"Soleil\":1.5,\"Lune\":1.5,\"Mercure\":1,\"Vénus\":1,\"Mars\":1,\"Jupiter\":1,\"Saturne\":1,\"Uranus\":1,\"Neptune\":1,\"Pluton\":1,\"Chiron\":0.8};\n    const _getOrbSA = (a, b) => { let d = Math.abs(a - b); return d > 180 ? 360 - d : d; };\n    for (const pSA of _SA_PL) {\n        const nd = natalDictLoc[pSA]; if (!nd?.deg) continue;\n        const saDeg = (nd.deg + _solarArc) % 360;\n        const saSign = signs[Math.floor(saDeg / 30) % 12];\n        const saHouse = getLocation(saDeg).maison;\n        for (const [pNat, nData] of Object.entries(natalDictLoc)) {\n            if (!_SA_TGT.has(pNat) || pSA === pNat) continue;\n            const diff = _getOrbSA(saDeg, nData.deg);\n            for (const [aspName, aspDeg] of Object.entries(_SA_ASP)) {\n                const orbe = Math.abs(diff - aspDeg);\n                if (orbe <= _SA_ORB) {\n                    const house = nData.house;\n                    const arcTight = Math.max(0, 1 - orbe / _SA_ORB);\n                    const arcPw = _SA_PW[pSA] ?? 1;\n                    if (house >= 1 && house <= 12) {\n                        rapportMaisons[house - 1].arcs_solaires.pu