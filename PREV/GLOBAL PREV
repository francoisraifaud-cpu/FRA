lon = rest.indexOf(' : ');\n        if (colon > 0 && colon <= 90) {\n          const after = rest.slice(colon + 3);\n          if (after.length > 60) {\n            out.push('<h5 style=\"' + h5Style + '\">' + esc(prefix + rest.slice(0, colon)) + '</h5>');\n            if (after.trim()) out.push('<p style=\"font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:4px 0 9px;text-align:justify;\">' + inl(after) + '</p>');\n            handled = true;\n          } else if ((prefix + rest).length <= 130) { line = '#### ' + prefix + rest; }\n        } else if ((prefix + rest).length <= 130) { line = '#### ' + prefix + rest; }\n      } else {\n        const mainM = stripped.match(/^(\\d+[.)]\\s+)(.+)$/);\n        if (mainM) {\n          const prefix = mainM[1], rest = mainM[2];\n          if ((prefix + rest).length <= 155) {\n            line = '### ' + prefix + rest;\n          } else {\n            const colon = rest.indexOf(' : ');\n            if (colon > 0 && colon <= 120) {\n              const after = rest.slice(colon + 3);\n              out.push('<h4 style=\"' + h4Style + '\">' + esc(prefix + rest.slice(0, colon)) + '</h4>');\n              if (after.trim()) out.push('<p style=\"font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:9px 0;text-align:justify;\">' + inl(after) + '</p>');\n              handled = true;\n            } else { line = '### ' + prefix + rest; }\n          }\n        } else if (/^\\*{2,3}[^*]{4,120}\\*{2,3}$/.test(line)) {\n          line = '### ' + stripped;\n        } else if (stripped.length <= 130 && /^[\\p{Emoji_Presentation}\\p{So}A-ZÀ-ÿ][^:\\n]{2,55} : [\\p{Emoji_Presentation}\\p{So}A-ZÀ-ÿ].{2,70}$/u.test(stripped)) {\n          line = '#### ' + stripped;\n        } else if (/^(conclusion|synthèse|en\\s+synthèse|en\\s+conclusion|recommandation)/i.test(stripped) && stripped.length < 120) {\n          const colonIdx = stripped.indexOf(' : ');\n          if (colonIdx > 0 && colonIdx <= 50 && stripped.slice(colonIdx + 3).trim().length > 2