,\n        fullDegree : p.longitude_absolue,\n        isRetro    : p.est_retrograde === \"True\" || p.est_retrograde === true ? \"True\" : \"False\",\n        signe      : p.signe || null\n    };\n};\n\n// ---- 1. NORMALISER toutes les planètes dans transitsData ----\nconst transitsNormalized = transitsRaw.map(day => {\n    if (!day?.planetes) return day;\n    const normalizedPlanetes = {};\n    for (const [planetName, planetData] of Object.entries(day.planetes)) {\n        normalizedPlanetes[planetName] = normalizePlanet(planetData);\n    }\n    return { ...day, planetes: normalizedPlanetes };\n});\n\n// ---- 2. LUNE HAUTE PRÉCISION : indexer par date ----\n// v8 : ajout latitude, distanceUA, declinaison (null-safe)\nconst luneByDate = {};\nluneRaw.forEach(entry => {\n    const date = entry.date_heure.substring(0, 10);\n    if (!luneByDate[date]) luneByDate[date] = [];\n    luneByDate[date].push({\n        heure      : entry.date_heure.substring(11, 16),\n        fullDegree : entry.lune.longitude_absolue,\n        signe      : entry.lune.signe,\n        degInSign  : entry.lune.degre_dans_signe,\n        vitesse    : entry.lune.vitesse_journaliere,\n        latitude   : entry.lune.latitude    ?? null,\n        distanceUA : entry.lune.distance_ua  ?? null,\n        declinaison: entry.lune.declinaison  ?? null\n    });\n});\n\n// ---- 3. ÉCLIPSES NATALES ----\nconst eclipses = eclipsesRaw.map(e => {\n    const obj = {\n        astre : e.astre,\n        type  : e.type,\n        date  : e.date_maximum.substring(0, 10),\n        heure : e.date_maximum.substring(11, 16),\n        label : `Éclipse ${e.type} de ${e.astre} le ${e.date_maximum.substring(0, 10)}`\n    };\n    if (e.saros_number)       obj.saros_number       = e.saros_number;\n    if (e.saros_type_eclipse) obj.saros_type_eclipse  = e.saros_type_eclipse;\n    if (e.saros_theme)        obj.saros_theme         = e.saros_theme;\n    if (e.saros_keywords)     obj.saros_keywords      = e.saros_keywords;\n    return o