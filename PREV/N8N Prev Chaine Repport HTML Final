    {
      "parameters": {
        "jsCode": "// Corrige le nom de fichier et le MIME type du PDF\nconst items = $input.all();\nconst validItems = [];\n\nfor (const item of items) {\n  if (!item.binary) continue;\n  const binaryKey = Object.keys(item.binary)[0];\n  if (!binaryKey) continue;\n\n  let nomFichier = 'rapport-previsions.pdf';\n  try {\n    const vars = $('Extract Variables').first().json;\n    const typeRapport = (vars.rapport || 'Annuel').trim();\n    const prenom = vars.prenom || '';\n    const nom = vars.nom || '';\n    const stripAccents = (s) => s.normalize('NFD').replace(/[\\u0300-\\u036f]/g,'');\n    const prenomClean = stripAccents(prenom).trim();\n    const nomClean = stripAccents(nom).toUpperCase().trim();\n    const nomAffiche = `${prenomClean} ${nomClean}`.trim() || 'Client';\n    const dateEntree = (vars.date_entree || '').replace(/\\//g, '_');\n    const dateSortie = (vars.date_sortie || '').replace(/\\//g, '_');\n    nomFichier = `Rapport Previsions - ${typeRapport} - ${dateEntree} - ${dateSortie} - ${nomAffiche}.pdf`;\n  } catch(e) {}\n\n  item.binary[binaryKey].fileName    = nomFichier;\n  item.binary[binaryKey].mimeType    = 'application/pdf';\n  item.binary[binaryKey].fileExtension = 'pdf';\n  validItems.push(item);\n}\n\nreturn validItems;"
      },
