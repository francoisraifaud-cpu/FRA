        "jsCode": "// Prépare le HTML pour Gotenberg (conversion PDF)\nconst items = $input.all();\nconst newItems = [];\nfor (const item of items) {\n  if (item.binary?.html_file) {\n    newItems.push({ json: item.json, binary: { data: item.binary.html_file } });\n    continue;\n  }\n  const htmlContent = item.json.html || '<html><body>Erreur HTML</body></html>';\n  const binaryData = await this.helpers.prepareBinaryData(\n    Buffer.from(htmlContent), 'index.html', 'text/html'\n  );\n  newItems.push({ json: item.json, binary: { data: binaryData } });\n}\nreturn newItems;"
