// ---- CALCULS STATIQUES NATAUX (C1-C5) ----

const MAITRES_R = {"Bélier":"Mars","Taureau":"Vénus","Gémeaux":"Mercure","Cancer":"Lune","Lion":"Soleil","Vierge":"Mercure","Balance":"Vénus","Scorpion":"Pluton","Sagittaire":"Jupiter","Capricorne":"Saturne","Verseau":"Uranus","Poissons":"Neptune"};
const DOMICILE_R  = {"Soleil":["Lion"],"Lune":["Cancer"],"Mercure":["Gémeaux","Vierge"],"Vénus":["Taureau","Balance"],"Mars":["Bélier","Scorpion"],"Jupiter":["Sagittaire","Poissons"],"Saturne":["Capricorne","Verseau"],"Uranus":["Verseau"],"Neptune":["Poissons"],"Pluton":["Scorpion"]};
const EXALTATION_R= {"Soleil":"Bélier","Lune":"Taureau","Mercure":"Vierge","Vénus":"Poissons","Mars":"Capricorne","Jupiter":"Cancer","Saturne":"Balance","Uranus":"Scorpion","Neptune":"Cancer","Pluton":"Lion"};
const EXIL_R      = {"Soleil":["Verseau"],"Lune":["Capricorne"],"Mercure":["Sagittaire","Poissons"],"Vénus":["Bélier","Scorpion"],"Mars":["Taureau","Balance"],"Jupiter":["Gémeaux","Vierge"],"Saturne":["Cancer","Lion"],"Uranus":["Lion"],"Neptune":["Vierge"],"Pluton":["Taureau"]};
const CHUTE_R     = {"Soleil":"Balance","Lune":"Scorpion","Mercure":"Poissons","Vénus":"Vierge","Mars":"Cancer","Jupiter":"Capricorne","Saturne":"Bélier","Uranus":"Taureau","Neptune":"Capricorne","Pluton":"Verseau"};

const getDig = (p, s) => {
    if ((DOMICILE_R[p]||[]).includes(s))  return {dignite:L.domicile,  force:L.fort,   sym:"✦",  cls:"dig-fort"};
    if (EXALTATION_R[p] === s)            return {dignite:L.exaltation,force:L.fort,   sym:"✧",  cls:"dig-fort"};
    if ((EXIL_R[p]||[]).includes(s))      return {dignite:L.exil,      force:L.faible, sym:"✗",  cls:"dig-faible"};
    if (CHUTE_R[p] === s)                 return {dignite:L.chute,     force:L.faible, sym:"✗✗", cls:"dig-chute"};
    return {dignite:L.peregrin, force:L.neutre, sym:"", cls:"dig-neutre"};
};

const natalDictR = {};
natalPlanets.forEach(p => {
    const name = p.planet?.fr || p.planet?.en || "";
    if (!name) return;
    const deg  = p.fullDegree;
    const sign = p.zodiac_sign?.name?.fr || signs[Math.floor(deg/30)%12];
    const house= findNatalHouse(deg);
    const isRetro = p.isRetro === true || p.isRetro === "True";
    const dig  = getDig(name, sign);
    natalDictR[name] = { deg, sign, house, isRetro, ...dig };
});

const NALSP_ORB = {"Conjonction":10,"Opposition":10,"Carré":8,"Trigone":8,"Sextile":6};
const NALSP_DEG = {"Conjonction":0,"Sextile":60,"Carré":90,"Trigone":120,"Opposition":180};
const natalAspR = {};
const natalNamesR = Object.keys(natalDictR);
natalNamesR.forEach(n => { natalAspR[n] = []; });
for (let i=0; i<natalNamesR.length; i++) {
    for (let j=i+1; j<natalNamesR.length; j++) {
        const nA=natalNamesR[i], nB=natalNamesR[j];
        let diff = Math.abs(natalDictR[nA].deg - natalDictR[nB].deg);
        if (diff>180) diff=360-diff;
        for (const [asp, maxOrb] of Object.entries(NALSP_ORB)) {
            const orbe = parseFloat(Math.abs(diff - NALSP_DEG[asp]).toFixed(2));
            if (orbe <= maxOrb) {
                natalAspR[nA].push({ planete:nB, type:asp, orbe, maison:natalDictR[nB].house, signe:natalDictR[nB].sign });
                natalAspR[nB].push({ planete:nA, type:asp, orbe, maison:natalDictR[nA].house, signe:natalDictR[nA].sign });
            }
        }
    }
}
natalNamesR.forEach(n => { natalAspR[n].sort((a,b)=>a.orbe-b.orbe); });

const receptionsR = [];
for (let i=0; i<natalNamesR.length; i++) {
    for (let j=i+1; j<natalNamesR.length; j++) {
        const pA=natalNamesR[i], pB=natalNamesR[j];
        const sA=natalDictR[pA]?.sign, sB=natalDictR[pB]?.sign;
        if (!sA||!sB) continue;
        const AenDomB=(DOMICILE_R[pB]||[]).includes(sA), BenDomA=(DOMICILE_R[pA]||[]).includes(sB);
        const AenExaB=EXALTATION_R[pB]===sA,              BenExaA=EXALTATION_R[pA]===sB;
        if (AenDomB && BenDomA) receptionsR.push({ pA,pB,type:"domicile",maisA:natalDictR[pA].house,maisB:natalDictR[pB].house });
        else if ((AenDomB&&BenExaA)||(BenDomA&&AenExaB)) receptionsR.push({ pA,pB,type:"semi",maisA:natalDictR[pA].house,maisB:natalDictR[pB].house });
    }
}

const buildAxe = (maisNum) => {
    const h = natalHouses.find(h=>h.maison===maisNum); if (!h) return null;
    const signe0 = h.segments?.[0]?.signe || "Bélier";
    const m1 = MAITRES_R[signe0]; if (!m1||!natalDictR[m1]) return null;
    const nd1=natalDictR[m1], r1=nd1.isRetro?"[℞] ":"";
    const m2=MAITRES_R[nd1.sign]; const nd2=m2?natalDictR[m2]:null;
    const m3=nd2?MAITRES_R[nd2.sign]:null; const nd3=m3?natalDictR[m3]:null;
    return {
        signe0, m1, nd1, r1,
        m2: m2&&m2!==m1?m2:null, nd2: nd2&&m2!==m1?nd2:null, r2: nd2?.isRetro?"[℞] ":"",
        m3: m3&&m3!==m2&&m3!==m1?m3:null, nd3: nd3&&m3!==m2&&m3!==m1?nd3:null, r3: nd3?.isRetro?"[℞] ":"",
    };
};

const renderAxeMaitrises = (maisNum) => {
    const ax = buildAxe(maisNum); if (!ax) return "";
    const digColor = (force) => force==="FORT"?"#15803d":force==="FAIBLE"?"#b91c1c":"#64748b";
    const digBg    = (force) => force==="FORT"?"#f0fdf4":force==="FAIBLE"?"#fff1f2":"#f8fafc";

    const node = (p, nd, r) => nd ? `<span class="axe-node">
        <span class="axe-planet">${g(p)}${p}</span>
        ${r?`<span class="axe-retro">℞</span>`:""}
