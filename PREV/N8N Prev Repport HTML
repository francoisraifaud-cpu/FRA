        .cyc-icon{font-size:1.5rem;color:#2E5FA3;line-height:1}.cyc-text{font-size:0.88rem;color:#1e293b;font-weight:600;line-height:1.5}
        .cyc-badge2{color:#a3bfdb;border-color:#a3bfdb}
    </style>
</head>
<body>
<div class="report-container">
    <div class="main-header">
        <h1>${L.titre} —<br>${prenomNom}</h1>
        <p class="subtitle">${_lumHeaderDP}</p>
        <p class="details">${labelType.toUpperCase()} &middot; ${dateEntreeStr} ➔ ${dateSortieStr}</p>
    </div>
    ${(() => {
        const helioLines = [];
        if (helioConditions) {
            Object.entries(helioConditions).forEach(([name, v]) => {
                if (v.condition) {
                    const orient = v.orientation ? ` · ${v.orientation}` : '';
                    const isCazimi = v.condition.includes('CAZIMI');
                    const isCombuste = v.condition.includes('COMBUSTE');
                    const color = isCazimi ? '#1F3864' : isCombuste ? '#dc2626' : '#6b7280';
                    const icon = isCazimi ? '☀️' : isCombuste ? '🔥' : '🌤️';
                    helioLines.push(`<div style="display:flex;align-items:center;gap:8px;padding:4px 0"><span>${icon}</span><span style="font-weight:700">${glyphs[name]||''} ${name}</span> <span style="color:${color};font-size:0.9em">${v.condition}${orient}</span></div>`);
                }
            });
        }
        if (helioLines.length === 0 && !chartRulerTrad) return '';
        let html = '<div style="background:#eef2fb;border:1px solid #2E5FA3;border-radius:10px;padding:14px 18px;margin:0 0 20px">';
        if (chartRulerTrad) {
            html += `<div style="font-weight:700;color:#1F3864;margin-bottom:8px;font-size:1em">👑 ${L.coMaitre} <strong>${chartRulerTrad}</strong></div>`;
        }
        if (helioLines.length > 0) {
            html += `<div style="font-weight:700;color:#1F3864;margin-bottom:6px;font-size:0.95em">☀ ${L.condHelio}</div>`;
            html += helioLines.join('');
        }
        html += '</div>';
        return html;
    })()}
    ${eclipseNatalH ? `<div style="background:linear-gradient(135deg,#fff0e6,#fff8f5);border:2px solid #7c2d12;border-radius:10px;padding:14px 18px;margin:0 0 20px;"><div style="color:#7c2d12;font-weight:700;font-size:1.05em;margin-bottom:6px">⚡ ${L.neeSousEcl}</div><div>${L.eclipse} <strong>${eclipseNatalH.type}</strong> ${L.de} <strong>${eclipseNatalH.astre}</strong> ${L.en} <strong>${eclipseNatalH.sign}</strong> — ${L.maison} <strong>${eclipseNatalH.house}</strong> (${((eclipseNatalH.degree??0)%30).toFixed(1)}°). ${L.eclNatDesc}${eclipseNatalH.house} ${L.eclNatDesc2}</div></div>` : ""}
    ${(etoileMatchesNatH.length || etoileCuspNatH.length) ? `<div style="background:#fff8e1;border:1px solid #ffb300;border-radius:8px;padding:10px 16px;margin:0 0 16px;color:#5d4037">★ ${L.themeStellair} ${[...new Set([...etoileMatchesNatH.map(e=>e.etoile),...etoileCuspNatH.map(e=>e.etoile)])].join(' · ')} ${L.voirSection}</div>` : ""}
    ${"" /* Parans Brady — SUPPRIMÉ du rapport Prévisions (déjà présent dans le DHN) */}
    ${_primaryDirections && _primaryDirections.length > 0 ? (() => {
        const aspGlyph = {"Conjonction":"☌","Opposition":"☍","Carré":"□","Trigone":"△","Sextile":"⚹"};
        const dpRows = _primaryDirections.map((dp, i) => {
            const bg = i % 2 === 0 ? '#faf5ff' : '#ffffff';
            const orbCol = dp.orbYears <= 0.3 ? '#991b1b' : dp.orbYears <= 0.7 ? '#b45309' : '#4b5563';
            const orbBold = dp.orbYears <= 0.5 ? 'font-weight:700' : '';
            return `<tr style="background:${bg}"><td style="padding:7px 12px;font-weight:600">${glyphs[dp.promissor]||''}  ${dp.promissor}</td><td style="padding:7px 12px;text-align:center;font-size:1.1em">${aspGlyph[dp.aspect]||dp.aspect}</td><td style="padding:7px 12px;font-weight:600">${glyphs[dp.significator]||''} ${dp.significator}</td><td style="padding:7px 12px;text-align:center;font-size:0.85em;color:#6b7280">${dp.direction}</td><td style="padding:7px 12px;text-align:center">${dp.exactAge.toFixed(1)} ans</td><td style="padding:7px 12px;text-align:center;color:${orbCol};${orbBold}">${dp.orbYears.toFixed(2)} an${dp.orbYears >= 2 ? 's' : ''}</td><td style="padding:7px 12px;text-align:center;font-size:0.85em">M${dp.promHouse||'?'} → M${dp.sigHouse||'?'}</td></tr>`;
        }).join('');
        return `<div class="house-block" style="page-break-before:always;margin-bottom:30px">
            <div class="house-banner" style="background:linear-gradient(135deg,#4a1d96,#7c3aed)">
                <div class="house-title" style="color:white">🔱 ${L.dirPrimaires}</div>
                <div class="house-meta"><span class="type-badge" style="background:#fbbf24;color:#1a1a2e;font-weight:700">${_primaryDirections.length} ${_primaryDirections.length>1?L.dirsActives:L.dirActive}</span><span class="type-badge" style="background:rgba(255,255,255,0.2);color:white;margin-left:6px">${L.methodeDP}</span></div>
            </div>
            <div class="house-content">
                <div style="background:#faf5ff;border:2px solid #7c3aed;border-radius:8px;padding:12px 16px;margin-bottom:14px;color:#4a1d96;font-size:0.9em">
                    ${L.dpWarning}
                </div>
                <table style="width:100%;border-collapse:collapse;font-size:0.9rem">
                    <tr style="background:linear-gradient(135deg,#4a1d96,#7c3aed);color:white"><th style="padding:8px 12px;text-align:left">${L.promisseur}</th><th style="padding:8px 12px;text-align:center">${L.aspect}</th><th style="padding:8px 12px;text-align:left">${L.significateur}</th><th style="padding:8px 12px;text-align:center">${L.type}</th><th style="padding:8px 12px;text-align:center">${L.ageExact}</th><th style="padding:8px 12px;text-align:center">${L.orbe}</th><th style="padding:8px 12px;text-align:center">${L.maisons_pl}</th></tr>
                    ${dpRows}
                </table>
                ${firdariaActive ? `<div style="margin-top:16px;padding:12px 16px;background:#faf5ff;border:1px solid #c4b5fd;border-radius:8px;font-size:0.88rem;line-height:1.55;color:#5b21b6;text-align:left;hyphens:none">${L.dpFirdBridge}</div>` : ''}
            </div>
        </div>`;
    })() : ''}
    ${_solarArcRows.length > 0 ? (() => {
        const aspGlyphSA = {"Conjonction":"☌","Opposition":"☍","Carré":"□","Trigone":"△","Sextile":"⚹","Quinconce":"⚻"};
        const escSA = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const saRows = _solarArcRows.map((row, i) => {
            if (row.fallback) {
                return `<tr style="background:${i % 2 ? '#ffffff' : '#fff7ed'}"><td colspan="6" style="padding:8px 12px;font-size:0.85rem">${escSA(row.fallback)}</td></tr>`;
            }
            const bg = i % 2 === 0 ? '#fff7ed' : '#ffffff';
            const orbDisp = (isEN ? row.orbRaw : String(row.orbRaw).replace('.', ',')) + '°';
            const gDir = glyphs[row.directed] || '';
            const gTgt = glyphs[row.target] || '';
            const noteCell = row.note ? escSA(row.note) : '—';
            return `<tr style="background:${bg}"><td style="padding:7px 10px;font-weight:600">${gDir} ${escSA(row.directed)}<div style="font-size:0.72rem;color:#9a3412;font-weight:500">${escSA(row.dirSign)} · M${row.dirHouse}</div></td><td style="padding:7px 10px;text-align:center;font-size:1.05em">${aspGlyphSA[row.aspect] || row.aspect}</td><td style="padding:7px 10px;font-weight:600">${gTgt} ${escSA(row.target)}</td><td style="padding:7px 10px;text-align:center;font-weight:600">M${row.targetHouse}</td><td style="padding:7px 10px;text-align:center;font-weight:600">${orbDisp}</td><td style="padding:7px 10px;font-size:0.82rem;color:#57534e">${noteCell}</td></tr>`;
        }).join('');
        return `<div class="house-block" style="page-break-before:always;break-before:page;margin-bottom:30px">
            <div class="house-banner" style="background:linear-gradient(135deg,#9a3412,#ea580c)">
                <div class="house-title" style="color:white">☀ ${L.solarArcTitle}</div>
                <div class="house-meta"><span class="type-badge" style="background:#ffedd5;color:#9a3412;font-weight:700">${_solarArcRows.length} ${L.solarArcCountLbl}</span><span class="type-badge" style="background:rgba(255,255,255,0.22);color:white;margin-left:6px">${L.solarArcBadge}</span></div>
            </div>
            <div class="house-content">
                <div style="background:#fff7ed;border:1px solid #fdba74;border-radius:8px;padding:10px 14px;margin-bottom:12px;color:#7c2d12;font-size:0.88rem;line-height:1.5">${L.saIntro}</div>
                <table style="width:100%;border-collapse:collapse;font-size:0.88rem">
                    <tr style="background:linear-gradient(135deg,#9a3412,#ea580c);color:white"><th style="padding:8px 10px;text-align:left">${L.saDirected}</th><th style="padding:8px 10px;text-align:center">${L.aspect}</th><th style="padding:8px 10px;text-align:left">${L.saTarget}</th><th style="padding:8px 10px;text-align:center">${L.saHouseTgt}</th><th style="padding:8px 10px;text-align:center">${L.saOrb}</th><th style="padding:8px 10px;text-align:left">${L.saNote}</th></tr>
                    ${saRows}
                </table>
            </div>
        </div>`;
    })() : ''}
    ${firdariaActive ? `<div class="house-block" style="${((_primaryDirections && _primaryDirections.length > 0) || _solarArcRows.length > 0) ? 'page-break-before:always;break-before:page;' : ''}margin-bottom:30px">
        <div class="house-banner" style="background:${tc.bg}">
            <div class="house-title">⏳ ${L.firdariaTitle}</div>
            <div class="house-meta"><span class="type-badge" style="background:${tc.badge};color:${tc.badgeTxt}">${L.periodeMaj} ${firdariaActive.major}</span></div>
        </div>
        <div class="house-content">
            <div class="timeline-item" style="border-left-color:#2E5FA3;background:#eef2fb">
                <div class="event-text" style="font-size:0.95rem">
                    <strong>${L.chronoMaj}</strong> ${firdariaActive.major} (${L.age} ${firdariaActive.startAge}–${firdariaActive.endAge})<br>
                    <strong>${L.sousPeriode}</strong> ${firdariaActive.sub}<br>
                    <span style="color:#64748b;font-size:0.9em;margin-top:6px;display:block">${L.firdariaDesc} <strong>${firdariaActive.major}</strong> ${isEN?'and':'et'} <strong>${firdariaActive.sub}</strong> ${L.firdariaDesc2}</span>
                </div>
            </div>
        </div>
    </div>` : ''}
    ${progressionsRaw ? (() => {
        const progAge = typeof progressionsRaw.age === 'number' ? progressionsRaw.age.toFixed(0) : '?';
        const progPlanetsHTML = Object.entries(progressionsRaw.planetes || {}).map(([pName, pd], i) => {
            const bg = i % 2 === 0 ? '#fafafa' : '#ffffff';
            return `<tr style="background:${bg}"><td style="padding:7px 14px;font-weight:700">${glyphs[pName]||''} ${pName}</td><td style="padding:7px 14px">${pd.deg||'?'}</td><td style="padding:7px 14px;text-align:center">${signGlyphs[pd.sign]||''} ${pd.sign||'?'}</td><td style="padding:7px 14px;text-align:center">M${pd.house||'?'}</td><td style="padding:7px 14px;text-align:center">${pd.retro ? '℞' : '—'}</td></tr>`;
        }).join('');
        const _progAspNoSA = (progressionsRaw.aspects || []).filter(a => typeof a !== 'string' || a.indexOf('ARC SOLAIRE') === -1);
        const progAspectsHTML = _progAspNoSA.length > 0
            ? `<div class="section-title" style="color:#2E5FA3;margin-top:18px;page-break-before:always">🔮 ${L.aspEvtProg}</div>` +
              _progAspNoSA.map(a => { const txt = typeof a === 'string' ? a : `${a.pProg || '?'} en ${a.aspect || '?'} à ${a.pNat || '?'} natal (M${a.maisonNat || '?'}) — orbe ${a.exactitude || '?'}°`; return `<div class="timeline-item" style="border-left-color:#2E5FA3;background:#eef2fb"><div class="event-text" style="font-size:0.9rem">${txt}</div></div>`; }).join('')
            : '';
        return `<div class="house-block" style="margin-bottom:45px">
            <div class="house-banner" style="background:${tc.bg}">
                <div class="house-title">🔮 ${L.progSec}</div>
                <div class="house-meta"><span class="type-badge" style="background:${tc.badge};color:${tc.badgeTxt}">${L.age} ~${progAge} ${L.ans}</span></div>
            </div>
            <div class="house-content">
                <table style="width:100%;border-collapse:collapse;font-size:0.9rem;margin-bottom:10px">
                    <tr style="background:${tc.bg};color:white"><th style="padding:8px 14px;text-align:left">${L.planete}</th><th style="padding:8px 14px;text-align:left">${L.position}</th><th style="padding:8px 14px;text-align:center">${L.signe}</th><th style="padding:8px 14px;text-align:center">${L.maison}</th><th style="padding:8px 14px;text-align:center">${L.retro}</th></tr>
                    ${progPlanetsHTML}
                </table>
                ${progAspectsHTML}
            </div>
        </div>`;
    })() : ''}
    ${_rsRaw ? (() => {
        const escH = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const rsLines = (_rsRaw.text || '').split('\n').filter(l => l.trim());
        const rsItemsHTML = rsLines.map(l => `<div class="timeline-item" style="border-left-color:#e8a735;background:#fffbeb"><div class="event-text" style="font-size:0.9rem">${escH(l)}</div></div>`).join('');
        return `<div class="house-block" style="margin-bottom:45px">
            <div class="house-banner" style="background:#b8860b">
                <div class="house-title">🌞 ${L.revSolaire}</div>
                <div class="house-meta"><span class="type-badge" style="background:#fff8e1;color:#8b6914">${L.date} : ${_rsRaw.date || '?'}</span>${_rsRaw.ascSign ? `<span class="type-badge" style="background:#fff8e1;color:#8b6914;margin-left:8px">${L.ascRS} ${_rsRaw.ascSign} → M${_rsRaw.ascHouse || '?'}</span>` : ''}</div>
            </div>
            <div class="house-content">${rsItemsHTML}</div>
        </div>`;
    })() : ''}
    ${_rlRaw ? (() => {
        const escH = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const rlItemsHTML = (_rlRaw.lines || []).map(l => `<div class="timeline-item" style="border-left-color:#7c3aed;background:#f5f3ff"><div class="event-text" style="font-size:0.85rem">${escH(l)}</div></div>`).join('');
        return `<div class="house-block" style="margin-bottom:45px">
            <div class="house-banner" style="background:#5b21b6">
                <div class="house-title">🌙 ${L.revLunaires}</div>
                <div class="house-meta"><span class="type-badge" style="background:#ede9fe;color:#5b21b6">${_rlRaw.count || '?'} ${L.retLunaires}</span></div>
            </div>
            <div class="house-content">${rlItemsHTML}</div>
        </div>`;
    })() : ''}
    ${_tpRaw?.length > 0 ? (() => {
        const escH = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const tpItemsHTML = _tpRaw.map(t => {
            const isPrecise = t.includes('📌') || t.includes('★');
            const bg = isPrecise ? '#eef2fb' : '#f8fafc';
            const bc = isPrecise ? '#1d4ed8' : '#64748b';
            return `<div class="timeline-item" style="border-left-color:${bc};background:${bg}"><div class="event-text" style="font-size:0.85rem">${escH(t)}</div></div>`;
        }).join('');
        return `<div class="house-block" style="margin-bottom:45px">
            <div class="house-banner" style="background:#1e40af">
                <div class="house-title">🎯 ${L.transitsProg}</div>
                <div class="house-meta"><span class="type-badge" style="background:#dbeafe;color:#1e40af">${_tpRaw.length} aspect(s)</span></div>
            </div>
            <div class="house-content">${tpItemsHTML}</div>
        </div>`;
    })() : ''}
    ${chartShapeHTML}
    ${heatmapHTML}
    ${natalAdvancedHTML}
    ${sensitivityHTML}
    ${mondiauxGlobalHTML}
    ${blocsMaisons}
</div>
</body>
</html>`;

const safeFilename = titrePrincipal
    .normalize("NFD").replace(/[\u0300-\u036f]/g,"")
    .replace(/[^a-zA-Z0-9_\-]/g,"_").replace(/_+/g,"_").replace(/^_|_$/g,"");

return [{
    json: { 
        titre: titrePrincipal, 
        typeRapport, 
        prenomNom, 
        desiredFilename: _desiredPdfName + ".pdf",
        filename: safeFilename + ".html"
    },
    binary: {
        html_file: {
            data: Buffer.from(html,"utf8").toString("base64"),
            mimeType: "text/html",
            fileName: "index.html" // Requis par Gotenberg
        }
    }
}];
