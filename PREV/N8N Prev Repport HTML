    h += `</div></div>`;
    if (hd.eventSignatures && hd.eventSignatures.length > 0) {
        const _sB = {high:'#fef2f2',medium:'#fffbeb',low:'#f0fdf4'};
        const _sR = {high:'#fca5a5',medium:'#fcd34d',low:'#86efac'};
