        <span class="axe-dig" style="color:${digColor(nd.force)};background:${digBg(nd.force)}">${nd.sym||""} ${nd.dignite}</span>
    </span>` : "";

    const warnings = [];
    if (ax.nd1.force===L.faible) warnings.push(`⚠ ${ax.m1} ${ax.nd1.sym} ${ax.nd1.dignite} : ${L.signalFrag}`);
    if (ax.nd1.force===L.fort)   warnings.push(`✦ ${ax.m1} ${ax.nd1.sym} ${ax.nd1.dignite} : ${L.signalPuiss}`);
