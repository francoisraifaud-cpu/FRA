const _renderHeatmap = (hd, bgColor, badgeBg, badgeTxt) => {
    if (!hd?.grid?.length) return "";
    const grid = hd.grid, labels = hd.colLabels, maxI = hd.maxIntensity || 1;
    const norm = hd.normalized || [];
    const top3 = hd.top3 || [];
    const getHC = (v) => { const r = v / maxI; if (r === 0) return '#f8fafc'; if (r < 0.25) return '#dbeafe'; if (r < 0.5) return '#93c5fd'; if (r < 0.75) return '#3b82f6'; return '#1e40af'; };
    const getTC = (v) => v / maxI >= 0.5 ? '#fff' : '#1e3a8a';
    const _nBg = (n) => n >= 75 ? '#1e40af' : n >= 50 ? '#3b82f6' : n >= 25 ? '#93c5fd' : '#dbeafe';
    const _nTc = (n) => n >= 50 ? '#fff' : '#1e3a8a';
    let h = `<div class="house-block" style="margin-bottom:45px"><div class="house-banner" style="background:${bgColor}"><div class="house-title">${hd.title}</div><div class="house-meta"><span class="type-badge" style="background:${badgeBg};color:${badgeTxt}">${hd.subtitle}</span>`;
    if (hd.profLord) h += `<span class="type-badge" style="background:#fff8e1;color:#8b6914;margin-left:8px">♛ ${hd.profLord} (${L.seigneur}) ×1.5</span>`;
    if (hd.firdMajor) h += `<span class="type-badge" style="background:#e8f0fe;color:#1F3864;margin-left:8px">⏳ ${hd.firdMajor} (${L.firdaria}) ×1.3</span>`;
    h += `</div></div><div class="house-content">`;
    const _gr = hd.granularity || "annual";
    const _grFR = {daily:"pour cette journée",weekly:"par jour sur la semaine",monthly:"par semaine sur le mois",annual:"par mois sur l'année"};
    const _grEN = {daily:"for this day",weekly:"per day over the week",monthly:"per week over the month",annual:"per month over the year"};
    const _pedagDT = isEN
        ? `<strong>💡 How to read this heatmap?</strong><br>This heat map synthesizes the <strong>density of astrological activations</strong> per house ${_grEN[_gr]}. Each cell is a weighted score combining: <strong>planetary weight</strong> (Pluto ×5, Neptune/Uranus/Saturn ×4…), <strong>aspect type</strong> (Conjunction ×1.3, Square/Opposition ×1.2, Trine ×0.8, Sextile ×0.7), <strong>angular house bonus</strong> (Houses 1/4/7/10 ×1.2, cadent ×0.85), and <strong>time-lord amplification</strong> (Annual Lord ×1.5, Firdaria ×1.3). Long transits are <em>distributed</em> over their full duration, repeat passages are reduced (×0.8), and eclipses are capped at 2 per cell. The <strong style="color:#991b1b">Tension</strong> column sums hard aspects (□ ☍ ☌ ⚻), while <strong style="color:#1e40af">Support</strong> sums soft aspects (△ ⚹). <strong>Score</strong> normalizes each house on a 0–100 scale.`
        : `<strong>💡 Comment lire cette heatmap ?</strong><br>Cette carte thermique synthétise la <strong>densité d'activations astrologiques</strong> par maison ${_grFR[_gr]}. Chaque cellule est un score pondéré combinant : <strong>poids planétaire</strong> (Pluton ×5, Neptune/Uranus/Saturne ×4…), <strong>type d'aspect</strong> (Conjonction ×1.3, Carré/Opposition ×1.2, Trigone ×0.8, Sextile ×0.7), <strong>bonus maisons angulaires</strong> (M1/4/7/10 ×1.2, cadentes ×0.85), et <strong>amplification temporelle</strong> (Seigneur de l'année ×1.5, Firdaria ×1.3). Les transits longs sont <em>distribués</em> sur toute leur durée, les passages multiples (rétrogradation) sont réduits (×0.8), et les éclipses sont plafonnées à 2 par cellule. La colonne <strong style="color:#991b1b">Tension</strong> totalise les aspects durs (□ ☍ ☌ ⚻), tandis que <strong style="color:#1e40af">Support</strong> totalise les aspects doux (△ ⚹). <strong>Score</strong> normalise chaque maison sur une échelle 0-100.`;
    h += `<div style="background:#f0f7ff;border:1px solid #d0daf0;border-radius:8px;padding:14px 18px;margin:0 0 16px;font-size:0.84rem;color:#334155;line-height:1.55">${_pedagDT}</div>`;
    h += `<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:0.72rem;text-align:center"><tr style="background:${bgColor};color:white"><th style="padding:4px 4px;text-align:left">${isEN ? 'House' : 'Maison'}</th>`;
    labels.forEach(l => { h += `<th style="padding:4px 2px">${l}</th>`; });
