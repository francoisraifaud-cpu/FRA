        ${ax.m3 ? `<span class="axe-arrow">→</span>${node(ax.m3, ax.nd3, ax.nd3?.isRetro)}` : ""}
    </div>
    ${warnings.length ? `<div class="axe-warnings">${warnings.map(w=>`<div class="axe-warn">${w}</div>`).join("")}</div>` : ""}`;
};

