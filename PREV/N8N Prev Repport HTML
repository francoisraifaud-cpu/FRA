        h += `<div style="page-break-before:always;break-before:page;margin-top:16px;padding:14px 18px;background:#fafbff;border:1px solid #d0daf0;border-radius:8px"><div style="font-size:0.85rem;font-weight:700;color:#1e3a8a;margin-bottom:10px">${isEN ? '🔍 Event Signatures' : '🔍 Signatures Événementielles'}</div>`;
        hd.eventSignatures.forEach((sig, idx) => {
            const bg=_sB[sig.level]||_sB.low, brd=_sR[sig.level]||_sR.low, tx=_sT[sig.level]||_sT.low;
