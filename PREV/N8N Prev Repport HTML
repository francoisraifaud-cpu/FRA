    const _saRe = /^☀ ARC SOLAIRE :\s*(.+?)\s+dirigé\s+\(([^,]+),\s*M(\d+)\)\s+en\s+(.+?)\s+avec\s+(.+?)\s+natal\s+\(M(\d+)\)\s+—\s+orbe\s+([\d.]+)°\s*([\s\S]*)$/;
    progressionsRaw.aspects.forEach(a => {
