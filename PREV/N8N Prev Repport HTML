                .replace(/^\([^)]*\)\s*/, '')
                .replace(/\[poids\s+[\d.]+\]\.?\s*/i, '')
                .replace(/\s*Direction lente et structurante[^.]*\.?\s*/gi, '')
                .replace(/^[\s.…—\-]+/, '')
                .trim();
            _solarArcRows.push({
                directed: m[1].trim(),
                dirSign: m[2].trim(),
                dirHouse: m[3],
                aspect: m[4].trim(),
                target: m[5].trim(),
                targetHouse: m[6],
                orbRaw: m[7],
                note
            });
        } else {
            _solarArcRows.push({ fallback: a });
        }
    });
}

