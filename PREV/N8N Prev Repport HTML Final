const ZODIAC_MAP = {'Bélier':'♈','Taureau':'♉','Gémeaux':'♊','Cancer':'♋','Lion':'♌','Vierge':'♍','Balance':'♎','Scorpion':'♏','Sagittaire':'♐','Capricorne':'♑','Verseau':'♒','Poissons':'♓'};
const esc = (t) => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

const md = (text) => {
  if (!text || text.trim() === '') return '<p style="color:#aaa;font-style:italic;font-size:14px;">⚠️ ' + (isEN ? 'Analysis not available.' : 'Analyse non disponible pour cette section.') + '</p>';
  const rB3 = /\*\*\*(.*?)\*\*\*/g, rB2 = /\*\*(.*?)\*\*/g, rB1 = /\*(.*?)\*/g;
  const inl = (t) => esc(t).replace(rB3,'<strong><em>$1</em></strong>').replace(rB2,'<strong>$1</strong>').replace(rB1,'<em>$1</em>');
  const h3Style = "font-family:'Source Sans 3','Segoe UI',sans-serif;font-size:18px;font-weight:800;color:#1a1a2e;margin:28px 0 10px;line-height:1.3;";
  const h4Style = "font-family:'Source Sans 3','Segoe UI',sans-serif;font-size:16px;font-weight:700;color:" + theme.accent + ";margin:24px 0 8px;padding-left:12px;border-left:3px solid " + theme.accent + ";line-height:1.4;";
  const h5Style = "font-family:'Source Sans 3','Segoe UI',sans-serif;font-size:15px;font-weight:700;color:#1a1a2e;margin:16px 0 6px;line-height:1.4;";
  // Pré-processing A : titre gras wrappé multi-ligne
  text = String(text);
  if (text.includes('\\n')) text = text.replace(/\\n/g, '\n');
  text = text
    .replace(/^([\*]{0,3}\d[\d.]*[\.\)]\s[^\n]{4,})\n([^\n\*]{3,80}[\*]{1,3})/gm, '$1 $2');
  // Pré-processing B : parenthèse non fermée en fin de ligne numérotée
  text = text.replace(
    /^([\*]{0,3}\d[\d.]*[\.\)]\s[^\n]*\([^\n)]*)\n([\wÀ-ÿ\u2019\u2018'-]+\))/gm,
    '$1 $2');
  // Pré-processing C : continuation très courte après titre numéroté
  text = text.replace(
    /^([\*]{0,3}\d[\d.]*[\.\)]\s[^\n]{30,140})\n([^\n\d\*\#\.]{2,25})\n/gm,
    '$1 $2\n');
  // Pré-processing D : LLM colle titre et corps sur une même ligne avec ## comme séparateur
  text = text.replace(/^(#{1,3} .+?)\s+#{2,}\s+([^\n]+)$/gm, '$1\n$2');
  const lines = text.split('\n');
  const out = [];
  let inList = false;
  for (let line of lines) {
    line = line.replace(/^[\uFEFF\u200B]+/, '');
    if (/^#{1,}[^\S\r\n]/.test(line)) line = line.replace(/^(#{1,})[^\S\r\n]+/, '$1 ');
    const isBullet = /^[-*]\s+\S/.test(line) && !/^\*\*/.test(line);
    if (!isBullet && inList) { out.push('</ul>'); inList = false; }
    line = line.replace(/\s+#+\s*$/, '');
    const stripped = line.replace(/\*/g, '');
    let handled = false;
    if (/^#{1,} /.test(line)) {
      line = line.replace(/\*/g, '');
      if (/^# [^#]/.test(line)) line = '#' + line;
    } else {
      const subM = stripped.match(/^(\d+\.\d+[.)]\s+)(.+)$/);
      if (subM) {
        const prefix = subM[1], rest = subM[2], colon = rest.indexOf(' : ');
        if (colon > 0 && colon <= 90) {
          const after = rest.slice(colon + 3);
          if (after.length > 60) {
            out.push('<h5 style="' + h5Style + '">' + esc(prefix + rest.slice(0, colon)) + '</h5>');
            if (after.trim()) out.push('<p style="font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:4px 0 9px;text-align:justify;">' + inl(after) + '</p>');
            handled = true;
          } else if ((prefix + rest).length <= 130) { line = '#### ' + prefix + rest; }
        } else if ((prefix + rest).length <= 130) { line = '#### ' + prefix + rest; }
      } else {
        const mainM = stripped.match(/^(\d+[.)]\s+)(.+)$/);
        if (mainM) {
          const prefix = mainM[1], rest = mainM[2];
          if ((prefix + rest).length <= 155) {
            line = '### ' + prefix + rest;
          } else {
            const colon = rest.indexOf(' : ');
            if (colon > 0 && colon <= 120) {
              const after = rest.slice(colon + 3);
              out.push('<h4 style="' + h4Style + '">' + esc(prefix + rest.slice(0, colon)) + '</h4>');
              if (after.trim()) out.push('<p style="font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:9px 0;text-align:justify;">' + inl(after) + '</p>');
              handled = true;
            } else { line = '### ' + prefix + rest; }
          }
        } else if (/^\*{2,3}[^*]{4,120}\*{2,3}$/.test(line)) {
          line = '### ' + stripped;
        } else if (stripped.length <= 130 && /^[\p{Emoji_Presentation}\p{So}A-ZÀ-ÿ][^:\n]{2,55} : [\p{Emoji_Presentation}\p{So}A-ZÀ-ÿ].{2,70}$/u.test(stripped)) {
          line = '#### ' + stripped;
        } else if (/^(conclusion|synthèse|en\s+synthèse|en\s+conclusion|recommandation)/i.test(stripped) && stripped.length < 120) {
          const colonIdx = stripped.indexOf(' : ');
          if (colonIdx > 0 && colonIdx <= 50 && stripped.slice(colonIdx + 3).trim().length > 20) {
            out.push('<h4 style="' + h4Style + '">' + esc(stripped.slice(0, colonIdx)) + '</h4>');
            out.push('<p style="font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:9px 0;text-align:justify;">' + inl(stripped.slice(colonIdx + 3)) + '</p>');
            handled = true;
          } else { line = '### ' + stripped; }
        } else if (stripped.length >= 8 && stripped.length <= 90 && /^[\p{Emoji_Presentation}\p{So}A-ZÀ-ÿ]/u.test(stripped) && !/[.!?;:,…]$/.test(stripped.trim())) {
          line = '### ' + stripped;
        }
      }
    }
    if (handled) continue;
    if (line.startsWith('## ') && !line.startsWith('### ')) {
      out.push('<p style="font-family:\'Source Sans 3\',\'Segoe UI\',sans-serif;font-size:16px;font-weight:700;color:' + theme.accent + ';margin:24px 0 8px;padding-left:12px;border-left:3px solid ' + theme.accent + ';line-height:1.4;"><b>' + esc(line.slice(3)) + '</b></p>');
    } else if (line.startsWith('### ')) {
      out.push('<p style="font-family:\'Source Sans 3\',\'Segoe UI\',sans-serif;font-size:15px;font-weight:700;color:#1a1a2e;margin:16px 0 6px;line-height:1.4;"><b>' + esc(line.slice(4)) + '</b></p>');
    } else if (line.startsWith('#### ')) {
      out.push('<h5 style="' + h5Style + '">' + esc(line.slice(5)) + '</h5>');
    } else if (isBullet) {
      if (!inList) { out.push('<ul style="margin:10px 0 12px 20px;padding:0;">'); inList = true; }
      out.push('<li style="font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:7px 0;">' + inl(line.replace(/^[-*]\s+/, '')) + '</li>');
    } else if (line.trim() === '') {
      out.push('<div style="height:10px;"></div>');
    } else if (line.match(/^---+$/) || line.match(/^\*\*\*+$/)) {
      out.push('<hr style="border:0;border-top:1px solid #e8ebf5;margin:22px 0;">');
    } else {
      out.push('<p style="font-size:15.5px;line-height:1.82;color:#2c2c3a;margin:9px 0;text-align:justify;">' + inl(line) + '</p>');
    }
  }
  if (inList) out.push('</ul>');
  return out.join('');
};

