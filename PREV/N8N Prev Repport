const processGroup = (planets, suiviT, suiviA, sectionT, sectionA, orbe, days, idx, date, prevDay) => {
    for (const pT of planets) {
        if (!days[idx].planetes?.[pT]) continue;
        const posT = days[idx].planetes[pT].fullDegree;
        const loc  = getLocation(posT);
        if (!suiviT[pT] || suiviT[pT].maison !== loc.maison || suiviT[pT].signe !== loc.signe) {
            if (suiviT[pT]) {
                const s = suiviT[pT];
                rapportMaisons[s.maison-1][sectionT].push({ planete:pT, signe:s.signe, debut:s.debut, fin:prevDay });
            }
            suiviT[pT] = { ...loc, debut: date };
        }
        for (const pN of natalPlanets) {
            const nameN = pN.planet?.fr || pN.planet?.en || "";
            if (!nameN) continue;
            let diff = Math.abs(posT - pN.fullDegree);
            if (diff > 180) diff = 360 - diff;
            for (const [degAng, type] of Object.entries(ANGLES_ASP)) {
                const key = `${pT}_${type}_${nameN}`;
                const orb = Math.abs(diff - Number(degAng));
                if (orb <= orbe) {
                    if (!suiviA[key]) {
                        suiviA[key] = { type, pTransit:pT, pNatal:nameN, debut:date, maison:loc.maison, isAngle:angleSet.has(nameN), bestOrb:orb, peakDate:date };
                    } else if (orb < suiviA[key].bestOrb) {
                        suiviA[key].bestOrb = orb; suiviA[key].peakDate = date;
                    }
                } else if (suiviA[key]) {
                    const asp = suiviA[key];
                    rapportMaisons[asp.maison-1][sectionA].push({ ...asp, fin:prevDay });
                    delete suiviA[key];
                }
            }
        }
    }
};

const processAngles = (allPlanets, idx, date, prevDay) => {
    for (const pT of allPlanets) {
        if (!days[idx].planetes?.[pT]) continue;
        const posT = days[idx].planetes[pT].fullDegree;
        for (const [angleName, angleDeg] of Object.entries(natalAngles)) {
            let diff = Math.abs(posT - angleDeg);
            if (diff > 180) diff = 360 - diff;
            const key = `${pT}_angle_${angleName}`;
            const inOrb = diff <= ORBE_ANGLE;
            if (inOrb && !suiviAngle[key]) {
                const maisAngle = ANGLE_NAMES[angleName]?.maison || 1;
                const loc = getLocation(posT);
                suiviAngle[key] = { planete:pT, angleName, angleKey:ANGLE_NAMES[angleName]?.key||angleName, debut:date, maison:maisAngle, maisTransit:loc.maison };
            } else if (!inOrb && suiviAngle[key]) {
                const a = suiviAngle[key];
                const signe = signs[Math.floor(days[idx].planetes[pT].fullDegree / 30) % 12];
                rapportMaisons[a.maison-1].passages_angles.push({ ...a, fin:prevDay, signe });
                delete suiviAngle[key];
            }
        }
    }
};

const processTransitTransit = (idx, date, prevDay) => {
    for (const pair of ttPairs) {
        const { p1, p2, orbe, cat } = pair;
        if (!days[idx].planetes?.[p1] || !days[idx].planetes?.[p2]) continue;
        const pos1 = days[idx].planetes[p1].fullDegree;
        const pos2 = days[idx].planetes[p2].fullDegree;
        let diff = Math.abs(pos1 - pos2);
        if (diff > 180) diff = 360 - diff;

        for (const [degAng, type] of Object.entries(TT_ASPECTS)) {
            const key = `TT_${p1}_${type}_${p2}`;
            const orb = Math.abs(diff - Number(degAng));
            if (orb <= orbe && !suiviTT[key]) {
                const loc1 = getLocation(pos1);
                const loc2 = getLocation(pos2);
                suiviTT[key] = { type, p1, p2, cat, debut:date, maison:loc1.maison, maison2:loc2.maison, signe1:signs[Math.floor(pos1/30)%12], signe2:signs[Math.floor(pos2/30)%12] };
            } else if (orb > orbe && suiviTT[key]) {
                const asp = suiviTT[key];
                rapportMaisons[asp.maison-1].aspects_mondiaux.push({ ...asp, fin:prevDay });
                delete suiviTT[key];
            }
        }
    }
};

