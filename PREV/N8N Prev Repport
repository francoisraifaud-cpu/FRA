const buildTTPairs = () => {
    const pairs = [];
    for (let i = 0; i < slowPlanets.length; i++) {
        for (let j = i + 1; j < slowPlanets.length; j++) {
            pairs.push({ p1: slowPlanets[i], p2: slowPlanets[j], orbe: ORBE_TT_LL, cat: "lente_lente" });
        }
    }
    if (fastPlanets.length > 0) {
        for (const pr of fastPlanets) {
            for (const pl of slowPlanets) {
                if (pr !== pl) pairs.push({ p1: pr, p2: pl, orbe: ORBE_TT_RL, cat: "rapide_lente" });
            }
        }
    }
    return pairs;
};
