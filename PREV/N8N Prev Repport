    const signe=signs[Math.floor(degAbs/30)%12], deg=degAbs%30, r=[];
    if(deg>=28.5) r.push("Anarète 29°");
    if(deg<0.5)   r.push("Ingress 0°");
    if(SIGNS_CARD.has(signe)&&(Math.abs(deg-13)<0.5||Math.abs(deg-26)<0.5)) r.push(`${Math.round(deg)}° ${signe} crit.`);
    if(SIGNS_FIXE.has(signe)&&((deg>=8&&deg<9.5)||(deg>=21&&deg<22.5))) r.push(`${Math.round(deg)}° ${signe} crit.`);
    if(SIGNS_MUT.has(signe)&&(Math.abs(deg-4)<0.5||Math.abs(deg-17)<0.5)) r.push(`${Math.round(deg)}° ${signe} crit.`);
    return r;
};
