    const ascIdxA  = ascSignA ? signs.indexOf(ascSignA) : -1;
    const signeProfA = ascIdxA >= 0 ? signs[(ascIdxA + maisAnn - 1) % 12] : (natalHouses.find(h=>h.maison===maisAnn)?.segments[0]?.signe || null);
    const seigneur = signeProfA ? MAITRES_TRAD_A[signeProfA] : null;
    const seignNd  = seigneur ? natalDictLoc[seigneur] : null;
    const moisDeb  = dStartMonA;
    const dec      = ((moisDeb - moisNaissA + 12) % 12);
    const maisMens = ((maisAnn - 1 + dec) % 12) + 1;

    const ageNext     = ageA + 1;
    const maisNext    = ((ageNext % 12) + 12) % 12 + 1;
    const signeNext   = ascIdxA >= 0 ? signs[(ascIdxA + maisNext - 1) % 12] : (natalHouses.find(h=>h.maison===maisNext)?.segments[0]?.signe || null);
    const seigneurNext = signeNext ? MAITRES_TRAD_A[signeNext] : null;
    const seignNdNext  = seigneurNext ? natalDictLoc[seigneurNext] : null;
    const bdayInRange  = dStart <= new Date(anneeRpA, dateNaissA.getMonth(), jourNaissA) &&
                         new Date(anneeRpA, dateNaissA.getMonth(), jourNaissA) <= dEnd;
    const bascule = bdayInRange ? {
        date: `${jourNaissA}/${String(moisNaissA).padStart(2,"0")}/${anneeRpA}`,
        ageNext, maisNext, signeNext, seigneurNext,
        seignMaisonNext: seignNdNext?.house || null
    } : null;

    profectionsA = { age:ageA, maisAnn, seigneur, seignMaison:seignNd?.house, signeCusp:signeProfA, maisMens, bascule };
    if (maisAnn >= 1 && maisAnn <= 12)
        rapportMaisons[maisAnn-1].profection = { role:"annuelle", age:ageA, seigneur, seignMaison:seignNd?.house, bascule };
    if (maisMens >= 1 && maisMens <= 12 && maisMens !== maisAnn && typeRapport !== "Annuel")
        rapportMaisons[maisMens-1].profection = { role:"mensuelle", maisAnn };
    if (seignNd?.house >= 1 && seignNd?.house <= 12 && seignNd.house !== maisAnn)
        rapportMaisons[seignNd.house-1].profection = Object.assign({}, rapportMaisons[seignNd.house-1].profection || {}, { seigneurIci:seigneur, maisAnn });
    if (bascule && maisNext >= 1 && maisNext <= 12 && maisNext !== maisAnn)
        rapportMaisons[maisNext-1].profection = Object.assign({}, rapportMaisons[maisNext-1].profection || {}, { role:"bascule", bascule });
    if (bascule && seignNdNext?.house >= 1 && seignNdNext?.house <= 12 && seignNdNext.house !== maisAnn && seignNdNext.house !== (seignNd?.house || -1))
        rapportMaisons[seignNdNext.house-1].profection = Object.assign({}, rapportMaisons[seignNdNext.house-1].profection || {}, { seigneurNextIci:seigneurNext, maisNext });
}

const calcAntA = (d) => ((180 - d) + 360) % 360;
const calcConA = (d) => (360 - d) % 360;
const natalAntisciaA = Object.keys(natalDictLoc).map(p => ({
    pNatal: p, deg: natalDictLoc[p].deg,
    antiscion: calcAntA(natalDictLoc[p].deg),
    contra: calcConA(natalDictLoc[p].deg),
    maison: natalDictLoc[p].house
}));
const ORBE_ANT_A = 1.5;
let suiviAntA = {};

// Cycles de vie (C11) — inclut Nœud Nord
const CYCLES_PL = {
    "Saturne" : { periode:29.5, phases:[{frac:1/4,label:"Carré Saturne ~7 ans"},{frac:1/2,label:"Opposition Saturne ~15 ans"},{frac:3/4,label:"Carré Saturne ~22 ans"},{frac:1,label:"Retour Saturne ~30 ans"},{frac:3/2,label:"Opposition 2e cycle ~44 ans"},{frac:2,label:"2e Retour Saturne ~59 ans"}]},
    "Jupiter" : { periode:11.86, phases:[{frac:1/2,label:"Opposition Jupiter ~6 ans"},{frac:1,label:"Retour Jupiter ~12 ans"},{frac:3/2,label:"Opposition Jupiter ~18 ans"},{frac:2,label:"Retour Jupiter ~24 ans"},{frac:5/2,label:"Retour Jupiter ~30 ans"},{frac:3,label:"Retour Jupiter ~36 ans"},{frac:7/2,label:"Opposition Jupiter ~42 ans"},{frac:4,label:"Retour Jupiter ~48 ans"}]},
    "Uranus"  : { periode:84,   phases:[{frac:1/4,label:"Carré Uranus ~21 ans"},{frac:1/2,label:"Opposition Uranus ~42 ans (mi-vie)"},{frac:3/4,label:"Carré Uranus ~63 ans"},{frac:1,label:"Retour Uranus ~84 ans"}]},
    "Chiron"  : { periode:50.7, phases:[{frac:1/2,label:"Opposition Chiron ~25 ans"},{frac:1,label:"Retour Chiron ~51 ans"}]},
    "Nœud Nord":{ periode:18.6, phases:[{frac:1/2,label:"Opposition Nœuds ~9 ans"},{frac:1,label:"Retour Nœud ~19 ans"},{frac:3/2,label:"Opposition Nœuds ~28 ans"},{frac:2,label:"Retour Nœud ~37 ans"}]},
};
const dateNaissCyc = parseDate(perso.date);
const cyclesActifsA = [];
if (dateNaissCyc && !isNaN(dateNaissCyc)) {
    const MS_AN = 365.25 * 24 * 3600 * 1000;
    const ageDebA = (dStart - dateNaissCyc) / MS_AN;
    const ageFnA  = (dEnd   - dateNaissCyc) / MS_AN;
    for (const [pl, cyc] of Object.entries(CYCLES_PL)) {
        for (const ph of cyc.phases) {
            const ageP = cyc.periode * ph.frac;
            if (ageP >= ageDebA - 0.5 && ageP <= ageFnA + 0.5) {
                const dp = new Date(dateNaissCyc.getTime() + ageP * MS_AN);
                const m  = natalDictLoc[pl]?.house;
                cyclesActifsA.push({ planete:pl, label:ph.label, age:(ageP ?? 0).toFixed(1), date:dp.toISOString().split("T")[0], maison:m });
            }
        }
    }
}
cyclesActifsA.forEach(c => {
    if (c.maison >= 1 && c.maison <= 12)
        rapportMaisons[c.maison-1].cycles_vie.push(`${c.label} — approx. ${c.date} (âge ~${c.age} ans).`);
});

// Ingress planétaires (C9) — inclut Nœud Nord et Nœud Sud
const slowPl_A = ["Jupiter","Saturne","Uranus","Neptune","Pluton","Nœud Nord","Nœud Sud","Chiron"];
let prevSignesA = {};

// =====================================================================
// BOUCLE PRINCIPALE JOURS
// =====================================================================
days.forEach((day, idx) => {
    const date    = day.date;
    const prevDay = idx > 0 ? days[idx-1].date : date;

    processGroup(slowPlanets, suiviTL, suiviAL, "transits_lentes",  "aspects_lentes",  ORBE_L, days, idx, date, prevDay);
    processGroup(fastPlanets, suiviTR, suiviAR, "transits_rapides", "aspects_rapides", ORBE_R, days, idx, date, prevDay);
    processAngles(allTransitPlanets, idx, date, prevDay);
    processTransitTransit(idx, date, prevDay);

    // Translation de lumière
    for (const pF of allTransitPlanets.filter(p => fastPlanets.includes ? fastPlanets.includes(p) : ["Soleil","Lune","Mercure","Vénus","Mars"].includes(p))) {
        if (!days[idx].planetes?.[pF]) continue;
        const posF = days[idx].planetes[pF].fullDegree;
        for (let i = 0; i < slowPlanets.length; i++) {
            for (let j = i+1; j < slowPlanets.length; j++) {
                const pS1 = slowPlanets[i], pS2 = slowPlanets[j];
                if (!days[idx].planetes?.[pS1] || !days[idx].planetes?.[pS2]) continue;
                const posS1 = days[idx].planetes[pS1].fullDegree, posS2 = days[idx].planetes[pS2].fullDegree;
                let dS = Math.abs(posS1-posS2); if (dS>180) dS=360-dS;
                if ([0,60,90,120,180].some(d => Math.abs(dS-d)<=3)) continue;
                const d1 = chkTLAsp(posF, posS1), d2 = chkTLAsp(posF, posS2);
                const key = `TL_${pF}_${pS1}_${pS2}`;
                if (d1!==null && d2!==null && !suiviTL_map[key]) {
                    suiviTL_map[key] = { pF, pS1, pS2, asp1:TL_ASP_DEG_MAP[d1], asp2:TL_ASP_DEG_MAP[d2], debut:date, maisS1:getLocation(posS1).maison, maisS2:getLocation(posS2).maison, signeF:signs[Math.floor(posF/30)%12] };
                } else if ((d1===null || d2===null) && suiviTL_map[key]) {
                    const tl = suiviTL_map[key];
                    [...new Set([tl.maisS1, tl.maisS2])].forEach(m => {
                        if (m>=1 && m<=12) rapportMaisons[m-1].translations_lumiere.push({...tl, fin:prevDay});
                    });
                    delete suiviTL_map[key];
                }
            }
        }
    }

    // Stations rétrogrades (Nœud Nord/Sud exclus car toujours rétrogrades par définition)
    for (const p of retroPlanets) {
        if (!day.planetes?.[p]) continue;
        const rawRetro = day.planetes[p].isRetro;
        const isRetro  = rawRetro === "True" || rawRetro === true;
        if (suiviRetro[p] !== null && suiviRetro[p] !== isRetro) {
            const posT = day.planetes[p].fullDegree;
            const loc  = getLocation(posT);
            rapportMaisons[loc.maison-1].stations_retro.push({ planete:p, type:isRetro ? "Station rétrograde" : "Station directe", date, signe:signs[Math.floor(posT/30)%12], maison:loc.maison, fullDegree:posT });
        }
        suiviRetro[p] = isRetro;
    }

    // Lunaisons
    let luneDeg = null;
    const luneEntries = luneData[date];
    if (luneEntries?.length > 0) {
        const midi = luneEntries.find(e => e.heure >= "12:00") || luneEntries[0];
        luneDeg = midi.fullDegree;
    } else if (day.planetes?.Lune) { luneDeg = day.planetes.Lune.fullDegree; }
    const soleilDeg = day.planetes?.Soleil?.fullDegree;
    if (luneDeg !== null && soleilDeg !== undefined) {
        const diff = ((luneDeg - soleilDeg) + 360) % 360;
        if (prevLuneSoleilDiff !== null) {
            if (diff < 20 && prevLuneSoleilDiff > 340) {
                const loc = getLocation(luneDeg);
                rapportMaisons[loc.maison-1].lunaisons.push({ type:"Nouvelle Lune", date, signe:signs[Math.floor(luneDeg/30)%12], degre:luneDeg, maison:loc.maison });
            } else if (diff >= 170 && diff <= 190 && prevLuneSoleilDiff < 170) {
                const loc = getLocation(luneDeg);
                rapportMaisons[loc.maison-1].lunaisons.push({ type:"Pleine Lune", date, signe:signs[Math.floor(luneDeg/30)%12], degre:luneDeg, maison:loc.maison });
            } else if (diff >= 80 && diff <= 100 && prevLuneSoleilDiff < 80) {
                const loc = getLocation(luneDeg);
                rapportMaisons[loc.maison-1].lunaisons.push({ type:"Premier Quartier", date, signe:signs[Math.floor(luneDeg/30)%12], degre:luneDeg, maison:loc.maison });
            } else if (diff >= 260 && diff <= 280 && prevLuneSoleilDiff < 260) {
                const loc = getLocation(luneDeg);
                rapportMaisons[loc.maison-1].lunaisons.push({ type:"Dernier Quartier", date, signe:signs[Math.floor(luneDeg/30)%12], degre:luneDeg, maison:loc.maison });
            }
        }
        prevLuneSoleilDiff = diff;
    }

    // =====================================================================
    // FIX BUG #1 — Fenêtres stellaires sorties du bloc if(eclipsesByDate)
    // FIX BUG #2 — Ajout de stellarByAngleAT (IC, ASC, MC, DSC)
    // Ce bloc try s'exécute désormais CHAQUE JOUR, indépendamment des éclipses
    // =====================================================================
    try {
        const allTP2_st = [...new Set([...slowPlanets,...fastPlanets])];

        // --- Planètes natales conjointes à une étoile fixe (inchangé) ---
        for (const [pN, etoiles] of Object.entries(stellarByPlanetAT)) {
            const nData = natalDictLoc[pN]; if (!nData) continue;
            for (const em of etoiles) {
                if (em.etoile_degree === undefined) continue;
                for (const pT of allTP2_st) {
                    if (!day?.planetes?.[pT]) continue;
                    let dS = Math.abs(day.planetes[pT].fullDegree - em.etoile_degree); if (dS>180) dS=360-dS;
                    const key = 'STAT_'+pT+'|||'+em.etoile+'|||'+pN;
                    if (dS <= ORBE_STELL_AT && !suiviStellairAT[key]) {
                        suiviStellairAT[key] = { pT, etoile:em.etoile, pN, maison:nData.house, debut:date, isRoyal:ETOILES_ROY_AT.has(em.etoile), desc:em.desc };
                    } else if (dS > ORBE_STELL_AT && suiviStellairAT[key]) {
                        const s = suiviStellairAT[key];
                        const descSnippet = (s.desc || '').substring(0,100);
                        const txt = '★ ' + (s.isRoyal ? 'FENÊTRE ROYALE' : 'Fenêtre stellaire') + ' — Du ' + s.debut + ' au ' + date + ' : ' + s.pT + ' active ' + s.etoile + (s.isRoyal?' [ÉTOILE ROYALE]':'') + ', conjointe à ' + s.pN + ' natal (M' + s.maison + '). Nature : ' + descSnippet + '…';
                        if (s.maison>=1&&s.maison<=12) { rapportMaisons[s.maison-1].fenetre_stellaire.push(txt); rapportMaisons[s.maison-1]._hm_etoiles.push({date: s.debut, isRoyal: !!s.isRoyal}); }
                        delete suiviStellairAT[key];
                    }
                }
            }
        }

        // --- FIX BUG #2 : Angles nataux conjoints à une étoile fixe (IC, ASC, MC, DSC) ---
        const ANGLE_KEY_TO_FULL = { "ASC":"Ascendant", "IC":"Imum Coeli", "DSC":"Descendant", "MC":"Milieu du Ciel" };
        for (const [angleKey, etoiles] of Object.entries(stellarByAngleAT)) {
            const fullName    = ANGLE_KEY_TO_FULL[angleKey] || angleKey;
            const angleDeg    = natalAngles[fullName];
            const angleMaison = ANGLE_MAIS_AT[angleKey] || 1;
            if (angleDeg === undefined) continue;
            for (const em of etoiles) {
                if (em.etoile_degree === undefined) continue;
                for (const pT of allTP2_st) {
                    if (!day?.planetes?.[pT]) continue;
                    let dS = Math.abs(day.planetes[pT].fullDegree - em.etoile_degree); if (dS>180) dS=360-dS;
                    const key = 'STAT_'+pT+'|||'+em.etoile+'|||angle_'+angleKey;
                    if (dS <= ORBE_STELL_AT && !suiviStellairAT[key]) {
                        suiviStellairAT[key] = { pT, etoile:em.etoile, pN:'angle '+angleKey, maison:angleMaison, debut:date, isRoyal:ETOILES_ROY_AT.has(em.etoile), desc:em.desc };
                    } else if (dS > ORBE_STELL_AT && suiviStellairAT[key]) {
                        const s = suiviStellairAT[key];
                        const descSnippetA = (s.desc || '').substring(0,100);
                        const txt = '★ ' + (s.isRoyal ? 'FENÊTRE ROYALE' : 'Fenêtre stellaire') + ' — Du ' + s.debut + ' au ' + date + ' : ' + s.pT + ' active ' + s.etoile + (s.isRoyal?' [ÉTOILE ROYALE]':'') + ', conjointe à l\'angle ' + angleKey + ' natal (M' + s.maison + '). Nature : ' + descSnippetA + '…';
                        if (s.maison>=1&&s.maison<=12) { rapportMaisons[s.maison-1].fenetre_stellaire.push(txt); rapportMaisons[s.maison-1]._hm_etoiles.push({date: s.debut, isRoyal: !!s.isRoyal}); }
                        delete suiviStellairAT[key];
                    }
                }
            }
        }
    } catch(eS) { console.warn("[Fenêtres stellaires] Erreur jour " + date + " :", eS.message); }
    // =====================================================================
    // FIN DES CORRECTIONS
    // =====================================================================

    // Éclipses (bloc conservé identique, l'ancien code stellaire a été retiré d'ici)
    if (eclipsesByDate[date]) {
        const e = eclipsesByDate[date];
        const refDeg = (e.astre === "Soleil") ? (day.planetes?.Soleil?.fullDegree || 0) : (luneDeg ?? day.planetes?.Lune?.fullDegree ?? 0);
        const loc = getLocation(refDeg);
        const eclObj = { astre:e.astre, type:e.type, date:e.date, heure:e.heure, label:e.label, signe:signs[Math.floor(refDeg/30)%12], maison:loc.maison, fullDegree:refDeg };
        if (e.saros_number)       eclObj.saros_number       = e.saros_number;
        if (e.saros_type_eclipse) eclObj.saros_type_eclipse  = e.saros_type_eclipse;
        if (e.saros_theme)        eclObj.saros_theme         = e.saros_theme;
        if (e.saros_keywords)     eclObj.saros_keywords      = e.saros_keywords;
        rapportMaisons[loc.maison-1].eclipses.push(eclObj);

        // Résonance éclipse natale (reste dans le bloc éclipse — c'est logique)
        if (eclipticNatalAT) {
            const eRN  = eclipsesByDate[date];
            const refD2 = eRN.astre === 'Soleil' ? (day.planetes?.Soleil?.fullDegree||0) : (luneDeg ?? day.planetes?.Lune?.fullDegree ?? 0);
            let dE2 = Math.abs(refD2 - eclipticNatalAT.degree); if (dE2>180) dE2=360-dE2;
            if (dE2 <= ORBE_ECL_RES_AT) {
                const txt = '⚡ RÉSONANCE ÉCLIPTIQUE NATALE — ' + eRN.date + ' : éclipse à ' + (dE2 ?? 0).toFixed(1) + '° du degré natal (' + eclipticNatalAT.label + '). Transformation amplifiée × 2.';
                [eclipticNatalAT.house, getLocation(refD2).maison].filter((h,i,a)=>h>=1&&h<=12&&a.indexOf(h)===i).forEach(h => { rapportMaisons[h-1].eclipse_natal_active.push(txt); rapportMaisons[h-1]._hm_eclipse_natal_active.push({date: eRN.date}); });
            }
        }
    }
});

// =====================================================================
// BOUCLE SECONDAIRE : Midpoints & Degrés critiques & Antiscia
// (identique à l'original)
// =====================================================================
days.forEach(day => {
    if (!day?.date || !day?.planetes) return;
    const date = day.date;
    const allTP2 = [...new Set([...slowPlanets,...fastPlanets])];
    for (const pT of allTP2) {
        if (!day.planetes[pT]) continue;
        const posT = day.planetes[pT].fullDegree;
        for (const mp of natalMidpointsA) {
            for (const midDeg of [mp.mid1, mp.mid2]) {
                let diff=Math.abs(posT-midDeg); if(diff>180)diff=360-diff;
                const key=`MP_${pT}_${mp.key}_${midDeg>mp.mid1+1?"o":"c"}`;
                if(diff<=ORBE_MP && !suiviMP[key]) {
                    suiviMP[key]={pTransit:pT,mp,debut:date,maison:getLocation(posT).maison,maisA:mp.maisA,maisB:mp.maisB};
                } else if(diff>ORBE_MP && suiviMP[key]) {
                    const s=suiviMP[key];
                    const txt=`${s.debut===date?s.debut:`Du ${s.debut} au ${date}`} : ${s.pTransit} active midpoint ${s.mp.key} → ${s.mp.pA} (M${s.mp.maisA}) ↔ ${s.mp.pB} (M${s.mp.maisB}).`;
                    [...new Set([s.maison,s.maisA,s.maisB])].forEach(m=>{if(m>=1&&m<=12){ rapportMaisons[m-1].midpoints.push(txt); rapportMaisons[m-1]._hm_midpoints.push({date: s.debut}); }});
                    delete suiviMP[key];
                }
            }
        }
        const crits=getCritDeg(posT);
        if(crits.length) {
            for(const [pN,critsN] of Object.entries(dcNataux)) {
                let dN=Math.abs(posT-natalDictLoc[pN].deg); if(dN>180)dN=360-dN;
                if(dN<=2) {
                    const m=natalDictLoc[pN].house;
                    if(m>=1&&m<=12) rapportMaisons[m-1].degres_critiques.push(`${date} : ${pT} (${crits.join(", ")}) sur ${pN} natal (${critsN.join(", ")}) — double degré critique.`);
                }
            }
        }
        // Antiscia (C10)
        for (const ant of natalAntisciaA) {
            for (const [aType, aDeg] of [["antiscion", ant.antiscion], ["contra", ant.contra]]) {
                let dA=Math.abs(posT-aDeg); if(dA>180)dA=360-dA;
                const key=`ANT_${pT}_${ant.pNatal}_${aType}`;
                if(dA<=ORBE_ANT_A && !suiviAntA[key]) {
                    suiviAntA[key]={debut:date,pTransit:pT,pNatal:ant.pNatal,type:aType,maison:ant.maison,aDeg};
                } else if(dA>ORBE_ANT_A && suiviAntA[key]) {
                    const s=suiviAntA[key];
                    const sAnt=signs[Math.floor(s.aDeg/30)%12];
                    const txt=`${s.debut===date?s.debut:`Du ${s.debut} au ${date}`} : ${s.pTransit} active le ${s.type} de ${s.pNatal} natal (miroir en ${sAnt}) — M${s.maison} activé silencieusement.`;
                    if(s.maison>=1&&s.maison<=12) { rapportMaisons[s.maison-1].antiscia.push(txt); rapportMaisons[s.maison-1]._hm_antiscia.push({date: s.debut}); }
                    delete suiviAntA[key];
                }
            }
        }
    }
});

// =====================================================================
// CLÔTURE DES SUIVIS OUVERTS (identique à l'original)
// =====================================================================
const lastDate = days[days.length-1].date;
const lastDay  = days[days.length-1];

Object.keys(suiviTL).forEach(pT => { const s=suiviTL[pT]; rapportMaisons[s.maison-1].transits_lentes.push({planete:pT,signe:s.signe,debut:s.debut,fin:lastDate}); });
Object.keys(suiviAL).forEach(key => { const a=suiviAL[key]; rapportMaisons[a.maison-1].aspects_lentes.push({...a,fin:lastDate}); });
Object.keys(suiviTR).forEach(pT => { const s=suiviTR[pT]; rapportMaisons[s.maison-1].transits_rapides.push({planete:pT,signe:s.signe,debut:s.debut,fin:lastDate}); });
Object.keys(suiviAR).forEach(key => { const a=suiviAR[key]; rapportMaisons[a.maison-1].aspects_rapides.push({...a,fin:lastDate}); });
Object.keys(suiviAngle).forEach(key => {
    const a=suiviAngle[key];
    const signe = a.planete && lastDay.planetes?.[a.planete] ? signs[Math.floor(lastDay.planetes[a.planete].fullDegree/30)%12] : "?";
