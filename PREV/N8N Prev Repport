});

// Détecter les ingress — inclut Nœud Nord et Nœud Sud
days.forEach(day => {
    if (!day?.date || !day?.planetes) return;
    const date = day.date;
    for (const pT of slowPl_A) {
        if (!day.planetes[pT]) continue;
        const posT  = day.planetes[pT].fullDegree;
        const signT = signs[Math.floor(posT/30)%12];
        const houseT= getLocation(posT).maison;
        if (prevSignesA[pT] && prevSignesA[pT] !== signT) {
            const isRetro = day.planetes[pT].isRetro === "True" || day.planetes[pT].isRetro === true;
            const txt = `${date} : ${pT} entre en ${signT}${isRetro?" (℞ ré-entrée)":""} — ingress M${houseT}.`;
            if (houseT >= 1 && houseT <= 12) { rapportMaisons[houseT-1].ingress.push(txt); rapportMaisons[houseT-1]._hm_ingress.push({date}); }
        }
        prevSignesA[pT] = signT;
    }
});

Object.keys(suiviTT).forEach(key => {
    const a = suiviTT[key];
    rapportMaisons[a.maison-1].aspects_mondiaux.push({...a,fin:lastDate});
