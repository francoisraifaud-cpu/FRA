          "jsCode": "// WEBHOOK-PREV-EXTRACT-v2 — champs lieu Google optionnels (aligné Thème / DHN). Désactiver le pin sur ce nœud.\n\nconst item = $input.all()[0].json;\n\nconst body =\n  item.body !== undefined && item.body !== null && typeof item.body === \"object\" && !Array.isArray(item.body)\n    ? item.body\n    : item;\n\nfunction numOpt(v) {\n  if (v === null || v === undefined) return null;\n  if (typeof v === \"number\" && Number.isFinite(v)) return v;\n  if (typeof v === \"string\" && String(v).trim()) {\n    const x = parseFloat(String(v).trim().replace(\",\", \".\"));\n    return Number.isFinite(x) ? x : null;\n  }\n  return null;\n}\n\nif (body.event === \"order.paid\" || body.orderId) {\n  const mail = body.customerEmail || body.mail || null;\n  const out = {\n    nom: body.nom ?? null,\n    prenom: body.prenom ?? null,\n    date: body.date ?? null,\n    heure: body.heure ?? null,\n    lieu: body.lieu ?? null,\n    pays: body.pays ?? null,\n    mail,\n    rapport: body.rapport ?? null,\n    annee: body.annee ?? null,\n    date_entree: body.date_entree ?? null,\n    date_sortie: body.date_sortie ?? null,\n    langue: body.langue ?? \"Français\",\n    consigne_redaction: body.consigne_redaction ?? \"Tu\",\n    genre: body.genre ?? \"M\",\n    orderId: body.orderId ?? null,\n    stripeCheckoutSessionId: body.stripeCheckoutSessionId ?? null,\n    stripePaymentIntentId: body.stripePaymentIntentId ?? null,\n    amountTotal: body.amountTotal ?? null,\n    currency: body.currency ?? null,\n    stripeEventId: body.stripeEventId ?? null,\n    source: \"site\",\n  };\n\n  const blat = numOpt(body.birth_place_lat);\n  const blng = numOpt(body.birth_place_lng);\n  const pid =\n    typeof body.birth_place_place_id === \"string\" && body.birth_place_place_id.trim()\n      ? body.birth_place_place_id.trim()\n      : null;\n  const fa =\n    typeof body.birth_place_formatted_address === \"string\" && body.birth_place_formatted_address.trim()\n      ? body.birth_place_formatted_address.trim()\n      : null;\n  const btr =\n    typeof body.birth_time_reference === \"string\" && body.birth_time_reference.trim()\n      ? body.birth_time_reference.trim()\n      : \"civil_at_birth_place\";\n\n  if (blat !== null && blng !== null && Math.abs(blat) <= 90 && Math.abs(blng) <= 180) {\n    out.birth_place_lat = blat;\n    out.birth_place_lng = blng;\n    if (pid) out.birth_place_place_id = pid;\n    if (fa) out.birth_place_formatted_address = fa;\n    out.birth_time_reference = btr;\n  }\n\n  return [{ json: out }];\n}\n\n\n// B) Gmail (sujet Prev)\nfunction findPlainText(payload) {\n  if (!payload) return null;\n  if (payload.mimeType === 'text/plain' && payload.body && payload.body.data) return payload.body.data;\n  if (payload.parts) {\n    for (const part of payload.parts) {\n      const found = findPlainText(part);\n      if (found) return found;\n    }\n  }\n  return null;\n}\n\nconst b64 = findPlainText(item.payload);\nlet text = b64\n  ? Buffer.from(b64.replace(/-/g, '+').replace(/_/g, '/'), 'base64').toString('utf-8')\n  : (item.snippet || '');\n\nconst normalized = text.replace(/\\r?\\n/g, ';');\nconst parts = normalized.split(';').map(p => p.trim()).filter(p => p.length > 0);\n\nfunction decodeQP(str) {\n  return str.replace(/=([0-9A-Fa-f]{2})/g, (_, h) => String.fromCharCode(parseInt(h, 16)));\n}\n\nconst result = {};\n\nfor (const part of parts) {\n  const eqIndex = part.indexOf('=');\n  if (eqIndex === -1) continue;\n  \n  const rawLabel = part.slice(0, eqIndex).trim();\n  let val = part.slice(eqIndex + 1).trim();\n  \n  // Nettoyer les points-virgules finaux éventuels\n  val = val.replace(/;$/, '').trim();\n  \n  const label = decodeQP(rawLabel).toLowerCase().trim();\n  // Normalisation pour enlever les accents (ex: Prénom -> prenom)\n  const normalizedLabel = label.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n\n  if (normalizedLabel === 'nom') result.nom = val || null;\n  else if (normalizedLabel === 'prenom')