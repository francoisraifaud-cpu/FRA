const parseDate = (str) => {
    if (!str) return null;
    str = str.trim();
    if (str.includes("/")) {
        const [d, m, y] = str.split("/");
        return new Date(`${y}-${m.padStart(2,"0")}-${d.padStart(2,"0")}`);
    }
    return new Date(str);
};
