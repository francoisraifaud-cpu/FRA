                const approxYearsAgo = Math.round(degInSign);
                const recentTag = degInSign < 2 ? "RÉCENT (< 2 ans)" : `il y a ~${approxYearsAgo} ans (vers ${Math.round(anneeRapport - approxYearsAgo)})`;
