// ---- 9. BOUCLE PRINCIPALE ----
let prevLuneSoleilDiff = null;

try {
daysArray.forEach(day => {
    if (!day?.date || !day?.planetes) return;
    const date = day.date;

    // === LENTES ===
    for (const pT of slowPlanets) {
        const pData = day.planetes[pT]; if (!pData?.fullDegree) continue;
