      });
      if (_s32DeuilApplied.length > 0) {
        console.log(`[S32] Cap DEUIL appliqué: ${_s32DeuilApplied.length} sigs sans signal majeur`,
          _s32DeuilApplied.map(a => `${a.before}→${a.after}`).join(", "));
