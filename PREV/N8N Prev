    if (!name) return;
    name = _NATAL_NAME_NORMALIZE[name] || name;
    natalDict[name] = { deg:p.fullDegree, sign:p.zodiac_sign?.name?.fr || signs[Math.floor(p.fullDegree/30)%12], house:findNatalHouse(p.fullDegree), declinaison:p.declinaison ?? null };
});

