    // P44 : Lunaison embolismique
    case "embolismic_lunation": {
      if (_mdseEmbolismicLunation) {
        const embHouses = cond.houses || [];
        if (embHouses.includes(_mdseEmbolismicLunation.house) || embHouses.length === 0) {
