    _pFinalDisp.forEach(fd=>{const fh=natalDict[fd]?.house;if(fh&&keyH.includes(fh)){w+=6;fct.push(`Disp.final ${fd} M${fh}`);}if(keyP.includes(fd)){w+=4;fct.push(`Disp.final=${fd}`);}});
