      "parameters": {
        "jsCode": "// On récupère les données qui arrivent du Merge\nconst items = $input.all();\n\nconst planètesData = $('3a. Calcul Planètes1').first()?.json;\nconst maisonsData  = $('3b. Calcul Maisons').first()?.json;\nconst persoData    = $('Extract Variables').first()?.json;\n\n// Eclipse natale à la naissance (optionnel — s'arrête si pas d'éclipse ce jour-là)\nconst eclipseNatal = (() => {\n    try {\n        const eclipseItems = $('Download Eclipses 1').all();\n        if (!eclipseItems || eclipseItems.length === 0) return null;\n        const d = eclipseItems[0]?.json;\n        if (!d) return null;\n        // Vérifier que le nœud a bien retourné des données valides (pas d'erreur)\n        if (d.error || d.statusCode === 404 || d.statusCode === 204) return null;\n        // Vérifier qu'il y a bien une éclipse (au moins un des champs type/eclipse_type/typeEclipse)\n        if (d.type || d.eclipse_type || d.typeEclipse || d.eclipseType) return d;\n        // Format alternatif : tableau d'éclipses\n        if (Array.isArray(d) && d.length > 0 && (d[0].type || d[0].eclipse_type)) return d[0];\n        return null;\n    } catch(e) {\n        // Nœud non connecté ou sans données → normal pour la majorité des naissances\n        return null;\n    }\n})();\n\n// Étoiles fixes natales (nœud 3c)\nconst etoilesFixesData = (() => {\n    try {\n        const efItems = $('3c. Étoiles Fixes').all();\n        if (!efItems || efItems.length === 0) return null;\n        const d = efItems[0]?.json;\n        return d || null;\n    } catch(e) {\n        return null;\n    }\n})();\n\nreturn [{\n    json: {\n        planetes:      planètesData,\n        maisons:       maisonsData,\n        perso:         persoData,\n        eclipseNatal:  eclipseNatal,\n        etoilesFixes:  etoilesFixesData\n    }\n}];\n"
      },
