      "parameters": {
        "jsCode": "const input = $input.first()?.json;\nif (!input?.maisons) {\n    return [{ json: { error: \"Données manquantes\" } }];\n}\n\n// EXTRACTION DYNAMIQUE DES VARIABLES\nlet perso = input.perso || {};\ntry {\n    if (!perso.nom) perso = $(\"Extract Variables\").first()?.json || $(\"Extract Variables4\").first()?.json || {};\n} catch(e) {}\n\nconst prenom = perso.prenom || '';\nconst nom    = perso.nom    || '';\n\nlet headerTitle = `Données Techniques Thème Astral —<br>Inconnu`;\nif (prenom && nom)   headerTitle = `Données Techniques Thème Astral —<br>${prenom}<br>${nom}`;\nelse if (prenom || nom) headerTitle = `Données Techniques Thème Astral —<br>${prenom || nom}`;\n\nconst dateNaissance  = perso.date  || 'Date inconnue';\nconst heureNaissance = perso.heure ? perso.heure.replace(':', 'H') : 'Heure inconnue';\nconst lieuNaissance  = perso.lieu  || 'Lieu inconnu';\nconst infosNaissance = `${dateNaissance} · ${heureNaissance} · ${lieuNaissance}`;\n\nconst stats          = input.stats          || {};\nconst configurations = input.configurations || [];\nconst angularPlanets = input.angularPlanets || [];\nconst criticalPlanets= input.criticalPlanets|| [];\nconst mutualReceptions=input.mutualReceptions||[];\nconst antiscia       = input.antiscia       || [];\nconst helioConditions= input.helioConditions|| {};\nconst eclipseNatal   = input.eclipseNatal   || null;\nconst etoileMatches      = input.etoileMatches     || [];\nconst etoileCuspMatches  = input.etoileCuspMatches || [];\n\n// Helpers\nconst getAngularInfo  = pName => angularPlanets.find(ap => ap.planet === pName) || null;\nconst getCriticalInfo = pName => criticalPlanets.find(cp => cp.planet === pName) || null;\nconst getHelioInfo    = pName => helioConditions[pName] || null;\nconst getEtoileInfos  = pName => etoileMatches.filter(em => em.planete === pName);\nconst getCuspEtoiles  = hNum  => etoileCuspMatches.filter(ec => ec.maison === hNum);\n\n// ─────────────────────────────────────────────────────────────────\n// GÉNÉRATION DE LA ROUE SVG — Améliorations v2 :\n//  • Tick proéminent + point coloré à la position réelle exacte\n//  • Ligne de liaison plus visible entre position réelle et glyphe déplacé\n//  • Algorithme de spreading avec rappel élastique vers la position réelle\n//    (limite la dérive max à ~18°)\n//  • MIN_GAP réduit de 8.5° à 7.0° pour un meilleur ancrage\n// ─────────────────────────────────────────────────────────────────\nconst generateWheelSVG = (planetes, maisons) => {\n\n    const pGlyphs = {\n        \"Soleil\":\"☉\",\"Lune\":\"☽\",\"Mercure\":\"☿\",\"Vénus\":\"♀\",\"Mars\":\"♂\",\n        \"Jupiter\":\"♃\",\"Saturne\":\"♄\",\"Uranus\":\"♅\",\"Neptune\":\"♆\",\"Pluton\":\"♇\",\n        \"Chiron\":\"⚷\",\"Nœud Nord\":\"☊\",\"Nœud Sud\":\"☋\",\"Part de Fortune\":\"⊕\",\n        \"Lot de l'Esprit\":\"⊗\",\"Lilith\":\"⚸\",\"Cérès\":\"⚳\",\"Vesta\":\"⚶\",\"Junon\":\"⚵\",\"Pallas\":\"⚴\"\n    };\n    const signGlyphs = [\"♈\",\"♉\",\"♊\",\"♋\",\"♌\",\"♍\",\"♎\",\"♏\",\"♐\",\"♑\",\"♒\",\"♓\"];\n    const baseColors = [\n        \"#1F3864\",\"#2E5FA3\",\"#1F3864\",\"#2E5FA3\",\"#1F3864\",\"#2E5FA3\",\n        \"#1F3864\",\"#2E5FA3\",\"#1F3864\",\"#2E5FA3\",\"#1F3864\",\"#2E5FA3\"\n    ];\n\n    const CX=400, CY=400;\n    const R_OUT=372, R_SG=350, R_SI=325;\n    const R_PO=292;\n    const R_HN=198, R_HI=168, R_AS=160;\n    const R_GLYPH=16;\n\n    const ascObj = planetes.find(p => p.planet.fr === \"Ascendant\");\n    const ascDeg = ascObj ? ascObj.fullDegree : 0;\n\n    const e2s = d => ((180 - (d - ascDeg)) % 360 + 360) % 360;\n    const d2r = d => d * Math.PI / 180;\n    const pol = (a, r) => ({ x: CX + r * Math.cos(d2r(a)), y: CY + r * Math.sin(d2r(a)) });\n    const angDiff = (a, b) => { let d = ((a - b) % 360 + 360) % 360; return d > 180 ? d - 360 : d; };\n\n    const SIGNES = [\"Bélier\",\"Taureau\",\"Gémeaux\",\"Cancer\",\"Lion\",\"Vierge\",\"Balance\",\"Scorpion\",\"Sagittaire\",\"Capricorne\",\"Verseau\",\"Poissons\"];\n    const cuspides = maisons.map(m => {\n        const seg = m.segments.find(s => s.type === \"Cuspide\");\n        if (!seg) return 0;\n        const si = SIGNES.indexOf(seg.signe);\n        return (si >= 0 ? si * 30 : 0) + seg.degre_debut;\n    });\n\n    let s = [];\n\n    s.push(`<defs><radialGradient id=\"houseGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\"><stop offset=\"0%\" stop-color=\"#ffffff\"/><stop offset=\"100%\" stop-color=\"#f4f6fa\"/></radialGradient></defs>`);\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R_OUT+8}\" fill=\"white\" stroke=\"#c0c0cc\" stroke-width=\"1.5\"/>`);\n\n    for (let i = 0; i < 12; i++) {\n        for (let d = 0; d < 3; d++) {\n            const eclStart = i*30 + d*10, eclEnd = i*30 + (d+1)*10;\n            const a1 = e2s(eclStart), a2 = e2s(eclEnd);\n            const o1 = pol(a1,R_OUT), o2 = pol(a2,R_OUT), i1 = pol(a1,R_SI), i2 = pol(a2,R_SI);\n            s.push(`<path d=\"M${i1.x.toFixed(2)},${i1.y.toFixed(2)} L${o1.x.toFixed(2)},${o1.y.toFixed(2)} A${R_OUT},${R_OUT} 0 0,0 ${o2.x.toFixed(2)},${o2.y.toFixed(2)} L${i2.x.toFixed(2)},${i2.y.toFixed(2)} A${R_SI},${R_SI} 0 0,1 ${i1.x.toFixed(2)},${i1.y.toFixed(2)} Z\" fill=\"${baseColors[i]}\" stroke=\"#ffffff\" stroke-width=\"0.5\"/>`);\n            if (d > 0) s.push(`<line x1=\"${i1.x.toFixed(2)}\" y1=\"${i1.y.toFixed(2)}\" x2=\"${o1.x.toFixed(2)}\" y2=\"${o1.y.toFixed(2)}\" stroke=\"#ffffff\" stroke-width=\"0.8\" stroke-dasharray=\"3,3\" opacity=\"0.6\"/>`);\n        }\n        const sBorder = e2s(i*30);\n        const b1 = pol(sBorder, R_SI), b2 = pol(sBorder, R_OUT);\n        s.push(`<line x1=\"${b1.x.toFixed(2)}\" y1=\"${b1.y.toFixed(2)}\" x2=\"${b2.x.toFixed(2)}\" y2=\"${b2.y.toFixed(2)}\" stroke=\"#ffffff\" stroke-width=\"1.5\"/>`);\n        const midA = e2s(i*30 + 15), gPos = pol(midA, R_SG);\n        s.push(`<text x=\"${gPos.x.toFixed(2)}\" y=\"${gPos.y.toFixed(2)}\" font-size=\"22\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#ffffff\" font-family=\"serif\" font-weight=\"bold\">${signGlyphs[i]}</text>`);\n    }\n\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R_SI}\" fill=\"white\" stroke=\"#707080\" stroke-width=\"1.8\"/>`);\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R_HI}\" fill=\"url(#houseGrad)\" stroke=\"#909090\" stroke-width=\"1.2\"/>`);\n\n    const axMap = { 0:\"AC\", 3:\"IC\", 6:\"DC\", 9:\"MC\" };\n    for (let i = 0; i < 12; i++) {\n        const cEcl = cuspides[i], svgA = e2s(cEcl);\n        const isAxis = [0,3,6,9].includes(i);\n        const pOut = pol(svgA, R_SI), pIn = pol(svgA, R_HI);\n        s.push(`<line x1=\"${pOut.x.toFixed(2)}\" y1=\"${pOut.y.toFixed(2)}\" x2=\"${pIn.x.toFixed(2)}\" y2=\"${pIn.y.toFixed(2)}\" stroke=\"${isAxis ? \"#1a237e\" : \"#b0b0c8\"}\" stroke-width=\"${isAxis ? 2.8 : 0.9}\" ${isAxis ? \"\" : 'stroke-dasharray=\"4,4\"'}/>`);\n        const nxEcl = cuspides[(i+1)%12], span = (nxEcl - cEcl + 360) % 360;\n        const midEcl = (cEcl + span/2 + 360) % 360, nPos = pol(e2s(midEcl), R_HN);\n        s.push(`<text x=\"${nPos.x.toFixed(2)}\" y=\"${nPos.y.toFixed(2)}\" font-size=\"24\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#1F3864\" font-weight=\"900\" font-family=\"Arial,sans-serif\">${i+1}</text>`);\n        if (isAxis) {\n            const axPos = pol(svgA, R_OUT+24);\n            s.push(`<text x=\"${axPos.x.toFixed(2)}\" y=\"${axPos.y.toFixed(2)}\" font-size=\"18\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#1a237e\" font-weight=\"900\" font-family=\"Arial,sans-serif\">${axMap[i]}</text>`);\n        }\n    }\n\n    // Aspects\n    const aspDef = {\n        \"Sextile\":   { col:\"#009944\", w:1.0, op:0.6, z:1 },\n        \"Trigone\":   { col:\"#1155cc\", w:1.4, op:0.7, z:2 },\n        \"Carré\":     { col:\"#ee4400\", w:1.7, op:0.78, z:3 },\n        \"Opposition\":{ col:\"#cc0000\", w:2.0, op:0.83, z:4 },\n        \"Conjonction\":{ col:\"#9900dd\", w:2.3, op:0.88, z:5 }\n    };\n    const posMap = {};\n    planetes.forEach(p => { if (p.planet.fr) posMap[p.planet.fr] = p.fullDegree; });\n    // Filtrer uniquement les aspects majeurs (isMajor ou aspect reconnu dans aspDef)\n    [...(input.aspects || [])].filter(a => aspDef[a.aspect] && (a.isMajor !== false) && posMap[a.p1] !== undefined && posMap[a.p2] !== undefined)\n        .sort((a,b) => (aspDef[a.aspect]?.z||0) - (aspDef[b.aspect]?.z||0))\n        .forEach(asp => {\n            const st = aspDef[asp.aspect];\n            const a1 = d2r(e2s(posMap[asp.p1])), a2 = d2r(e2s(posMap[asp.p2]));\n            s.push(`<line x1=\"${(CX + R_AS*Math.cos(a1)).toFixed(1)}\" y1=\"${(CY + R_AS*Math.sin(a1)).toFixed(1)}\" x2=\"${(CX + R_AS*Math.cos(a2)).toFixed(1)}\" y2=\"${(CY + R_AS*Math.sin(a2)).toFixed(1)}\" stroke=\"${st.col}\" stroke-width=\"${st.w}\" opacity=\"${st.op}\"/>`);\n        });\n\n    // ── PLANÈTES avec algorithme de spreading amélioré ──\n    const skipPl = [\"Descendant\",\"Imum Coeli\",\"Ascendant\",\"Milieu du Ciel\"];\n    let validPlanets = planetes\n        .filter(p => p.planet.fr && !skipPl.includes(p.planet.fr))\n        .map(p => ({\n            name: p.planet.fr,\n            fullDeg: p.fullDegree,\n            a: p.fullDegree,\n            retro: !!(p.retroStr && p.retroStr.includes(\"Rétro\"))\n        }))\n        .sort((a,b) => a.fullDeg - b.fullDeg);\n\n    let nPlanets = validPlanets.length;\n    if (nPlanets > 0) {\n        // ── Phase 1 : séparation minimale (MIN_GAP réduit à 7°) ──\n        const MIN_GAP = 7.0;\n        for (let pass = 0; pass < 2000; pass++) {\n            let moved = false;\n            validPlanets.sort((a,b) => ((a.a%360+360)%360) - ((b.a%360+360)%360));\n            for (let i = 0; i < nPlanets; i++) {\n                const j = (i+1) % nPlanets;\n                const ai = (validPlanets[i].a % 360 + 360) % 360;\n                const aj = (validPlanets[j].a % 360 + 360) % 360;\n                let diff = ((aj - ai + 360) % 360);\n                if (diff < MIN_GAP) {\n                    const push = (MIN_GAP - diff) / 2;\n                    validPlanets[i].a -= push;\n                    validPlanets[j].a += push;\n                    moved = true;\n                }\n            }\n            if (!moved) break;\n        }\n\n        // ── Phase 2 : rappel élastique vers la position réelle ──\n        // Après chaque itération de rappel, on vérifie qu'aucun overlap n'est recréé\n        for (let iter = 0; iter < 120; iter++) {\n            let movedBack = false;\n            validPlanets.sort((a,b) => ((a.a%360+360)%360) - ((b.a%360+360)%360));\n            for (let i = 0; i < nPlanets; i++) {\n                const currA = (validPlanets[i].a % 360 + 360) % 360;\n                const realA = (validPlanets[i].fullDeg % 360 + 360) % 360;\n                const diff  = ((realA - currA + 540) % 360) - 180; // diff signé\n                if (Math.abs(diff) < 0.15) continue;\n                const step   = diff * 0.08;  // nudge 8% vers le degré réel\n                const newA   = currA + step;\n                const prevI  = (i - 1 + nPlanets) % nPlanets;\n                const nextI  = (i + 1) % nPlanets;\n                const prevA  = (validPlanets[prevI].a % 360 + 360) % 360;\n                const nextA  = (validPlanets[nextI].a % 360 + 360) % 360;\n                const gapP   = ((newA - prevA + 360) % 360);\n                const gapN   = ((nextA - newA + 360) % 360);\n                // Appliquer seulement si pas de nouvel overlap (et pas le seul planète)\n                if ((nPlanets === 1) || (gapP >= MIN_GAP - 0.1 && gapN >= MIN_GAP - 0.1)) {\n                    validPlanets[i].a = newA;\n                    movedBack = true;\n                }\n            }\n            if (!movedBack) break;\n        }\n\n        // ── Phase 3 : correction de l'ordre d'affichage dans les clusters serrés ──\n        // La Phase 1 re-trie par angle d'affichage à chaque passe, ce qui peut\n        // inverser l'ordre de planètes très proches (ex : Lune entre Vesta et Lilith\n        // se retrouve affichée après Lilith).\n        // Pour chaque groupe de planètes dont les degrés réels sont proches\n        // (< 3 × MIN_GAP), on réaffecte les angles d'affichage dans le même ordre\n        // relatif que les degrés réels — sans toucher aux gaps déjà calculés.\n        {\n            validPlanets.sort((a,b) => ((a.fullDeg%360+360)%360) - ((b.fullDeg%360+360)%360));\n            let ci = 0;\n            while (ci < nPlanets) {\n                let cj = ci + 1;\n                while (cj < nPlanets) {\n                    const span = ((validPlanets[cj].fullDeg - validPlanets[ci].fullDeg + 360) % 360);\n                    if (span > MIN_GAP * 3) break;\n                    cj++;\n                }\n                if (cj > ci + 1) {\n                    // Cluster détecté de ci à cj-1 : réaffecter les angles d'affichage\n                    // en respectant l'ordre des degrés réels (validPlanets[ci..cj-1]\n                    // sont déjà triés par fullDeg).\n                    const dispAngles = validPlanets.slice(ci, cj)\n                        .map(p => p.a)\n                        .sort((a,b) => ((a%360+360)%360) - ((b%360+360)%360));\n                    for (let k = 0; k < cj - ci; k++) {\n                        validPlanets[ci + k].a = dispAngles[k];\n                    }\n                }\n                ci = cj;\n            }\n        }\n\n        let htmlLines = \"\", htmlDots = \"\", htmlBgs = \"\", htmlGlyphs = \"\";\n\n        validPlanets.forEach(p => {\n            const adjDeg   = (p.a % 360 + 360) % 360;\n            const svgA     = e2s(adjDeg);\n            const realSvgA = e2s(p.fullDeg);\n            const pos      = pol(svgA, R_PO);\n            const glyph    = pGlyphs[p.name] || \"?\";\n\n            // ── Tick proéminent au degré RÉEL exact ──\n            const tk1 = pol(realSvgA, R_SI + 1);   // légèrement dans la ceinture\n            const tk2 = pol(realSvgA, R_SI - 20);  // plus long (était -13)\n            htmlLines += `<line x1=\"${tk1.x.toFixed(1)}\" y1=\"${tk1.y.toFixed(1)}\" x2=\"${tk2.x.toFixed(1)}\" y2=\"${tk2.y.toFixed(1)}\" stroke=\"#1F3864\" stroke-width=\"2.2\"/>`;\n\n            // ── Point coloré (petit cercle) à la position réelle ──\n            const dotPos = pol(realSvgA, R_SI - 3);\n            htmlDots += `<circle cx=\"${dotPos.x.toFixed(1)}\" cy=\"${dotPos.y.toFixed(1)}\" r=\"3\" fill=\"#1F3864\" stroke=\"white\" stroke-width=\"0.8\" opacity=\"0.9\"/>`;\n\n            // ── Ligne de liaison (si glyphe déplacé) ──\n            const diffA = Math.abs(angDiff(svgA, realSvgA));\n            if (diffA > 0.5) {\n                const la = pol(realSvgA, R_SI - 20);\n                const lb = pol(svgA, R_PO + R_GLYPH + 2);\n                htmlLines += `<line x1=\"${la.x.toFixed(1)}\" y1=\"${la.y.toFixed(1)}\" x2=\"${lb.x.toFixed(1)}\" y2=\"${lb.y.toFixed(1)}\" stroke=\"#444\" stroke-width=\"1.3\" opacity=\"0.7\" stroke-dasharray=\"3,2\"/>`;\n            }\n\n            htmlBgs += `<circle cx=\"${pos.x.toFixed(1)}\" cy=\"${pos.y.toFixed(1)}\" r=\"${R_GLYPH}\" fill=\"white\" fill-opacity=\"0.95\" stroke=\"none\"/>`;\n\n            const isMarsOrVenus = (glyph === \"♀\" || glyph === \"♂\");\n            const strokeAttr = isMarsOrVenus ? 'stroke=\"#111\" stroke-width=\"1.4\"' : 'stroke=\"none\"';\n            htmlGlyphs += `<text x=\"${pos.x.toFixed(1)}\" y=\"${pos.y.toFixed(1)}\" font-size=\"25\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#111\" ${strokeAttr} font-weight=\"bold\" font-family=\"'Segoe UI Symbol', 'Apple Symbols', 'Symbola', 'Arial Unicode MS', serif\">${glyph}</text>`;\n\n            if (p.retro) {\n                htmlGlyphs += `<text x=\"${(pos.x+11).toFixed(1)}\" y=\"${(pos.y+11).toFixed(1)}\" font-size=\"10\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#cc0000\" font-weight=\"900\" font-family=\"Arial,sans-serif\">R</text>`;\n            }\n        });\n\n        s.push(htmlLines);\n        s.push(htmlDots);\n        s.push(htmlBgs);\n        s.push(htmlGlyphs);\n    }\n\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"7\" fill=\"#1a237e\" stroke=\"white\" stroke-width=\"2\"/>`);\n    s.push(`<circle cx=\"${CX}\" cy=\"${CY}\" r=\"2.5\" fill=\"white\"/>`);\n\n    return `<svg viewBox=\"-20 -20 840 840\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%; max-width:850px; height:auto; display:block; margin:auto;\">${s.join('')}</svg>`;\n};\n\n// ─────────────────────────────────────────────────────────────────\n// CONSTRUCTION DU DOCUMENT HTML\n// ─────────────────────────────────────────────────────────────────\nlet html = `<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Données Techniques Thème Astral</title>\n<style>\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap');\n    * { box-sizing: border-box; }\n    body { font-family: 'Source Sans 3', 'Segoe UI', sans-serif; background: #f0f4f8; color: #2c2c3a; padding: 20px; font-size: 16px; line-height: 1.6; }\n    .container { max-width: 1000px; margin: auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,.05); }\n    .main-header { background: #1F3864; padding: 52px 44px 48px; color: white; text-align: center; border-radius: 14px; margin-bottom: 20px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    .main-header h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; font-weight: 700; letter-spacing: 0.3px; color: #ffffff; margin: 0 0 10px; line-height: 1.35; }\n    .main-header p.subtitle { font-size: 15.5px; font-weight: 300; letter-spacing: 2.5px; text-transform: uppercase; color: #8ab4f8; margin: 0 0 6px; }\n    .main-header p.details { font-size: 15.5px; font-weight: 400; color: #aac4ff; letter-spacing: 0.5px; margin: 8px 0 0; }\n    h2.section-title, .stat-card-header, .legend-title { background: #1F3864 !important; color: white !important; font-family: 'Playfair Display', Georgia, serif !important; font-size: 1.2em !important; font-weight: 600 !important; padding: 0 15px !important; border-radius: 8px !important; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; margin: 0 !important; height: 48px !important; letter-spacing: 0.2px !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    h2.section-title { margin: 30px 0 15px 0 !important; }\n    .stat-card-header { border-bottom-left-radius: 0 !important; border-bottom-right-radius: 0 !important; }\n    .legend-title { margin: 0 0 15px 0 !important; }\n    .sign-group h3 { background: #2E5FA3 !important; color: white !important; font-family: 'Playfair Display', Georgia, serif !important; font-size: 1.2em !important; font-weight: 600 !important; padding: 0 15px !important; margin: 0 !important; display: flex !important; align-items: center !important; height: 48px !important; letter-spacing: 0.2px !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 1em; }\n    th, td { padding: 12px; text-align: left; border: 1px solid #cbd5e1; }\n    th { background: #2E5FA3 !important; color: white !important; font-size: 0.95em; text-transform: uppercase; -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    tr:nth-child(even) { background: #f8fafc; }\n    .tag { font-size: 0.9em; background: #e8f0fe; color: #1F3864; padding: 4px 10px; border-radius: 4px; margin-right: 4px; font-weight: bold; display: inline-block; margin-bottom: 4px; }\n    .tag-ang  { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }\n    .tag-crit { background: #fde8e8; color: #9b1c1c; border: 1px solid #f87171; }\n    .tag-helio { background: #e0f7fa; color: #006064; border: 1px solid #00acc1; }\n    .tag-etoile { background: #fff8e1; color: #5d4037; border: 1px solid #ffb300; }\n    .tag-eclipse { background: #fff0e6; color: #7c2d12; border: 1px solid #ea580c; }\n    .stats-box { display: flex; gap: 20px; margin-top: 15px; flex-wrap: wrap; }\n    .stat-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; flex: 1; min-width: 160px; font-size: 1em; display: flex; flex-direction: column; overflow: hidden; }\n    .stat-card-body { padding: 15px; text-align: center; font-size: 1.05em; color: #2c2c3a; flex-grow: 1; display: flex; align-items: center; line-height: 1.4; }\n    .stat-card-body-column { flex-direction: column; justify-content: center; gap: 6px; }\n    .aspects-bar { padding: 15px 20px; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; display: flex; gap: 15px; flex-wrap: nowrap; justify-content: center; align-items: center; white-space: nowrap; overflow: hidden; font-size: 1.05em; margin-bottom: 20px; }\n    .wheel-container { background: #fff; padding: 0; margin: 0; text-align: center; }\n    .wheel-page-break { page-break-before: always; break-before: page; margin-top: 20px; }\n    .svg-container { width: 100%; display: flex; justify-content: center; }\n    .legend-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 20px; text-align: left; font-size: 1.05em; border-top: 1px solid #eee; padding-top: 20px; }\n    .legend-item { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }\n    .legend-glyph { font-size: 1.4em; width: 25px; text-align: center; font-weight: bold; font-family: 'Segoe UI Symbol', 'Arial Unicode MS', sans-serif; }\n    .glyph-bold-fix { font-weight: 900; -webkit-text-stroke: 1px #1F3864; }\n    .sign-group { background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 15px; overflow: hidden; }\n    .sign-group ul { list-style: none; padding: 15px 20px 15px 35px; margin: 0; }\n    .sign-group li { margin-bottom: 8px; font-size: 1.05em; position: relative; }\n    .sign-group li:before { content: \"•\"; position: absolute; left: -15px; color: #1F3864; font-weight: bold; }\n    .empty-msg { padding: 15px 20px; margin: 0; color: #94a3b8; font-size: 1.05em; font-style: italic; }\n    /* Éclipse bannière */\n    .eclipse-banner { background: linear-gradient(135deg, #fff0e6, #fff8f5); border: 2px solid #ea580c; border-radius: 10px; padding: 16px 20px; margin-bottom: 20px; }\n    .eclipse-banner-title { color: #7c2d12; font-family: 'Playfair Display', Georgia, serif; font-size: 1.15em; font-weight: 700; margin-bottom: 6px; }\n    /* Configurations & Réceptions */\n    .config-item { background: #f5f0fa; border-left: 4px solid #7c3aed; border-radius: 0 6px 6px 0; padding: 10px 14px; margin-bottom: 8px; }\n    .config-type { color: #5b21b6; font-weight: 700; font-size: 0.9em; text-transform: uppercase; letter-spacing: 0.5px; }\n    @media print {\n        @page { size: A4 portrait; margin: 10mm 15mm; }\n        body { padding: 0; background: white; font-size: 12pt; color: #000; }\n        .container { padding: 0; box-shadow: none; border: none; max-width: 100%; margin: 0; }\n        .main-header { padding: 35px 25px; margin-bottom: 20px; }\n        .main-header h1 { font-size: 32px; }\n        h2.section-title, .stat-card-header, .legend-title, .sign-group h3 { height: 40px !important; font-size: 15px !important; padding: 0 12px !important; }\n        h2.section-title { margin: 20px 0 15px 0 !important; page-break-after: avoid; break-after: avoid; }\n        .legend-title { margin: 0 0 10px 0 !important; }\n        .wheel-container { page-break-inside: avoid; margin-top: 0; padding: 0; }\n        .wheel-page-break { page-break-before: always; break-before: page; margin-top: 0; padding-top: 10px; }\n        .svg-container svg { height: auto !important; width: 100% !important; max-width: 850px !important; max-height: 950px !important; margin: 0 auto; display: block; }\n        .force-page-break-legend { page-break-before: always; break-before: page; margin-top: 0; padding-top: 10px; }\n        .legend-grid { margin-top: 0; padding-top: 10px; border: none; }\n        .page-break { page-break-before: always; break-before: page; margin-top: 0 !important; padding-top: 0 !important; }\n        .sign-group { page-break-inside: avoid; break-inside: avoid; }\n        table { page-break-inside: auto; }\n        tr { page-break-inside: avoid; page-break-after: auto; }\n    }\n</style>\n</head>\n<body>\n<div class=\"container\">\n\n<div class=\"main-header\">\n    <h1>${headerTitle}</h1>\n    <p class=\"subtitle\">A N A L Y S E &nbsp; P E R S O N N A L I S É E</p>\n    <p class=\"details\">${infosNaissance}</p>\n</div>`;\n\n// ── Bannière éclipse natale ──\nif (eclipseNatal) {\n    html += `<div class=\"eclipse-banner\">\n        <div class=\"eclipse-banner-title\">⚡ Éclipse à la Naissance</div>\n        <div>Éclipse <strong>${eclipseNatal.type}</strong> de <strong>${eclipseNatal.astre || '?'}</strong>\n        en <strong>${eclipseNatal.sign}</strong> — Maison <strong>${eclipseNatal.house}</strong>\n        (${(eclipseNatal.degree % 30).toFixed(1)}°)</div>\n        <div style=\"color:#7c2d12;font-size:0.9em;margin-top:6px;font-style:italic\">\n        Les thèmes de la Maison ${eclipseNatal.house} sont chargés d'une mission de transformation karmique.\n        Tout transit futur sur ce degré réactivera cette signature natale.\n        </div>\n    </div>`;\n}\n\n// ── Stats (secte + hémisphères + éléments + modes + dominante + almutem) ──\nconst hemis = stats.hemispheres || {};\nconst domStr = stats.planete_dominante ? `<strong>${stats.planete_dominante}</strong>` : '—';\nconst almuStr = stats.almutem_figuris  ? `Almutem : <strong>${stats.almutem_figuris}</strong>` : '';\nhtml += `<div class=\"stats-box\">\n    <div class=\"stat-card\">\n        <div class=\"stat-card-header\">☀️ Thème &amp; Hémisphères</div>\n        <div class=\"stat-card-body stat-card-body-column\">\n            <div style=\"width:100%\"><strong>${stats.sect || '—'}</strong></div>\n            <div style=\"width:100%;font-size:0.9em;color:#64748b\">N:${hemis.Nord||0} S:${hemis.Sud||0} | E:${hemis.Est||0} O:${hemis.Ouest||0}</div>\n        </div>\n    </div>\n    <div class=\"stat-card\">\n        <div class=\"stat-card-header\">🔥 Éléments</div>\n        <div class=\"stat-card-body stat-card-body-column\">\n            <div style=\"width:100%\">Feu: <strong>${stats.elements?.Feu||0}</strong></div>\n            <div style=\"width:100%\">Terre: <strong>${stats.elements?.Terre||0}</strong></div>\n            <div style=\"width:100%\">Air: <strong>${stats.elements?.Air||0}</strong></div>\n            <div style=\"width:100%\">Eau: <strong>${stats.elements?.Eau||0}</strong></div>\n        </div>\n    </div>\n    <div class=\"stat-card\">\n        <div class=\"stat-card-header\">⚙️ Modes</div>\n        <div class=\"stat-card-body stat-card-body-column\">\n            <div style=\"width:100%\">Cardinal: <strong>${stats.modes?.Cardinal||0}</strong></div>\n            <div style=\"width:100%\">Fixe: <strong>${stats.modes?.Fixe||0}</strong></div>\n            <div style=\"width:100%\">Mutable: <strong>${stats.modes?.Mutable||0}</strong></div>\n        </div>\n    </div>\n    <div class=\"stat-card\">\n        <div class=\"stat-card-header\">🌟 Dominante</div>\n        <div class=\"stat-card-body stat-card-body-column\" style=\"justify-content:center;text-align:center\">\n            <div style=\"font-size:1.2em\">${domStr}</div>\n            <div style=\"font-size:0.85em;color:#64748b\">${almuStr}</div>\n        </div>\n    </div>\n</div>`;\n\n// ── Aspects légende ──\nhtml += `<h2 class=\"section-title\">Aspects</h2>\n<div class=\"aspects-bar\">\n    <span style=\"display:flex;align-items:center;gap:6px;\"><svg width=\"22\" height=\"10\"><line x1=\"0\" y1=\"5\" x2=\"22\" y2=\"5\" stroke=\"#9900dd\" stroke-width=\"3\"/></svg><span style=\"color:#9900dd;font-weight:bold\">Conjonction</span></span>\n    <span style=\"display:flex;align-items:center;gap:6px;\"><svg width=\"22\" height=\"10\"><line x1=\"0\" y1=\"5\" x2=\"22\" y2=\"5\" stroke=\"#cc0000\" stroke-width=\"2.5\"/></svg><span style=\"color:#cc0000;font-weight:bold\">Opposition</span></span>\n    <span style=\"display:flex;align-items:center;gap:6px;\"><svg width=\"22\" height=\"10\"><line x1=\"0\" y1=\"5\" x2=\"22\" y2=\"5\" stroke=\"#ee4400\" stroke-width=\"2\"/></svg><span style=\"color:#ee4400;font-weight:bold\">Carré</span></span>\n    <span style=\"display:flex;align-items:center;gap:6px;\"><svg width=\"22\" height=\"10\"><line x1=\"0\" y1=\"5\" x2=\"22\" y2=\"5\" stroke=\"#1155cc\" stroke-width=\"1.7\"/></svg><span style=\"color:#1155cc;font-weight:bold\">Trigone</span></span>\n    <span style=\"display:flex;align-items:center;gap:6px;\"><svg width=\"22\" height=\"10\"><line x1=\"0\" y1=\"5\" x2=\"22\" y2=\"5\" stroke=\"#009944\" stroke-width=\"1.3\"/></svg><span style=\"color:#009944;font-weight:bold\">Sextile</span></span>\n</div>`;\n\n// ── Roue ──\nhtml += `<div class=\"wheel-page-break\"></div>\n<div class=\"wheel-container\">\n    <div class=\"svg-container\">\n        ${generateWheelSVG(input.planetes, input.maisons)}\n    </div>\n    <p style=\"text-align:center;font-size:0.8em;color:#64748b;margin-top:8px;\">\n        Le trait court + point bleu = position réelle exacte de la planète. La ligne pointillée relie la position réelle au glyphe quand il est déplacé pour éviter le chevauchement.\n    </p>\n</div>`;\n\n// ── Légende (page 3) ──\nhtml += `<div class=\"force-page-break-legend\">\n    <div class=\"legend-grid\">\n        <div><div class=\"legend-title\">Planètes et Objets</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">☉</span> Soleil</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">☽</span> Lune</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">☿</span> Mercure</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph glyph-bold-fix\" style=\"color:#1F3864;\">♀</span> Vénus</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph glyph-bold-fix\" style=\"color:#1F3864;\">♂</span> Mars</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">♃</span> Jupiter</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">♄</span> Saturne</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">♅</span> Uranus</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">♆</span> Neptune</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">♇</span> Pluton</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">⚷</span> Chiron</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">☊</span> Nœud Nord</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">⊕</span> Part de Fortune</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864;\">⊗</span> Lot de l'Esprit</div>\n        </div>\n        <div><div class=\"legend-title\">Signes du Zodiaque</div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864\">♈</span> Bélier — <small>Feu / Cardinal</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#2E5FA3\">♉</span> Taureau — <small>Terre / Fixe</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864\">♊</span> Gémeaux — <small>Air / Mutable</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#2E5FA3\">♋</span> Cancer — <small>Eau / Cardinal</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864\">♌</span> Lion — <small>Feu / Fixe</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#2E5FA3\">♍</span> Vierge — <small>Terre / Mutable</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864\">♎</span> Balance — <small>Air / Cardinal</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#2E5FA3\">♏</span> Scorpion — <small>Eau / Fixe</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864\">♐</span> Sagittaire — <small>Feu / Mutable</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#2E5FA3\">♑</span> Capricorne — <small>Terre / Cardinal</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#1F3864\">♒</span> Verseau — <small>Air / Fixe</small></div>\n            <div class=\"legend-item\"><span class=\"legend-glyph\" style=\"color:#2E5FA3\">♓</span> Poissons — <small>Eau / Mutable</small></div>\n        </div>\n        <div><div class=\"legend-title\">Maisons et Angles</div>\n            <div class=\"legend-item\"><strong>AC</strong> : Ascendant (Maison 1)</div>\n            <div class=\"legend-item\"><strong>MC</strong> : Milieu du Ciel (Maison 10)</div>\n            <div class=\"legend-item\"><strong>DC</strong> : Descendant (Maison 7)</div>\n            <div class=\"legend-item\"><strong>IC</strong> : Fond du Ciel (Maison 4)</div>\n            <div class=\"legend-item\" style=\"margin-top:10px;font-style:italic;color:#64748b;font-size:0.9em;line-height:1.4;\">Dégradé dans la ceinture = 3 décans par signe (10° chacun). <strong>Point bleu</strong> + trait = degré réel exact.</div>\n        </div>\n    </div>\n</div>`;\n\n// ── Planètes et Points Sensibles (par signe) ──\nconst dMap = {\n    \"Soleil\": { dom:[\"Lion\"], exa:[\"Bélier\"], exi:[\"Verseau\"], chu:[\"Balance\"] },\n    \"Lune\":   { dom:[\"Cancer\"], exa:[\"Taureau\"], exi:[\"Capricorne\"], chu:[\"Scorpion\"] },\n    \"Mercure\":{ dom:[\"Gémeaux\",\"Vierge\"], exa:[\"Vierge\"], exi:[\"Sagittaire\",\"Poissons\"], chu:[\"Poissons\"] },\n    \"Vénus\":  { dom:[\"Taureau\",\"Balance\"], exa:[\"Poissons\"], exi:[\"Scorpion\",\"Bélier\"], chu:[\"Vierge\"] },\n    \"Mars\":   { dom:[\"Bélier\",\"Scorpion\"], exa:[\"Capricorne\"], exi:[\"Balance\",\"Taureau\"], chu:[\"Cancer\"] },\n    \"Jupiter\":{ dom:[\"Sagittaire\",\"Poissons\"], exa:[\"Cancer\"], exi:[\"Gémeaux\",\"Vierge\"], chu:[\"Capricorne\"] },\n    \"Saturne\":{ dom:[\"Capricorne\",\"Verseau\"], exa:[\"Balance\"], exi:[\"Cancer\",\"Lion\"], chu:[\"Bélier\"] },\n    \"Uranus\": { dom:[\"Verseau\"], exa:[\"Scorpion\"], exi:[\"Lion\"], chu:[\"Taureau\"] },\n    \"Neptune\":{ dom:[\"Poissons\"], exa:[\"Cancer\"], exi:[\"Vierge\"], chu:[\"Capricorne\"] },\n    \"Pluton\": { dom:[\"Scorpion\"], exa:[\"Lion\"], exi:[\"Taureau\"], chu:[\"Verseau\"] }\n};\n\nhtml += `<h2 class=\"section-title page-break\">Planètes et Points Sensibles</h2>`;\n\nconst signesOrder = [\n    { name:\"Bélier\",glyph:\"♈\" },{ name:\"Taureau\",glyph:\"♉\" },{ name:\"Gémeaux\",glyph:\"♊\" },{ name:\"Cancer\",glyph:\"♋\" },\n    { name:\"Lion\",glyph:\"♌\" },{ name:\"Vierge\",glyph:\"♍\" },{ name:\"Balance\",glyph:\"♎\" },{ name:\"Scorpion\",glyph:\"♏\" },\n    { name:\"Sagittaire\",glyph:\"♐\" },{ name:\"Capricorne\",glyph:\"♑\" },{ name:\"Verseau\",glyph:\"♒\" },{ name:\"Poissons\",glyph:\"♓\" }\n];\n\nlet sortedTablePlanets = [...input.planetes].sort((a,b) => a.fullDegree - b.fullDegree);\n\nsignesOrder.forEach((sig, idx) => {\n    let inSign = sortedTablePlanets.filter(p => Math.floor(p.fullDegree / 30) === idx);\n\n    html += `<div class=\"sign-group\">`;\n    html += `<h3><span>${sig.name}</span> <span style=\"font-family:'Segoe UI Symbol', sans-serif; font-weight:normal; color:#ffffff; margin-left:8px;\">${sig.glyph}</span></h3>`;\n\n    if (inSign.length > 0) {\n        html += `<ul>`;\n        inSign.forEach(p => {\n            const name = p.planet.fr || p.planet.en;\n            const dIndex = Math.min(Math.floor(p.normDegree / 10), 2);\n            const decanRulers = [\"Mars\",\"Vénus\",\"Mercure\",\"Lune\",\"Soleil\",\"Mercure\",\"Vénus\",\"Pluton\",\"Jupiter\",\"Saturne\",\"Uranus\",\"Neptune\"];\n            const decanRuler = decanRulers[(idx + (dIndex * 4)) % 12];\n\n            let dignite = \"-\";\n            if (dMap[name]) {\n                const d = dMap[name];\n                if (d.dom.includes(sig.name))      dignite = \"En Domicile\";\n                else if (d.exa.includes(sig.name)) dignite = \"En Exaltation\";\n                else if (d.exi.includes(sig.name)) dignite = \"En Exil\";\n                else if (d.chu.includes(sig.name)) dignite = \"En Chute\";\n                else                               dignite = \"Pérégrine\";\n            }\n\n            let retro    = (p.retroStr && p.retroStr.includes(\"Rétro\")) ? \" [R]\" : \"\";\n            let digStr   = dignite !== \"-\" ? ` — <strong>${dignite}</strong>` : \"\";\n            let isAngle  = [\"Ascendant\",\"Milieu du Ciel\",\"Imum Coeli\",\"Descendant\"].includes(name);\n            let nameDisplay = isAngle ? (name === \"Imum Coeli\" ? \"Imum Coeli (Fond du Ciel)\" : name) : name;\n\n            // Tags enrichis\n            let tags = \"\";\n            const angInfo = getAngularInfo(name);\n            if (angInfo) tags += ` <span class=\"tag tag-ang\">⭐ Angulaire (${angInfo.angle}, ${angInfo.orb}°)</span>`;\n\n            const critInfo = getCriticalInfo(name);\n            if (critInfo) tags += ` <span class=\"tag tag-crit\">⚠ ${critInfo.flags.join(' | ')}</span>`;\n\n            const helioInfo = getHelioInfo(name);\n            if (helioInfo?.condition)   tags += ` <span class=\"tag tag-helio\">☀ ${helioInfo.condition.split('—')[0].trim()}</span>`;\n            if (helioInfo?.orientation && (name === \"Vénus\" || name === \"Mercure\")) {\n                const isMatin = helioInfo.orientation.toLowerCase().includes(\"matin\") || helioInfo.orientation.toLowerCase().includes(\"oriental\");\n                tags += ` <span class=\"tag tag-etoile\">${isMatin ? \"🌅 Étoile du Matin\" : \"🌆 Étoile du Soir\"}</span>`;\n            }\n\n            if (eclipseNatal?.house && name !== \"Ascendant\") {\n                // Vérifier si la planète est très proche du degré de l'éclipse\n                const eclDiff = Math.abs(((p.fullDegree - eclipseNatal.degree + 540) % 360) - 180);\n                if (eclDiff <= 3) tags += ` <span class=\"tag tag-eclipse\">⚡ Éclipse natale (${eclDiff.toFixed(1)}°)</span>`;\n            }\n\n            const etoileInfos = getEtoileInfos(name);\n            etoileInfos.forEach(em => {\n                const precLabel = em.precision.includes(\"forte\") ? \"★★\" : \"★\";\n                tags += ` <span class=\"tag tag-etoile\">${precLabel} ${em.etoile} (${em.orb}°)</span>`;\n            });\n\n            html += `<li><strong>${nameDisplay}${retro}</strong> : ${(p.normDegree || 0).toFixed(2)}° (Décan ${dIndex+1} — ${decanRuler})${digStr}${tags}</li>`;\n        });\n        html += `</ul>`;\n    } else {\n        html += `<p class=\"empty-msg\">Aucun point sensible dans ce signe.</p>`;\n    }\n\n    html += `</div>`;\n});\n\n// ── Cascade des maîtrises ──\nhtml += `<h2 class=\"section-title page-break\">Analyse Multi-Signes (Cascade des Maîtrises)</h2>\n<table><tr><th>Maison</th><th>Segment</th><th>Degré Début</th><th>Maître</th><th>Locataires</th></tr>`;\n\ninput.maisons.forEach(m => {\n    const sc = m.segments.length;\n    m.segments.forEach((seg, idx) => {\n        const locs = seg.locataires.map(l => {\n            let extra = \"\";\n            const lh = getHelioInfo(l.planete);\n            if (lh?.orientation && (l.planete === \"Vénus\" || l.planete === \"Mercure\")) {\n                const isMatin = lh.orientation.toLowerCase().includes(\"matin\") || lh.orientation.toLowerCase().includes(\"oriental\");\n                extra = ` <span style=\"font-size:0.78em;color:#92400e\">${isMatin ? \"🌅\" : \"🌆\"}</span>`;\n            }\n            return `<span class=\"tag\">${l.planete}${l.retro}${extra}</span>`;\n        }).join(\" \") || \"<em style='color:#94a3b8'>Aucun</em>\";\n\n        let mStr = \"-\";\n        if (seg.maitre) {\n            const md = seg.maitre.dignite !== \"-\" ? ` - ${seg.maitre.dignite}` : \"\";\n            // Conditions hélio du maître\n            const mhc = getHelioInfo(seg.maitre.planete);\n            const mhcStr = mhc?.condition ? `<br><small style=\"color:#0369a1\">☀ ${mhc.condition.split('—')[0].trim()}</small>` : \"\";\n            mStr = `<strong>${seg.maitre.planete}</strong>${seg.maitre.retro} (M${seg.maitre.maison}${md})${mhcStr}`;\n            if (seg.maitre.patron) {\n                mStr += `<br><small style='color:#64748b'>↳ ${seg.maitre.patron.planete} (M${seg.maitre.patron.maison})</small>`;\n            } else {\n                mStr += `<br><small style='color:#16a34a'>↳ Domicile absolu</small>`;\n            }\n        }\n\n        html += `<tr>`;\n        if (idx === 0) {\n            const eclTag   = eclipseNatal?.house === m.maison ? ` <span style=\"color:#ea580c;font-size:0.8em\">⚡</span>` : \"\";\n            const cuspStars = getCuspEtoiles(m.maison);\n            const cuspTag  = cuspStars.length > 0\n                ? ` <span style=\"color:#5d4037;font-size:0.8em\" title=\"${cuspStars.map(e=>e.etoile+'('+e.orb+'°)').join(', ')}\">★</span>`\n                : \"\";\n            html += `<td rowspan=\"${sc}\" style=\"background:#f8fafc;vertical-align:top;font-weight:bold;color:#1F3864;\">M${m.maison}${eclTag}${cuspTag}</td>`;\n        }\n        html += `<td>${seg.signe}<br><small style=\"color:#64748b\">(${seg.type})</small></td><td>${seg.degre_debut.toFixed(2)}°</td><td>${mStr}</td><td>${locs}</td></tr>`;\n    });\n});\nhtml += `</table>`;\n\n// ── Configurations natales (si présentes) ──\nif (configurations.length > 0) {\n    html += `<h2 class=\"section-title page-break\">Configurations Natales</h2>`;\n    configurations.forEach(c => {\n        html += `<div class=\"config-item\"><div class=\"config-type\">${c.type}</div><div>${c.description}</div></div>`;\n    });\n}\n\n// ── Réceptions mutuelles (si présentes) ──\nif (mutualReceptions.length > 0) {\n    html += `<h2 class=\"section-title\">Réceptions Mutuelles</h2>\n    <table><tr><th>Planète A</th><th>Signe A</th><th>Maison A</th><th>Planète B</th><th>Signe B</th><th>Maison B</th></tr>`;\n    mutualReceptions.forEach(mr => {\n        html += `<tr><td><strong>${mr.p1}</strong></td><td>${mr.sign1}</td><td>M${mr.house1}</td><td><strong>${mr.p2}</strong></td><td>${mr.sign2}</td><td>M${mr.house2}</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Aspects majeurs ──\nconst aspectColors = { \"Carré\":\"#ee4400\",\"Trigone\":\"#1155cc\",\"Opposition\":\"#cc0000\",\"Sextile\":\"#009944\",\"Conjonction\":\"#9900dd\" };\n// Ne garder que les aspects majeurs pour ce tableau\nconst majorAspects = (input.aspects || []).filter(a => a.isMajor !== false && aspectColors[a.aspect]);\n\nhtml += `<h2 class=\"section-title page-break\">Aspects Majeurs</h2>\n<table><tr><th>Planète 1</th><th>Aspect</th><th>Planète 2</th><th>Orbe</th></tr>`;\nmajorAspects.forEach(a => {\n    const c = aspectColors[a.aspect] || \"#1e293b\";\n    html += `<tr><td><strong>${a.p1}</strong></td><td style=\"color:${c};font-weight:bold;\">${a.aspect}</td><td><strong>${a.p2}</strong></td><td>${a.exactitude}°</td></tr>`;\n});\nhtml += `</table>`;\n\n// ── Aspects mineurs (section compacte, si présents) ──\nconst minorAspects = (input.aspects || []).filter(a => a.isMajor === false);\nif (minorAspects.length > 0) {\n    html += `<h2 class=\"section-title\">Aspects Mineurs</h2>\n    <table><tr><th>Planète 1</th><th>Aspect</th><th>Planète 2</th><th>Orbe</th></tr>`;\n    minorAspects.forEach(a => {\n        html += `<tr><td>${a.p1}</td><td style=\"color:#64748b;font-weight:bold;\">${a.aspect}</td><td>${a.p2}</td><td>${a.exactitude}°</td></tr>`;\n    });\n    html += `</table>`;\n}\n\n// ── Étoiles Fixes — Influences stellaires ──\nif (etoileMatches.length > 0 || etoileCuspMatches.length > 0) {\n    html += `<h2 class=\"section-title page-break\">Étoiles Fixes — Influences Stellaires</h2>`;\n    html += `<p style=\"color:#5d4037;font-style:italic;margin:0 0 15px;padding:12px 16px;background:#fff8e1;border-radius:8px;border-left:4px solid #ffb300;font-size:0.95em;\">\n        Orbes appliqués : <strong>±2°</strong> pour Aldébaran, Sirius, Régulus, Spica, Antarès (étoiles royales/majeures) — <strong>±1°</strong> pour Algol, Pléiades, Véga, Fomalhaut.\n        Précision : <strong style=\"color:#065f46\">★★ forte ≤1°</strong> / <strong style=\"color:#92400e\">★ notable ≤2°</strong> (uniquement pour les étoiles à ±2°).\n        Une conjonction étoile fixe / planète ou angle natal est une <em>signature permanente</em> du thème.\n    </p>`;\n\n    if (etoileMatches.length > 0) {\n        html += `<h3 style=\"background:#2E5FA3;color:white;font-family:'Playfair Display',Georgia,serif;font-size:1.05em;font-weight:600;padding:8px 15px;border-radius:6px;margin:0 0 10px;\">Conjonctions Planètes Natales / Étoiles Fixes</h3>`;\n        html += `<table>\n            <tr><th>Planète Natale</th><th>Étoile Fixe</th><th>Maison</th><th>Signe</th><th>Orbe</th><th>Précision</th></tr>`;\n        etoileMatches.forEach(em => {\n            const precColor  = em.precision.includes(\"forte\") ? \"#065f46\" : \"#92400e\";\n            const precSymbol = em.precision.includes(\"forte\") ? \"★★\" : \"★\";\n            const angleStyle = em.isAngle ? \" style=\\\"background:#f0f4ff\\\"\" : \"\";\n            html += `<tr${angleStyle}>\n                <td><strong>${em.planete}</strong>${em.isAngle ? ' <small style=\"color:#1F3864\">[angle]</small>' : ''}</td>\n                <td>\n                    <strong style=\"color:#5d4037\">${em.etoile}</strong>\n                    <small style=\"color:#94a3b8;display:block\">${em.etoile_en}</small>\n                </td>\n                <td style=\"text-align:center;font-weight:bold;color:#1F3864\">M${em.maison}</td>\n                <td>${em.signe}</td>\n                <td style=\"text-align:center\">${em.orb}°</td>\n                <td style=\"text-align:center;font-weight:bold;color:${precColor}\">${precSymbol} ${em.precision.replace(\"forte (≤1°)\",\"forte\").replace(\"notable (≤2°)\",\"notable\")}</td>\n            </tr>\n            <tr style=\"background:#fffde7\">\n                <td colspan=\"6\" style=\"font-style:italic;color:#5d4037;font-size:0.88em;padding:6px 12px 10px\">${em.desc}</td>\n            </tr>`;\n        });\n        html += `</table>`;\n    }\n\n    if (etoileCuspMatches.length > 0) {\n        html += `<h3 style=\"background:#2E5FA3;color:white;font-family:'Playfair Display',Georgia,serif;font-size:1.05em;font-weight:600;padding:8px 15px;border-radius:6px;margin:15px 0 10px;\">Étoiles Fixes sur les 4 Angles (M1 ASC · M4 IC · M7 DSC · M10 MC)</h3>`;\n        html += `<p style=\"margin:0 0 10px;font-size:0.9em;color:#64748b;font-style:italic;\">\n            Une étoile fixe sur un angle teinte l'identité fondamentale de ce pilier du thème, indépendamment de tout locataire.\n            Son influence est déterminante pour l'expression globale du thème.\n        </p>`;\n        html += `<table>\n            <tr><th>Angle</th><th>Étoile Fixe</th><th>Signe de la Cuspide</th><th>Orbe</th><th>Précision</th></tr>`;\n        etoileCuspMatches.forEach(ec => {\n            const precColor  = ec.precision.includes(\"forte\") ? \"#065f46\" : \"#92400e\";\n            const precSymbol = ec.precision.includes(\"forte\") ? \"★★\" : \"★\";\n      