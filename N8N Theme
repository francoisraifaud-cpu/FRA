h += `- Émotion (Lune) en ${moon.zodiac_sign.name.fr} (Maison ${getHouseNumber(moon.fullDegree)}). Aspects reçus : ${getAspectsStr(\"Lune\")}\\n`;\nif(asc) pSynth += `- Masque social (Ascendant) en ${ascSign}. Aspects reçus : ${getAspectsStr(\"Ascendant\")}\\n`;\nif(mc) pSynth += `- Destin et Réalisation (Milieu du Ciel) en ${mc.zodiac_sign.name.fr}. Aspects reçus : ${getAspectsStr(\"Milieu du Ciel\")}\\n`;\nif(chartRuler) {\n    let cr_sign = chartRuler.zodiac_sign.name.fr;\n    let cr_dig = getDignity(chartRulerName, cr_sign);\n    let cr_dig_str = cr_dig !== \"-\" ? ` - État: ${cr_dig}` : \"\";\n    pSynth += `- GOUVERNEUR DU THÈME (Maître de l'Asc) : ${chartRulerName}${chartRuler.retroStr}, en Maison ${getHouseNumber(chartRuler.fullDegree)} (${cr_sign}${cr_dig_str}). Aspects de ce gouverneur : ${getAspectsStr(chartRulerName)}.\\n`;\n}\nif(pof) {\n    pSynth += `- PART DE FORTUNE (Abondance/Réussite) : En ${pof.zodiac_sign.name.fr} (Maison ${getHouseNumber(pof.fullDegree)}). Aspects : ${getAspectsStr(\"Part de Fortune\")}\\n`;\n}\nif(nn && ns) {\n    pSynth += `- AXE KARMIQUE (Nœuds Lunaires) : Le chemin part du Nœud Sud en ${ns.zodiac_sign.name.fr} (Maison ${getHouseNumber(ns.fullDegree)}) pour aller vers le Nœud Nord en ${nn.zodiac_sign.name.fr} (Maison ${getHouseNumber(nn.fullDegree)}).\\n`;\n}\npSynth += `Synthétise ces dynamiques (Éléments/Modes dominants ou manquants, secte diurne/nocturne, tensions ou facilités majeures des piliers, part de fortune et chemin de vie global via l'axe des Nœuds).`;\nprompts[\"synthese_globale\"] = pSynth;\n\nreturn [{ json: { planetes: planetes, maisons: fiches_maisons, aspects: aspects, stats: stats, prompts: prompts, perso: perso } }];"
